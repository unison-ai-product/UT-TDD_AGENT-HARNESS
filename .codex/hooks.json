{
  "$comment": "Codex CLI project-local hook adapter (PLAN-L7-139). Official Codex discovery reads <repo>/.codex/hooks.json or <repo>/.codex/config.toml when the project is trusted. This mirrors the Claude guard hooks in .claude/settings.json, wired with Codex tool names, and reuses the same TypeScript entrypoints. Do not move this to global ~/.codex/.",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "apply_patch|write_file",
        "hooks": [
          {
            "type": "command",
            "command": "bun .claude/hooks/work-guard.ts",
            "timeout": 5,
            "statusMessage": "work guard: block edits to foreign uncommitted files unless explicitly bypassed (Codex parity, PLAN-L7-139)",
            "blockOnFailure": true
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun src/cli.ts session start",
            "timeout": 5,
            "statusMessage": "session-log: session start (fail-open)"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "apply_patch|write_file|exec_command|local_shell",
        "hooks": [
          {
            "type": "command",
            "command": "bun src/cli.ts hook post-tool-use",
            "timeout": 5,
            "statusMessage": "session-log: post tool use (fail-open)"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun src/cli.ts session summary",
            "timeout": 5,
            "statusMessage": "session-log: PLAN digest summary (fail-open)"
          }
        ]
      }
    ]
  }
}
