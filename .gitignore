CLAUDE.local.md
AGENTS.override.md
.claude/settings.local.json
.claude/agent-memory/
.claude/scheduled_tasks.lock
.env
.env.*
*.pem
*.key
credentials.json

# UT-TDD runtime state
.ut-tdd/audit/*.jsonl
.ut-tdd/audit/escalation_state.json
.ut-tdd/cache/*
!.ut-tdd/cache/.gitkeep
.ut-tdd/state/*
!.ut-tdd/state/.gitkeep
.ut-tdd/handover/CURRENT.*
.ut-tdd/handover/*.bak
.ut-tdd/adapters/local*.yaml
.ut-tdd/teams/local*.yaml
.ut-tdd/tmp/
.tools/

# HELIX runtime state
.helix/

# Python bytecode (旧 W1-W3a port の残骸。ADR-001 で TS rebuild、念のため残置)
__pycache__/
*.py[cod]
*$py.class

# PLAN frontmatter runtime lock (W1 cross-platform lock impl)
docs/plans/*.lock

# Node / TypeScript (UT-TDD harness core, ADR-001)
node_modules/
dist/
*.tsbuildinfo
coverage/
.vitest/

# OS / editor junk (Windows / macOS / Linux クロスプラットフォーム team)
.DS_Store
Thumbs.db
ehthumbs.db
*.swp
*~

# debug logs
*-debug.log
npm-debug.log*
bun-debug.log*
# 注: .vscode/ は共有設定 (settings.json / extensions.json) を commit したい場合があるため意図的に未 ignore (team 判断)
