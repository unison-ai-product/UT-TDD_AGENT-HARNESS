#!/bin/bash
if [[ "${BASH_VERSINFO[0]:-0}" -lt 4 ]]; then
  echo "エラー: helix sprint は bash 4 以上が必要です (現 ${BASH_VERSION:-unknown})" >&2
  echo "macOS の場合: brew install bash && シェルを /opt/homebrew/bin/bash に変更" >&2
  exit 1
fi
set -euo pipefail

# helix-sprint: L4 マイクロスプリント管理
# Usage: helix-sprint <status|next|complete|reset> [--track be|fe]

source "$(cd "$(dirname "$0")" && pwd)/lib/helix-common.sh"
PHASE_FILE="$HELIX_DIR/phase.yaml"

STEPS=(".1a" ".1b" ".2" ".3" ".4" ".5")
B_STEPS=(".b1" ".b2" ".b3")
declare -A STEP_NAMES=(
  [".1a"]="コード調査 (impact analysis)"
  [".1b"]="変更計画 (plan + 事前調査)"
  [".2"]="最小実装 (skeleton + codex review Critical/High)"
  [".3"]="安全性・互換性 (security first-pass)"
  [".4"]="テスト・検証 (coverage + codex review)"
  [".5"]="仕上げ (full review + doc alignment)"
  [".b1"]="結合テスト設計 (BE+FE integration plan)"
  [".b2"]="結合実装 (endpoint binding + integration tests)"
  [".b3"]="E2E確認 (critical path verification)"
)

usage() {
  echo "Usage: helix sprint <status|next|complete|reset|addon> [--track be|fe] [--json]"
  echo ""
  echo "Commands:"
  echo "  status                現在のスプリント状態を表示"
  echo "  next [--track t]      次のステップに進む（fullstack Phase A は --track be|fe 必須）"
  echo "  complete              現在のステップを完了（非 fullstack 用）"
  echo "  complete --auto-check [--plan-id PLAN-082] [--sprint .3] [--skip-full-regression] [--strict]"
  echo "                        Sprint Exit mandatory 4 種の監査を実行"
  echo "  addon <check>         on-demand sprint step の placeholder を追加"
  echo "  reset                 スプリントをリセット"
}

# --- .helix/ チェック ---
if [[ ! -d "$HELIX_DIR" ]]; then
  echo "Error: .helix/ not found. Run 'helix init' first." >&2
  exit "$EXIT_PREREQ_ERROR"
fi

if [[ ! -f "$PHASE_FILE" ]]; then
  echo "Error: $PHASE_FILE not found. Run 'helix init' first." >&2
  exit "$EXIT_PREREQ_ERROR"
fi

# --- sprint セクションの読み書き (yaml_parser.py) ---
YP="$SCRIPT_DIR/lib/yaml_parser.py"

yaml_read() {
  local path="$1"
  python3 "$YP" read "$PHASE_FILE" "$path" 2>/dev/null || true
}

yaml_write() {
  local path="$1"
  local value="$2"
  cp "$PHASE_FILE" "$PHASE_FILE.bak" 2>/dev/null || true
  python3 "$YP" write "$PHASE_FILE" "$path" "$value" 2>/dev/null
}

normalize_stage() {
  local value="$1"
  case "$value" in
    0.2) echo ".2" ;;
    0.3) echo ".3" ;;
    0.4) echo ".4" ;;
    0.5) echo ".5" ;;
    *) echo "$value" ;;
  esac
}

get_sprint_step() {
  local value
  value="$(yaml_read "sprint.current_step")"
  normalize_stage "$value"
}

set_sprint_step() {
  local step="$1"
  yaml_write "sprint.current_step" "$step"
}

mark_step_done() {
  local step="$1"
  yaml_write "sprint.steps.${step}.status" "completed"
}

get_step_status() {
  local step="$1"
  local value
  value="$(yaml_read "sprint.steps.${step}.status")"
  if [[ -z "$value" ]]; then
    echo "pending"
  else
    echo "$value"
  fi
}

get_sprint_drive() {
  yaml_read "sprint.drive"
}

get_sprint_phase() {
  yaml_read "sprint.phase"
}

set_sprint_phase() {
  local phase="$1"
  yaml_write "sprint.phase" "$phase"
}

get_track_stage() {
  local track="$1"
  local value
  value="$(yaml_read "sprint.tracks.${track}.stage")"
  normalize_stage "$value"
}

set_track_stage() {
  local track="$1"
  local stage="$2"
  yaml_write "sprint.tracks.${track}.stage" "$stage"
}

get_track_status() {
  local track="$1"
  local value
  value="$(yaml_read "sprint.tracks.${track}.status")"
  if [[ -z "$value" ]]; then
    echo "active"
  else
    echo "$value"
  fi
}

set_track_status() {
  local track="$1"
  local status="$2"
  yaml_write "sprint.tracks.${track}.status" "$status"
}

get_contract_ci() {
  local value
  value="$(yaml_read "sprint.tracks.contract.ci")"
  if [[ -z "$value" ]]; then
    echo "pending"
  else
    echo "$value"
  fi
}

set_contract_ci() {
  local status="$1"
  yaml_write "sprint.tracks.contract.ci" "$status"
}

get_phase_b_current_step() {
  local value
  value="$(yaml_read "sprint.phase_b.current_step")"
  normalize_stage "$value"
}

set_phase_b_current_step() {
  local step="$1"
  yaml_write "sprint.phase_b.current_step" "$step"
}

get_phase_b_status() {
  local value
  value="$(yaml_read "sprint.phase_b.status")"
  if [[ -z "$value" ]]; then
    echo "pending"
  else
    echo "$value"
  fi
}

set_phase_b_status() {
  local status="$1"
  yaml_write "sprint.phase_b.status" "$status"
}

mark_phase_b_step_done() {
  local step="$1"
  yaml_write "sprint.phase_b.steps.${step}.status" "completed"
}

get_phase_b_step_status() {
  local step="$1"
  local value
  value="$(yaml_read "sprint.phase_b.steps.${step}.status")"
  if [[ -z "$value" ]]; then
    echo "pending"
  else
    echo "$value"
  fi
}

next_step_for() {
  local current="$1"
  local found=false
  local step
  for step in "${STEPS[@]}"; do
    if [[ "$found" == true ]]; then
      echo "$step"
      return
    fi
    if [[ "$step" == "$current" ]]; then
      found=true
    fi
  done
  echo ""
}

next_phase_b_step_for() {
  local current="$1"
  local found=false
  local step
  for step in "${B_STEPS[@]}"; do
    if [[ "$found" == true ]]; then
      echo "$step"
      return
    fi
    if [[ "$step" == "$current" ]]; then
      found=true
    fi
  done
  echo ""
}

print_recommended_action() {
  local step="$1"
  echo ""
  echo "[helix-sprint] 推奨アクション:"
  case "$step" in
    .1a) echo "  helix codex --role legacy --task 'impact analysis: [対象]' --read-only" ;;
    .1b) echo "  helix codex --role tl --task 'change plan: [機能名]' --read-only" ;;
    .2)  echo "  helix codex --role se --task 'skeleton: [機能名]' --full-auto" ;;
    .3)  echo "  helix codex --role security --task 'security first-pass: [機能名]'" ;;
    .4)  echo "  helix codex --role qa --task 'test and verify: [機能名]'"
         echo "  codex review --uncommitted" ;;
    .5)  echo "  helix codex --role tl --task 'full review: [機能名]'"
         echo "  helix gate G4" ;;
    .b1) echo "  helix codex --role qa --task 'integration test design: [機能名] (BE+FE 結合観点を定義)'"
         echo "  helix gate G4 --static-only" ;;
    .b2) echo "  helix codex --role se --task 'integration implementation: [機能名] (endpoint 結合 + integration test 実装)' --full-auto" ;;
    .b3) echo "  helix codex --role qa --task 'run E2E critical path: [機能名]'"
         echo "  helix gate G4" ;;
  esac
}

trigger_auto_review_if_needed() {
  local completed_step="$1"
  case "$completed_step" in
    .2|.5)
      echo "[helix-sprint] Codex レビューをバックグラウンドで起動..."
      "$SCRIPT_DIR/helix-review" --uncommitted --bg 2>/dev/null || true
      ;;
    .3)
      echo "[helix-sprint] セキュリティ first-pass をバックグラウンドで起動..."
      "$SCRIPT_DIR/helix-codex" --role security --task 'Sprint .3 完了: セキュリティ first-pass を実施。OWASP Top 10 の観点で未コミット変更をチェックし、Critical/High の問題があれば報告せよ。' --read-only --thinking medium 2>/dev/null &
      disown 2>/dev/null || true
      ;;
  esac
}

run_g4_static_check() {
  echo "[helix-sprint] Sprint 完了。G4 静的チェックを自動実行..."
  if "$SCRIPT_DIR/helix-gate" G4 --static-only; then
    echo "[helix-sprint] G4 静的チェック PASS"
  else
    echo "[helix-sprint] G4 静的チェック FAIL — 'helix gate G4' で詳細を確認してください"
  fi
}

yaml_read_from_file() {
  local file_path="$1"
  local path="$2"
  python3 "$YP" read "$file_path" "$path" 2>/dev/null || true
}

get_framework_detected() {
  local framework_file="$HELIX_DIR/framework.yaml"
  if [[ ! -f "$framework_file" ]]; then
    echo ""
    return
  fi
  yaml_read_from_file "$framework_file" "detected"
}

get_framework_tool() {
  local tool_name="$1"
  local framework_file="$HELIX_DIR/framework.yaml"
  if [[ ! -f "$framework_file" ]]; then
    echo ""
    return
  fi
  yaml_read_from_file "$framework_file" "tools.${tool_name}"
}

get_default_build_command() {
  local framework_build detected
  framework_build="$(get_framework_tool build)"
  if [[ -n "$framework_build" ]]; then
    echo "$framework_build"
    return
  fi

  detected="$(get_framework_detected)"
  case "$detected" in
    node) echo "npm run build" ;;
    go) echo "go build ./..." ;;
    rust) echo "cargo build" ;;
    *) echo "" ;;
  esac
}

resolve_strict_command() {
  local check_name="$1"
  case "$check_name" in
    lint)
      echo "${HELIX_SPRINT_LINT_CMD:-$(get_framework_tool lint)}"
      ;;
    test)
      echo "${HELIX_SPRINT_TEST_CMD:-$(get_framework_tool test)}"
      ;;
    build)
      if [[ -n "${HELIX_SPRINT_BUILD_CMD:-}" ]]; then
        echo "$HELIX_SPRINT_BUILD_CMD"
      else
        echo "$(get_default_build_command)"
      fi
      ;;
    *)
      echo ""
      ;;
  esac
}

print_strict_detail() {
  local output="$1"
  [[ -z "$output" ]] && return 0
  while IFS= read -r line; do
    [[ -z "$line" ]] && continue
    echo "[strict][detail] $line" >&2
  done <<< "$output"
}

run_named_strict_check() {
  local check_name="$1"
  local command_text output rc
  command_text="$(resolve_strict_command "$check_name")"

  if [[ -z "$command_text" ]]; then
    echo "[strict] ${check_name}: ok (no command configured)"
    return 0
  fi

  set +e
  output="$(bash -lc "$command_text" 2>&1)"
  rc=$?
  set -e

  if [[ $rc -eq 0 ]]; then
    echo "[strict] ${check_name}: ok"
    return 0
  fi

  echo "[strict] ${check_name}: failed"
  print_strict_detail "$output"
  return 1
}

list_changed_design_files() {
  if ! command -v git >/dev/null 2>&1; then
    return 0
  fi

  declare -A seen=()
  local line rel_path abs_path
  while IFS= read -r line; do
    [[ -z "$line" ]] && continue
    rel_path="${line:3}"
    if [[ "$rel_path" == *" -> "* ]]; then
      rel_path="${rel_path##* -> }"
    fi
    case "$rel_path" in
      *D-API/*|*D-CONTRACT/*|*D-DB/*|*D-[A-Z0-9-]*/*)
        abs_path="$PROJECT_ROOT/$rel_path"
        if [[ -f "$abs_path" && -z "${seen[$abs_path]:-}" ]]; then
          seen["$abs_path"]=1
          printf '%s\n' "$abs_path"
        fi
        ;;
    esac
  done < <(git -C "$PROJECT_ROOT" status --porcelain --untracked-files=all 2>/dev/null || true)
}

drift_output_is_blocking() {
  local output="$1"
  [[ "$output" == *"WARN:"* ]] && return 0
  [[ "$output" == *"unknown deliverable"* ]] && return 0
  [[ "$output" == *"frozen deliverable update detected"* ]] && return 0
  return 1
}

run_strict_drift_check() {
  if [[ "${HELIX_SPRINT_DRIFT_CHECK_CMD:-}" == ":" ]]; then
    echo "[strict] drift-check: ok"
    return 0
  fi
  local files=()
  local file output rc
  while IFS= read -r file; do
    [[ -n "$file" ]] && files+=("$file")
  done < <(list_changed_design_files)

  if [[ ${#files[@]} -eq 0 ]]; then
    echo "[strict] drift-check: ok"
    return 0
  fi

  for file in "${files[@]}"; do
    set +e
    output="$("$SCRIPT_DIR/helix-drift-check" "$file" 2>&1)"
    rc=$?
    set -e

    if [[ $rc -ne 0 ]]; then
      echo "[strict] drift-check: failed"
      print_strict_detail "$output"
      return 1
    fi

    if drift_output_is_blocking "$output"; then
      echo "[strict] drift-check: failed"
      print_strict_detail "$output"
      return 1
    fi
  done

  echo "[strict] drift-check: ok"
  return 0
}

run_sprint_strict_checks() {
  run_named_strict_check lint || return 1
  run_named_strict_check test || return 1
  run_named_strict_check build || return 1
  run_strict_drift_check || return 1
  return 0
}

log_sprint_step() {
  local step="$1" next="$2"
  if [[ -f "$HELIX_DIR/helix.db" ]]; then
    HELIX_DB_PATH="$HELIX_DIR/helix.db" python3 "$SCRIPT_DIR/lib/helix_db.py" insert action_logs \
      "{\"task_run_id\":0,\"action_index\":0,\"action_type\":\"sprint-step\",\"action_desc\":\"completed $step → $next\",\"status\":\"passed\"}" 2>/dev/null || true
  fi
}

ensure_fullstack_tracks() {
  if [[ "$(get_sprint_drive)" != "fullstack" ]]; then
    return
  fi

  [[ -n "$(get_track_stage be)" ]] || set_track_stage be ".1a"
  [[ -n "$(yaml_read "sprint.tracks.be.status")" ]] || set_track_status be "active"
  [[ -n "$(get_track_stage fe)" ]] || set_track_stage fe ".1a"
  [[ -n "$(yaml_read "sprint.tracks.fe.status")" ]] || set_track_status fe "active"
  [[ -n "$(yaml_read "sprint.tracks.contract.ci")" ]] || set_contract_ci "pending"
  [[ -n "$(get_sprint_phase)" ]] || set_sprint_phase "A"
  [[ -n "$(yaml_read "sprint.phase_b.status")" ]] || set_phase_b_status "pending"
  [[ -n "$(yaml_read "sprint.phase_b.current_step")" ]] || set_phase_b_current_step "null"
  local step
  for step in "${B_STEPS[@]}"; do
    [[ -n "$(yaml_read "sprint.phase_b.steps.${step}.status")" ]] || yaml_write "sprint.phase_b.steps.${step}.status" "pending"
  done
}

run_fullstack_contract_check_before_phase_b() {
  local be_stage fe_stage contract_ci
  be_stage="$(get_track_stage be)"
  fe_stage="$(get_track_stage fe)"
  contract_ci="$(get_contract_ci)"

  # Phase B 昇格前の契約検証（TL判定: helix-gate 配下のチェックを必須化）
  if [[ "$be_stage" == ".5" && "$fe_stage" == ".5" && "$contract_ci" != "pass" ]]; then
    if [[ ! -x "$SCRIPT_DIR/helix-gate-api-check" ]]; then
      echo "[helix-sprint] WARNING: helix gate-api-check が見つからないため契約検証をスキップします"
      return
    fi

    echo "[helix-sprint] Phase B 昇格前の契約検証を実行中..."
    if "$SCRIPT_DIR/helix-gate-api-check" 2>/dev/null; then
      echo "[helix-sprint] 契約検証 PASS → contract.ci を pass に設定"
      python3 "$YP" write "$PHASE_FILE" sprint.tracks.contract.ci pass 2>/dev/null || true
    else
      echo "[helix-sprint] 契約検証 FAIL → contract.ci は pending のまま"
      echo "[helix-sprint] helix gate-api-check を確認して修正してください"
    fi
  fi
}

refresh_fullstack_phase() {
  if [[ "$(get_sprint_drive)" != "fullstack" ]]; then
    return
  fi

  ensure_fullstack_tracks
  local be_stage fe_stage contract_ci phase_b_current phase_b_status
  be_stage="$(get_track_stage be)"
  fe_stage="$(get_track_stage fe)"
  contract_ci="$(get_contract_ci)"
  phase_b_current="$(get_phase_b_current_step)"
  phase_b_status="$(get_phase_b_status)"

  if [[ "$be_stage" == ".5" && "$fe_stage" == ".5" && "$contract_ci" == "pass" ]]; then
    set_sprint_phase "B"
    if [[ -z "$phase_b_current" ]]; then
      set_phase_b_current_step ".b1"
      phase_b_current=".b1"
    fi
    if [[ "$phase_b_status" == "pending" ]]; then
      set_phase_b_status "active"
    fi
  else
    set_sprint_phase "A"
  fi
}

print_standard_status() {
  echo "=== L4 Sprint Status ==="
  echo ""
  local current status marker step
  current="$(get_sprint_step)"
  for step in "${STEPS[@]}"; do
    status="$(get_step_status "$step")"
    marker=" "
    if [[ "$step" == "$current" ]]; then
      marker="→"
      status="in_progress"
    elif [[ "$status" == "completed" ]]; then
      marker="✓"
    fi
    printf "  %s %s  %-8s  %s\n" "$marker" "$step" "[$status]" "${STEP_NAMES[$step]}"
  done
  echo ""
  if [[ -z "$current" ]]; then
    echo "Sprint 未開始。'helix sprint next' で開始"
  elif [[ "$current" == "completed" ]]; then
    echo "Sprint 完了"
  else
    echo "現在: $current — ${STEP_NAMES[$current]}"
  fi
}

print_fullstack_status() {
  ensure_fullstack_tracks
  refresh_fullstack_phase
  local phase be_stage be_status fe_stage fe_status contract_ci
  phase="$(get_sprint_phase)"
  be_stage="$(get_track_stage be)"
  be_status="$(get_track_status be)"
  fe_stage="$(get_track_stage fe)"
  fe_status="$(get_track_status fe)"
  contract_ci="$(get_contract_ci)"

  echo "=== L4 Sprint Status ==="
  echo ""
  echo "  Drive: fullstack"
  echo "  Phase: ${phase:-A}"
  echo "  BE Track: $be_stage [$be_status]"
  echo "  FE Track: $fe_stage [$fe_status]"
  echo "  Contract CI: $contract_ci"
  if [[ "$phase" == "B" ]]; then
    local phase_b_current phase_b_status step marker status
    phase_b_current="$(get_phase_b_current_step)"
    phase_b_status="$(get_phase_b_status)"
    echo "  Phase B Status: $phase_b_status"
    echo "  Phase B Steps:"
    for step in "${B_STEPS[@]}"; do
      status="$(get_phase_b_step_status "$step")"
      marker=" "
      if [[ "$step" == "$phase_b_current" ]]; then
        marker="→"
        status="in_progress"
      elif [[ "$status" == "completed" ]]; then
        marker="✓"
      fi
      printf "    %s %s  %-8s  %s\n" "$marker" "$step" "[$status]" "${STEP_NAMES[$step]}"
    done
  else
    echo ""
    echo "Phase B 昇格条件: be.stage=.5 && fe.stage=.5 && contract.ci=pass"
  fi
}

command_status() {
  if [[ $# -gt 0 ]]; then
    echo "Error: status にオプションは指定できません" >&2
    exit 1
  fi
  if [[ "${JSON_OUTPUT:-false}" == true ]]; then
    if [[ "$(get_sprint_drive)" == "fullstack" ]]; then
      ensure_fullstack_tracks
      refresh_fullstack_phase
      local phase be_stage be_status fe_stage fe_status contract_ci
      phase="$(get_sprint_phase)"
      be_stage="$(get_track_stage be)"
      be_status="$(get_track_status be)"
      fe_stage="$(get_track_stage fe)"
      fe_status="$(get_track_status fe)"
      contract_ci="$(get_contract_ci)"
      local phase_b_current phase_b_status phase_b_steps_line step status
      phase_b_current="$(get_phase_b_current_step)"
      phase_b_status="$(get_phase_b_status)"
      phase_b_steps_line=""
      for step in "${B_STEPS[@]}"; do
        status="$(get_phase_b_step_status "$step")"
        if [[ "$step" == "$phase_b_current" ]]; then
          status="in_progress"
        fi
        phase_b_steps_line+="${step}=${status}"$'\n'
      done
      PHASE="$phase" BE_STAGE="$be_stage" BE_STATUS="$be_status" FE_STAGE="$fe_stage" FE_STATUS="$fe_status" CONTRACT_CI="$contract_ci" PHASE_B_CURRENT="$phase_b_current" PHASE_B_STATUS="$phase_b_status" PHASE_B_STEPS_LINE="$phase_b_steps_line" python3 - <<'PY'
import json
import os

phase_b_steps = {}
for line in os.environ.get("PHASE_B_STEPS_LINE", "").splitlines():
    if "=" not in line:
        continue
    key, value = line.split("=", 1)
    phase_b_steps[key] = value

print(json.dumps({
    "drive": "fullstack",
    "phase": os.environ.get("PHASE", "A") or "A",
    "tracks": {
        "be": {
            "stage": os.environ.get("BE_STAGE", ".1a") or ".1a",
            "status": os.environ.get("BE_STATUS", "active") or "active",
        },
        "fe": {
            "stage": os.environ.get("FE_STAGE", ".1a") or ".1a",
            "status": os.environ.get("FE_STATUS", "active") or "active",
        },
        "contract": {
            "ci": os.environ.get("CONTRACT_CI", "pending") or "pending",
        },
    },
    "phase_b": {
        "current_step": os.environ.get("PHASE_B_CURRENT", "") or "",
        "status": os.environ.get("PHASE_B_STATUS", "pending") or "pending",
        "steps": phase_b_steps,
    },
}, ensure_ascii=False))
PY
    else
      local current step statuses_line status
      current="$(get_sprint_step)"
      statuses_line=""
      for step in "${STEPS[@]}"; do
        status="$(get_step_status "$step")"
        if [[ "$step" == "$current" ]]; then
          status="in_progress"
        fi
        statuses_line+="${step}=${status}"$'\n'
      done
      CURRENT="$current" STATUSES_LINE="$statuses_line" python3 - <<'PY'
import json
import os

steps = {}
for line in os.environ.get("STATUSES_LINE", "").splitlines():
    if "=" not in line:
        continue
    key, value = line.split("=", 1)
    steps[key] = value

print(json.dumps({
    "drive": "standard",
    "current_step": os.environ.get("CURRENT", ""),
    "steps": steps,
}, ensure_ascii=False))
PY
    fi
    return
  fi
  if [[ "$(get_sprint_drive)" == "fullstack" ]]; then
    print_fullstack_status
  else
    print_standard_status
  fi
}

command_next() {
  local track=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --track)
        if [[ $# -lt 2 ]]; then
          echo "Error: --track には be または fe を指定してください" >&2
          exit 1
        fi
        track="$2"
        shift 2
        ;;
      *)
        echo "Error: Unknown option for next: $1" >&2
        exit 1
        ;;
    esac
  done

  if [[ "$(get_sprint_drive)" == "fullstack" ]]; then
    ensure_fullstack_tracks
    refresh_fullstack_phase
    local sprint_phase
    sprint_phase="$(get_sprint_phase)"

    if [[ "$sprint_phase" == "B" ]]; then
      if [[ -n "$track" ]]; then
        echo "Error: fullstack Phase B では --track は指定できません。'helix sprint next' を実行してください" >&2
        exit 1
      fi

      local current_b next_b
      current_b="$(get_phase_b_current_step)"
      if [[ -z "$current_b" ]]; then
        set_phase_b_current_step ".b1"
        set_phase_b_status "active"
        echo "[helix-sprint] Phase B 開始: .b1 — ${STEP_NAMES[.b1]}"
        print_recommended_action ".b1"
        return
      fi

      if [[ "$current_b" == "completed" ]]; then
        echo "[helix-sprint] Phase B は既に完了しています"
        return
      fi

      mark_phase_b_step_done "$current_b"
      next_b="$(next_phase_b_step_for "$current_b")"
      if [[ -z "$next_b" ]]; then
        set_phase_b_current_step "completed"
        set_phase_b_status "completed"
        echo "[helix-sprint] Phase B 完了: $current_b 完了 → 結合フェーズ完了"
        run_g4_static_check
        log_sprint_step "$current_b" "completed"
      else
        set_phase_b_current_step "$next_b"
        set_phase_b_status "active"
        echo "[helix-sprint] Phase B: $current_b 完了 → $next_b — ${STEP_NAMES[$next_b]}"
        print_recommended_action "$next_b"
        log_sprint_step "$current_b" "$next_b"
      fi
      trigger_auto_review_if_needed "$current_b"
      return
    fi

    case "$track" in
      be|fe) ;;
      "")
        echo "Error: fullstack では 'helix sprint next --track be|fe' が必要です" >&2
        exit 1
        ;;
      *)
        echo "Error: Invalid --track value '$track'. Use: be or fe" >&2
        exit 1
        ;;
    esac

    local current next_step previous_phase current_phase
    current="$(get_track_stage "$track")"
    if [[ -z "$current" ]]; then
      set_track_stage "$track" ".1a"
      set_track_status "$track" "active"
      echo "[helix-sprint] ${track^^} Track 開始: .1a — ${STEP_NAMES[.1a]}"
      print_recommended_action ".1a"
      refresh_fullstack_phase
      return
    fi

    previous_phase="$(get_sprint_phase)"
    next_step="$(next_step_for "$current")"
    if [[ -z "$next_step" ]]; then
      set_track_status "$track" "completed"
      echo "[helix-sprint] ${track^^} Track は .5 完了済みです"
    else
      set_track_stage "$track" "$next_step"
      if [[ "$next_step" == ".5" ]]; then
        set_track_status "$track" "completed"
        echo "[helix-sprint] ${track^^} Track: $current 完了 → $next_step (completed)"
      else
        set_track_status "$track" "active"
        echo "[helix-sprint] ${track^^} Track: $current 完了 → $next_step"
      fi
      print_recommended_action "$next_step"
    fi

    run_fullstack_contract_check_before_phase_b
    refresh_fullstack_phase
    current_phase="$(get_sprint_phase)"
    if [[ "$previous_phase" != "B" && "$current_phase" == "B" ]]; then
      [[ -n "$(get_phase_b_current_step)" ]] || set_phase_b_current_step ".b1"
      set_phase_b_status "active"
      echo "[helix-sprint] Phase B 昇格: L4.5 結合フェーズを開始 (.b1)"
      print_recommended_action ".b1"
    fi
    if [[ -n "$next_step" ]]; then
      log_sprint_step "$current" "$next_step"
    fi
    trigger_auto_review_if_needed "$current"
    return
  fi

  if [[ -n "$track" ]]; then
    echo "Error: --track は fullstack 駆動でのみ使用できます" >&2
    exit 1
  fi

  local current next_step
  current="$(get_sprint_step)"
  if [[ -z "$current" ]]; then
    # 未開始 → .1a から
    set_sprint_step ".1a"
    echo "[helix-sprint] Sprint 開始: .1a — ${STEP_NAMES[.1a]}"
    print_recommended_action ".1a"
  elif [[ "$current" == "completed" ]]; then
    echo "[helix-sprint] Sprint は既に完了しています"
  else
    # 現在のステップを完了して次へ
    mark_step_done "$current"
    next_step="$(next_step_for "$current")"
    if [[ -z "$next_step" ]]; then
      set_sprint_step "completed"
      next_step="completed"
      echo "[helix-sprint] $current 完了 — Sprint 完了"
      run_g4_static_check
    else
      set_sprint_step "$next_step"
      echo "[helix-sprint] $current 完了 → $next_step — ${STEP_NAMES[$next_step]}"
      print_recommended_action "$next_step"
    fi
    log_sprint_step "$current" "$next_step"
    trigger_auto_review_if_needed "$current"
  fi
}

run_sprint_auto_check() {
  local plan_id="$1"
  local sprint="$2"
  local strict_mode="$3"
  local skip_full_regression="$4"
  local cmd=(python3 "$SCRIPT_DIR/lib/sprint_lint.py" --plan-id "$plan_id" --sprint "$sprint")
  if [[ "$skip_full_regression" == true ]]; then
    cmd+=(--skip-full-regression)
  fi
  if [[ "$strict_mode" == true ]]; then
    cmd+=(--strict)
  fi
  if [[ "${JSON_OUTPUT:-false}" == true ]]; then
    cmd+=(--json)
  fi
  "${cmd[@]}"
}

command_complete() {
  local auto_check=false
  local strict_mode=false
  local skip_full_regression=false
  local plan_id=""
  local sprint=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --auto-check)
        auto_check=true
        shift
        ;;
      --strict)
        strict_mode=true
        shift
        ;;
      --skip-full-regression)
        skip_full_regression=true
        shift
        ;;
      --plan-id)
        if [[ $# -lt 2 ]]; then
          echo "Error: --plan-id には PLAN-XXX を指定してください" >&2
          exit "$EXIT_INPUT_ERROR"
        fi
        plan_id="$2"
        shift 2
        ;;
      --sprint)
        if [[ $# -lt 2 ]]; then
          echo "Error: --sprint には .3 のようなステップを指定してください" >&2
          exit "$EXIT_INPUT_ERROR"
        fi
        sprint="$2"
        shift 2
        ;;
      *)
        echo "Error: Unknown option for complete: $1" >&2
        exit "$EXIT_INPUT_ERROR"
        ;;
    esac
  done

  if [[ "$auto_check" == true ]]; then
    [[ -n "$plan_id" ]] || plan_id="${HELIX_PLAN_ID:-PLAN-UNKNOWN}"
    [[ -n "$sprint" ]] || sprint="$(get_sprint_step)"
    if [[ -z "$sprint" || "$sprint" == "completed" ]]; then
      sprint="${HELIX_SPRINT_STEP:-unknown}"
    fi
    run_sprint_auto_check "$plan_id" "$sprint" "$strict_mode" "$skip_full_regression"
    return
  fi

  if [[ "$(get_sprint_drive)" == "fullstack" ]]; then
    echo "Error: fullstack では 'helix sprint next --track be|fe' を使用してください" >&2
    exit 1
  fi

  local current
  current="$(get_sprint_step)"
  if [[ -z "$current" || "$current" == "completed" ]]; then
    echo "Error: 完了するステップがありません" >&2
    exit 1
  fi

  if [[ "$current" == ".5" ]]; then
    if ! run_sprint_strict_checks; then
      echo "[helix-sprint] strict checks failed. Sprint は未完了のままです" >&2
      exit 1
    fi
  fi

  mark_step_done "$current"
  echo "[helix-sprint] $current 完了"
  echo ""

  if [[ "$current" == ".5" ]]; then
    set_sprint_step "completed"
    run_g4_static_check
  else
    echo "[helix-sprint] 次のステップへ進むには 'helix sprint next' を実行してください"
  fi
  # 自動で次へは進まない（next で明示的に進む）
}

command_addon() {
  local check_name="${1:-}"
  local plan_id=""
  shift || true

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --plan-id)
        if [[ $# -lt 2 ]]; then
          echo "Error: --plan-id には PLAN-XXX を指定してください" >&2
          exit "$EXIT_INPUT_ERROR"
        fi
        plan_id="$2"
        shift 2
        ;;
      *)
        echo "Error: Unknown option for addon: $1" >&2
        exit "$EXIT_INPUT_ERROR"
        ;;
    esac
  done

  if [[ -z "$check_name" ]]; then
    echo "Error: addon には check 名が必要です" >&2
    exit "$EXIT_INPUT_ERROR"
  fi

  [[ -n "$plan_id" ]] || plan_id="${HELIX_PLAN_ID:-PLAN-UNKNOWN}"

  if [[ "${JSON_OUTPUT:-false}" == true ]]; then
    CHECK_NAME="$check_name" PLAN_ID="$plan_id" python3 - <<'PY'
import json
import os

print(json.dumps({
    "status": "placeholder",
    "check": os.environ["CHECK_NAME"],
    "plan_id": os.environ["PLAN_ID"],
    "message": "PLAN-082 Phase 3 placeholder only; actual addon check is implemented in a later PLAN.",
}, ensure_ascii=False))
PY
    return
  fi

  echo "[helix-sprint] addon placeholder: $check_name"
  echo "[helix-sprint] plan_id: $plan_id"
  echo "[helix-sprint] Phase 3 では placeholder のみです。実 check は後続 PLAN で実装します。"
}

command_reset() {
  if [[ $# -gt 0 ]]; then
    echo "Error: reset にオプションは指定できません" >&2
    exit 1
  fi

  set_sprint_step ""
  local step
  for step in "${STEPS[@]}"; do
    yaml_write "sprint.steps.${step}.status" "pending"
  done
  yaml_write "sprint.status" "active"

  if [[ "$(get_sprint_drive)" == "fullstack" ]]; then
    set_sprint_phase "A"
    set_track_stage be ".1a"
    set_track_status be "active"
    set_track_stage fe ".1a"
    set_track_status fe "active"
    set_contract_ci "pending"
    set_phase_b_current_step "null"
    set_phase_b_status "pending"
    for step in "${B_STEPS[@]}"; do
      yaml_write "sprint.phase_b.steps.${step}.status" "pending"
    done
    echo "[helix-sprint] Sprint リセット完了 (fullstack twin tracks 初期化)"
  else
    yaml_write "sprint.tracks" "null"
    yaml_write "sprint.phase" "null"
    echo "[helix-sprint] Sprint リセット完了"
  fi
}

# --- グローバルオプション ---
JSON_OUTPUT=false
POSITIONAL=()
while [[ $# -gt 0 ]]; do
  case "$1" in
    --json)
      JSON_OUTPUT=true
      shift
      ;;
    *)
      POSITIONAL+=("$1")
      shift
      ;;
  esac
done
set -- "${POSITIONAL[@]}"

# --- サブコマンド ---
CMD="${1:-status}"
shift || true

case "$CMD" in
  status) command_status "$@" ;;
  next) command_next "$@" ;;
  complete) command_complete "$@" ;;
  addon) command_addon "$@" ;;
  reset) command_reset "$@" ;;

  --help|-h)
    usage
    ;;

  *)
    echo "Error: Unknown command: $CMD" >&2
    usage >&2
    exit "$EXIT_INPUT_ERROR"
    ;;
esac
