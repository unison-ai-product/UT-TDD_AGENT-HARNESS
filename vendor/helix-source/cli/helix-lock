#!/bin/bash
set -euo pipefail

# shellcheck source=cli/lib/helix-common.sh
source "$(cd "$(dirname "$0")" && pwd)/lib/helix-common.sh"

usage() {
  cat <<'USAGE'
使い方: helix lock <subcommand> [args...]

サブコマンド:
  acquire --name <key> [--timeout <seconds>] [--scope home|project] [--ttl <seconds>]
            file lock + DB metadata lock を取得
  release --name <key> [--scope home|project]
            lock を解放
  list [--scope home|project|all]
            DB lock 一覧を表示
  status --name <key> [--scope home|project]
            lock 状態を表示
USAGE
}

CMD="${1:-help}"
shift 2>/dev/null || true

case "$CMD" in
  acquire|release|list|status)
    export HELIX_LOCK_OWNER_PID="${HELIX_LOCK_OWNER_PID:-$PPID}"
    exec python3 "$SCRIPT_DIR/lib/lock_helper.py" \
      --db-path "$DB_PATH" \
      --project-root "$PROJECT_ROOT" \
      "$CMD" "$@"
    ;;
  help|-h|--help)
    usage
    ;;
  *)
    echo "エラー: 不明な lock subcommand: $CMD" >&2
    usage >&2
    exit 1
    ;;
esac
