}

emit_summary_from_capture() {
  local stdout_file="$1"
  [[ -f "$stdout_file" ]] || return 0
  [[ -s "$stdout_file" ]] || return 0

  local summary_block=""
  summary_block="$(
    awk -v start="$SUMMARY_START_MARKER" -v end="$SUMMARY_END_MARKER" '
      $0 == start {
        capture = 1
        block = $0 ORS
        next
      }
      capture {
        block = block $0 ORS
        if ($0 == end) {
          last = block
          capture = 0
          block = ""
        }
      }
      END { printf "%s", last }
    ' "$stdout_file"
  )"

  if [[ -n "$summary_block" ]]; then
    printf '%s' "$summary_block"
    return 0
  fi

  echo "$SUMMARY_MISSING_WARNING" >&2
  tail -n 30 "$stdout_file"
}

extract_summary_field_from_file() {
  local stdout_file="$1"
  local field_name="$2"
  [[ -f "$stdout_file" ]] || return 0

  awk -v start="$SUMMARY_START_MARKER" -v end="$SUMMARY_END_MARKER" -v field="$field_name" '
    $0 == start { capture = 1; next }
    $0 == end { capture = 0 }
    capture && $0 ~ ("^" field ":") {
      sub("^" field ":[[:space:]]*", "", $0)
      print
      exit
    }
  ' "$stdout_file"
}

