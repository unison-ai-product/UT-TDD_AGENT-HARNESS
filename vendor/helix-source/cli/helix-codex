  return 1
}

extract_baseline_plan_id() {
  local baseline_file="$1"
  sed -n 's/^# plan_id: //p' "$baseline_file" 2>/dev/null | head -n 1
}

extract_audit_pid() {
  local audit_file="$1"
  sed -n 's/^# pid: //p' "$audit_file" 2>/dev/null | head -n 1
}

is_pid_alive_shell() {
  local pid="$1"
  kill -0 "$pid" 2>/dev/null
}

has_matching_same_plan_audit_log() {
  local audit_dir="$1"
  local candidate_pid="$2"
  local candidate=""
  local logged_pid=""

  while IFS= read -r candidate; do
    [[ -n "$candidate" ]] || continue
    logged_pid="$(extract_audit_pid "$candidate")"
    [[ "$logged_pid" == "$candidate_pid" ]] && return 0
  done < <(
    find "$audit_dir" -maxdepth 1 -type f -name "*-${PLAN_ID}-*.log" ! -name "*-stderr.log" -print 2>/dev/null \
      | LC_ALL=C sort
  )

  return 1
}

auto_detect_concurrent_baselines() {
  local before_file="$1"
  local baseline_dir="$2"
  local audit_dir="$PROJECT_ROOT/.helix/audit/codex-runs"
  local baseline_root_real=""
  local candidate=""
  local candidate_real=""
  local candidate_pid=""
  local candidate_plan_id=""
  local auto_added=0

  [[ -n "${PLAN_ID:-}" ]] || return 0
  [[ -d "$audit_dir" && -d "$baseline_dir" && -f "$before_file" ]] || return 0

  baseline_root_real="$(realpath "$baseline_dir" 2>/dev/null || true)"
  [[ -n "$baseline_root_real" ]] || return 0

  shopt -s nullglob
  for candidate in "$baseline_dir"/codex-baseline-*.txt; do
    [[ "$candidate" == "$before_file" ]] && continue
    [[ -L "$candidate" || ! -f "$candidate" ]] && continue

    candidate_real="$(realpath "$candidate" 2>/dev/null || true)"
    [[ -n "$candidate_real" ]] || continue
    case "$candidate_real" in
      "$baseline_root_real"/*) ;;
      *) continue ;;
    esac

    if [[ ! "$(basename "$candidate_real")" =~ ^codex-baseline-([0-9]+)-([0-9]+)\.txt$ ]]; then
      continue
    fi
    candidate_pid="${BASH_REMATCH[1]}"
    [[ "$candidate_pid" != "$$" ]] || continue
    is_pid_alive_shell "$candidate_pid" || continue
    has_matching_same_plan_audit_log "$audit_dir" "$candidate_pid" || continue

    candidate_plan_id="$(extract_baseline_plan_id "$candidate_real")"
    [[ "$candidate_plan_id" == "$PLAN_ID" ]] || continue

    if ! concurrent_from_contains "$candidate_real"; then
      CONCURRENT_FROM_FILES+=("$candidate_real")
      auto_added=$((auto_added + 1))
    fi
  done
  shopt -u nullglob

  if [[ "$auto_added" -gt 0 ]]; then
    echo "[helix-codex] auto-detect: plan=$PLAN_ID baseline=$auto_added file(s)" >&2
  fi
}

