run_auto_role_fallback_chain() {
  local source_role="$1"
  local chain_role=""
  local chain_model=""
  local error_type=""
  local attempted=false

  while IFS= read -r chain_role; do
    [[ -n "$chain_role" ]] || continue
    chain_model="$(resolve_role_primary_model "$chain_role")"
    if [[ -z "$chain_model" ]]; then
      echo "[helix-codex] auto-fallback をスキップ: role $chain_role の primary model を解決できません" >&2
      continue
    fi
    if model_was_tried "$chain_model"; then
      echo "[helix-codex] auto-fallback をスキップ: role $chain_role の primary model は既試行です ($chain_model)" >&2
      continue
    fi

    attempted=true
    active_role="$chain_role"
    active_model="$chain_model"
    record_tried_model "$chain_model"
    echo "[helix-codex] usage limit 検知。auto-fallback: role $source_role -> $active_role (model=$active_model)" >&2

    set +e
    run_codex_once "$active_model" "$active_role"
    codex_exit=$?
    set -e

    if [[ $codex_exit -eq 0 ]]; then
      echo "[helix-codex] auto-fallback 成功: role $active_role (model=$active_model)" >&2
      return 0
    fi

    error_type=$(classify_codex_error "$codex_exit" "$LAST_STDERR_FILE")
    echo "[helix-codex] auto-fallback 失敗: role $active_role (model=$active_model, error=$error_type, exit=$codex_exit)" >&2
  done < <(auto_fallback_roles_for "$source_role")

  if [[ "$attempted" == false ]]; then
    echo "[helix-codex] auto-fallback chain 定義なし: role $source_role" >&2
  fi
  return "$codex_exit"
}

