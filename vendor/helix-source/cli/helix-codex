  fi
  local rc=$?
  if [[ -n "$agent_slot_id" ]]; then
    if [[ $rc -eq 0 ]]; then
      agent_slot_status="completed"
    elif [[ $rc -eq 130 || $rc -eq 143 ]]; then
      agent_slot_status="cancelled"
    fi
    "$SCRIPT_DIR/helix-agent" release --slot-id "$agent_slot_id" --status "$agent_slot_status" --exit-code "$rc" >/dev/null 2>&1 || true
    trap - INT TERM
    unset HELIX_AGENT_SLOT_ID
  fi
  if [[ $rc -eq 0 ]]; then
    check_write_expected_delta "$STDOUT_FILE" || true
  fi
  LAST_OUTPUT_BYTES="$(wc -c < "$STDOUT_FILE" | tr -d '[:space:]')"
  LAST_SUMMARY_DECISION="$(extract_summary_field_from_file "$STDOUT_FILE" "decision")"
  LAST_SUMMARY_COST_CENTS="$(extract_summary_field_from_file "$STDOUT_FILE" "cost_cents")"
  emit_summary_from_capture "$STDOUT_FILE"
  if [[ $rc -eq 0 ]]; then
    run_codex_post_hook "$STDOUT_FILE" "$AUDIT_FILE" "$run_role"
  fi
  rm -f "$STDOUT_FILE" 2>/dev/null || true
  return $rc
}

record_invocation_telemetry() {
  local db_path="${HELIX_DIR}/helix.db"
  local ended_at_ms=""
  local duration_ms=0
  local decision="${LAST_SUMMARY_DECISION:-}"
  local parent_invocation_id=""
  local payload=""

  ended_at_ms="$(python3 - <<'PY'
import time
print(int(time.time() * 1000))
PY
)"
  if [[ "$RUN_STARTED_AT_MS" =~ ^[0-9]+$ && "$ended_at_ms" =~ ^[0-9]+$ ]]; then
    duration_ms=$((ended_at_ms - RUN_STARTED_AT_MS))
    if (( duration_ms < 0 )); then
      duration_ms=0
    fi
  fi

  if [[ -z "$decision" ]]; then
    if [[ $codex_exit -eq 0 ]]; then
      decision="passed"
    else
      decision="failed"
    fi
  fi

  if [[ "${HELIX_PARENT_INVOCATION_ID:-}" =~ ^[0-9]+$ ]]; then
    parent_invocation_id="${HELIX_PARENT_INVOCATION_ID}"
  fi

  payload="$(
    HELIX_INVOCATION_TYPE="codex" \
    HELIX_INVOCATION_ROLE="$ROLE" \
    HELIX_INVOCATION_MODEL="$codex_model" \
    HELIX_INVOCATION_TASK_ID="$TASK_ID" \
    HELIX_INVOCATION_PLAN_ID="$PLAN_ID" \
    HELIX_INVOCATION_SPRINT="$L4_SPRINT" \
    HELIX_INVOCATION_INPUT_BYTES="$PROMPT_BYTES" \
    HELIX_INVOCATION_OUTPUT_BYTES="$LAST_OUTPUT_BYTES" \
    HELIX_INVOCATION_DURATION_MS="$duration_ms" \
    HELIX_INVOCATION_DECISION="$decision" \
    HELIX_INVOCATION_COST_CENTS="${LAST_SUMMARY_COST_CENTS:-}" \
    HELIX_INVOCATION_PARENT_ID="$parent_invocation_id" \
    python3 - <<'PY'
import json
import os


def _int_env(name):
    value = os.environ.get(name, "").strip()
    return int(value) if value.isdigit() else None


def _float_env(name):
    value = os.environ.get(name, "").strip()
    if not value:
        return None
    try:
        return float(value)
    except ValueError:
        return None


payload = {
    "type": os.environ["HELIX_INVOCATION_TYPE"],
    "role": os.environ.get("HELIX_INVOCATION_ROLE") or None,
    "model": os.environ.get("HELIX_INVOCATION_MODEL") or None,
    "task_id": os.environ.get("HELIX_INVOCATION_TASK_ID") or None,
    "plan_id": os.environ.get("HELIX_INVOCATION_PLAN_ID") or None,
    "sprint": os.environ.get("HELIX_INVOCATION_SPRINT") or None,
    "input_bytes": _int_env("HELIX_INVOCATION_INPUT_BYTES"),
    "output_bytes": _int_env("HELIX_INVOCATION_OUTPUT_BYTES"),
    "duration_ms": _int_env("HELIX_INVOCATION_DURATION_MS"),
    "decision": os.environ.get("HELIX_INVOCATION_DECISION") or None,
    "cost_cents": _float_env("HELIX_INVOCATION_COST_CENTS"),
    "parent_invocation_id": _int_env("HELIX_INVOCATION_PARENT_ID"),
}
payload["raw_meta"] = {
    "role": payload["role"],
    "model": payload["model"],
    "task_id": payload["task_id"],
    "plan_id": payload["plan_id"],
    "sprint": payload["sprint"],
    "decision": payload["decision"],
    "duration_ms": payload["duration_ms"],
    "cost_cents": payload["cost_cents"],
}
print(json.dumps(payload, ensure_ascii=False))
PY
  )" || return 0

  python3 "$SCRIPT_DIR/lib/helix_db.py" record-invocation "$db_path" "$payload" >/dev/null 2>&1 || true
}

# Primary model リトライループ
retry=0
codex_exit=1
active_model="$codex_model"
active_role="$ROLE"
last_error_type="other"
TRIED_MODELS=()
record_tried_model "$codex_model"

while [[ $retry -le $MAX_RETRY ]]; do
  set +e
  run_codex_once "$active_model" "$active_role"
  codex_exit=$?
  set -e

  if [[ $codex_exit -eq 0 ]]; then
    break
  fi

  retry=$((retry + 1))
  if [[ $retry -le $MAX_RETRY ]]; then
    last_error_type=$(classify_codex_error "$codex_exit" "$LAST_STDERR_FILE")
    backoff=$(calculate_backoff "$last_error_type" "$retry")
    echo "[helix-codex] リトライ ($retry/$MAX_RETRY, error=$last_error_type, backoff=${backoff}s)..." >&2
    if [[ $backoff -gt 0 ]]; then
      sleep "$backoff" 2>/dev/null || true
    fi
  fi
done

if [[ $codex_exit -ne 0 ]]; then
  last_error_type=$(classify_codex_error "$codex_exit" "$LAST_STDERR_FILE")
fi

# --- Layer 0/1/2 フォールバック: usage_limit 時のみ Layer 2 を Layer 1 より先に試行 ---
if [[ $codex_exit -ne 0 ]]; then
  if [[ -n "$CLI_FALLBACK_MODEL" ]]; then
    run_model_fallback "$CLI_FALLBACK_MODEL"
  fi

  if [[ $codex_exit -ne 0 ]]; then
    last_error_type=$(classify_codex_error "$codex_exit" "$LAST_STDERR_FILE")
    if [[ "$last_error_type" == "usage_limit" ]] && [[ "${HELIX_CODEX_AUTO_FALLBACK:-0}" == "1" ]]; then
      run_auto_role_fallback_chain "$ROLE" || true
      if [[ $codex_exit -ne 0 ]] && [[ -n "$registry_default_fallback" ]] && ! model_was_tried "$registry_default_fallback"; then
        run_model_fallback "$registry_default_fallback"
      fi
    elif [[ -z "$CLI_FALLBACK_MODEL" ]] && [[ -n "$FALLBACK_MODEL" ]]; then
      run_model_fallback "$FALLBACK_MODEL"
    fi
  fi
fi

# --- Layer 3 フォールバック: Claude Code 用 prompt をローカル生成 ---
# v1 は Claude Code を自動実行せず、契約プラン/CLI 利用前提の prompt を .helix/tasks/ に渡す。
if [[ $codex_exit -ne 0 ]] && [[ "$FALLBACK_PROVIDER" == "claude-code" ]]; then
  fallback_dir="$HELIX_DIR/tasks"
  mkdir -p "$fallback_dir"
  fallback_output="$fallback_dir/codex-fallback-$(date +%Y%m%d-%H%M%S).claude.md"
  claude_args=(--role "$ROLE" --output "$fallback_output")
  if [[ -n "$TASK_FILE" ]]; then
    claude_args+=(--task-file "$TASK_FILE_REAL")
  else
    claude_args+=(--task "$TASK")
  fi
  if [[ -f "$HELIX_DIR/handover/CURRENT.md" ]]; then
    claude_args+=(--handover)
  fi

  if "$SCRIPT_DIR/helix-claude" "${claude_args[@]}" >/dev/null; then
    echo "[helix-codex] Claude Code fallback prompt generated: ${fallback_output#$PROJECT_ROOT_REAL/}" >&2
  else
    echo "[helix-codex] Claude Code fallback prompt generation failed" >&2
  fi
fi

if [[ -n "$DIFF_BEFORE" && -n "$DIFF_AFTER" && -n "$UNTRACKED_AFTER" ]]; then
  write_git_change_snapshot "$DIFF_AFTER"
  write_git_untracked_snapshot "$UNTRACKED_AFTER"
  auto_detect_concurrent_baselines "$DIFF_BEFORE" "$BASELINE_DIR"
  if ! check_allowed_files_delta "$DIFF_BEFORE" "$DIFF_AFTER" "$UNTRACKED_AFTER" "$BASELINE_DIR"; then
    codex_exit=1
  fi
  rm -f "$DIFF_BEFORE" "$DIFF_AFTER" "$UNTRACKED_AFTER" 2>/dev/null || true
fi

record_invocation_telemetry || true

# コスト記録（バックグラウンド）
cost_bg_pid=""
if [[ -f "$HELIX_DIR/helix.db" ]]; then
  # active_model / active_role は最後に試行した実行コンテキストを表す
  HELIX_DB_PATH="$HELIX_DIR/helix.db" python3 "$SCRIPT_DIR/lib/helix_db.py" insert cost_log \
    "{\"role\":\"$active_role\",\"model\":\"$active_model\",\"thinking\":\"$THINKING\",\"retries\":$retry,\"exit_code\":$codex_exit}" 2>/dev/null &
  cost_bg_pid=$!
fi

if [[ -n "$cost_bg_pid" ]]; then
  ( sleep 5; kill -TERM "$cost_bg_pid" 2>/dev/null ) &
  kill_sentinel=$!
  wait "$cost_bg_pid" 2>/dev/null || true
  kill "$kill_sentinel" 2>/dev/null || true
  wait "$kill_sentinel" 2>/dev/null || true
fi

exit "$codex_exit"
