#!/bin/bash
set -euo pipefail

# helix-codex: HELIX スキル注入付き Codex CLI ラッパー
# Usage: helix-codex --role <role> --task "タスク内容" [--thinking <level>]

source "$(cd "$(dirname "$0")" && pwd)/lib/helix-common.sh"
ROLES_DIR="$SCRIPT_DIR/roles"
SKILLS_DIR="$HELIX_HOME/skills"
PROJECT_GENERATED_SKILLS_DIR="$PROJECT_ROOT/skills/generated"
PROJECT_SKILLS_DIR="$PROJECT_ROOT/skills"
PROJECT_CLAUDE_SKILLS_DIR="$PROJECT_ROOT/.claude/skills"
CODEX_BIN="${CODEX_BIN:-}"

# --- パス検証ユーティリティ ---
PROJECT_ROOT_REAL="$(realpath "$PROJECT_ROOT")"
ROLES_DIR_REAL="$(realpath "$ROLES_DIR")"
SKILLS_DIR_REAL="$(realpath "$SKILLS_DIR")"
HELIX_HOME_REAL="$(realpath "$HELIX_HOME")"
HOME_HELIX_REAL="$(realpath -m "$HOME/.helix")"
PROJECT_GENERATED_SKILLS_DIR_REAL="$(realpath -m "$PROJECT_GENERATED_SKILLS_DIR")"
PROJECT_SKILLS_DIR_REAL="$(realpath -m "$PROJECT_SKILLS_DIR")"
PROJECT_CLAUDE_SKILLS_DIR_REAL="$(realpath -m "$PROJECT_CLAUDE_SKILLS_DIR")"

resolve_codex_bin() {
  if [[ -n "$CODEX_BIN" ]]; then
    echo "$CODEX_BIN"
    return 0
  fi

  local candidate
  local candidate_real
  while IFS= read -r candidate; do
    [[ -z "$candidate" ]] && continue
    candidate_real="$(realpath -m "$candidate")"
    case "$candidate_real" in
      "$SCRIPT_DIR/codex"|"$HELIX_HOME_REAL/cli/codex")
        continue
        ;;
    esac
    if [[ -x "$candidate_real" ]]; then
      echo "$candidate_real"
      return 0
    fi
  done < <(type -P -a codex 2>/dev/null || true)

  if [[ -x "$HOME/.npm-global/bin/codex" ]]; then
    echo "$HOME/.npm-global/bin/codex"
    return 0
  fi

  echo ""
  return 1
}

CODEX_BIN="$(resolve_codex_bin || true)"

# --- 引数パース ---
ROLE=""
TASK=""
TASK_FILE=""
THINKING=""
THINKING_EXPLICIT=false
AUTO_THINKING=false
DRY_RUN=false
SANDBOX="workspace-write"
SANDBOX_EXPLICIT=false
# 2026-04-30: full-auto を default 化 (Codex hang 防止、~/.codex/config.toml の
# full_auto=true と整合させる。--no-full-auto で opt-out 可能)。
FULL_AUTO="--full-auto"
FULL_AUTO_EXPLICIT=false
CONSENT_MODE="auto"
NO_RECORD="${NO_RECORD:-${HELIX_AGENT_NO_RECORD:-0}}"
PLAN_ONLY=false
PLAN_ONLY_REASON=""
PLAN_ID=""
TASK_ID=""
WBS_ID=""
L4_SPRINT=""
ACCEPTANCE_ITEMS=()
REFERENCE_DOCS=()
ALLOWED_FILES=""
AUTO_ALLOWED_FILES=false
AUTO_ALLOWED_FILES_THRESHOLD="${HELIX_CODEX_AUTO_ALLOWED_FILES_THRESHOLD:-0.5}"
AUTO_ALLOWED_FILES_CONFIDENCE="0.000"
AUTO_ALLOWED_FILES_LOW_CONFIDENCE=true
AUTO_ALLOWED_FILES_CANDIDATES=()
AUTO_ALLOWED_FILES_MODE="disabled"
CONCURRENT_FROM_FILES=()
APPROVAL_ID=""
APPROVAL_FILE=""
TIMEOUT=1800
MAX_RETRY=2          # GAP-038: デフォルトはロール別後続で上書き
FALLBACK_MODEL=""    # Layer 0/1: 明示または default_fallback の代替モデル
CLI_FALLBACK_MODEL="" # Layer 0: --fallback-model で明示指定された代替モデル
FALLBACK_PROVIDER="" # GAP-038 Phase 3: Layer 3 ローカル委譲先
MODEL_OVERRIDE_NORMALIZED=""
SUMMARY_START_MARKER="---SUMMARY_START---"
SUMMARY_END_MARKER="---SUMMARY_END---"
SUMMARY_MISSING_WARNING="[helix-codex] WARNING: summary marker missing, falling back to last 30 lines"
SPARK_MODEL_ID="gpt-5.3-codex-spark"
SPARK_DISABLED_MODEL_ID="gpt-5.3-codex"
RUN_STARTED_AT_MS="$(python3 - <<'PY'
import time
print(int(time.time() * 1000))
PY
)"
PROMPT_BYTES=0
LAST_SUMMARY_DECISION=""
LAST_SUMMARY_COST_CENTS=""
LAST_OUTPUT_BYTES=0

while [[ $# -gt 0 ]]; do
  case $1 in
    --role)            ROLE="$2"; shift 2 ;;
    --task)            TASK="$2"; shift 2 ;;
    --task-file)       TASK_FILE="$2"; shift 2 ;;
    --thinking)        THINKING="$2"; THINKING_EXPLICIT=true; shift 2 ;;
    --auto-thinking)   AUTO_THINKING=true; shift ;;
    --timeout)         TIMEOUT="$2"; shift 2 ;;
    --max-retries)     MAX_RETRY="$2"; shift 2 ;;
    --fallback-model)  CLI_FALLBACK_MODEL="$2"; FALLBACK_MODEL="$2"; shift 2 ;;
    --fallback-provider) FALLBACK_PROVIDER="$2"; shift 2 ;;
    --sandbox)         SANDBOX="$2"; SANDBOX_EXPLICIT=true; shift 2 ;;
    --read-only)       SANDBOX="read-only"; SANDBOX_EXPLICIT=true; shift ;;
    --full-auto)       FULL_AUTO="--full-auto"; FULL_AUTO_EXPLICIT=true; shift ;;
    --no-full-auto)    FULL_AUTO=""; FULL_AUTO_EXPLICIT=true; shift ;;
    --consent)         CONSENT_MODE="$2"; shift 2 ;;
    --plan-only)       CONSENT_MODE="plan-only"; shift ;;
    --approved)        CONSENT_MODE="approved"; shift ;;
    --no-record)       NO_RECORD="1"; shift ;;
    --plan-id)         PLAN_ID="$2"; shift 2 ;;
    --task-id)         TASK_ID="$2"; shift 2 ;;
    --wbs-id)          WBS_ID="$2"; shift 2 ;;
    --l4-sprint)       L4_SPRINT="$2"; shift 2 ;;
    --acceptance)      ACCEPTANCE_ITEMS+=("$2"); shift 2 ;;
    --reference-doc)   REFERENCE_DOCS+=("$2"); shift 2 ;;
    --allowed-files)   ALLOWED_FILES="$2"; shift 2 ;;
    --auto-allowed-files) AUTO_ALLOWED_FILES=true; shift ;;
    --concurrent-from) CONCURRENT_FROM_FILES+=("$2"); shift 2 ;;
    --approval-id)     APPROVAL_ID="$2"; shift 2 ;;
    --approval-file)   APPROVAL_FILE="$2"; shift 2 ;;
    --dry-run)         DRY_RUN=true; shift ;;
    --help|-h)
      echo "使い方: helix codex --role <role> (--task \"タスク\" | --task-file <path>)"
      echo ""
      echo "Options:"
      echo "  --role <role>            ロール（tl/se/pg/fe/qa/security/dba/devops/docs/research/legacy/perf）"
      echo "  --task \"...\"             タスク内容（文字列）"
      echo "  --task-file <path>       タスク内容をファイルから読む（大きなプロンプト向け、ARG_MAX 回避）"
      echo "  --thinking <level>       思考レベル（low/medium/high/xhigh）。省略時はロール別デフォルト"
      echo "  --auto-thinking          タスク難度から thinking を自動推定（--thinking と併用時は手動優先）"
      echo "  --timeout <sec>          codex exec タイムアウト秒（デフォルト: 1800）"
      echo "  --max-retries <n>        最大リトライ回数（デフォルト: 2、0 でリトライなし）"
      echo "  --fallback-model <name>  Codex 失敗時の代替モデル（例: gpt-5.2-codex）"
      echo "  --fallback-provider claude-code"
      echo "                           Codex 失敗時に Claude Code 用 prompt を .helix/tasks/ へ生成"
      echo "  HELIX_MODEL_OVERRIDE     環境変数でモデルを強制上書き（models.yaml より優先）"
      echo "  --sandbox    サンドボックスモード (read-only|workspace-write|danger-full-access)"
      echo "               デフォルト: workspace-write"
      echo "               danger-full-access は対話確認、非対話では HELIX_ALLOW_DANGER_SANDBOX=1 が必要"
      echo "  --read-only  --sandbox read-only のショートカット"
      echo "  --full-auto          承認なしで自律実行"
      echo "  --consent <mode>     plan-only|approved|auto（デフォルト: auto）"
      echo "  --plan-only          計画のみ。read-only + no-full-auto を強制"
      echo "  --approved           明示承認済みとして write 実行を許可"
      echo "  --no-record          agent_slots への fire/release 記録を無効化"
      echo "  --plan-id <id>       HELIX plan id をプロンプトへ注入"
      echo "  --task-id <id>       HELIX task id をプロンプトへ注入"
      echo "  --wbs-id <id>        L3 WBS id をプロンプトへ注入"
      echo "  --l4-sprint <step>   L4 sprint (.1a/.1b/.2/.3/.4/.5) を注入"
      echo "  --acceptance <text>  受入条件を追加（複数可）"
      echo "  --reference-doc <p>  参照ドキュメントを追加（複数可）"
      echo "  --allowed-files <g>  編集許可ファイル/グロブを注入"
      echo "  --auto-allowed-files task description から allowed_files 候補を自動推定"
      echo "  --concurrent-from <p> 並列 baseline を post-validation へ追加（複数可）"
      echo "  --approval-id <id>   承認証跡 ID（.helix/approvals/<id>.* を検証）"
      echo "  --approval-file <p>  承認証跡ファイルを明示"
      echo "  HELIX_CODEX_REQUIRE_APPROVED=1          write 実行に --approved を必須化"
      echo "  HELIX_CODEX_REQUIRE_APPROVAL_EVIDENCE=1 --approved に承認証跡を必須化"
      echo "  --dry-run    実行せずプロンプトだけ表示"
      echo ""
      echo "Roles:"
      for f in "$ROLES_DIR"/*.conf; do
        basename "$f" .conf
      done
      exit 0
      ;;
    *) echo "エラー: 不明なオプションです: $1" >&2; exit 1 ;;
  esac
done

# --- --task と --task-file の排他チェック ---
if [[ -n "$TASK" && -n "$TASK_FILE" ]]; then
  echo "エラー: --task と --task-file は同時指定できません" >&2
  exit 1
fi

if [[ -n "$ALLOWED_FILES" && "$AUTO_ALLOWED_FILES" == true ]]; then
  echo "エラー: --allowed-files と --auto-allowed-files は同時指定できません" >&2
  exit 1
fi

# --- --task-file 読み込み ---
if [[ -n "$TASK_FILE" ]]; then
  TASK_FILE_REAL="$(realpath "$TASK_FILE" 2>/dev/null || true)"
  if [[ -z "$TASK_FILE_REAL" || ! -f "$TASK_FILE_REAL" ]]; then
    echo "エラー: --task-file が見つかりません: $TASK_FILE" >&2
    exit 1
  fi
  ensure_within_any_dir "$TASK_FILE_REAL" "task file" "$PROJECT_ROOT_REAL" "$HELIX_HOME_REAL" "$HOME_HELIX_REAL"
  if [[ ! -r "$TASK_FILE_REAL" ]]; then
    echo "エラー: --task-file を読み込めません: $TASK_FILE" >&2
    exit 1
  fi
  TASK=$(cat "$TASK_FILE_REAL")
fi

# --- max_retries バリデーション ---
if ! [[ "$MAX_RETRY" =~ ^[0-9]+$ ]] || [[ "$MAX_RETRY" -gt 10 ]]; then
  echo "エラー: 無効な --max-retries 値です: '$MAX_RETRY'（0-10 の整数を指定）" >&2
  exit 1
fi

if [[ -z "$ROLE" || -z "$TASK" ]]; then
  echo "エラー: --role と --task は必須です" >&2
  echo "--help で使い方を確認してください" >&2
  exit 1
fi

case "${NO_RECORD,,}" in
  1|true|yes|on) NO_RECORD="1" ;;
  *) NO_RECORD="0" ;;
esac

if [[ "$ROLE" == "recommender" || "${HELIX_DYNAMIC_SKILL_RECOMMENDER_ACTIVE:-0}" == "1" ]]; then
  NO_RECORD="1"
fi

case "$CONSENT_MODE" in
  auto|plan-only|approved) ;;
  *)
    echo "エラー: 無効な --consent 値です: '$CONSENT_MODE'（有効値: auto|plan-only|approved）" >&2
    exit 1
    ;;
esac

# --- ロール名バリデーション ---
if [[ ! "$ROLE" =~ ^[a-z0-9_-]+$ ]]; then
  echo "エラー: 無効な --role 値です: '$ROLE'（許可パターン: ^[a-z0-9_-]+$）" >&2
  exit 1
fi

if [[ -n "$FALLBACK_PROVIDER" ]]; then
  case "$FALLBACK_PROVIDER" in
    claude-code) ;;
    *)
      echo "エラー: 無効な --fallback-provider 値です: '$FALLBACK_PROVIDER'（有効値: claude-code）" >&2
      exit 1
      ;;
  esac

  case "$ROLE" in
    pg|fe|qa|dba|devops|docs|research) ;;
    *)
      echo "エラー: role=$ROLE では --fallback-provider claude-code は許可されていません" >&2
      exit 1
      ;;
  esac
fi

# --- thinking level バリデーション ---
if [[ -n "$THINKING" ]]; then
  case "$THINKING" in
    low|medium|high|xhigh) ;;
    *)
      echo "エラー: 無効な --thinking 値です: '$THINKING'（有効値: low|medium|high|xhigh）" >&2
      exit 1
      ;;
  esac
fi

# PLAN-022 W-P2-1b: get_default_thinking() は廃止。
# 全ロール conf に codex_thinking= が必須化された (W-P2-1a)。
# --thinking 未指定 + conf 未定義 の組み合わせは下流で exit 1 する。

validate_sandbox_mode() {
  local sandbox="$1"
  case "$sandbox" in
    read-only|workspace-write|danger-full-access) ;;
    *)
      echo "エラー: 無効な --sandbox 値です: '$sandbox'（有効値: read-only|workspace-write|danger-full-access）" >&2
      return 1
      ;;
  esac
}

guard_danger_sandbox() {
  [[ "$SANDBOX" == "danger-full-access" ]] || return 0
  [[ "$DRY_RUN" == true ]] && return 0

  if [[ -t 0 && -t 2 && -r /dev/tty ]]; then
    local confirm=""
    printf '[helix-codex] 警告: --sandbox danger-full-access を使用します。続行しますか? [y/N] ' >&2
    IFS= read -r confirm < /dev/tty || true
    case "$confirm" in
      y|Y|yes|YES) ;;
      *)
        echo "エラー: danger-full-access がユーザー確認で拒否されました" >&2
        return 1
        ;;
    esac
  elif [[ "${HELIX_ALLOW_DANGER_SANDBOX:-}" != "1" ]]; then
    echo "エラー: 非対話環境で --sandbox danger-full-access を使うには HELIX_ALLOW_DANGER_SANDBOX=1 が必要です" >&2
    return 1
  fi
}

normalize_model_alias() {
  case "$1" in
    spark) printf '%s\n' "$SPARK_MODEL_ID" ;;
    codex) printf '%s\n' "$SPARK_DISABLED_MODEL_ID" ;;
    *)     printf '%s\n' "$1" ;;
  esac
}

disable_spark_enabled() {
  [[ "${HELIX_DISABLE_SPARK:-0}" == "1" ]]
}

is_spark_model() {
  [[ "$1" == "$SPARK_MODEL_ID" ]]
}

spark_rewrite_applies_to_role() {
  case "$1" in
    docs|pg) return 0 ;;
    *)       return 1 ;;
  esac
}

rewrite_spark_model_if_disabled() {
  local model="$1"
  local role="${2:-}"
  if disable_spark_enabled && spark_rewrite_applies_to_role "$role" && is_spark_model "$model"; then
    printf '%s\n' "$SPARK_DISABLED_MODEL_ID"
  else
    printf '%s\n' "$model"
  fi
}

warn_disable_spark_override() {
  local source_label="$1"
  local model="$2"
  if disable_spark_enabled && is_spark_model "$model"; then
    echo "[helix-codex] WARNING: HELIX_DISABLE_SPARK=1 ですが ${source_label} が ${SPARK_MODEL_ID} を明示指定したため、その指定を優先します" >&2
  fi
}

config_bool() {
  local dotpath="$1"
  local default="$2"
  local value=""

  if [[ -f "$CONFIG_FILE" && -f "$YAML_PARSER" ]]; then
    value=$(python3 "$YAML_PARSER" read "$CONFIG_FILE" "$dotpath" 2>/dev/null || true)
  fi

  case "${value,,}" in
    true|yes|on|1) echo 1 ;;
    false|no|off|0) echo 0 ;;
    *) echo "$default" ;;
  esac
}

env_or_config_bool() {
  local env_name="$1"
  local dotpath="$2"
  local default="$3"
  local env_value="${!env_name:-}"

  case "${env_value,,}" in
    true|yes|on|1) echo 1 ;;
    false|no|off|0) echo 0 ;;
    "") config_bool "$dotpath" "$default" ;;
    *) echo "$default" ;;
  esac
}

detect_task_type() {
  python3 "$SCRIPT_DIR/lib/task_type_inference.py" --mode detect --task "$1"
}

estimate_allowed_files_from_task() {
  local estimator_output=""
  local path=""
  local joined_candidates=""

  [[ "$AUTO_ALLOWED_FILES" == true ]] || return 0

  estimator_output="$(HELIX_SCRIPT_LIB="$SCRIPT_DIR/lib" \
    HELIX_ESTIMATOR_TASK="$TASK_RAW" \
    HELIX_ESTIMATOR_REPO_ROOT="$PROJECT_ROOT" \
    HELIX_ESTIMATOR_THRESHOLD="$AUTO_ALLOWED_FILES_THRESHOLD" \
    python3 - <<'PY'
import os
import sys
from pathlib import Path

sys.path.insert(0, os.environ["HELIX_SCRIPT_LIB"])
from allowed_files_estimator import estimate_allowed_files, extract_keywords, find_matching_files

task = os.environ["HELIX_ESTIMATOR_TASK"]
repo_root = Path(os.environ["HELIX_ESTIMATOR_REPO_ROOT"])
threshold = float(os.environ["HELIX_ESTIMATOR_THRESHOLD"])

candidates, confidence, low_confidence = estimate_allowed_files(task, repo_root, threshold)
if low_confidence:
    candidates = find_matching_files(extract_keywords(task), repo_root)

print(f"confidence={confidence:.3f}")
print(f"low_confidence={'1' if low_confidence else '0'}")
for path in candidates:
    print(path.as_posix())
PY
  )" || {
    echo "エラー: --auto-allowed-files の候補推定に失敗しました" >&2
    exit 1
  }

  AUTO_ALLOWED_FILES_CONFIDENCE="$(sed -n 's/^confidence=//p' <<< "$estimator_output" | head -n 1)"
  if [[ "$(sed -n 's/^low_confidence=//p' <<< "$estimator_output" | head -n 1)" == "1" ]]; then
    AUTO_ALLOWED_FILES_LOW_CONFIDENCE=true
  else
    AUTO_ALLOWED_FILES_LOW_CONFIDENCE=false
  fi

  AUTO_ALLOWED_FILES_CANDIDATES=()
  while IFS= read -r path; do
    [[ -n "$path" ]] && AUTO_ALLOWED_FILES_CANDIDATES+=("$path")
  done < <(sed -n '3,$p' <<< "$estimator_output")

  if [[ ${#AUTO_ALLOWED_FILES_CANDIDATES[@]} -gt 0 ]]; then
    joined_candidates="$(IFS=,; echo "${AUTO_ALLOWED_FILES_CANDIDATES[*]}")"
  fi

  if [[ "$DRY_RUN" == true || "$SANDBOX" == "read-only" ]]; then
    AUTO_ALLOWED_FILES_MODE="dry-run"
    return 0
  fi

  if [[ "$AUTO_ALLOWED_FILES_LOW_CONFIDENCE" == true ]]; then
    AUTO_ALLOWED_FILES_MODE="suggestion"
    if [[ -n "$joined_candidates" ]]; then
      echo "[helix-codex] WARNING: auto-allowed-files low confidence=${AUTO_ALLOWED_FILES_CONFIDENCE}; not enforcing. suggestion: $joined_candidates" >&2
    else
      echo "[helix-codex] WARNING: auto-allowed-files low confidence=${AUTO_ALLOWED_FILES_CONFIDENCE}; suggestion なし。manual --allowed-files を推奨します" >&2
    fi
    return 0
  fi

  ALLOWED_FILES="$joined_candidates"
  AUTO_ALLOWED_FILES_MODE="applied"
  echo "[helix-codex] auto-allowed-files applied (confidence=${AUTO_ALLOWED_FILES_CONFIDENCE}): $ALLOWED_FILES" >&2
}

ensure_task_type_prefix() {
  python3 "$SCRIPT_DIR/lib/task_type_inference.py" --mode prefix --task "$1"
}

should_include_review_template_for_task_type() {
  [[ "$(python3 "$SCRIPT_DIR/lib/task_type_inference.py" --mode review-template --task-type "$1")" == "true" ]]
}

detect_plan_only_task() {
  local task="$1"
  local task_type="${2:-不明}"
  local raw_task="${3:-$task}"
  local plan_pattern='計画|実装順|工程表|整理|方針|案を|洗い出し|レビュー|調査|見積|plan|planning|review|analyze|analysis|investigate|research'
  local execute_pattern='実装して|修正して|対応して|導入して|実行して|進めて|やって|閉じて|直して|作って|追加して|変更して|apply|proceed|implement|fix|install|run|execute|change|add'
  local explicit_implementation_pattern='^[[:space:]]*\[タスク種別\][[:space:]]*:?[[:space:]]*(\*\*|__|`)?[[:space:]]*実装([[:space:][:punct:]]|$)'

  if grep -Eq "$explicit_implementation_pattern" <<< "$raw_task"; then
    return 1
  fi

  case "$task_type" in
    レビュー|設計|調査) return 0 ;;
  esac

  if grep -Eiq "$plan_pattern" <<< "$task" && ! grep -Eiq "$execute_pattern" <<< "$task"; then
    return 0
  fi

  case "$task_type" in
    実装) return 1 ;;
  esac

  return 1
}

apply_consent_guard() {
  local require_approved
  require_approved=$(env_or_config_bool HELIX_CODEX_REQUIRE_APPROVED "codex.require_approved" 0)

  case "$CONSENT_MODE" in
    plan-only)
      PLAN_ONLY=true
      PLAN_ONLY_REASON="--consent plan-only"
      ;;
    approved)
      PLAN_ONLY=false
      PLAN_ONLY_REASON="approved"
      ;;
    auto)
      if detect_plan_only_task "$TASK" "$TASK_TYPE" "$TASK_RAW"; then
        PLAN_ONLY=true
        PLAN_ONLY_REASON="auto-detected plan/review task"
      fi
      ;;
  esac

  if [[ "$PLAN_ONLY" == true ]]; then
    if [[ "$SANDBOX" != "read-only" || -n "$FULL_AUTO" ]]; then
      echo "[helix-codex] plan-only guard: $PLAN_ONLY_REASON -> sandbox=read-only, full-auto=off" >&2
    fi
    SANDBOX="read-only"
    FULL_AUTO=""
  elif [[ "$require_approved" == "1" && "$DRY_RUN" != true && "$SANDBOX" != "read-only" && "$CONSENT_MODE" != "approved" ]]; then
    echo "エラー: codex.require_approved=true のため write 実行には --approved または --consent approved が必要です" >&2
    exit 1
  fi
}

validate_agent_policy() {
  local policy_output
  if ! policy_output=$(python3 "$SCRIPT_DIR/lib/agent_policy_guard.py" \
    --role "$ROLE" \
    --engine codex \
    --task "$TASK" \
    --json 2>&1); then
    echo "エラー: HELIX agent policy に違反しています" >&2
    echo "$policy_output" >&2
    exit 1
  fi
}

validate_reference_docs() {
  local ref
  local ref_real

  for ref in "${REFERENCE_DOCS[@]}"; do
    [[ -z "$ref" ]] && continue
    if [[ "$ref" == /* ]]; then
      ref_real="$(realpath -m "$ref")"
    else
      ref_real="$(realpath -m "$PROJECT_ROOT/$ref")"
    fi
