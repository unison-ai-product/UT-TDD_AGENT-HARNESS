classify_codex_error() {
  local code="$1"
  local stderr_file="${2:-}"
  if [[ -n "$stderr_file" && -f "$stderr_file" ]] && grep -qi 'hit your usage limit' "$stderr_file"; then
    echo "usage_limit"
    return 0
  fi
  case "$code" in
    124)     echo "timeout" ;;
    7|8|28)  echo "network" ;;  # curl-style exit codes
    *)       echo "other" ;;
  esac
}

calculate_backoff() {
  local error_type="$1"
  local attempt="$2"
  case "$error_type" in
    timeout)  echo 0 ;;                            # 即リトライ
    network)  echo $((1 << (attempt - 1))) ;;      # 1, 2, 4, 8 ...（エクスポネンシャル）
    *)        echo 1 ;;                            # 標準
  esac
}

