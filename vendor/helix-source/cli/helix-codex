parse_array() {
  local key="$1"
  local file="$2"
  local in_array=false
  while IFS= read -r line; do
    if [[ "$line" == "${key}=(" ]]; then
      in_array=true
      continue
    fi
    if [[ "$in_array" == true ]]; then
      if [[ "$line" == ")" ]]; then
        break
      fi
      local item
      item=$(echo "$line" | sed 's/^[[:space:]]*//' | sed 's/[[:space:]]*$//')
      if [[ -n "$item" ]]; then
        echo "$item"
      fi
    fi
  done < "$file"
}

