from pathlib import Path

MODEL_RE = re.compile(r"^[A-Za-z0-9._-]+$")

sys.path.insert(0, os.environ["HELIX_SCRIPT_LIB"])
from yaml_parser import parse_yaml


def add_strings(value, sink):
    if isinstance(value, str):
        if MODEL_RE.fullmatch(value):
            sink.add(value)
        return
    if isinstance(value, list):
        for item in value:
            add_strings(item, sink)
        return
    if isinstance(value, dict):
        for item in value.values():
            add_strings(item, sink)


path = Path(os.environ["HELIX_ALLOWED_FILE"])
data = parse_yaml(path.read_text(encoding="utf-8"))
if not isinstance(data, dict):
    raise SystemExit(1)

roles = data.get("roles", {})
allowed = set()
if isinstance(roles, dict):
    for role_config in roles.values():
        add_strings(role_config, allowed)
        if not isinstance(role_config, dict):
            continue
        for key in ("primary", "fallback", "model", "models"):
            if key in role_config:
                add_strings(role_config[key], allowed)

for key in ("default_primary", "default_fallback", "primary", "fallback", "model", "models"):
    if key in data:
        add_strings(data[key], allowed)

print("\n".join(sorted(allowed)))
PY
  ) || {
    echo "エラー: models.yaml から許可モデル一覧を取得できません: $allowed_file" >&2
    return 1
  }

  if [[ -z "$allowed" ]]; then
    echo "エラー: models.yaml に許可モデルが定義されていません: $allowed_file" >&2
    return 1
