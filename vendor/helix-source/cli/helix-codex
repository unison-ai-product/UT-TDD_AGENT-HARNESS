validate_wbs_context() {
  [[ -n "$WBS_ID" ]] || return 0

  if [[ ! "$WBS_ID" =~ ^[A-Za-z0-9._-]+$ ]]; then
    echo "エラー: 無効な --wbs-id 値です: $WBS_ID" >&2
    exit 1
  fi

  local doc_candidates=()
  local ref
  local ref_real
  local found_line=""
  local doc

  for ref in "${REFERENCE_DOCS[@]}"; do
    [[ -z "$ref" ]] && continue
    if [[ "$ref" == /* ]]; then
      ref_real="$(realpath -m "$ref")"
    else
      ref_real="$(realpath -m "$PROJECT_ROOT/$ref")"
    fi
    [[ -f "$ref_real" ]] && doc_candidates+=("$ref_real")
  done

  [[ -f "$PROJECT_ROOT/docs/design/L3-schedule-wbs.md" ]] && doc_candidates+=("$PROJECT_ROOT/docs/design/L3-schedule-wbs.md")
  while IFS= read -r doc; do
    [[ -f "$doc" ]] && doc_candidates+=("$doc")
  done < <(find "$PROJECT_ROOT/docs" -path '*/L3-schedule-wbs.md' -type f 2>/dev/null || true)

  if [[ ${#doc_candidates[@]} -eq 0 ]]; then
    echo "エラー: --wbs-id 指定時は L3 工程表または --reference-doc が必要です" >&2
    exit 1
  fi

  found_line=$(
    HELIX_WBS_ID="$WBS_ID" python3 - "${doc_candidates[@]}" <<'PY' 2>/dev/null || true
import os
import sys
from pathlib import Path

wbs_id = os.environ["HELIX_WBS_ID"]
seen = set()
for raw in sys.argv[1:]:
    path = Path(raw)
    if path in seen or not path.is_file():
        continue
    seen.add(path)
    for line in path.read_text(encoding="utf-8", errors="replace").splitlines():
        if wbs_id in line:
            print(line)
            raise SystemExit(0)
raise SystemExit(1)
PY
  )

  if [[ -z "$found_line" ]]; then
    echo "エラー: WBS が工程表に見つかりません: $WBS_ID" >&2
    exit 1
  fi

  if [[ -n "$L4_SPRINT" && "$found_line" != *"$L4_SPRINT"* ]]; then
    echo "エラー: WBS $WBS_ID の工程表行に L4 sprint '$L4_SPRINT' が見つかりません" >&2
    echo "該当行: $found_line" >&2
    exit 1
  fi
}

