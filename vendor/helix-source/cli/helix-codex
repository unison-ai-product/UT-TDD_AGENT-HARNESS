  [[ "$require_evidence" == "1" ]] || return 0
  [[ "$DRY_RUN" == true || "$SANDBOX" == "read-only" || "$CONSENT_MODE" != "approved" ]] && return 0

  local candidates=()
  local key
  local candidate
  local candidate_real

  if [[ -n "$APPROVAL_FILE" ]]; then
    if [[ "$APPROVAL_FILE" == /* ]]; then
      candidate_real="$(realpath -m "$APPROVAL_FILE")"
    else
      candidate_real="$(realpath -m "$PROJECT_ROOT/$APPROVAL_FILE")"
    fi
    ensure_within_dir "$candidate_real" "$PROJECT_ROOT_REAL" "approval file"
    if [[ -f "$candidate_real" ]]; then
      return 0
    fi
    echo "エラー: --approval-file が見つかりません: $APPROVAL_FILE" >&2
    exit 1
  fi

  local keys=()
  [[ -n "$APPROVAL_ID" ]] && keys+=("$APPROVAL_ID")
  [[ -n "$WBS_ID" ]] && keys+=("$WBS_ID")
  [[ -n "$TASK_ID" ]] && keys+=("$TASK_ID")
  [[ -n "$PLAN_ID" ]] && keys+=("$PLAN_ID")

  for key in "${keys[@]}"; do
