#!/bin/bash
set -euo pipefail

# shellcheck source=cli/lib/helix-common.sh
source "$(cd "$(dirname "$0")" && pwd)/lib/helix-common.sh"

usage() {
  cat <<'USAGE'
使い方: helix scheduler <subcommand> [args...]

サブコマンド:
  add --schedule "<cron|+5m>" --task "<type>:<payload>" [--id <id>]
  add-at --at "<iso|+5m>" --task "<type>:<payload>" [--id <id>]
  list [--status <s>]
  cancel --id <id>
  status --id <id>
  run-due [--max <n>] [--dry-run] [--no-requeue-stale]
  requeue-stale [--older-than <seconds>]
USAGE
}

CMD="${1:-help}"
shift 2>/dev/null || true

case "$CMD" in
  add|add-at|list|cancel|status|run-due|requeue-stale)
    exec python3 "$SCRIPT_DIR/lib/scheduler_helper.py" \
      --db-path "$DB_PATH" \
      "$CMD" "$@"
    ;;
  help|-h|--help)
    usage
    ;;
  *)
    echo "エラー: 不明な scheduler subcommand: $CMD" >&2
    usage >&2
    exit 1
    ;;
esac
