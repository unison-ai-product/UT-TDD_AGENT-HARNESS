#!/bin/bash
set -euo pipefail

# helix-matrix: matrix.yaml ベースの生成/検証ユーティリティ
# Usage: helix-matrix <init|compile|validate|status|update|auto-detect|add-feature> [options]

source "$(cd "$(dirname "$0")" && pwd)/lib/helix-common.sh"
TEMPLATES_DIR="$SCRIPT_DIR/templates"
BASE_RULES_DIR="$TEMPLATES_DIR/rules"
COMPILER="$SCRIPT_DIR/lib/matrix_compiler.py"

usage() {
  cat <<'USAGE'
Usage: helix matrix <subcommand> [options]

Subcommands:
  init       templates から .helix/matrix.yaml + .helix/rules/ を生成
             Options: --force
  compile    matrix.yaml + rules から派生ファイルを生成
             Options: --force
  validate   matrix.yaml の構造検証（必須キー/ID/循環参照）
  status     feature x deliverable の状態一覧を表示
  add-feature matrix.yaml に feature を追加して自動 compile
             Usage: add-feature <name> --drive <be|fe|db|fullstack|agent> [--scope feature|shared|platform] [--ui] [--risk <flags>]
  update     deliverable state を手動更新
             Options: --feature <id> --deliverable <D-ID> --status <done|waived|not_applicable|in_progress>
  auto-detect 実ファイルの存在から deliverable state を自動更新

Examples:
  helix matrix init
  helix matrix compile
  helix matrix compile --force
  helix matrix validate
  helix matrix status
  helix matrix add-feature user-auth --drive be --ui --risk auth,pii
  helix matrix update --feature user-auth --deliverable D-ARCH --status done
  helix matrix auto-detect
USAGE
}

copy_template() {
  local src="$1"
  local dst="$2"
  local force="$3"
  if [[ ! -f "$src" ]]; then
    echo "エラー: テンプレートが見つかりません: $src" >&2
    exit 1
  fi
  if [[ -f "$dst" && "$force" != true ]]; then
    echo "  skip: ${dst#$PROJECT_ROOT/} (already exists)"
    return
  fi
  mkdir -p "$(dirname "$dst")"
  cp "$src" "$dst"
  echo "  created: ${dst#$PROJECT_ROOT/}"
}

run_init() {
  local force=false
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --force) force=true; shift ;;
      --help|-h) usage; exit 0 ;;
      *) echo "エラー: 不明なオプションです: $1" >&2; exit 1 ;;
    esac
  done

  mkdir -p "$HELIX_DIR" "$HELIX_DIR/rules" "$HELIX_DIR/state" "$HELIX_DIR/runtime"
  echo "=== HELIX Matrix Init ==="
  copy_template "$TEMPLATES_DIR/matrix.yaml" "$HELIX_DIR/matrix.yaml" "$force"
  copy_template "$BASE_RULES_DIR/deliverables.yaml" "$HELIX_DIR/rules/deliverables.yaml" "$force"
  copy_template "$TEMPLATES_DIR/rules/structure.yaml" "$HELIX_DIR/rules/structure.yaml" "$force"
  copy_template "$BASE_RULES_DIR/naming.yaml" "$HELIX_DIR/rules/naming.yaml" "$force"
  copy_template "$BASE_RULES_DIR/common-defs.yaml" "$HELIX_DIR/rules/common-defs.yaml" "$force"
  echo "完了: matrix テンプレートを初期化しました"
}

run_compile() {
  local force=false
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --force) force=true; shift ;;
      --help|-h) usage; exit 0 ;;
      *) echo "エラー: 不明なオプションです: $1" >&2; exit 1 ;;
    esac
  done

  if [[ ! -f "$HELIX_DIR/matrix.yaml" ]]; then
    echo "エラー: $HELIX_DIR/matrix.yaml が見つかりません。先に 'helix matrix init' を実行してください。" >&2
    exit 1
  fi

  mkdir -p "$HELIX_DIR/state" "$HELIX_DIR/runtime"
  if [[ "$force" == true ]]; then
    python3 "$COMPILER" --project-root "$PROJECT_ROOT" compile --force
  else
    python3 "$COMPILER" --project-root "$PROJECT_ROOT" compile
  fi
}

run_validate() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --help|-h) usage; exit 0 ;;
      *) echo "エラー: 不明なオプションです: $1" >&2; exit 1 ;;
    esac
  done
  python3 "$COMPILER" --project-root "$PROJECT_ROOT" validate
}

run_status() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --help|-h) usage; exit 0 ;;
      *) echo "エラー: 不明なオプションです: $1" >&2; exit 1 ;;
    esac
  done
  python3 "$COMPILER" --project-root "$PROJECT_ROOT" status
}

run_update() {
  local feature=""
  local deliverable=""
  local status=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --feature)
        feature="${2:-}"
        shift 2
        ;;
      --deliverable)
        deliverable="${2:-}"
        shift 2
        ;;
      --status)
        status="${2:-}"
        shift 2
        ;;
      --help|-h)
        usage
        exit 0
        ;;
      *)
        echo "エラー: 不明なオプションです: $1" >&2
        exit 1
        ;;
    esac
  done

  if [[ -z "$feature" || -z "$deliverable" || -z "$status" ]]; then
    echo "エラー: --feature --deliverable --status は必須です" >&2
    exit 1
  fi
  python3 "$COMPILER" --project-root "$PROJECT_ROOT" update \
    --feature "$feature" \
    --deliverable "$deliverable" \
    --status "$status"
}

run_auto_detect() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --help|-h) usage; exit 0 ;;
      *) echo "エラー: 不明なオプションです: $1" >&2; exit 1 ;;
    esac
  done
  python3 "$COMPILER" --project-root "$PROJECT_ROOT" auto-detect
}

run_add_feature() {
  local name="${1:-}"
  if [[ -z "$name" ]]; then
    echo "エラー: feature 名を指定してください" >&2
    echo "例: helix matrix add-feature user-auth --drive be" >&2
    exit 1
  fi
  shift

  local drive=""
  local scope="feature"
  local ui=false
  local risk=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --drive)
        drive="${2:-}"
        shift 2
        ;;
      --scope)
        scope="${2:-}"
        shift 2
        ;;
      --ui)
        ui=true
        shift
        ;;
      --risk)
        risk="${2:-}"
        shift 2
        ;;
      --help|-h)
        usage
        exit 0
        ;;
      *)
        echo "エラー: 不明なオプションです: $1" >&2
        exit 1
        ;;
    esac
  done

  if [[ -z "$drive" ]]; then
    echo "エラー: --drive は必須です（be|fe|db|fullstack|agent）" >&2
    exit 1
  fi

  local cmd=(
    python3 "$COMPILER" --project-root "$PROJECT_ROOT" add-feature "$name"
    --drive "$drive"
    --scope "$scope"
  )
  if [[ "$ui" == true ]]; then
    cmd+=(--ui)
  fi
  if [[ -n "$risk" ]]; then
    cmd+=(--risk "$risk")
  fi

  "${cmd[@]}"
}

CMD="${1:-help}"
shift 2>/dev/null || true

case "$CMD" in
  init) run_init "$@" ;;
  compile) run_compile "$@" ;;
  validate) run_validate "$@" ;;
  status) run_status "$@" ;;
  add-feature) run_add_feature "$@" ;;
  update) run_update "$@" ;;
  auto-detect) run_auto_detect "$@" ;;
  help|-h|--help) usage ;;
  *)
    echo "エラー: 不明なサブコマンドです: $CMD" >&2
    usage
    exit 1
    ;;
esac
