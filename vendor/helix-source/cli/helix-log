#!/bin/bash
set -euo pipefail

# helix-log: HELIX ログ・評価システム
# Usage: helix log <init|feedback|report|export> [args...]

source "$(cd "$(dirname "$0")" && pwd)/lib/helix-common.sh"
DB_PY="$SCRIPT_DIR/lib/helix_db.py"
DB_PATH="$HELIX_DIR/helix.db"

CMD="${1:-help}"
shift 2>/dev/null || true

case "$CMD" in
  init)
    mkdir -p "$HELIX_DIR"
    python3 "$DB_PY" init "$DB_PATH"
    ;;

  feedback)
    # helix log feedback --task T001 --type correction --category task-selection --desc "..." --impact high
    local_task="" local_type="correction" local_cat="" local_desc="" local_impact="medium" local_resolution=""
    while [[ $# -gt 0 ]]; do
      case $1 in
        --task)       local_task="$2"; shift 2 ;;
        --type)       local_type="$2"; shift 2 ;;
        --category)   local_cat="$2"; shift 2 ;;
        --desc)       local_desc="$2"; shift 2 ;;
        --impact)     local_impact="$2"; shift 2 ;;
        --resolution) local_resolution="$2"; shift 2 ;;
        *) shift ;;
      esac
    done

    if [[ -z "$local_desc" ]]; then
      echo "Usage: helix log feedback --desc '...' [--task T001] [--type correction|praise|suggestion|complaint] [--category task-selection|quality|missing-action|wrong-role|scope] [--impact high|medium|low]" >&2
      exit 1
    fi

    # task_run_id を取得（task_id からDB検索）
    local_run_id="0"
    if [[ -n "$local_task" ]]; then
      local_run_id="$(python3 "$DB_PY" latest-task-run "$DB_PATH" "$local_task" 2>/dev/null || true)"
    fi

    python3 "$DB_PY" record-feedback-argv "$DB_PATH" "${local_run_id:-0}" \
      "$local_type" "$local_cat" "$local_desc" "$local_impact" "$local_resolution"
    ;;

  report)
    local_report_type="${1:-summary}"
    [[ $# -gt 0 ]] && shift || true
    local_report_date=""
    while [[ $# -gt 0 ]]; do
      case $1 in
        --date)
          local_report_date="${2:-}"
          shift 2
          ;;
        *)
          echo "Error: unknown report option: $1" >&2
          exit 1
          ;;
      esac
    done
    if [[ ! -f "$DB_PATH" ]]; then
      echo "DB なし。'helix log init' で初期化してください。" >&2
      exit 1
    fi
    if [[ -n "$local_report_date" ]]; then
      python3 "$DB_PY" report "$DB_PATH" "$local_report_type" "$local_report_date"
    else
      python3 "$DB_PY" report "$DB_PATH" "$local_report_type"
    fi
    ;;

  export)
    local_format="json"
    local_output=""
    while [[ $# -gt 0 ]]; do
      case $1 in
        --format) local_format="$2"; shift 2 ;;
        --output) local_output="$2"; shift 2 ;;
        *) shift ;;
      esac
    done

    if [[ "$local_format" != "json" ]]; then
      echo "Error: --format は json のみ対応です" >&2
      exit 1
    fi
    if [[ -z "$local_output" ]]; then
      echo "Usage: helix log export --format json --output <path>" >&2
      exit 1
    fi
    if [[ ! -f "$DB_PATH" ]]; then
      echo "DB なし。'helix log init' で初期化してください。" >&2
      exit 1
    fi

    python3 "$DB_PY" export-json "$DB_PATH" "$local_output"
    ;;

  help|-h|--help)
    cat <<'USAGE'
Usage: helix log <command> [args...]

HELIX ログ・評価システム — SQLite ベース

Commands:
  init                    DB 初期化（.helix/helix.db）
  feedback               ユーザーフィードバック記録
    --desc "内容"         フィードバック内容（必須）
    --task T001           対象タスク
    --type correction     種別: correction|praise|suggestion|complaint
    --category scope      分類: task-selection|quality|missing-action|wrong-role|scope
    --impact high         影響度: high|medium|low
  report [type]          レポート表示
    summary               全体サマリ（デフォルト）
    tasks                 タスク実行履歴
    actions               アクション型別パフォーマンス
    feedback              フィードバック分析
    quality               タスク選択品質（observation pass率 + 修正頻度）
    session --date YYYY-MM-DD
                          hook/gate/cost_log の日次セッション集計
  export --format json --output <path>
                         DB 全テーブルを JSON にエクスポート

Data flow:
  helix task run → task_runs + action_logs に自動記録
  helix task observe → observations に自動記録
  helix log feedback → feedback に手動記録
  helix log report quality → タスク選択の改善ポイントを表示
  helix log export --format json --output logs/helix-db.json
USAGE
    ;;

  *)
    echo "Error: Unknown command '$CMD'" >&2
    exit 1
    ;;
esac
