#!/usr/bin/env bash
# Stop hook entry for auto handover dump + compact recommendation.
set -uo pipefail

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$REPO_ROOT" || exit 0

threshold="${HELIX_CONTEXT_COMPACT_THRESHOLD:-0.70}"
session_id="$(timeout 3 python3 -m cli.lib.session_helper 2>/dev/null || echo "")"
result_json='{}'

if command -v timeout >/dev/null 2>&1; then
  result_json="$(timeout 5 python3 -m cli.lib.handover_auto_dump auto-dump --json --threshold "$threshold" --release-running --session-id "${session_id}" 2>/dev/null)" || result_json='{}'
else
  result_json="$(python3 -m cli.lib.handover_auto_dump auto-dump --json --threshold "$threshold" --release-running --session-id "${session_id}" 2>/dev/null)" || result_json='{}'
fi

parsed="$(
  RESULT_JSON="$result_json" THRESHOLD="$threshold" python3 - <<'PY' 2>/dev/null
import json
import os

try:
    payload = json.loads(os.environ.get("RESULT_JSON", "{}"))
except json.JSONDecodeError:
    payload = {}

threshold = os.environ.get("THRESHOLD", "0.70")
try:
    threshold_pct = f"{int(float(threshold) * 100)}%"
except ValueError:
    threshold_pct = "70%"

pct = payload.get("context_pct_estimate")
if pct is None:
    pct_text = "?%"
else:
    pct_text = f"{int(float(pct) * 100)}%"

print(
    "\t".join(
        [
            "yes" if payload.get("compact_recommended") else "no",
            "yes" if payload.get("ok") else "no",
            str(payload.get("revision", "?")),
            pct_text,
            threshold_pct,
        ]
    )
)
PY
)"

released_count=$(printf '%s' "$result_json" | RESULT_JSON="$result_json" python3 - <<'PY' 2>/dev/null
import json
import os

try:
    payload = json.loads(os.environ.get("RESULT_JSON", "{}"))
except (TypeError, json.JSONDecodeError):
    payload = {}
print(int(payload.get("released_count", 0) or 0))
PY
)

IFS=$'\t' read -r recommend ok revision pct threshold_pct <<<"$parsed"

if [[ "${ok:-no}" != "yes" ]]; then
  echo "[HELIX] handover auto-dump skipped"
elif [[ "${recommend:-no}" == "yes" ]]; then
  cat <<EOF
[HELIX] handover/CURRENT.json updated (revision ${revision:-?})
[HELIX] 推定 context 使用率: ${pct:-?%} (threshold ${threshold_pct:-70%} 超過) - /compact を推奨します
EOF
else
  echo "[HELIX] handover/CURRENT.json updated"
fi

if [[ "$released_count" -gt 0 ]]; then
  echo "[HELIX] session ${session_id} の running slot ${released_count} 件を cancelled で release"
fi

exit 0
