#!/bin/bash
set -euo pipefail

# helix-status: プロジェクト全体の HELIX 状態を表示
# Usage: helix-status [--json]

JSON_OUTPUT=false
while [[ $# -gt 0 ]]; do
  case "${1:-}" in
    --json) JSON_OUTPUT=true; shift ;;
    --help|-h)
      echo "Usage: helix status [--json]"
      echo ""
      echo "プロジェクト全体の HELIX 状態を表示します。"
      exit 0
      ;;
    *)
      echo "エラー: 不明なオプションです: $1" >&2
      exit 2
      ;;
  esac
done

source "$(cd "$(dirname "$0")" && pwd)/lib/helix-common.sh"
YAML_PARSER="$SCRIPT_DIR/lib/yaml_parser.py"
PHASE_FILE="$HELIX_DIR/phase.yaml"

if [[ ! -d "$HELIX_DIR" ]]; then
  echo "HELIX 未初期化。'helix init' で初期化してください。" >&2
  exit 1
fi

if [[ ! -f "$PHASE_FILE" ]]; then
  echo "phase.yaml が見つかりません。" >&2
  exit 1
fi

# --- JSON で phase.yaml を読む ---
if ! PHASE_JSON=$(python3 "$YAML_PARSER" dump "$PHASE_FILE" 2>/dev/null); then
  echo "phase.yaml の読み込みに失敗しました。" >&2
  exit 1
fi

if [[ "$JSON_OUTPUT" == true ]]; then
  PHASE_JSON="$PHASE_JSON" python3 - <<'PY'
import json
import os
import sys

try:
    data = json.loads(os.environ.get("PHASE_JSON", ""))
except Exception as exc:
    print(f"phase.yaml の JSON 読み込みに失敗しました: {exc}", file=sys.stderr)
    raise SystemExit(1)

print(json.dumps(data, ensure_ascii=False))
PY
  exit $?
fi

if ! PHASE_JSON="$PHASE_JSON" HELIX_DIR="$HELIX_DIR" PROJECT_ROOT="$PROJECT_ROOT" python3 - <<'PY'
import json
import os
import sys
from pathlib import Path


def _safe_dict(value):
    return value if isinstance(value, dict) else {}


def _print_sprint(data):
    sprint = _safe_dict(data.get("sprint", {}))
    sprint_drive = str((sprint.get("drive", "") or ""))
    sprint_step = sprint.get("current_step", "") or "N/A"

    if sprint_drive == "fullstack":
        tracks = _safe_dict(sprint.get("tracks", {}))
        phase_raw = str(sprint.get("phase") or "A")
        phase_label = {"A": "A (並行実装)", "B": "B (結合)"}.get(phase_raw, phase_raw)

        def track_value(name):
            raw = tracks.get(name, {})
            if not isinstance(raw, dict):
                return ".1a", "active"
            stage_raw = str(raw.get("stage") or ".1a")
            stage = {"0.2": ".2", "0.3": ".3", "0.4": ".4", "0.5": ".5"}.get(stage_raw, stage_raw)
            status = str(raw.get("status") or "active")
            return stage, status

        be_stage, be_status = track_value("be")
        fe_stage, fe_status = track_value("fe")
        contract_raw = tracks.get("contract", {})
        contract_ci = str(contract_raw.get("ci") or "pending") if isinstance(contract_raw, dict) else "pending"

        print("Sprint:")
        print(f"  Phase:   {phase_label}")
        print(f"  BE Track: {be_stage} ({be_status})")
        print(f"  FE Track: {fe_stage} ({fe_status})")
        print(f"  Contract CI: {contract_ci}")
        print("")
        return

    if sprint_step == "N/A":
        return

    steps = _safe_dict(sprint.get("steps", {}))
    current = sprint.get("current_step", "")
    print(f"Sprint: {sprint_step}")
    for step in [".1a", ".1b", ".2", ".3", ".4", ".5"]:
        status = steps.get(step, {})
        if isinstance(status, dict):
            status = status.get("status", "pending")
        icon = "✓" if status == "completed" else ("→" if step == current else " ")
        print(f"  {icon} {step}  [{status}]")
    print("")


def _print_reverse(data):
    reverse_gates = _safe_dict(data.get("reverse_gates", {}))
    has_reverse = any(
        isinstance(v, dict) and v.get("status", "pending") != "pending"
        for v in reverse_gates.values()
    )
    type_gates = [
        (type_name, gates)
        for type_name, gates in reverse_gates.items()
        if isinstance(gates, dict) and any(isinstance(v, dict) for v in gates.values())
    ]
    if has_reverse or type_gates:
        print("Reverse Gates:")
        if has_reverse:
            for rg in ["RG0", "RG1", "RG2", "RG3"]:
                value = reverse_gates.get(rg, {})
                status = value.get("status", "pending") if isinstance(value, dict) else "pending"
                icon = {"passed": "✓", "failed": "✗"}.get(status, " ")
                print(f"  {icon} {rg}  {status}")
        for type_name, gates in type_gates:
            parts = []
            for rg in ["RG0", "RG1", "RG2", "RG3", "RGC"]:
                value = gates.get(rg, {})
                status = value.get("status", "pending") if isinstance(value, dict) else "pending"
                if status != "pending":
                    parts.append(f"{rg}={status}")
            if parts:
                print(f"  {type_name}: " + " ".join(parts))
        print("")

    reverse = _safe_dict(data.get("reverse", {}))
    if reverse.get("status", "") == "completed":
        print("Reverse: Reverse 完了 → Forward 接続待ち")
        completed_at = reverse.get("completed_at", "")
        if completed_at:
            print(f"  completed_at: {completed_at}")
        print("")


def _print_retros():
    helix_dir = Path(os.environ["HELIX_DIR"])
    retros_dir = helix_dir / "retros"
    if not retros_dir.is_dir():
        return
    retros = sorted(retros_dir.glob("*.md"))
    if not retros:
        return
    print(f"Retros: {len(retros)} 件")
    for retro in retros:
        print(f"  {retro.name}")
    print("")


def _print_design_docs():
    project_root = Path(os.environ["PROJECT_ROOT"])
    design_dir = project_root / "docs" / "design"
    if not design_dir.is_dir():
        return
    design_count = len(list(design_dir.glob("*.md"))) + len(list(design_dir.glob("*.yaml")))
    if design_count <= 0:
        return
    print(f"Design Docs: {design_count} 件")
    for path in sorted(design_dir.iterdir(), key=lambda p: p.name)[:10]:
        print(f"  {path.name}")
    print("")


def _print_action_guide(data):
    phase = str(data.get("current_phase", "") or "").strip()
    gates = _safe_dict(data.get("gates", {}))
    failed = []
    for gate in ["G1", "G1.5", "G1R", "G2", "G3", "G4", "G5", "G6", "G7", "G9", "G10", "G11"]:
        value = gates.get(gate, {})
        status = value.get("status", "pending") if isinstance(value, dict) else str(value)
        if status == "failed":
            failed.append(gate)

    print("Action Guide:")
    if failed:
        print("  該当ゲートの指摘事項を確認し修正")
        print(f"  失敗ゲート: {','.join(failed) or 'unknown'}")
        return

    actions = {
        "L1": "helix plan draft で設計を開始",
        "L2": "helix gate G2 で設計凍結ゲートを確認",
        "L3": "helix gate G3 で実装着手ゲートを確認",
        "L4": "helix sprint status でスプリント進捗確認",
        "L5": "helix gate G5 でデザイン凍結ゲートを確認",
        "L6": "helix gate G6 で RC 判定を実施",
        "L7": "helix gate G7 の安定性確認後に helix pr を準備",
        "L8": "受入条件を確認し PO 承認へ進む",
        "L9": "helix gate G9 でデプロイ安定性を確認",
        "L10": "helix gate G10 で観測完了を確認",
        "L11": "helix gate G11 で運用学習を完了",
    }
    action = actions.get(phase, "helix status で状態を継続確認し、未通過ゲートを解消")
    print(f"  {action}")


def main():
    try:
        data = json.loads(os.environ.get("PHASE_JSON", ""))
    except Exception as exc:
        print(f"phase.yaml の JSON 読み込みに失敗しました: {exc}", file=sys.stderr)
        return 1

    project = data.get("project", "") or "unknown"
    mode = data.get("current_mode", "") or "forward"
    phase = data.get("current_phase", "") or "unknown"

    print("=== HELIX Project Status ===")
    print("")
    print(f"Project: {project}")
    print(f"Mode:    {mode}")
    print(f"Phase:   {phase}")
    print("")

    print("Gates:")
    gates = _safe_dict(data.get("gates", {}))
    for gate in ["G1", "G1.5", "G1R", "G2", "G3", "G4", "G5", "G6", "G7", "G9", "G10", "G11"]:
        value = gates.get(gate, {})
        if isinstance(value, dict):
            status = value.get("status", "pending")
            date = value.get("date", "")
        else:
            status = str(value)
            date = ""
        icon = {"passed": "✓", "failed": "✗", "invalidated": "!", "skipped": "—"}.get(status, " ")
        date_str = f"  ({date})" if date else ""
        print(f"  {icon} {gate:5s}  {status}{date_str}")
    print("")

    _print_sprint(data)
    _print_reverse(data)
    _print_retros()
    _print_design_docs()
    _print_action_guide(data)
    return 0


raise SystemExit(main())
PY
then
  echo "phase.yaml の表示処理に失敗しました。" >&2
  exit 1
fi
