#!/bin/bash
set -euo pipefail

# helix-dashboard: HELIX state dashboard
# Usage: helix dashboard [--json]

JSON_OUTPUT=false

while [[ $# -gt 0 ]]; do
  case "${1:-}" in
    --json)
      JSON_OUTPUT=true
      shift
      ;;
    --help|-h)
      cat <<'USAGE'
Usage: helix dashboard [--json]

HELIX の主要状態を 1 画面に集約して表示します。

Options:
  --json   dashboard payload を JSON で出力
USAGE
      exit 0
      ;;
    *)
      echo "エラー: 不明なオプションです: $1" >&2
      exit 2
      ;;
  esac
done

source "$(cd "$(dirname "$0")" && pwd)/lib/helix-common.sh"

if [[ ! -d "$HELIX_DIR" ]]; then
  echo "HELIX 未初期化。'helix init' で初期化してください。" >&2
  exit "$EXIT_PREREQ_ERROR"
fi

if [[ ! -f "$HELIX_DIR/phase.yaml" ]]; then
  echo "phase.yaml が見つかりません。" >&2
  exit "$EXIT_PREREQ_ERROR"
fi

FORMAT="text"
if [[ "$JSON_OUTPUT" == true ]]; then
  FORMAT="json"
fi

python3 - "$SCRIPT_DIR" "$PROJECT_ROOT" "$HELIX_DIR" "$FORMAT" <<'PY'
from __future__ import annotations

import json
import sqlite3
import sys
from collections import Counter
from pathlib import Path
from typing import Any

script_dir = Path(sys.argv[1])
project_root = Path(sys.argv[2])
helix_dir = Path(sys.argv[3])
output_format = sys.argv[4]

sys.path.insert(0, str(script_dir / "lib"))
from yaml_parser import parse_yaml  # noqa: E402


def read_yaml(path: Path) -> dict[str, Any]:
    if not path.exists():
        return {}
    try:
        data = parse_yaml(path.read_text(encoding="utf-8"))
    except Exception:
        return {}
    return data if isinstance(data, dict) else {}


def safe_dict(value: Any) -> dict[str, Any]:
    return value if isinstance(value, dict) else {}


def gate_summary(phase: dict[str, Any]) -> dict[str, Any]:
    gates = safe_dict(phase.get("gates"))
    statuses: dict[str, str] = {}
    for name in ["G0.5", "G1", "G1.5", "G1R", "G2", "G3", "G4", "G5", "G6", "G7", "G9", "G10", "G11"]:
        raw = gates.get(name, {})
        if isinstance(raw, dict):
            statuses[name] = str(raw.get("status", "pending") or "pending")
        elif raw:
            statuses[name] = str(raw)
        else:
            statuses[name] = "pending"
    return {"statuses": statuses, "counts": dict(Counter(statuses.values()))}


def plans_summary() -> dict[str, Any]:
    plans_dir = helix_dir / "plans"
    statuses: Counter[str] = Counter()
    total = 0
    if plans_dir.is_dir():
        for path in sorted(plans_dir.glob("PLAN-*.yaml")):
            if path.name.endswith(".lock"):
                continue
            data = read_yaml(path)
            status = str(data.get("status", "unknown") or "unknown")
            statuses[status] += 1
            total += 1
    return {"total": total, "counts": dict(statuses)}


def scrum_summary() -> dict[str, Any]:
    scrum_dir = helix_dir / "scrum"
    sprint = read_yaml(scrum_dir / "sprint.yaml")
    backlog = read_yaml(scrum_dir / "backlog.yaml")
    hypotheses = safe_dict(backlog.get("hypotheses"))
    hypothesis_counts: Counter[str] = Counter()
    for value in hypotheses.values():
        if isinstance(value, dict):
            hypothesis_counts[str(value.get("status", "queued") or "queued")] += 1

    current_sprint = sprint.get("current_sprint", 0) if sprint else 0
    current = safe_dict(safe_dict(sprint.get("sprints")).get(str(current_sprint)))
    return {
        "initialized": scrum_dir.is_dir(),
        "current_sprint": current_sprint,
        "status": current.get("status", "none") if current else "none",
        "goal": current.get("goal", "") if current else "",
        "hypotheses": dict(hypothesis_counts),
    }


def reverse_summary() -> dict[str, Any]:
    candidates = [
        helix_dir / "reverse" / "R4-gap-register.yaml",
        helix_dir / "reverse" / "R4-gap-register.md",
        helix_dir / "reverse" / "D4-design-routing.yaml",
        helix_dir / "reverse" / "N4-normalization-gap-register.yaml",
        helix_dir / "reverse" / "U4-upgrade-routing.md",
        helix_dir / "reverse" / "F4-fullback-routing.md",
        project_root / "docs" / "reverse" / "gap_register.md",
    ]
    gap_file = next((path for path in candidates if path.exists()), None)
    gaps: Counter[str] = Counter()
    total = 0
    if gap_file:
        if gap_file.suffix in {".yaml", ".yml"}:
            data = read_yaml(gap_file)
            rows: list[dict[str, Any]] = []

            def collect(value: Any) -> None:
                if isinstance(value, dict):
                    if any(key in value for key in ("gap_id", "id", "status", "closure_status", "forward_status")):
                        rows.append(value)
                    for child in value.values():
                        collect(child)
                elif isinstance(value, list):
                    for child in value:
                        collect(child)

            collect(data)
            seen: set[int] = set()
            for row in rows:
                identity = id(row)
                if identity in seen:
                    continue
                seen.add(identity)
                status = str(
                    row.get("status")
                    or row.get("closure_status")
                    or row.get("forward_status")
                    or "unknown"
                )
                gaps[status] += 1
                total += 1
        else:
            status_index: int | None = None
            in_gap_list = False
            for line in gap_file.read_text(encoding="utf-8").splitlines():
                stripped = line.strip()
                if stripped.startswith("### 1.2") or stripped.startswith("## Gap 一覧"):
                    in_gap_list = True
                    continue
                if in_gap_list and stripped.startswith("## 2."):
                    break
                if not in_gap_list:
                    continue
                if not stripped.startswith("|"):
                    continue
                cells = [cell.strip() for cell in stripped.strip("|").split("|")]
                if any(cell in {"状態", "status"} for cell in cells):
                    status_index = next(i for i, cell in enumerate(cells) if cell in {"状態", "status"})
                    continue
                if not cells or not cells[0].startswith("GAP-"):
                    continue
                if len(cells) < 2:
                    continue
                index = status_index if status_index is not None and status_index < len(cells) else len(cells) - 1
                status = cells[index].replace("*", "").strip() or "unknown"
                if status.startswith("解決済"):
                    status = "解決済"
                elif status.startswith("部分解決"):
                    status = "部分解決"
                gaps[status] += 1
                total += 1
    return {
        "gap_register": str(gap_file.relative_to(project_root)) if gap_file and gap_file.is_relative_to(project_root) else (str(gap_file) if gap_file else None),
        "total": total,
        "counts": dict(gaps),
    }


def db_counts(table: str, status_column: str = "status") -> dict[str, int]:
    db_path = helix_dir / "helix.db"
    if not db_path.exists():
        return {}
    try:
        conn = sqlite3.connect(str(db_path))
        rows = conn.execute(
            f"SELECT {status_column}, COUNT(*) FROM {table} GROUP BY {status_column}"
        ).fetchall()
    except Exception:
        return {}
    finally:
        try:
            conn.close()
        except Exception:
            pass
    return {str(status or "unknown"): int(count) for status, count in rows}


def yaml_collection_count(path: Path, key: str) -> int:
    data = read_yaml(path)
    value = data.get(key)
    if isinstance(value, dict):
        return len(value)
    if isinstance(value, list):
        return len(value)
    return 0


def artifact_summary() -> dict[str, Any]:
    design_dir = project_root / "docs" / "design"
    features_dir = project_root / "docs" / "features"
    design_count = len(list(design_dir.glob("*"))) if design_dir.is_dir() else 0
    if features_dir.is_dir():
        design_count += sum(1 for p in features_dir.glob("*/D-*") if p.is_dir())
    return {
        "design_docs": design_count,
        "retros": len(list((helix_dir / "retros").glob("*.md"))) if (helix_dir / "retros").is_dir() else 0,
        "session_summaries": len(list((helix_dir / "session-summaries").glob("*.md"))) if (helix_dir / "session-summaries").is_dir() else 0,
        "handover": 1 if (helix_dir / "handover" / "CURRENT.md").exists() else 0,
        "deferred_findings": yaml_collection_count(helix_dir / "audit" / "deferred-findings.yaml", "findings"),
        "debt_items": yaml_collection_count(helix_dir / "debt-register.yaml", "items"),
        "jobs": db_counts("jobs"),
        "schedules": db_counts("schedules"),
    }


def next_action(phase: str, gate_counts: dict[str, int]) -> str:
    if gate_counts.get("failed", 0) > 0:
        return "failed gate の指摘事項を修正してください"
    actions = {
        "L1": "helix plan draft で設計を開始",
        "L2": "helix gate G2 で設計凍結ゲートを確認",
        "L3": "helix gate G3 で実装着手ゲートを確認",
        "L4": "helix sprint status でスプリント進捗確認",
        "L5": "helix gate G5 でデザイン凍結ゲートを確認",
        "L6": "helix gate G6 で RC 判定を実施",
        "L7": "helix gate G7 の安定性確認後に helix pr を準備",
        "L8": "受入条件を確認し PO 承認へ進む",
        "L9": "helix gate G9 でデプロイ安定性を確認",
        "L10": "helix gate G10 で観測完了を確認",
        "L11": "helix gate G11 で運用学習を完了",
    }
    return actions.get(phase, "helix status で状態を確認")


phase_data = read_yaml(helix_dir / "phase.yaml")
gates = gate_summary(phase_data)
phase_name = str(phase_data.get("current_phase", "unknown") or "unknown")

payload = {
    "project": phase_data.get("project", "unknown") or "unknown",
    "mode": phase_data.get("current_mode", "forward") or "forward",
    "phase": phase_name,
    "gates": gates,
    "plans": plans_summary(),
    "scrum": scrum_summary(),
    "reverse": reverse_summary(),
    "artifacts": artifact_summary(),
}
payload["next_action"] = next_action(phase_name, gates["counts"])

if output_format == "json":
    print(json.dumps(payload, ensure_ascii=False, indent=2, sort_keys=True))
    raise SystemExit(0)

print("=== HELIX Dashboard ===")
print("")
print(f"Project: {payload['project']}")
print(f"Mode:    {payload['mode']}")
print(f"Phase:   {payload['phase']}")
print("")

gate_counts = payload["gates"]["counts"]
print("Gates:")
print(
    "  "
    + "  ".join(
        f"{name}={gate_counts.get(name, 0)}"
        for name in ["passed", "failed", "pending", "skipped", "invalidated"]
        if gate_counts.get(name, 0)
    )
)
for name, status in payload["gates"]["statuses"].items():
    if status in {"failed", "invalidated"}:
        print(f"  ! {name}: {status}")
print("")

plan_counts = payload["plans"]["counts"]
print("Plans:")
print(f"  total={payload['plans']['total']}  " + "  ".join(f"{k}={v}" for k, v in sorted(plan_counts.items())))
print("")

scrum = payload["scrum"]
print("Scrum:")
if scrum["initialized"]:
    hypothesis_text = " ".join(f"{k}={v}" for k, v in sorted(scrum["hypotheses"].items())) or "none"
    print(f"  sprint={scrum['current_sprint']}  status={scrum['status']}  hypotheses={hypothesis_text}")
else:
    print("  not initialized")
print("")

reverse = payload["reverse"]
print("Reverse:")
if reverse["gap_register"]:
    gap_text = " ".join(f"{k}={v}" for k, v in sorted(reverse["counts"].items())) or "none"
    print(f"  gaps={reverse['total']}  {gap_text}")
    print(f"  source={reverse['gap_register']}")
else:
    print("  gap register not found")
print("")

artifacts = payload["artifacts"]
print("Artifacts:")
print(
    f"  design_docs={artifacts['design_docs']}  "
    f"retros={artifacts['retros']}  "
    f"session_summaries={artifacts['session_summaries']}  "
    f"handover={artifacts['handover']}  "
    f"deferred={artifacts['deferred_findings']}  "
    f"debt={artifacts['debt_items']}"
)
job_text = " ".join(f"{k}={v}" for k, v in sorted(artifacts["jobs"].items())) or "none"
schedule_text = " ".join(f"{k}={v}" for k, v in sorted(artifacts["schedules"].items())) or "none"
print(f"  jobs: {job_text}")
print(f"  schedules: {schedule_text}")
print("")
print("Next:")
print(f"  {payload['next_action']}")
PY
