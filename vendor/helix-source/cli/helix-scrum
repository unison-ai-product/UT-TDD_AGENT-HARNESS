# ============================
# web-search: 事例検索結果の記録
# ============================
cmd_web_search() {
  local query="" hid=""

  while [[ $# -gt 0 ]]; do
    case $1 in
      --query) query="$2"; shift 2 ;;
      --hypothesis) hid="$2"; shift 2 ;;
      --help|-h)
        cat <<'USAGE'
Usage: helix scrum web-search --query "..." --hypothesis H001

Scrum 向けの検索事例メモを mock/placeholder で保存します。

Options:
  --query         検索クエリ
  --hypothesis    仮説 ID (例: H001)
  --help, -h      この help を表示
USAGE
        return 0
        ;;
      *)
        echo "Usage: helix scrum web-search --query \"...\" --hypothesis H001" >&2
        exit "$EXIT_INPUT_ERROR"
        ;;
    esac
  done

  if [[ -z "$query" || -z "$hid" ]]; then
    echo "Usage: helix scrum web-search --query \"...\" --hypothesis H001" >&2
    exit "$EXIT_INPUT_ERROR"
  fi

  local research_dir timestamp research_file title question
  research_dir="$SCRUM_DIR/research/$hid"
  timestamp="$(scrum_timestamp)"
  research_file="$research_dir/${timestamp}.md"
  mkdir -p "$research_dir"

  title="$(scrum_lookup_field "$hid" "title")"
  question="$(scrum_lookup_field "$hid" "question")"
  [[ -z "$title" || "$title" == "null" ]] && title="(backlog 未登録)"
  [[ -z "$question" || "$question" == "null" ]] && question="(未設定)"

  cat > "$research_file" <<EOF
# Web Search Research: $hid

- Timestamp: $(date '+%Y-%m-%d %H:%M:%S %Z')
- Query: $query
- Mode: mock-placeholder
- Hypothesis: $hid
- Title: $title
- Question: $question

## Results

1. Reference URL: https://example.com/search?q=$(printf '%s' "$query" | tr ' ' '+')
   Summary: "$query" に関する一次調査の placeholder 結果。実 Web API 統合前の smoke 用エントリで、S0.5 の参照 URL と要約保存フローを固定する。
EOF

  echo "[scrum] web-search saved: ${research_file#$PROJECT_ROOT/}"
  echo "  references: 1"
}

