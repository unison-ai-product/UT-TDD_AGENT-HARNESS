# ============================
# メインディスパッチ
# ============================
case "$CMD" in
  init)    cmd_init "$@" ;;
  backlog) cmd_backlog "$@" ;;
  local)   cmd_local "$@" ;;
  plan)    cmd_plan "$@" ;;
  poc)     cmd_poc "$@" ;;
  verify)  cmd_verify "$@" ;;
  decide)  cmd_decide "$@" ;;
  review)  cmd_review "$@" ;;
  status)  cmd_status "$@" ;;
  trigger) cmd_trigger "$@" ;;
  web-search) cmd_web_search "$@" ;;
  acceptance-design) cmd_acceptance_design "$@" ;;
  help|-h|--help)
    cat <<'USAGE'
Usage: helix scrum <command> [args...]

HELIX Scrum — 検証駆動開発

Commands:
  init                    Scrum モード初期化
  backlog list            仮説バックログ表示
  backlog add             仮説追加 (--id --title --question --acceptance)
  local                   Forward 内 UPS loop 管理 (init|poc|verify|decide|list|stats)
  plan                    スプリント開始 (--goal --hypotheses H001,H002)
  poc                     PoC 実装を Codex に委譲 (--hypothesis H001)
  verify [script]         検証スクリプト実行 (引数なし=全実行)
  decide                  判定 (--hypothesis H001 --confirmed|--rejected|--pivot)
                          confirmed は verify script 成功が必須。例外時のみ --force
                          --strict-promote を指定すると昇格推奨チェックを追加
  review                  スプリントレビュー + レトロ（検証失敗時は fail-close、例外時のみ --force-complete）
  status                  現在の状態表示
  web-search              検索事例メモ保存 (--query --hypothesis)
  acceptance-design       受入条件テンプレ生成 (--hypothesis)
  trigger detect          差し込み候補を検出 (--scan PATH [--save] [--json])
  trigger list            差し込み候補一覧 (--status ... --type ... [--json])
  trigger transition      状態遷移 (--id ST-... --status ... --owner ...)
  trigger ttl             TTL 経過判定 ([--apply])
  trigger evaluate        4 象限評価 (--id ST-...)

Flow:
  init → backlog add → plan → poc → verify → decide → review → (next sprint)

検証スクリプトは verify/ に蓄積され、毎回全実行でリグレッションを検出。
confirmed な仮説は Forward HELIX (L2→) に接続。
USAGE
    ;;
  *)
    echo "Error: Unknown command '$CMD'" >&2
    echo "Run 'helix scrum help' for usage" >&2
    exit "$EXIT_INPUT_ERROR"
    ;;
esac
