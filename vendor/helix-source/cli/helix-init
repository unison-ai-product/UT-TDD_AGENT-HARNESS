#!/bin/bash
set -euo pipefail

# helix-init: HELIX プロジェクト初期化
# Usage: helix-init [--project-name "name"] [--force] [--monorepo-package "packages/foo"] [--start-phase L1..L11]

source "$(cd "$(dirname "$0")" && pwd)/lib/helix-common.sh"
TEMPLATES_DIR="$SCRIPT_DIR/templates"
REPO_ROOT="$PROJECT_ROOT"
HELIX_DIR="$PROJECT_ROOT/.helix"
PRIMARY_RULES_DIR="$TEMPLATES_DIR/rules"
FALLBACK_RULES_DIR="$HELIX_HOME/.helix/rules"

# --- 引数パース ---
PROJECT_NAME=""
FORCE=false
MONOREPO_PKG=""
START_PHASE="L1"

while [[ $# -gt 0 ]]; do
  case $1 in
    --project-name) PROJECT_NAME="$2"; shift 2 ;;
    --force) FORCE=true; shift ;;
    --monorepo-package) MONOREPO_PKG="$2"; shift 2 ;;
    --start-phase) START_PHASE="$2"; shift 2 ;;
    --help|-h)
      echo "使い方: helix init [--project-name \"name\"] [--force] [--monorepo-package \"packages/foo\"] [--start-phase L1..L11]"
      echo ""
      echo "Options:"
      echo "  --project-name  プロジェクト名（phase.yaml に設定）"
      echo "  --force         既存ファイルを上書き（CLAUDE.md / AGENTS.md 以外）"
      echo "  --monorepo-package  モノレポ内で HELIX 管理対象にするパッケージ相対パス"
      echo "  --start-phase L1..L11  既存プロジェクトに途中から導入する際の開始フェーズ (デフォルト: L1)"
      exit 0
      ;;
    *) echo "エラー: 不明なオプション: $1" >&2; exit 1 ;;
  esac
done

case "$START_PHASE" in
  L1|L2|L3|L4|L5|L6|L7|L8|L9|L10|L11) ;;
  *)
    echo "エラー: --start-phase は L1..L11 のいずれかを指定してください: $START_PHASE" >&2
    exit 2
    ;;
esac

if [[ -n "$MONOREPO_PKG" ]]; then
  PROJECT_ROOT="$REPO_ROOT/$MONOREPO_PKG"
  HELIX_DIR="$PROJECT_ROOT/.helix"
  if [[ ! -d "$PROJECT_ROOT" ]]; then
    echo "エラー: モノレポ対象パッケージが見つかりません: $MONOREPO_PKG" >&2
    exit 1
  fi
fi

if [[ -z "$PROJECT_NAME" ]]; then
  PROJECT_NAME="$(basename "$PROJECT_ROOT")"
fi

echo "=== HELIX Init ==="
echo "Project: $PROJECT_NAME"
if [[ -n "$MONOREPO_PKG" ]]; then
  echo "Repo:    $REPO_ROOT"
  echo "Root:    $PROJECT_ROOT"
  echo "モノレポモード: $MONOREPO_PKG を HELIX 管理します"
else
  echo "Root:    $PROJECT_ROOT"
fi
echo ""

# --- .helix/ ディレクトリ ---
copy_template() {
  local src="$1"
  local dst="$2"
  local name="$(basename "$dst")"
  if [[ -f "$dst" && "$FORCE" != true ]]; then
    echo "  skip: $name (already exists)"
    return
  fi
  cp "$src" "$dst"
  echo "  created: $name"
}

resolve_rule_template() {
  local rule_name="$1"
  if [[ -f "$PRIMARY_RULES_DIR/$rule_name" ]]; then
    printf '%s\n' "$PRIMARY_RULES_DIR/$rule_name"
    return 0
  fi
  if [[ -f "$FALLBACK_RULES_DIR/$rule_name" ]]; then
    printf '%s\n' "$FALLBACK_RULES_DIR/$rule_name"
    return 0
  fi
  return 1
}

mkdir -p "$HELIX_DIR"
echo "[.helix/]"
copy_template "$TEMPLATES_DIR/doc-map.yaml" "$HELIX_DIR/doc-map.yaml"
copy_template "$TEMPLATES_DIR/gate-checks.yaml" "$HELIX_DIR/gate-checks.yaml"
copy_template "$TEMPLATES_DIR/phase.yaml" "$HELIX_DIR/phase.yaml"
copy_template "$TEMPLATES_DIR/matrix.yaml" "$HELIX_DIR/matrix.yaml"
copy_template "$TEMPLATES_DIR/config.yaml" "$HELIX_DIR/config.yaml"
cp -n "$TEMPLATES_DIR/state-machine.yaml" "$HELIX_DIR/" 2>/dev/null || true

# matrix rules テンプレート
mkdir -p "$HELIX_DIR/rules"
for rule_name in deliverables.yaml naming.yaml common-defs.yaml; do
  rule_template="$(resolve_rule_template "$rule_name" || true)"
  if [[ -n "$rule_template" ]]; then
    copy_template "$rule_template" "$HELIX_DIR/rules/$rule_name"
  else
    echo "  warn: base rule not found: $rule_name (searched: $PRIMARY_RULES_DIR, $FALLBACK_RULES_DIR)"
  fi
done
if [[ -f "$TEMPLATES_DIR/rules/structure.yaml" ]]; then
  copy_template "$TEMPLATES_DIR/rules/structure.yaml" "$HELIX_DIR/rules/structure.yaml"
else
  echo "  warn: template rule not found: $TEMPLATES_DIR/rules/structure.yaml"
fi

# meta-phase pattern templates
mkdir -p "$HELIX_DIR/patterns"
if [[ -f "$TEMPLATES_DIR/patterns/pattern.yaml" ]]; then
  copy_template "$TEMPLATES_DIR/patterns/pattern.yaml" "$HELIX_DIR/patterns/pattern.yaml"
else
  echo "  warn: template pattern not found: $TEMPLATES_DIR/patterns/pattern.yaml"
fi

# matrix runtime/state ディレクトリ
for dir in "$HELIX_DIR/state" "$HELIX_DIR/runtime"; do
  if [[ ! -d "$dir" ]]; then
    mkdir -p "$dir"
    echo "  created: ${dir#$HELIX_DIR/}/"
  else
    echo "  skip: ${dir#$HELIX_DIR/}/ (already exists)"
  fi
done

# phase.yaml にプロジェクト名を設定
if [[ -f "$HELIX_DIR/phase.yaml" ]]; then
  sed -i "s/^project: .*/project: \"$PROJECT_NAME\"/" "$HELIX_DIR/phase.yaml"
  if [[ "$START_PHASE" != "L1" ]]; then
    python3 "$SCRIPT_DIR/lib/init_helpers.py" apply-start-phase \
      --phase-file "$HELIX_DIR/phase.yaml" \
      --start-phase "$START_PHASE"
    echo "[helix-init] start-phase=$START_PHASE 適用: 前提ゲートを skipped に設定"
    echo "[helix-init] Reverse HELIX 併用時は helix reverse R0 から開始してください"
  fi
fi
echo ""

# --- CLAUDE.md ---
echo "[CLAUDE.md]"
if [[ -f "$PROJECT_ROOT/CLAUDE.md" ]]; then
  echo "  skip: CLAUDE.md (already exists)"
elif [[ -f "$PROJECT_ROOT/.claude/CLAUDE.md" ]]; then
  echo "  skip: .claude/CLAUDE.md (already exists)"
else
  if [[ -f "$TEMPLATES_DIR/CLAUDE.md.template" ]]; then
    cp "$TEMPLATES_DIR/CLAUDE.md.template" "$PROJECT_ROOT/CLAUDE.md"
    sed -i "s/^# プロジェクト名/# $PROJECT_NAME/" "$PROJECT_ROOT/CLAUDE.md"
    echo "  created: CLAUDE.md (from template)"
  else
    echo "  warn: template not found"
  fi
fi
echo ""

# --- AGENTS.md ---
echo "[AGENTS.md]"
if [[ -f "$PROJECT_ROOT/AGENTS.md" ]]; then
  echo "  skip: AGENTS.md (already exists)"
else
  if [[ -f "$TEMPLATES_DIR/AGENTS.md.template" ]]; then
    cp "$TEMPLATES_DIR/AGENTS.md.template" "$PROJECT_ROOT/AGENTS.md"
    sed -i "s/^# Codex CLI — プロジェクト名/# Codex CLI — $PROJECT_NAME/" "$PROJECT_ROOT/AGENTS.md"
    echo "  created: AGENTS.md (from template)"
  else
    echo "  warn: template not found"
  fi
fi
echo ""

# --- Claude Code hooks ---
echo "[.claude/settings.json]"
mkdir -p "$PROJECT_ROOT/.claude"
PROJECT_CLAUDE_SETTINGS="$PROJECT_ROOT/.claude/settings.json"
set +e
merge_output="$(python3 "$SCRIPT_DIR/lib/merge_settings.py" "$PROJECT_CLAUDE_SETTINGS" 2>&1)"
merge_rc=$?
set -e
case "$merge_rc" in
  0)
    echo "  created/updated: .claude/settings.json"
    ;;
  1)
    echo "  skip: .claude/settings.json (HELIX hooks already present)"
    ;;
  *)
    printf '%s\n' "$merge_output" >&2
    echo "  error: .claude/settings.json の HELIX hook 設定に失敗しました" >&2
    exit "$merge_rc"
    ;;
esac
echo ""

# --- Claude Code project hook scripts ---
echo "[.claude/hooks]"
mkdir -p "$PROJECT_ROOT/.claude/hooks"
if compgen -G "$HELIX_HOME/.claude/hooks/*.sh" >/dev/null; then
  for hook_script in "$HELIX_HOME/.claude/hooks/"*.sh; do
    hook_name="$(basename "$hook_script")"
    cp "$hook_script" "$PROJECT_ROOT/.claude/hooks/$hook_name"
    chmod +x "$PROJECT_ROOT/.claude/hooks/$hook_name" 2>/dev/null || true
  done
  echo "  synced: .claude/hooks/*.sh"
else
  echo "  warn: HELIX hook scripts not found"
fi
echo ""

# --- .gitignore ---
echo "[.gitignore]"
GITIGNORE="$PROJECT_ROOT/.gitignore"
if [[ ! -f "$GITIGNORE" ]]; then
  touch "$GITIGNORE"
  echo "  created: .gitignore"
fi

add_gitignore() {
  local entry="$1"
  if ! grep -qF "$entry" "$GITIGNORE" 2>/dev/null; then
    echo "$entry" >> "$GITIGNORE"
    echo "  added: $entry"
  else
    echo "  skip: $entry (already in .gitignore)"
  fi
}

add_gitignore "CLAUDE.local.md"
add_gitignore "AGENTS.override.md"
add_gitignore ".claude/settings.local.json"
add_gitignore ".claude/agent-memory/"
add_gitignore ".claude/scheduled_tasks.lock"
add_gitignore ".env"
add_gitignore ".env.*"
add_gitignore "*.pem"
add_gitignore "*.key"
add_gitignore "credentials.json"
echo ""

# --- ディレクトリ構造 ---
echo "[directories]"
for dir in docs/design docs/adr .claude/agents; do
  if [[ ! -d "$PROJECT_ROOT/$dir" ]]; then
    mkdir -p "$PROJECT_ROOT/$dir"
    echo "  created: $dir/"
  else
    echo "  skip: $dir/ (already exists)"
  fi
done
echo ""

# --- Git hooks ---
echo "[git hooks]"
HOOKS_DIR="$PROJECT_ROOT/.git/hooks"
if [[ -d "$HOOKS_DIR" ]]; then
  if [[ -f "$TEMPLATES_DIR/hooks/pre-commit" ]]; then
    copy_template "$TEMPLATES_DIR/hooks/pre-commit" "$HOOKS_DIR/pre-commit"
    chmod +x "$HOOKS_DIR/pre-commit" 2>/dev/null || true
  else
    echo "  skip: hooks/pre-commit template not found"
  fi

  if [[ -f "$TEMPLATES_DIR/hooks/commit-msg" ]]; then
    copy_template "$TEMPLATES_DIR/hooks/commit-msg" "$HOOKS_DIR/commit-msg"
    chmod +x "$HOOKS_DIR/commit-msg" 2>/dev/null || true
  else
    echo "  skip: hooks/commit-msg template not found"
  fi

  if [[ -f "$TEMPLATES_DIR/hooks/post-merge" ]]; then
    copy_template "$TEMPLATES_DIR/hooks/post-merge" "$HOOKS_DIR/post-merge"
    chmod +x "$HOOKS_DIR/post-merge" 2>/dev/null || true
  else
    echo "  skip: hooks/post-merge template not found"
  fi
else
  echo "  skip: .git/hooks not found"
fi
echo ""

# --- サブエージェント ---
echo "[agents]"
AGENT_TEMPLATES="$TEMPLATES_DIR/agents"
if [[ -d "$AGENT_TEMPLATES" ]]; then
  for agent_file in "$AGENT_TEMPLATES"/*.md; do
    [[ ! -f "$agent_file" ]] && continue
    local_name=$(basename "$agent_file")
    dst="$PROJECT_ROOT/.claude/agents/$local_name"
    if [[ -f "$dst" && "$FORCE" != true ]]; then
      echo "  skip: $local_name (already exists)"
    else
      cp "$agent_file" "$dst"
      echo "  created: $local_name"
    fi
  done
else
  echo "  skip: agent templates not found"
fi
echo ""

# --- フレームワーク検出 ---
echo "[framework detection]"
DETECTED_FW=""
FW_LINT=""
FW_TYPECHECK=""
FW_TEST=""
if [[ -f "$PROJECT_ROOT/package.json" ]]; then
  DETECTED_FW="node"
  FW_LINT="npx eslint . --quiet"
  FW_TYPECHECK="npx tsc --noEmit"
  FW_TEST="npm test"
  echo "  detected: Node.js (package.json)"
elif [[ -f "$PROJECT_ROOT/pyproject.toml" || -f "$PROJECT_ROOT/requirements.txt" ]]; then
  DETECTED_FW="python"
  FW_LINT="ruff check src/"
  FW_TYPECHECK="mypy src/"
  FW_TEST="pytest"
  echo "  detected: Python"
elif [[ -f "$PROJECT_ROOT/go.mod" ]]; then
  DETECTED_FW="go"
  FW_LINT="staticcheck ./..."
  FW_TYPECHECK="go vet ./..."
  FW_TEST="go test ./..."
  echo "  detected: Go"
elif [[ -f "$PROJECT_ROOT/Cargo.toml" ]]; then
  DETECTED_FW="rust"
  FW_LINT="cargo clippy -- -D warnings"
  FW_TYPECHECK="cargo check"
  FW_TEST="cargo test"
  echo "  detected: Rust"
else
  DETECTED_FW="unknown"
  echo "  detected: unknown (Node.js defaults will be used)"
fi

FRAMEWORK_YAML="$HELIX_DIR/framework.yaml"
if [[ "$DETECTED_FW" == "unknown" ]]; then
  cat > "$FRAMEWORK_YAML" <<EOF
# helix_template_version: 3
detected: unknown
tools: {}
EOF
else
  cat > "$FRAMEWORK_YAML" <<EOF
# helix_template_version: 3
detected: $DETECTED_FW
tools:
  lint: "$FW_LINT"
  typecheck: "$FW_TYPECHECK"
  test: "$FW_TEST"
EOF
fi
echo "  created: .helix/framework.yaml"
echo ""

# matrix.yaml が存在すれば自動 compile
if [[ -f "$HELIX_DIR/matrix.yaml" ]]; then
  echo "matrix compile を実行中..."
  "$SCRIPT_DIR/helix-matrix" compile 2>/dev/null || true
  echo "matrix auto-detect を実行中..."
  "$SCRIPT_DIR/helix-matrix" auto-detect 2>/dev/null || true
  if [[ -f "$HELIX_DIR/runtime/index.json" && -f "$HELIX_DIR/state/deliverables.json" ]]; then
    echo "  成果物対照表を生成しました"
  else
    echo "  WARN: matrix compile / auto-detect に失敗しました（後で helix matrix compile / helix matrix auto-detect を実行してください）"
  fi
  echo ""
fi

# Git hooks (secrets 検知) を配備
HOOKS_INSTALLER="$HELIX_HOME/scripts/install-git-hooks.sh"
if [[ -x "$HOOKS_INSTALLER" ]]; then
  if [[ "${HELIX_SKIP_HOOK_INSTALL:-}" != "1" ]]; then
    echo "Git hooks を配備中..."
    if bash "$HOOKS_INSTALLER" 2>&1 | sed 's/^/  /'; then
      echo "Git hooks 配備完了"
    else
      echo "警告: Git hooks 配備失敗 (手動: bash $HOOKS_INSTALLER)" >&2
    fi
  else
    echo "HELIX_SKIP_HOOK_INSTALL=1 のため hooks 配備をスキップ"
  fi
fi

echo "=== Done ==="
echo "Next steps:"
echo "  1. CLAUDE.md を編集してプロジェクト情報を記入"
echo "  2. AGENTS.md を編集して Codex 向け差分を記入"
echo "  3. helix matrix compile / helix matrix auto-detect で成果物対照表を有効化"
echo "  4. helix status でプロジェクト状態を確認"
echo "  5. helix size でタスクサイジング"
echo "  6. helix gate --dry-run G2 でゲートチェック確認"
