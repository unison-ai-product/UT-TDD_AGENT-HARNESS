  check_retro_sections() {
    local retro_file="$1"
    python3 - "$retro_file" <<'PY'
import re
import sys
from pathlib import Path

retro_file = Path(sys.argv[1])
text = retro_file.read_text(encoding="utf-8")
required_sections = ("Keep", "Problem", "Try")
missing = []
warnings = []

for section in required_sections:
    pattern = rf"^##+\s+(?:\d+\.\s*)?{section}(?:\s|（|\(|$)"
    m = re.search(pattern, text, flags=re.MULTILINE)
    if not m:
        missing.append(f"section_missing:{section}")
        continue
    start = m.end()
    next_m = re.search(r"^##+\s+", text[start:], flags=re.MULTILINE)
    end = start + next_m.start() if next_m else len(text)
    block = text[start:end]
    bullets = re.findall(r"^-\s+\S.+$", block, flags=re.MULTILINE)
    table_rows = [
        line for line in re.findall(r"^\|.+\|$", block, flags=re.MULTILINE)
        if not re.match(r"^\|\s*-+\s*(\|\s*-+\s*)+\|$", line)
    ]
    evidence_lines = bullets + table_rows
    if len(evidence_lines) == 0:
        missing.append(f"bullet_missing:{section}")

    if section == "Try" and evidence_lines:
        has_owner = any(re.search(r"@\w+", line) for line in evidence_lines)
        has_due = any(re.search(r"\b\d{4}-\d{2}-\d{2}\b", line) for line in evidence_lines)
        if not has_owner or not has_due:
            warnings.append("Try section は @owner と YYYY-MM-DD の記載を推奨")

if missing:
    print(f"FAIL: {retro_file.name} -> {', '.join(missing)}")
    raise SystemExit(1)

print(f"PASS: {retro_file.name}")
for warning in warnings:
    print(f"WARN: {retro_file.name} -> {warning}")
PY
  }

