read_config_readiness_mode() {
  local config_file="$CONFIG_FILE"
  [[ -f "$config_file" ]] || return 0

  local value
  value=$(python3 "$YAML_PARSER" read "$config_file" "readiness.mode" 2>/dev/null || true)
  if [[ -n "$value" && "$value" != "null" && "$value" != "{}" ]]; then
    echo "$value"
    return 0
  fi

  awk '
    /^[[:space:]]*readiness:[[:space:]]*$/ {
      in_readiness = 1
      base_indent = match($0, /[^[:space:]]/) - 1
      next
    }
    in_readiness {
      if ($0 !~ /^[[:space:]]*$/ && $0 !~ /^[[:space:]]*#/) {
        indent = match($0, /[^[:space:]]/) - 1
        if (indent <= base_indent) {
          in_readiness = 0
        }
      }
      if (in_readiness && $0 ~ /^[[:space:]]*mode:[[:space:]]*/) {
        sub(/^[[:space:]]*mode:[[:space:]]*/, "", $0)
        gsub(/["'\'']/, "", $0)
        print $1
        exit
      }
    }
  ' "$config_file"
}

trim_value() {
  local value="$1"
  value="${value#"${value%%[![:space:]]*}"}"
  value="${value%"${value##*[![:space:]]}"}"
  printf '%s' "$value"
}

is_truthy() {
  local value
  value="$(trim_value "$1")"
  value="${value#\"}"
  value="${value%\"}"
  value="${value#\'}"
  value="${value%\'}"
  case "${value,,}" in
    true|1|yes|on)
      return 0
      ;;
  esac
  return 1
}

parse_readiness_mode() {
  local flag_value="${1:-}"
  local mode=""

  if [[ -n "$flag_value" ]]; then
    mode="$flag_value"
  elif [[ -n "${HELIX_READINESS_MODE:-}" ]]; then
    mode="$HELIX_READINESS_MODE"
  else
    mode="$(read_config_readiness_mode || true)"
  fi

  mode="${mode:-warning}"
  case "$mode" in
    warning|enforce|skip)
      echo "$mode"
      ;;
    *)
      echo "エラー: 無効な readiness mode です: $mode（warning|enforce|skip）" >&2
      exit "$EXIT_INPUT_ERROR"
      ;;
  esac
}

