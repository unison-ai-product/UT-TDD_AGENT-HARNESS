  fi
  readiness_mode=$(parse_readiness_mode "${READINESS_MODE_FLAG:-}")
  if [[ "$readiness_mode" != "skip" ]]; then
    readiness_output_file=$(mktemp "$HELIX_TMP_DIR/helix-readiness-${gate}-XXXXXX")
    if ! "$SCRIPT_DIR/helix-readiness" check --phase "$mapped_l" --json >"$readiness_output_file" 2>&1; then
      if [[ "$readiness_mode" == "warning" ]]; then
        echo "⚠ readiness exit not satisfied for $mapped_l (warning mode)" >&2
        cat "$readiness_output_file" >&2
      else
        echo "✗ readiness exit not satisfied for $mapped_l (enforce mode)" >&2
        cat "$readiness_output_file" >&2
        readiness_fail=1
        add_fail_reason "readiness"
      fi
    fi
    rm -f "$readiness_output_file"
  fi

  local total_fail=$((deliv_fail + mandatory_fail + ai_fail + readiness_fail))
  if [[ "$gate" =~ ^G(2|4|6)$ ]]; then
    if [[ "$SKIP_DETECTORS" == true ]]; then
      echo "[helix-gate] detector auto-run skipped (--skip-detectors)"
    elif [[ $total_fail -eq 0 ]]; then
      run_gate_detector_auto_checks "$gate"
      if [[ $detector_fail -gt 0 ]]; then
        add_fail_reason "detectors"
      fi
    fi
  fi

  # PLAN-075 Phase 5: V-model 4 artifact lint (G2/G3/G4 で advisory)
  if [[ "$gate" =~ ^G[234]$ ]] && [[ "$SKIP_DETECTORS" != true ]]; then
    run_gate_vmodel_lint "$gate"
    run_gate_subagent_audit "$gate"
    run_gate_design_doc_web_search_audit "$gate"
    run_gate_sprint_completion "$gate"
  fi

  # --- 総合判定 ---
  total_fail=$((total_fail + detector_fail))
  local g10_effective_outcome=""
  local g10_effective_status=""
  local g10_base_fail=$((deliv_fail + mandatory_fail + readiness_fail))
  if [[ "$gate" == "G10" ]]; then
    if [[ -n "$G10_OUTCOME" ]]; then
      g10_effective_outcome="$G10_OUTCOME"
      # PLAN-009 §3.4.1: 明示 outcome は AI verdict より優先する。
      total_fail="$g10_base_fail"
    elif [[ "$ai_fail" -gt 0 ]]; then
      g10_effective_outcome="blocked"
    else
      g10_effective_outcome="pass"
    fi

    g10_effective_status="$(g10_status_for_outcome "$g10_effective_outcome")"
    if [[ "$g10_base_fail" -gt 0 ]]; then
      g10_effective_status="failed"
    fi
    if [[ "$g10_effective_outcome" != "pass" && "$g10_base_fail" -eq 0 ]]; then
      total_fail=1
    fi
  fi
  local ended_ms duration_ms result
  ended_ms=$(now_ms)
  duration_ms=$((ended_ms - started_ms))
  if [[ $total_fail -gt 0 ]]; then
    result="fail"
  else
    result="pass"
  fi
  if [[ "$DRY_RUN" != true ]]; then
    log_gate_run "$gate" "$result" "$deliv_fail" "$static_fail" "$ai_fail" "$duration_ms" "$extra_fail_reasons"
  fi
  echo ""
  if [[ $total_fail -gt 0 ]]; then
    local readiness_summary=""
    if [[ "$readiness_fail" -gt 0 ]]; then
      readiness_summary=", readiness: $readiness_fail fail"
    fi
    local detector_fail_summary=""
    if [[ "$detector_fail" -gt 0 ]]; then
      detector_fail_summary=", detector: $detector_fail fail"
    fi
    echo "=== $gate FAIL (deliverable: $deliv_fail fail, mandatory: $mandatory_fail fail, advisory: $advisory_fail fail, ai: $ai_fail fail${readiness_summary}${detector_fail_summary}) ==="
    if [[ "$DRY_RUN" != true ]]; then
      log_gate_summary "$gate" "$result" "$deliv_fail" "$static_fail" "$ai_fail"
    fi
    if [[ -f "$PHASE_FILE" ]]; then
      if [[ "$gate" == "G10" ]]; then
        if [[ "$DRY_RUN" != true || "$G10_OUTCOME_EXPLICIT" == true ]]; then
          write_g10_outcome_phase "$g10_effective_status" "$g10_effective_outcome" "$G10_OUTCOME_OWNER" "$G10_OUTCOME_ETA" "$G10_OUTCOME_REASON"
        fi
      elif [[ "$DRY_RUN" != true ]]; then
        write_phase_or_die "gates.${gate}.status" "failed"
      fi
    fi
    if [[ "$JSON_OUTPUT" == true ]]; then
      emit_gate_json "$gate" "fail" "$static_pass" "$static_fail" "$prereq"
    fi
    exit "$EXIT_CHECK_FAILED"
  else
    echo "=== $gate PASS ==="
    if [[ "$DRY_RUN" != true ]]; then
      log_gate_summary "$gate" "$result" "$deliv_fail" "$static_fail" "$ai_fail"
    fi
    if [[ -f "$PHASE_FILE" ]]; then
      if [[ "$gate" == "G10" ]]; then
        if [[ "$DRY_RUN" != true || "$G10_OUTCOME_EXPLICIT" == true ]]; then
          write_g10_outcome_phase "$g10_effective_status" "$g10_effective_outcome" "$G10_OUTCOME_OWNER" "$G10_OUTCOME_ETA" "$G10_OUTCOME_REASON"
        fi
      elif [[ "$DRY_RUN" != true ]]; then
        write_phase_or_die "gates.${gate}.status" "passed"
        write_phase_or_die "gates.${gate}.date" "$(date '+%Y-%m-%d')"
        maybe_generate_retro "$gate"
      fi
    fi
    _emit_feedback \
      "$gate" \
      "$gate_name" \
      "gate_name=$gate_name; deliverable_fail=$deliv_fail; mandatory_fail=$mandatory_fail; advisory_fail=$advisory_fail; ai_fail=$ai_fail; static_pass=$static_pass; static_fail=$static_fail; extra_fail_reasons=${extra_fail_reasons:-none}"
    case "$gate" in
      G4)
        echo ""
        echo "[helix-gate] 品質改善の提案:"

        # TODO/FIXME/HACK/WORKAROUND の残存数を集計
        todo_count=$( (rg -c 'TODO|FIXME|HACK|WORKAROUND' src/ 2>/dev/null || true) | awk -F: '{s+=$2}END{print s+0}' )
        if [[ $todo_count -gt 0 ]]; then
          echo "  TODO/FIXME: $todo_count 件 → helix debt add で台帳化を推奨"
        fi

        # 負債台帳の未解決件数サマリ
        if [[ -f "$HELIX_DIR/debt-register.yaml" ]]; then
          debt_count=$(grep -c "status: open" "$HELIX_DIR/debt-register.yaml" 2>/dev/null || true)
          debt_count="${debt_count:-0}"
          echo "  技術負債: $debt_count 件（未解決）→ 次イテレーション 20% 枠で対応推奨"
        fi

        echo "  helix promote --auto で昇格候補を確認"
        echo "  helix bench で品質推移を確認"
      echo "次のアクション: helix gate G5 または helix gate G6 に進んでください"
      echo "[helix-gate] ヒント: 'helix promote --auto' で昇格候補を確認できます"
      ;;
      G6.5)
        echo "次のアクション: helix gate G6.7 に進んでください"
        ;;
      G6.7)
        echo "次のアクション: helix gate G6.9 に進んでください"
        ;;
      G6.9)
        echo "次のアクション: helix gate G7 に進んでください"
        ;;
      G6)
        echo "[helix-gate] ヒント: E2E テストを実行してください"
        echo "  npx playwright test（Playwright）"
        echo "  npm test -- --coverage（Jest）"
        echo "  pytest --cov（pytest）"
        echo "次のアクション: helix gate G7 → helix pr でリリース準備"
        ;;
      G7)
        echo "次のアクション: helix pr で PR を作成してください"
        echo ""
        echo "[helix-gate] L8 受入準備:"
        echo "  受入条件（D-ACC）と実装の突合を実施してください"
        echo "  helix matrix status で全成果物の状態を確認"
        ;;
    esac
    if [[ "$JSON_OUTPUT" == true ]]; then
      emit_gate_json "$gate" "pass" "$static_pass" "$static_fail" "$prereq"
    fi
  fi
}

# --- ミニレトロ自動生成 ---
maybe_generate_retro() {
  local gate="$1"
  local phase_desc=""

  case "$gate" in
    G2) phase_desc="設計フェーズ (L1-L2)" ;;
    G4) phase_desc="実装フェーズ (L3-L4)" ;;
    *)  return ;;
  esac

  local retro_dir="$HELIX_DIR/retros"
  mkdir -p "$retro_dir"
  local today
  today=$(date '+%Y-%m-%d')
  local retro_file="$retro_dir/${today}-${gate}.md"

  if [[ -f "$retro_file" ]]; then
    echo ""
    echo "[helix-gate] Retro already exists: $retro_file"
    return
  fi

  local template="$SCRIPT_DIR/templates/retro.md.template"
  if [[ -f "$template" ]]; then
    sed -e "s/{{GATE}}/$gate/g" \
        -e "s/{{DATE}}/$today/g" \
        -e "s/{{PHASE_DESC}}/$phase_desc/g" \
        "$template" > "$retro_file"
  else
    cat > "$retro_file" <<RETRO
# Mini Retro: $gate ($today)

## Phase: $phase_desc

## Keep
- うまくいったことを記載

## Problem
- 問題だったことを記載

## Try
- @owner 2026-01-01 次に試すアクション
RETRO
  fi

  echo ""
  echo "[helix-gate] ミニレトロ生成: $retro_file"
  echo "[helix-gate]   内容を記入してください（Try の @owner と YYYY-MM-DD は推奨）"
}

run_checks "$GATE"
