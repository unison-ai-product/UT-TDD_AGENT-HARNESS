#!/bin/bash
if [[ "${BASH_VERSINFO[0]:-0}" -lt 4 ]]; then
  echo "エラー: helix-gate は bash 4 以上が必要です (現 ${BASH_VERSION:-unknown})" >&2
  echo "macOS の場合: brew install bash && シェルを /opt/homebrew/bin/bash に変更" >&2
  exit 1
fi
set -euo pipefail

# helix-gate: HELIX ゲート自動検証
# Usage: helix-gate <gate-name> [--static-only] [--ai-only] [--dry-run] [--skip-detectors] [--pair-check <layer>] [--plan-id <PLAN-NNN>] [--readiness-mode warning|enforce|skip]
#
# 責務分離:
#   1. 前提条件チェック（prereq gate）      → check_prerequisites()
#   2. Deliverable チェック                 → deliverable_gate.py
#   3. Static チェック                      → gate-checks.yaml 実行
#   4. AI チェック                          → helix-codex 委譲
#   5. 総合判定 + phase.yaml 更新           → update_phase()
#   6. 後処理（retro 生成、提案メッセージ）  → post_gate()

source "$(cd "$(dirname "$0")" && pwd)/lib/helix-common.sh"
GATE_CHECKS="$HELIX_DIR/gate-checks.yaml"
PHASE_FILE="$HELIX_DIR/phase.yaml"
HELIX_CODEX="$SCRIPT_DIR/helix-codex"
REVIEW_SCHEMA="$SCRIPT_DIR/schemas/review-output.schema.json"
PLAN_SCHEMA="$SCRIPT_DIR/lib/plan_schema.py"

# --- 引数パース ---
GATE=""
STATIC_ONLY=false
AI_ONLY=false
DRY_RUN=false
UNDO=false
JSON_OUTPUT=false
CROSS_SPRINT=false
SKIP_DETECTORS=false
READINESS_MODE_FLAG=""
G5_PHASE=""
G10_OUTCOME=""
G10_OUTCOME_OWNER=""
G10_OUTCOME_ETA=""
G10_OUTCOME_REASON=""
G10_OUTCOME_EXPLICIT=false
PAIR_CHECK_LAYER=""
PAIR_CHECK_PLAN_ID=""
SUBGATE=""
DRIVE=""
HELIX_TMP_DIR="${TMPDIR:-$HELIX_DIR/tmp}"
mkdir -p "$HELIX_TMP_DIR"

while [[ $# -gt 0 ]]; do
  case $1 in
    --static-only) STATIC_ONLY=true; shift ;;
    --ai-only)     AI_ONLY=true; shift ;;
    --dry-run)     DRY_RUN=true; shift ;;
    --undo)        UNDO=true; shift ;;
    --json)        JSON_OUTPUT=true; shift ;;
    --cross-sprint) CROSS_SPRINT=true; shift ;;
    --skip-detectors) SKIP_DETECTORS=true; shift ;;
    --readiness-mode)
      if [[ -z "${2:-}" ]]; then
        echo "エラー: --readiness-mode には warning|enforce|skip が必要です" >&2
        exit "$EXIT_INPUT_ERROR"
      fi
      READINESS_MODE_FLAG="$2"
      shift 2
      ;;
    --readiness-mode=*)
      READINESS_MODE_FLAG="${1#--readiness-mode=}"
      shift
      ;;
    --phase)
      if [[ -z "${2:-}" ]]; then
        echo "エラー: --phase には phase 名が必要です" >&2
        exit "$EXIT_INPUT_ERROR"
      fi
      G5_PHASE="$2"
      shift 2
      ;;
    --phase=*)
      G5_PHASE="${1#--phase=}"
      shift
      ;;
    --outcome)
      if [[ -z "${2:-}" ]]; then
        echo "エラー: --outcome には pass|watch-continue|blocked|failed が必要です" >&2
        exit "$EXIT_INPUT_ERROR"
      fi
      G10_OUTCOME="$2"
      G10_OUTCOME_EXPLICIT=true
      shift 2
      ;;
    --outcome=*)
      G10_OUTCOME="${1#--outcome=}"
      G10_OUTCOME_EXPLICIT=true
      shift
      ;;
    --outcome-owner)
      if [[ -z "${2:-}" ]]; then
        echo "エラー: --outcome-owner には owner 名が必要です" >&2
        exit "$EXIT_INPUT_ERROR"
      fi
      G10_OUTCOME_OWNER="$2"
      shift 2
      ;;
    --outcome-owner=*)
      G10_OUTCOME_OWNER="${1#--outcome-owner=}"
      shift
      ;;
    --outcome-eta)
      if [[ -z "${2:-}" ]]; then
        echo "エラー: --outcome-eta には YYYY-MM-DD が必要です" >&2
        exit "$EXIT_INPUT_ERROR"
      fi
      G10_OUTCOME_ETA="$2"
      shift 2
      ;;
    --outcome-eta=*)
      G10_OUTCOME_ETA="${1#--outcome-eta=}"
      shift
      ;;
    --outcome-reason)
      if [[ -z "${2:-}" ]]; then
        echo "エラー: --outcome-reason には理由テキストが必要です" >&2
        exit "$EXIT_INPUT_ERROR"
      fi
      G10_OUTCOME_REASON="$2"
      shift 2
      ;;
    --outcome-reason=*)
      G10_OUTCOME_REASON="${1#--outcome-reason=}"
      shift
      ;;
    --pair-check)
      if [[ -z "${2:-}" ]]; then
        echo "エラー: --pair-check には requirement|architecture|detailed|functional|planning が必要です" >&2
        exit "$EXIT_INPUT_ERROR"
      fi
      PAIR_CHECK_LAYER="$2"
      shift 2
      ;;
    --pair-check=*)
      PAIR_CHECK_LAYER="${1#--pair-check=}"
      shift
      ;;
    --subgate)
      if [[ -z "${2:-}" ]]; then
        echo "エラー: --subgate には functional_freeze 等のサブゲート名が必要です" >&2
        exit "$EXIT_INPUT_ERROR"
      fi
      SUBGATE="$2"
      shift 2
      ;;
    --subgate=*)
      SUBGATE="${1#--subgate=}"
      shift
      ;;
    --plan-id)
      if [[ -z "${2:-}" ]]; then
        echo "エラー: --plan-id には PLAN-数字3桁 が必要です" >&2
        exit "$EXIT_INPUT_ERROR"
      fi
      PAIR_CHECK_PLAN_ID="$2"
      shift 2
      ;;
    --plan-id=*)
      PAIR_CHECK_PLAN_ID="${1#--plan-id=}"
      shift
      ;;
    --drive)
      if [[ -z "${2:-}" ]]; then
        echo "エラー: --drive には be|fe|db|fullstack が必要です" >&2
        exit "$EXIT_INPUT_ERROR"
      fi
      DRIVE="$2"
      shift 2
      ;;
    --drive=*)
      DRIVE="${1#--drive=}"
      shift
      ;;
    --help|-h)
      echo "使い方: helix gate <gate> [--static-only] [--ai-only] [--dry-run] [--skip-detectors] [--pair-check <layer>] [--subgate <name>] [--plan-id <PLAN-NNN>] [--drive <DRIVE>] [--undo] [--json] [--cross-sprint] [--readiness-mode <warning|enforce|skip>]"
      echo ""
      echo "Gates: G0.5, G1, G1R, G1.5, G2, G3, G4, G5, G6, G6.5, G6.7, G6.9, G7, G9, G10, G11"
      echo ""
      echo "Options:"
      echo "  --pair-check <layer>"
      echo "      design_review の vertical/horizontal 両 passed を機械確認"
      echo "  --subgate <name>"
      echo "      G ゲートのサブゲート (現在 functional_freeze のみ)"
      echo "  --plan-id <PLAN-NNN>"
      echo "      --pair-check / --subgate と併用して対象 plan_id を評価する"
      echo "  --drive <DRIVE>"
      echo "      be|fe|db|fullstack。--subgate では override、省略時は phase/plan から解決"
      echo "  --cross-sprint"
      echo "      直近完了 Sprint を helix.db から推定し、横断レビュー証跡を .helix/cross-sprint-reviews/ に保存"
      echo "  --skip-detectors"
      echo "      G2/G4/G6 の auto-run detector をスキップする (debug 用)"
      echo "  --readiness-mode <warning|enforce|skip>"
      echo "      readiness exit の AND 条件モード (default: warning)"
      echo "  --outcome <pass|watch-continue|blocked|failed>"
      echo "      G10 専用 outcome。明示時は AI verdict より優先"
      echo "  --outcome-owner <name> / --outcome-eta <YYYY-MM-DD> / --outcome-reason <text>"
      echo "      G10 outcome の詳細メタデータ"
      exit "$EXIT_SUCCESS"
      ;;
    *)
      if [[ -z "$GATE" ]]; then
        GATE="$1"; shift
      else
        echo "エラー: 不明なオプションです: $1" >&2; exit "$EXIT_INPUT_ERROR"
      fi
      ;;
  esac
done

if [[ "$JSON_OUTPUT" == true ]]; then
  exec 3>&1
  exec 1>&2
fi

if [[ -z "$GATE" ]]; then
  echo "エラー: ゲート名が必要です（G0.5, G1, G1R, G1.5, G2, G3, G4, G5, G6, G6.5, G6.7, G6.9, G7, G9, G10, G11）" >&2
  exit "$EXIT_INPUT_ERROR"
fi

if [[ ! "$GATE" =~ ^G(0\.5|1|1R|1\.5|2|3|4|5|6|6\.[579]|7|9|10|11)$ ]]; then
  echo "エラー: 無効なゲートです: $GATE（G0.5, G1, G1R, G1.5, G2-G7, G6.5/G6.7/G6.9, G9-G11 を指定してください）" >&2
  exit "$EXIT_INPUT_ERROR"
fi

if [[ "$GATE" != "G10" ]]; then
  if [[ "$G10_OUTCOME_EXPLICIT" == true || -n "$G10_OUTCOME_OWNER" || -n "$G10_OUTCOME_ETA" || -n "$G10_OUTCOME_REASON" ]]; then
    echo "エラー: --outcome/--outcome-owner/--outcome-eta/--outcome-reason は G10 専用です" >&2
    exit "$EXIT_INPUT_ERROR"
  fi
fi

if [[ -n "$G5_PHASE" ]]; then
  if [[ "$GATE" != "G5" ]]; then
    echo "エラー: --phase は G5 専用です" >&2
    exit "$EXIT_INPUT_ERROR"
  fi
  case "$G5_PHASE" in
    L5|L5a|L5b) ;;
    *)
      echo "エラー: 無効な phase です: $G5_PHASE（L5|L5a|L5b を指定してください）" >&2
      exit "$EXIT_INPUT_ERROR"
      ;;
  esac
fi

if [[ "$GATE" == "G10" && -n "$G10_OUTCOME" ]]; then
  case "$G10_OUTCOME" in
    pass|watch-continue|blocked|failed) ;;
    *)
      echo "エラー: 無効な G10 outcome です: $G10_OUTCOME（pass|watch-continue|blocked|failed）" >&2
      exit "$EXIT_INPUT_ERROR"
      ;;
  esac
fi

validate_iso_date() {
  local value="$1"
  [[ "$value" =~ ^[0-9]{4}-[0-9]{2}-[0-9]{2}$ ]] || return 1
  python3 - "$value" <<'PY' >/dev/null 2>&1
import datetime as dt
import sys

value = sys.argv[1]
try:
    parsed = dt.date.fromisoformat(value)
except ValueError:
    raise SystemExit(1)
raise SystemExit(0 if parsed.isoformat() == value else 1)
PY
}

date_plus_days() {
  local days="$1"
  python3 - "$days" <<'PY'
import datetime as dt
import sys

days = int(sys.argv[1])
print((dt.date.today() + dt.timedelta(days=days)).isoformat())
PY
}

normalize_optional_scalar() {
  local value="${1:-}"
  value="${value#"${value%%[![:space:]]*}"}"
  value="${value%"${value##*[![:space:]]}"}"
  value="${value#\"}"
  value="${value%\"}"
  value="${value#\'}"
  value="${value%\'}"
  case "$value" in
    ""|null|[]|{}) printf '' ;;
    *) printf '%s' "$value" ;;
  esac
}

vmodel_drive_list() {
  python3 - "$SCRIPT_DIR/lib" <<'PY'
import sys
from pathlib import Path

sys.path.insert(0, sys.argv[1])
import vmodel_loader

print("|".join(vmodel_loader.load_default().list_drives()))
PY
}

drive_in_vmodel() {
  local drive="$1"
  python3 - "$SCRIPT_DIR/lib" "$drive" <<'PY' >/dev/null 2>&1
import sys

sys.path.insert(0, sys.argv[1])
import vmodel_loader

raise SystemExit(0 if sys.argv[2] in vmodel_loader.load_default().list_drives() else 1)
PY
}

resolve_plan_metadata_drive() {
  local plan_id="$1"
  python3 - "$SCRIPT_DIR/lib" "$PROJECT_ROOT" "$plan_id" <<'PY'
import sys
from pathlib import Path

lib_dir = Path(sys.argv[1])
project_root = Path(sys.argv[2])
plan_id = sys.argv[3]
sys.path.insert(0, str(lib_dir))

import plan_frontmatter
import yaml_parser

plan_path = project_root / ".helix" / "plans" / f"{plan_id}.yaml"
if not plan_path.is_file():
    raise SystemExit(0)

plan_data = yaml_parser.parse_yaml(plan_path.read_text(encoding="utf-8"))
if not isinstance(plan_data, dict):
    raise SystemExit(0)

try:
    docs_path = plan_frontmatter.resolve_plan_doc_path(plan_path, plan_data)
    frontmatter, _body = plan_frontmatter._parse_frontmatter(docs_path.read_text(encoding="utf-8"))
except Exception:
    raise SystemExit(0)

drive = frontmatter.get("drive")
if isinstance(drive, str) and drive.strip():
    print(drive.strip())
PY
}

resolve_subgate_drive() {
  local plan_id="$1"
  local explicit_drive="${2:-}"
  local allowed
  local phase_drive=""
  local plan_drive=""
  local resolved=""
  allowed="$(vmodel_drive_list)"

  if [[ -f "$PHASE_FILE" ]]; then
    phase_drive="$(normalize_optional_scalar "$(python3 "$YAML_PARSER" read "$PHASE_FILE" "sprint.drive" 2>/dev/null || true)")"
    if [[ -n "$phase_drive" ]]; then
      if drive_in_vmodel "$phase_drive"; then
        resolved="$phase_drive"
      else
        echo "警告: phase.yaml の sprint.drive が無効なため無視します: $phase_drive (allowed: $allowed)" >&2
      fi
    fi
  fi

  if [[ -z "$resolved" ]]; then
    plan_drive="$(normalize_optional_scalar "$(resolve_plan_metadata_drive "$plan_id")")"
    if [[ -n "$plan_drive" ]]; then
      if drive_in_vmodel "$plan_drive"; then
        resolved="$plan_drive"
      else
        echo "警告: plan metadata の drive が無効なため無視します: $plan_drive (allowed: $allowed)" >&2
      fi
    fi
  fi

  if [[ -n "$explicit_drive" ]]; then
    if [[ -n "$resolved" ]]; then
      echo "警告: functional_freeze drive override (auto-resolved=$resolved, override=$explicit_drive)" >&2
    fi
    resolved="$explicit_drive"
  fi

  if [[ -z "$resolved" ]]; then
    echo "エラー: functional_freeze の drive を解決できませんでした。--drive を指定してください（phase.yaml の sprint.drive / plan metadata の drive を確認）" >&2
    return 1
  fi

  printf '%s\n' "$resolved"
}

if [[ "$GATE" == "G10" ]]; then
  if [[ "$G10_OUTCOME" == "watch-continue" || "$G10_OUTCOME" == "blocked" ]]; then
    if [[ -z "$G10_OUTCOME_OWNER" ]]; then
      echo "エラー: G10 outcome=$G10_OUTCOME には --outcome-owner が必要です" >&2
      exit "$EXIT_INPUT_ERROR"
    fi
    if [[ -z "$G10_OUTCOME_ETA" ]]; then
      if [[ "$G10_OUTCOME" == "watch-continue" ]]; then
        G10_OUTCOME_ETA="$(date_plus_days 30)"
      else
        G10_OUTCOME_ETA="$(date_plus_days 14)"
      fi
    fi
  fi
  if [[ -n "$G10_OUTCOME_ETA" ]] && ! validate_iso_date "$G10_OUTCOME_ETA"; then
    echo "エラー: --outcome-eta は YYYY-MM-DD の実在日で指定してください: $G10_OUTCOME_ETA" >&2
    exit "$EXIT_INPUT_ERROR"
  fi
fi

if [[ -n "$PAIR_CHECK_LAYER" || ( -n "$PAIR_CHECK_PLAN_ID" && -z "$SUBGATE" ) ]]; then
  if [[ -z "$PAIR_CHECK_LAYER" || -z "$PAIR_CHECK_PLAN_ID" ]]; then
    echo "エラー: --pair-check と --plan-id は同時指定が必要です" >&2
    exit "$EXIT_INPUT_ERROR"
  fi
  case "$PAIR_CHECK_LAYER" in
    requirement|architecture|detailed|functional|planning) ;;
    *)
      echo "エラー: --pair-check には requirement|architecture|detailed|functional|planning を指定してください: $PAIR_CHECK_LAYER" >&2
      exit "$EXIT_INPUT_ERROR"
      ;;
  esac
  if [[ ! "$PAIR_CHECK_PLAN_ID" =~ ^PLAN-[0-9]{3}$ ]]; then
    echo "エラー: --plan-id は PLAN-数字3桁 で指定してください: $PAIR_CHECK_PLAN_ID" >&2
    exit "$EXIT_INPUT_ERROR"
  fi
fi

if [[ -n "$SUBGATE" ]]; then
  if [[ "$GATE" != "G3" ]]; then
    echo "エラー: --subgate は G3 専用です" >&2
    exit "$EXIT_INPUT_ERROR"
  fi
  case "$SUBGATE" in
    functional_freeze) ;;
    *)
      echo "エラー: --subgate は functional_freeze のみサポート: $SUBGATE" >&2
      exit "$EXIT_INPUT_ERROR"
      ;;
  esac
  if [[ -z "$PAIR_CHECK_PLAN_ID" ]]; then
    echo "エラー: --subgate は --plan-id を必須" >&2
    exit "$EXIT_INPUT_ERROR"
  fi
  if [[ ! "$PAIR_CHECK_PLAN_ID" =~ ^PLAN-[0-9]{3}$ ]]; then
    echo "エラー: --plan-id は PLAN-数字3桁 で指定してください: $PAIR_CHECK_PLAN_ID" >&2
    exit "$EXIT_INPUT_ERROR"
  fi
  if [[ -n "$DRIVE" ]] && ! drive_in_vmodel "$DRIVE"; then
    echo "エラー: --drive は $(vmodel_drive_list): $DRIVE" >&2
    exit "$EXIT_INPUT_ERROR"
  fi
elif [[ -n "$DRIVE" ]]; then
  echo "警告: --drive は現状 --subgate と併用した場合のみ評価されます" >&2
fi

run_pair_check() {
  local gate="$1"
  local layer="$2"
  local plan_id="$3"

  if [[ ! -f "$DB_PATH" ]]; then
    echo "$gate fail: .helix/helix.db が見つかりません" >&2
    return 1
  fi

  python3 - "$SCRIPT_DIR/lib" "$DB_PATH" "$plan_id" "$layer" "$gate" <<'PY'
import sys
from pathlib import Path

lib_dir = Path(sys.argv[1])
db_path = Path(sys.argv[2])
plan_id = sys.argv[3]
layer = sys.argv[4]
gate = sys.argv[5]
sys.path.insert(0, str(lib_dir))

import helix_db

try:
    result = helix_db.query_design_review_pair(db_path, plan_id=plan_id, layer=layer)
except Exception as exc:
    print(f"{gate} fail: design_review query failed: {exc}", file=sys.stderr)
    raise SystemExit(1)

vertical_passed = bool(result.get("vertical_passed"))
horizontal_passed = bool(result.get("horizontal_passed"))
print(
    f"[pair-check] gate={gate} plan_id={plan_id} layer={layer} "
    f"vertical_passed={vertical_passed} horizontal_passed={horizontal_passed}"
)
if vertical_passed and horizontal_passed:
    raise SystemExit(0)

print(
    f"{gate} fail: design_review pair missing "
    f"(vertical_passed={vertical_passed}, horizontal_passed={horizontal_passed})",
    file=sys.stderr,
)
raise SystemExit(1)
PY
}

run_functional_freeze() {
  local gate="$1"
  local plan_id="$2"
  local drive="$3"
  local size="${HELIX_SIZE:-M}"
  local exit_gate_fail="$4"

  if [[ ! -f "$DB_PATH" ]]; then
    echo "$gate fail: .helix/helix.db が見つかりません" >&2
    return "$exit_gate_fail"
  fi

  python3 - "$SCRIPT_DIR/lib" "$DB_PATH" "$plan_id" "$drive" "$size" "$exit_gate_fail" <<'PY'
import json
import sys
from pathlib import Path

lib_dir = Path(sys.argv[1])
db_path = Path(sys.argv[2])
plan_id = sys.argv[3]
drive = sys.argv[4]
size = sys.argv[5]
exit_gate_fail = int(sys.argv[6])
sys.path.insert(0, str(lib_dir))

import helix_db

conn = helix_db.get_connection(db_path)
try:
    result = helix_db.query_functional_freeze_status(conn, plan_id, drive)
finally:
    conn.close()

enforce = (size == "L") or (drive in {"fe", "fullstack", "db"})
print(json.dumps(result, ensure_ascii=False, indent=2))

if result["verdict"] == "passed":
    raise SystemExit(0)

severity = "FAIL" if enforce else "WARN"
print(
    f"{severity}: functional_freeze {result['verdict']} (size={size}, drive={drive})",
    file=sys.stderr,
)
raise SystemExit(exit_gate_fail if enforce else 0)
PY
}

if [[ -n "$SUBGATE" ]]; then
  RESOLVED_DRIVE="$(resolve_subgate_drive "$PAIR_CHECK_PLAN_ID" "$DRIVE")" || exit "$EXIT_CHECK_FAILED"
  if run_functional_freeze "$GATE" "$PAIR_CHECK_PLAN_ID" "$RESOLVED_DRIVE" "$EXIT_CHECK_FAILED"; then
    exit "$EXIT_SUCCESS"
  else
    subgate_status=$?
    exit "$subgate_status"
  fi
fi

if [[ -n "$PAIR_CHECK_LAYER" ]]; then
  if run_pair_check "$GATE" "$PAIR_CHECK_LAYER" "$PAIR_CHECK_PLAN_ID"; then
    exit "$EXIT_SUCCESS"
  else
    pair_check_status=$?
    exit "$pair_check_status"
  fi
fi

emit_gate_json() {
  local gate="$1"
  local result="$2"
  local static_pass="$3"
  local static_fail="$4"
  local prereq_gate="$5"
  GATE_JSON_GATE="$gate" \
  GATE_JSON_RESULT="$result" \
  GATE_JSON_STATIC_PASS="$static_pass" \
  GATE_JSON_STATIC_FAIL="$static_fail" \
  GATE_JSON_PREREQ="$prereq_gate" \
  python3 - <<'PY' >&3
import json
import os

print(
    json.dumps(
        {
            "gate": os.environ.get("GATE_JSON_GATE", ""),
            "result": os.environ.get("GATE_JSON_RESULT", ""),
            "checks": {
                "static_pass": int(os.environ.get("GATE_JSON_STATIC_PASS", "0")),
                "static_fail": int(os.environ.get("GATE_JSON_STATIC_FAIL", "0")),
            },
            "prereq": os.environ.get("GATE_JSON_PREREQ", ""),
        },
        ensure_ascii=False,
    )
)
PY
}

YAML_PARSER="$SCRIPT_DIR/lib/yaml_parser.py"
DELIVERABLE_GATE="$SCRIPT_DIR/lib/deliverable_gate.py"
DESIGN_MD_WRAPPER="$SCRIPT_DIR/libexec/design-md"

STATE_MACHINE="$SCRIPT_DIR/templates/state-machine.yaml"
if [[ ! -f "$STATE_MACHINE" ]]; then
  echo "エラー: state-machine.yaml が見つかりません" >&2
  exit $EXIT_INTERNAL_ERROR
fi

write_phase_or_die() {
  local dotpath="$1"
  local value="$2"
  if ! python3 "$YAML_PARSER" write "$PHASE_FILE" "$dotpath" "$value"; then
    echo "エラー: phase.yaml 更新失敗: ${dotpath}=${value}" >&2
    exit "$EXIT_INTERNAL_ERROR"
  fi
}

write_g10_outcome_phase() {
  local status="$1"
  local outcome="$2"
  local owner="${3:-}"
  local eta="${4:-}"
  local reason="${5:-}"

  [[ -f "$PHASE_FILE" ]] || return 0
  write_phase_or_die "gates.G10.status" "$status"
  write_phase_or_die "gates.G10.outcome" "$outcome"
  write_phase_or_die "gates.G10.outcome_owner" "${owner:-null}"
  write_phase_or_die "gates.G10.outcome_eta" "${eta:-null}"
  write_phase_or_die "gates.G10.outcome_reason" "${reason:-null}"
  if [[ "$status" == "passed" ]]; then
