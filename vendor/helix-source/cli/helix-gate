import datetime as dt
import json
import os
import re
import sqlite3
from pathlib import Path


def table_exists(conn: sqlite3.Connection, name: str) -> bool:
    row = conn.execute(
        "SELECT 1 FROM sqlite_master WHERE type='table' AND name=?",
        (name,),
    ).fetchone()
    return row is not None


def latest_accuracy_sprint(conn: sqlite3.Connection):
    if not table_exists(conn, "accuracy_score"):
        return None
    row = conn.execute(
        """
        SELECT sprint, recorded_at
        FROM accuracy_score
        WHERE sprint IS NOT NULL AND TRIM(sprint) != ''
        ORDER BY recorded_at DESC, id DESC
        LIMIT 1
        """
    ).fetchone()
    if row is None:
        return None
    return {
        "value": str(row["sprint"]).strip(),
        "source": "accuracy_score",
        "recorded_at": str(row["recorded_at"] or ""),
    }


def latest_entry_sprint(conn: sqlite3.Connection):
    if not table_exists(conn, "entries"):
        return None
    row = conn.execute(
        """
        SELECT sprint_id, updated_at, created_at
        FROM entries
        WHERE sprint_id IS NOT NULL AND TRIM(sprint_id) != ''
        ORDER BY updated_at DESC, created_at DESC, id DESC
        LIMIT 1
        """
    ).fetchone()
    if row is None:
        return None
    return {
        "value": str(row["sprint_id"]).strip(),
        "source": "entries",
        "recorded_at": str(row["updated_at"] or row["created_at"] or ""),
    }


SPRINT_PATTERNS = (
    re.compile(r"(?:Sprint|sprint)\s+([.][1-5](?:[ab])?)"),
    re.compile(r"(^|[\s:(-])([.][1-5](?:[ab])?)(?=$|[\s),:-])"),
    re.compile(r"(PLAN-\d+[._-]W-\d+[a-z]?)", re.IGNORECASE),
)


def extract_sprint_token(text: str):
    if not text:
        return None
    for pattern in SPRINT_PATTERNS:
        match = pattern.search(text)
        if not match:
            continue
        value = match.group(2) if pattern.groups >= 2 else match.group(1)
        value = str(value or "").strip()
        if value:
            return value
    return None


def latest_task_run_sprint(conn: sqlite3.Connection):
    if not table_exists(conn, "task_runs"):
        return None
    rows = conn.execute(
        """
        SELECT task_id, task_type, plan_goal, output_log, completed_at, created_at
        FROM task_runs
        WHERE status = 'completed'
        ORDER BY COALESCE(completed_at, created_at) DESC, id DESC
        LIMIT 25
        """
    ).fetchall()
    for row in rows:
        for field in ("plan_goal", "output_log", "task_id", "task_type"):
            value = extract_sprint_token(str(row[field] or ""))
            if value:
                return {
                    "value": value,
                    "source": f"task_runs.{field}",
                    "recorded_at": str(row["completed_at"] or row["created_at"] or ""),
                }
    return None


def resolve_latest_completed_sprint(conn: sqlite3.Connection):
    for resolver in (latest_accuracy_sprint, latest_entry_sprint, latest_task_run_sprint):
        resolved = resolver(conn)
        if resolved:
            return resolved
    return {
        "value": None,
        "source": "helix.db",
        "recorded_at": "",
        "note": "completed sprint not found in helix.db",
    }


def build_review(conn: sqlite3.Connection, latest_sprint: dict):
    checks = []

    drift_count = 0
    if table_exists(conn, "deferred_findings"):
        row = conn.execute(
            """
            SELECT COUNT(*)
            FROM deferred_findings
            WHERE status IN ('open', 'carried')
              AND (
                phase IN ('L2', 'L3', 'G2', 'G3')
                OR LOWER(COALESCE(source, '')) LIKE '%review%'
                OR LOWER(COALESCE(source, '')) LIKE '%design%'
              )
            """
        ).fetchone()
        drift_count = int(row[0] or 0)
    checks.append(
        {
            "name": "design_drift",
            "status": "pass" if drift_count == 0 else "attention",
            "count": drift_count,
            "detail": "open/carried の設計・契約ドリフト系 finding 件数",
        }
    )

    regress_count = 0
    latest_token = str(latest_sprint.get("value") or "").strip()
    if table_exists(conn, "task_runs"):
        rows = conn.execute(
            """
            SELECT task_id, task_type, plan_goal, output_log, status
            FROM task_runs
            ORDER BY COALESCE(completed_at, created_at) DESC, id DESC
            LIMIT 100
            """
        ).fetchall()
        test_words = ("test", "pytest", "bats", "regress", "回帰")
        for row in rows:
            haystack = "\n".join(
                str(row[key] or "") for key in ("task_id", "task_type", "plan_goal", "output_log")
            ).lower()
            if not any(word in haystack for word in test_words):
                continue
            token = extract_sprint_token(
                "\n".join(str(row[key] or "") for key in ("plan_goal", "output_log", "task_id"))
            )
            if latest_token and token and token != latest_token:
                continue
            if str(row["status"] or "").lower() != "completed":
                regress_count += 1
    checks.append(
        {
            "name": "test_regress",
            "status": "pass" if regress_count == 0 else "attention",
            "count": regress_count,
            "detail": "直近 sprint に紐づく失敗 test/regression task_runs 件数",
        }
    )

    broken_links = 0
    if table_exists(conn, "entries") and table_exists(conn, "links"):
        row = conn.execute(
            """
            SELECT COUNT(*)
            FROM links l
            LEFT JOIN entries src ON src.id = l.from_id
            LEFT JOIN entries dst ON dst.id = l.to_id
            WHERE src.id IS NULL OR dst.id IS NULL
            """
        ).fetchone()
        broken_links = int(row[0] or 0)
    checks.append(
        {
            "name": "dependency_consistency",
            "status": "pass" if broken_links == 0 else "attention",
            "count": broken_links,
            "detail": "entries/links 間の孤立リンク件数",
        }
    )

    verdict = "pass" if all(item["status"] == "pass" for item in checks) else "attention"
    return verdict, checks


