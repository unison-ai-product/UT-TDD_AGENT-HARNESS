#!/bin/bash
set -euo pipefail

source "$(cd "$(dirname "$0")" && pwd)/lib/helix-common.sh"

case "${1:-}" in
  --help|-h)
    echo "使い方: helix session-summary"
    echo ""
    echo "セッション終了時に cost_log へ INSERT します。集計は \`helix log report session\` を使ってください。"
    exit 0
    ;;
esac

DB_PATH="${HELIX_TEST_DB_PATH:-${HELIX_DB_PATH:-$DB_PATH}}"

[[ ! -f "$DB_PATH" ]] && exit 0
[[ ! -d "$HELIX_DIR" ]] && exit 0

SESSION_ROLE="${HELIX_SESSION_ROLE:-claude-code}"
SESSION_MODEL="${HELIX_SESSION_MODEL:-${CLAUDE_MODEL:-claude-code}}"
SESSION_THINKING="${HELIX_SESSION_THINKING:-unknown}"

cost_payload="$(python3 - "$SESSION_ROLE" "$SESSION_MODEL" "$SESSION_THINKING" "$(date '+%Y-%m-%d')" "${HELIX_TEST_TIME:-$(date '+%Y-%m-%d %H:%M' | sed 's/^[^ ]* //')}" <<'PY'
import json
import sys

role, model, thinking, today, now_time = sys.argv[1:]
print(json.dumps({
    "role": role,
    "model": model,
    "thinking": thinking,
    "created_at": f"{today}T{now_time}:00",
}, ensure_ascii=False))
PY
)"
HELIX_DB_PATH="$DB_PATH" python3 "$DB_PY" insert cost_log "$cost_payload" >/dev/null 2>&1 || true

exit 0
