#!/usr/bin/env python3
from __future__ import annotations

import argparse
import hashlib
import json
import sqlite3
import sys
from pathlib import Path

SCRIPT_DIR = Path(__file__).resolve().parent
LIB_DIR = SCRIPT_DIR / "lib"
if str(LIB_DIR) not in sys.path:
    sys.path.append(str(LIB_DIR))

from global_store import sync_from_local
from learning_engine import analyze_success, resolve_success_run_ids, save_recipe
from paths import project_root as resolve_project_root


def _project_id(project_root: Path) -> str:
    digest = hashlib.sha1(str(project_root).encode("utf-8")).hexdigest()[:8]
    return f"{project_root.name}-{digest}"


def _parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(
        prog="helix learn",
        description="成功タスクから recipe を生成し global.db へ同期する",
    )
    group = parser.add_mutually_exclusive_group()
    group.add_argument("--task-id", help="task_run_id(数値) または task_id(T001 など)")
    group.add_argument("--all", action="store_true", help="全成功タスクを対象にする")
    return parser.parse_args()


def _load_pattern_keys(recipe_paths: list[str]) -> list[str]:
    pattern_keys: list[str] = []
    seen: set[str] = set()

    for recipe_path in recipe_paths:
        try:
            payload = json.loads(Path(recipe_path).read_text(encoding="utf-8"))
        except Exception:  # noqa: BLE001
            continue
        if not isinstance(payload, dict):
            continue
        pattern_key = str(payload.get("pattern_key") or "").strip()
        if not pattern_key or pattern_key in seen:
            continue
        seen.add(pattern_key)
        pattern_keys.append(pattern_key)

    return pattern_keys


def _count_projects_for_pattern(global_db: str, pattern_key: str) -> int:
    db_path = Path(global_db).expanduser()
    if not db_path.exists():
        return 0

    conn: sqlite3.Connection | None = None
    try:
        conn = sqlite3.connect(str(db_path))
        row = conn.execute(
            "SELECT COUNT(DISTINCT project_id) FROM recipe_index WHERE pattern_key = ?",
            (pattern_key,),
        ).fetchone()
        if not row:
            return 0
        try:
            return int(row[0] or 0)
        except (TypeError, ValueError):
            return 0
    except Exception:  # noqa: BLE001
        return 0
    finally:
        if conn is not None:
            conn.close()


def main() -> int:
    args = _parse_args()
    project_root = resolve_project_root()

    helix_dir = project_root / ".helix"
    db_path = helix_dir / "helix.db"

    if not db_path.exists():
        print(f"エラー: helix.db が見つかりません: {db_path}", file=sys.stderr)
        return 1

    try:
        run_ids = resolve_success_run_ids(
            db_path=str(db_path),
            task_id=args.task_id,
            all_success=bool(args.all),
        )
    except Exception as exc:  # noqa: BLE001
        print(f"エラー: 成功実行の取得に失敗しました: {exc}", file=sys.stderr)
        return 1

    if not run_ids:
        print("成功タスクが見つかりませんでした。")
        return 1

    generated_paths: list[str] = []
    failed: list[str] = []
    skipped_no_actions = 0

    for run_id in run_ids:
        try:
            recipe = analyze_success(task_run_id=run_id, db_path=str(db_path))
            if recipe is None:
                skipped_no_actions += 1
                continue
            output_path = save_recipe(recipe=recipe, project_root=str(project_root))
            generated_paths.append(output_path)
        except Exception as exc:  # noqa: BLE001
            failed.append(f"task_run_id={run_id}: {exc}")

    project_id = _project_id(project_root)
    sync_result = {
        "project_id": project_id,
        "synced_patterns": 0,
        "synced_runs": 0,
        "global_db": "",
    }
    try:
        sync_result = sync_from_local(local_db=str(db_path), project_id=project_id)
    except Exception as exc:  # noqa: BLE001
        print(f"警告: global 同期をスキップしました: {exc}", file=sys.stderr)

    print("=== helix learn ===")
    print(f"対象プロジェクト: {project_root}")
    print(f"recipe 生成数: {len(generated_paths)}")
    print(f"action_logs 欠損でスキップ: {skipped_no_actions}")
    for path in generated_paths:
        print(f"  - {path}")

    print("同期結果:")
    print(f"  - project_id: {sync_result.get('project_id')}")
    print(f"  - synced_patterns: {sync_result.get('synced_patterns')}")
    print(f"  - synced_runs: {sync_result.get('synced_runs')}")
    print(f"  - global_db: {sync_result.get('global_db')}")

    if failed:
        print("\n失敗:", file=sys.stderr)
        for item in failed:
            print(f"  - {item}", file=sys.stderr)
        return 1

    print("")
    print("昇格候補の確認: helix promote --auto")

    global_db = str(sync_result.get("global_db") or "").strip()
    if global_db:
        for pattern_key in _load_pattern_keys(generated_paths):
            similar_count = _count_projects_for_pattern(global_db, pattern_key)
            if similar_count >= 3:
                print(f"[helix-learn] 外部化候補: このパターンは {similar_count} プロジェクトで使用されています")
                print("  helix promote で共通スキル/スクリプトへの昇格を検討してください")
                print(f"  pattern_key: {pattern_key}")

    return 0


if __name__ == "__main__":
    try:
        raise SystemExit(main())
    except Exception as exc:  # noqa: BLE001
        print(f"エラー: helix learn 実行中に予期しないエラーが発生しました: {exc}", file=sys.stderr)
        raise SystemExit(1)
