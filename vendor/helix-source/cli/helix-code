#!/bin/bash
set -euo pipefail

# helix-code: コードインデックス catalog の管理・表示

HELIX_CODE_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$HELIX_CODE_DIR/lib/helix-common.sh"

LIB_DIR="$HELIX_CODE_DIR/lib"
JSONL_PATH="$PROJECT_ROOT/.helix/cache/code-catalog.jsonl"

usage() {
  cat <<'USAGE'
使い方: helix code <subcommand>

Subcommands:
  build                         tracked files を走査して JSONL + DB を同期
  list [--domain NAME] [--json] code_index 一覧を表示
  show <id>                     code_index の詳細を表示
  find <query> [-n 5] [--bucket coverage_eligible|private_helper|excluded|all]
                                query に近い流用候補を推挙
  dup [--threshold 0.85] [--domain NAME] [--include-entrypoints]
                                summary 類似の duplicate 候補を検出
  stats [--by domain|since]     code_index の件数を集計
  stats --uncovered [--scope all|core5] [--fail-under N] [--json]
                                未カバー public symbol を集計
  --help                        このヘルプ
USAGE
}

build_catalog() {
  python3 - "$LIB_DIR" "$PROJECT_ROOT" "$JSONL_PATH" <<'PY'
import sys
from pathlib import Path

lib_dir = Path(sys.argv[1])
repo_root = Path(sys.argv[2])
jsonl_path = Path(sys.argv[3])

sys.path.insert(0, str(lib_dir))
import code_catalog  # type: ignore
import helix_db  # type: ignore

db_path = Path(helix_db.resolve_default_db_path())
result = code_catalog.rebuild_catalog(repo_root, jsonl_path, db_path)
print(f"entry_count: {result.get('entry_count', 0)}")
print(f"jsonl_path: {result.get('jsonl_path', jsonl_path.as_posix())}")
print(f"db_path: {result.get('db_path', db_path.as_posix())}")
PY
}

list_entries() {
  local domain="$1"
  local as_json="$2"

  python3 - "$LIB_DIR" "$domain" "$as_json" <<'PY'
import json
import sqlite3
import sys
from pathlib import Path

lib_dir = Path(sys.argv[1])
domain = sys.argv[2]
as_json = sys.argv[3] == "true"

sys.path.insert(0, str(lib_dir))
import helix_db  # type: ignore

db_path = helix_db.resolve_default_db_path()
helix_db._prepare_db_path(db_path)
conn = helix_db._connect(db_path)
helix_db._ensure_schema(conn)
conn.row_factory = sqlite3.Row
try:
    sql = """
        SELECT id, domain, summary, path, line_no, since, related, source_hash, updated_at
        FROM code_index
    """
    params = []
    if domain:
        sql += " WHERE domain = ?"
        params.append(domain)
    sql += " ORDER BY id"
    rows = [dict(row) for row in conn.execute(sql, params).fetchall()]
finally:
    conn.close()

for row in rows:
    try:
        row["related"] = json.loads(row.get("related") or "[]")
    except Exception:
        row["related"] = []

if as_json:
    print(json.dumps({"entries": rows}, ensure_ascii=False, indent=2))
    raise SystemExit(0)

for row in rows:
    summary = str(row.get("summary") or "")
    if len(summary) > 80:
        summary = summary[:77] + "..."
    print(f"{row.get('id', '')}\t{row.get('domain', '')}\t{row.get('path', '')}:{row.get('line_no', '')}\t{summary}")
PY
}

show_entry() {
  local entry_id="$1"

  python3 - "$LIB_DIR" "$entry_id" <<'PY'
import json
import sqlite3
import sys
from pathlib import Path

lib_dir = Path(sys.argv[1])
entry_id = sys.argv[2]

sys.path.insert(0, str(lib_dir))
import helix_db  # type: ignore

db_path = helix_db.resolve_default_db_path()
helix_db._prepare_db_path(db_path)
conn = helix_db._connect(db_path)
helix_db._ensure_schema(conn)
conn.row_factory = sqlite3.Row
try:
    row = conn.execute(
        """
        SELECT id, domain, summary, path, line_no, since, related, source_hash, updated_at
        FROM code_index
        WHERE id = ?
        """,
        (entry_id,),
    ).fetchone()
finally:
    conn.close()

if row is None:
    print(f"エラー: code index entry が見つかりません: {entry_id}", file=sys.stderr)
    raise SystemExit(2)

data = dict(row)
try:
    related = json.loads(data.get("related") or "[]")
except Exception:
    related = []

source_hash = str(data.get("source_hash") or "")
print(f"id: {data.get('id', '')}")
print(f"domain: {data.get('domain', '')}")
print(f"summary: {data.get('summary', '')}")
print(f"path: {data.get('path', '')}")
print(f"line_no: {data.get('line_no', '')}")
print(f"location: {data.get('path', '')}:{data.get('line_no', '')}")
print(f"since: {data.get('since') or ''}")
print(f"related: {', '.join(str(item) for item in related)}")
print(f"source_hash: {source_hash[:12]}")
print(f"updated_at: {data.get('updated_at') or ''}")
PY
}

find_entries() {
  local query="$1"
  local top_n="$2"
  local bucket="$3"

  python3 - "$LIB_DIR" "$query" "$top_n" "$bucket" <<'PY'
import sys
from pathlib import Path

lib_dir = Path(sys.argv[1])
query = sys.argv[2]
top_n = int(sys.argv[3])
bucket = sys.argv[4]

sys.path.insert(0, str(lib_dir))
import code_recommender  # type: ignore

results = code_recommender.find_code(query, n=top_n, bucket=bucket)
for item in results:
    print(
        f"{item.get('id', '')}  {item.get('domain', '')}  "
        f"{item.get('path', '')}:{item.get('line_no', '')}  "
        f"{float(item.get('score', 0.0)):.2f}  {item.get('reason', '')}"
    )
PY
}

dup_entries() {
  local threshold="$1"
  local domain="$2"
  local include_entrypoints="$3"

  python3 - "$LIB_DIR" "$threshold" "$domain" "$include_entrypoints" <<'PY'
import sys
from pathlib import Path

lib_dir = Path(sys.argv[1])
threshold = float(sys.argv[2])
domain_filter = sys.argv[3]
include_entrypoints = sys.argv[4] == "true"

sys.path.insert(0, str(lib_dir))
import code_recommender  # type: ignore

results = code_recommender.find_duplicates(
    threshold,
    domain=domain_filter,
    include_entrypoints=include_entrypoints,
)
for item in results:
    print(
        f"{item.get('left_id', '')}  {item.get('right_id', '')}  "
        f"{float(item.get('score', 0.0)):.3f}  {item.get('domain', '')}"
    )
PY
}

stats_entries() {
  local group_by="$1"

  python3 - "$LIB_DIR" "$group_by" <<'PY'
import sqlite3
import sys
from pathlib import Path

lib_dir = Path(sys.argv[1])
group_by = sys.argv[2]

sys.path.insert(0, str(lib_dir))
import helix_db  # type: ignore

if group_by not in {"domain", "since"}:
    print(f"エラー: --by は domain または since を指定してください: {group_by}", file=sys.stderr)
    raise SystemExit(64)

db_path = helix_db.resolve_default_db_path()
helix_db._prepare_db_path(db_path)
conn = helix_db._connect(db_path)
helix_db._ensure_schema(conn)
conn.row_factory = sqlite3.Row
try:
    if group_by == "domain":
        rows = conn.execute(
            """
            SELECT domain AS key, COUNT(*) AS count
            FROM code_index
            GROUP BY domain
            ORDER BY domain
            """
        ).fetchall()
    else:
        rows = conn.execute(
            """
            SELECT COALESCE(NULLIF(since, ''), 'unknown') AS key, COUNT(*) AS count
            FROM code_index
            GROUP BY COALESCE(NULLIF(since, ''), 'unknown')
            ORDER BY key
            """
        ).fetchall()
finally:
    conn.close()

for row in rows:
    print(f"{row['key']}\t{row['count']}")
PY
}

stats_uncovered() {
  python3 - "$LIB_DIR" "$PROJECT_ROOT" "$@" <<'PY'
import argparse
import json
import sys
from pathlib import Path

lib_dir = Path(sys.argv[1])
repo_root = Path(sys.argv[2])
argv = sys.argv[3:]

sys.path.insert(0, str(lib_dir))
import code_catalog  # type: ignore


class HelixArgumentParser(argparse.ArgumentParser):
    def error(self, message: str) -> None:
        self.print_usage(sys.stderr)
        self.exit(64, f"{self.prog}: error: {message}\n")


def fail_under(value: str) -> int:
    try:
        parsed = int(value)
    except ValueError as exc:
        raise argparse.ArgumentTypeError("--fail-under は整数で指定してください") from exc
    if parsed < 0 or parsed > 100:
        raise argparse.ArgumentTypeError("--fail-under は 0..100 の範囲で指定してください")
    return parsed


parser = HelixArgumentParser(prog="helix code stats --uncovered")
parser.add_argument("--uncovered", action="store_true", required=True)
parser.add_argument("--scope", choices=["core5", "cli-lib", "all"], default="all")
parser.add_argument("--bucket", choices=["coverage_eligible", "private_helper", "excluded", "all"], default="coverage_eligible")
parser.add_argument("--seed-candidate", choices=["true", "false", "all"], default="all")
parser.add_argument("--seed-promotable", choices=["true", "false", "all"], default="all")
parser.add_argument("--fail-under", type=fail_under, default=0)
parser.add_argument("--json", action="store_true")
args = parser.parse_args(argv)

payload = code_catalog.compute_coverage_report(
    repo_root,
    scope=args.scope,
    bucket=args.bucket,
    seed_candidate=args.seed_candidate,
    seed_promotable=args.seed_promotable,
)
summary = payload["summary"]

if args.json:
    print(json.dumps(payload, ensure_ascii=False, sort_keys=False))
else:
    for item in payload["items"]:
        print(
            f"{item['path']}\t{item['line_no']}\t{item['symbol']}\t{item['kind']}\t"
            f"{item['bucket']}\t{str(item['seed_candidate']).lower()}\t"
            f"{str(item['seed_promotable']).lower()}"
        )
    bucket_counts = summary["bucket_counts"]
    print(
        f"summary: covered={summary['covered']} eligible={summary['eligible']} "
        f"coverage={float(summary['coverage_pct']):.1f}%"
    )
    print(
        "summary: "
        f"bucket=coverage_eligible:{bucket_counts['coverage_eligible']},"
        f"private_helper:{bucket_counts['private_helper']},"
        f"excluded:{bucket_counts['excluded']} "
        f"seed_candidate={summary['seed_candidate_count']} "
        f"seed_promotable={summary['seed_promotable_count']}"
    )

covered = int(summary.get("covered", 0))
eligible = int(summary.get("eligible", 0))
if eligible:
    coverage = (covered / eligible) * 100
else:
    coverage = 100.0

if args.fail_under is not None and coverage < args.fail_under:
    raise SystemExit(1)
raise SystemExit(0)
PY
}

main() {
  local cmd="${1:---help}"
  shift || true

  case "$cmd" in
    --help|-h|help)
      usage
      return 0
      ;;
    build)
      build_catalog
      return $?
      ;;
    list)
      local domain=""
      local as_json="false"
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --domain)
            [[ $# -ge 2 ]] || { echo "エラー: --domain には値が必要です" >&2; return 64; }
            domain="$2"
            shift 2
            ;;
          --json)
            as_json="true"
            shift
            ;;
          --help|-h)
            cat <<'USAGE'
使い方: helix code list [--domain NAME] [--json]
USAGE
            return 0
            ;;
          *)
            echo "エラー: 不明なオプションです: $1" >&2
            return 64
            ;;
        esac
      done
      list_entries "$domain" "$as_json"
      return $?
      ;;
    show)
      [[ $# -ge 1 ]] || { echo "エラー: show には id が必要です" >&2; return 64; }
      show_entry "$1"
      return $?
      ;;
    find)
      local top_n="5"
      local bucket="coverage_eligible"
      local query_parts=()
      while [[ $# -gt 0 ]]; do
        case "$1" in
          -n|--top-n)
            [[ $# -ge 2 ]] || { echo "エラー: -n には値が必要です" >&2; return 64; }
            top_n="$2"
            shift 2
            ;;
          --bucket)
            [[ $# -ge 2 ]] || { echo "エラー: --bucket には値が必要です" >&2; return 64; }
            case "$2" in
              coverage_eligible|private_helper|excluded|all) bucket="$2" ;;
              *) echo "エラー: --bucket は coverage_eligible/private_helper/excluded/all のいずれかです: $2" >&2; return 64 ;;
            esac
            shift 2
            ;;
          --help|-h)
            cat <<'USAGE'
使い方: helix code find <query> [-n 5] [--bucket coverage_eligible|private_helper|excluded|all]
USAGE
            return 0
            ;;
          -*)
            echo "エラー: 不明なオプションです: $1" >&2
            return 64
            ;;
          *)
            query_parts+=("$1")
            shift
            ;;
        esac
      done
      [[ "${#query_parts[@]}" -gt 0 ]] || { echo "エラー: find には query が必要です" >&2; return 64; }
      find_entries "${query_parts[*]}" "$top_n" "$bucket"
      return $?
      ;;
    dup)
      local threshold="0.85"
      local domain=""
      local include_entrypoints="false"
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --threshold)
            [[ $# -ge 2 ]] || { echo "エラー: --threshold には値が必要です" >&2; return 64; }
            threshold="$2"
            shift 2
            ;;
          --domain)
            [[ $# -ge 2 ]] || { echo "エラー: --domain には値が必要です" >&2; return 64; }
            domain="$2"
            shift 2
            ;;
          --include-entrypoints)
            include_entrypoints="true"
            shift
            ;;
          --help|-h)
            cat <<'USAGE'
使い方: helix code dup [--threshold 0.85] [--domain NAME] [--include-entrypoints]
USAGE
            return 0
            ;;
          *)
            echo "エラー: 不明なオプションです: $1" >&2
            return 64
            ;;
        esac
      done
      dup_entries "$threshold" "$domain" "$include_entrypoints"
      return $?
      ;;
    stats)
      for arg in "$@"; do
        if [[ "$arg" == "--uncovered" ]]; then
          stats_uncovered "$@"
          return $?
        fi
      done
      local group_by="domain"
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --by)
            [[ $# -ge 2 ]] || { echo "エラー: --by には値が必要です" >&2; return 64; }
            group_by="$2"
            shift 2
            ;;
          --help|-h)
            cat <<'USAGE'
使い方: helix code stats [--by domain|since]
       helix code stats --uncovered [--scope all|core5] [--fail-under N] [--json]
USAGE
            return 0
            ;;
          *)
            echo "エラー: 不明なオプションです: $1" >&2
            return 64
            ;;
        esac
      done
      stats_entries "$group_by"
      return 0
      ;;
    *)
      echo "エラー: 不明なサブコマンドです: $cmd" >&2
      usage >&2
      return 64
      ;;
  esac
}

main "$@"
