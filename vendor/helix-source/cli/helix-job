#!/bin/bash
set -euo pipefail

# shellcheck source=cli/lib/helix-common.sh
source "$(cd "$(dirname "$0")" && pwd)/lib/helix-common.sh"

usage() {
  cat <<'USAGE'
使い方: helix job <subcommand> [args...]

サブコマンド:
  enqueue   ジョブを登録
  pop       次のジョブを取得（P0 guard 付き）
  worker    ジョブ worker を起動（既定で stale running を復旧）
  status    ジョブ状態を表示
  cancel    ジョブをキャンセル
  retry     失敗ジョブを再試行
  requeue-stale  stale running ジョブを再投入
  list      ジョブ一覧を表示
USAGE
}

CMD="${1:-help}"
shift 2>/dev/null || true

case "$CMD" in
  pop)
    exec python3 "$SCRIPT_DIR/lib/job_p0_guard.py" \
      --db-path "$DB_PATH" \
      pop "$@"
    ;;
  worker)
    exec python3 "$SCRIPT_DIR/lib/job_p0_guard.py" \
      --db-path "$DB_PATH" \
      worker "$@"
    ;;
  enqueue|status|cancel|retry|requeue-stale|list)
    exec python3 "$SCRIPT_DIR/lib/job_queue_helper.py" \
      --db-path "$DB_PATH" \
      "$CMD" "$@"
    ;;
  help|-h|--help)
    usage
    ;;
  *)
    echo "エラー: 不明な job subcommand: $CMD" >&2
    usage >&2
    exit 1
    ;;
esac
