#!/bin/bash
set -euo pipefail

# helix-claude: Claude Code 向け plan/task 管理 harness
# v1 は API/SDK を使わず、Claude Code CLI/契約プラン利用を前提に prompt を生成する。

source "$(cd "$(dirname "$0")" && pwd)/lib/helix-common.sh"

ROLES_DIR="$SCRIPT_DIR/roles"
ROLE=""
TASK=""
TASK_FILE=""
PLAN_ID=""
HANDOVER=false
OUTPUT_PATH=""
DRY_RUN=false
EXECUTE=false
MODEL_ALIAS=""
ALLOW_PATHS=""
TIMEOUT_SECONDS=300
REQUIRE_APPROVAL=false
THINKING_OVERRIDE=""

usage() {
  cat <<'USAGE'
使い方: helix claude --role <role> (--task "..." | --task-file <path>) [options]

Claude Code 用のローカル委譲 prompt を生成します。API/SDK は使用しません。
既定は --dry-run 相当の prompt 生成です。--execute は PMO role のみ Claude CLI を実行します。

Options:
  --role <role>       ロール（tl/se/pg/fe/qa/security/dba/devops/docs/research/legacy/perf）
  --model <name>      PMO モデル alias（sonnet/haiku）
  --task "..."        タスク内容
  --task-file <path>  タスク内容をファイルから読む
  --plan-id <id>      HELIX plan id を明示
  --handover          .helix/handover/CURRENT.md があれば参照指示を含める
  --output <path>     生成 prompt を保存（プロジェクト配下のみ）
  --dry-run           実行せず prompt を表示
  --execute           PMO prompt を claude CLI で実行
  --allow-paths <glob> Haiku docs 編集モードの path whitelist
  --timeout <seconds> execute timeout（default: 300）
  --require-approval  人間承認が必要な作業であることを prompt に固定
  --thinking <level>  thinking hint（未指定時は role conf）

Examples:
  helix claude --role pg --task "UI修正" --plan-id PLAN-001 --dry-run
  helix claude --role docs --task-file .helix/tasks/T001.md --output .helix/tasks/T001.claude.md
  helix claude --role pmo --model sonnet --task "ping" --execute
  helix claude --role pmo --model haiku --task "docs確認" --execute --allow-paths "docs/**"
USAGE
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --role) ROLE="${2:-}"; shift 2 ;;
    --model) MODEL_ALIAS="${2:-}"; shift 2 ;;
    --task) TASK="${2:-}"; shift 2 ;;
    --task-file) TASK_FILE="${2:-}"; shift 2 ;;
    --plan-id) PLAN_ID="${2:-}"; shift 2 ;;
    --handover) HANDOVER=true; shift ;;
    --output) OUTPUT_PATH="${2:-}"; shift 2 ;;
    --dry-run) DRY_RUN=true; shift ;;
    --execute) EXECUTE=true; shift ;;
    --allow-paths) ALLOW_PATHS="${2:-}"; shift 2 ;;
    --timeout) TIMEOUT_SECONDS="${2:-}"; shift 2 ;;
    --require-approval) REQUIRE_APPROVAL=true; shift ;;
    --thinking) THINKING_OVERRIDE="${2:-}"; shift 2 ;;
    --help|-h) usage; exit 0 ;;
    *) echo "エラー: 不明なオプションです: $1" >&2; exit "$EXIT_INPUT_ERROR" ;;
  esac
done

if [[ -z "$ROLE" ]]; then
  echo "エラー: --role は必須です" >&2
  exit "$EXIT_INPUT_ERROR"
fi
if [[ ! "$ROLE" =~ ^[a-z0-9_-]+$ ]]; then
  echo "エラー: 無効な --role 値です: $ROLE" >&2
  exit "$EXIT_INPUT_ERROR"
fi
if [[ -n "$TASK" && -n "$TASK_FILE" ]]; then
  echo "エラー: --task と --task-file は同時指定できません" >&2
  exit "$EXIT_INPUT_ERROR"
fi
if [[ -z "$TASK" && -z "$TASK_FILE" ]]; then
  echo "エラー: --task または --task-file が必要です" >&2
  exit "$EXIT_INPUT_ERROR"
fi
if [[ "$DRY_RUN" == true && "$EXECUTE" == true ]]; then
  echo "エラー: --dry-run と --execute は同時指定できません" >&2
  exit "$EXIT_INPUT_ERROR"
fi
if [[ ! "$TIMEOUT_SECONDS" =~ ^[0-9]+$ || "$TIMEOUT_SECONDS" -lt 1 ]]; then
  echo "エラー: --timeout は 1 以上の整数で指定してください" >&2
  exit "$EXIT_INPUT_ERROR"
fi
if [[ -n "$MODEL_ALIAS" && ! "$MODEL_ALIAS" =~ ^[a-z0-9_-]+$ ]]; then
  echo "エラー: 無効な --model 値です: $MODEL_ALIAS" >&2
  exit "$EXIT_INPUT_ERROR"
fi
if [[ -n "$ALLOW_PATHS" && "$ROLE" != "pmo" ]]; then
  echo "エラー: --allow-paths は --role pmo でのみ使用できます" >&2
  exit "$EXIT_INPUT_ERROR"
fi
if [[ "$EXECUTE" == true && "$ROLE" != "pmo" && "$ROLE" != "impl-sonnet" && "$ROLE" != "pm-advisor" && "$ROLE" != "tl-advisor" ]]; then
  echo "エラー: --execute は --role pmo / impl-sonnet / pm-advisor / tl-advisor でのみ使用できます" >&2
  exit "$EXIT_INPUT_ERROR"
fi
if [[ "$ROLE" == "pmo" ]]; then
  MODEL_ALIAS="${MODEL_ALIAS:-sonnet}"
  if [[ "$MODEL_ALIAS" != "sonnet" && "$MODEL_ALIAS" != "haiku" ]]; then
    echo "エラー: PMO の --model は sonnet または haiku のみ指定できます: $MODEL_ALIAS" >&2
    exit "$EXIT_INPUT_ERROR"
  fi
elif [[ -n "$MODEL_ALIAS" ]]; then
  echo "エラー: --model は --role pmo でのみ使用できます" >&2
  exit "$EXIT_INPUT_ERROR"
fi

PROJECT_ROOT_REAL="$(realpath "$PROJECT_ROOT")"
HELIX_HOME_REAL="$(realpath "$HELIX_HOME")"
HOME_HELIX_REAL="$(realpath -m "$HOME/.helix")"
ROLES_DIR_REAL="$(realpath "$ROLES_DIR")"

ROLE_FILE_REAL="$(realpath -m "$ROLES_DIR/$ROLE.conf")"
ROLE_CONF_NAME="$ROLE"
if [[ "$ROLE" == "pmo" ]]; then
  ROLE_CONF_NAME="pmo-$MODEL_ALIAS"
  ROLE_FILE_REAL="$(realpath -m "$ROLES_DIR/$ROLE_CONF_NAME.conf")"
fi
ensure_within_dir "$ROLE_FILE_REAL" "$ROLES_DIR_REAL" "role file"
if [[ ! -f "$ROLE_FILE_REAL" ]]; then
  echo "エラー: ロールが見つかりません: $ROLE_CONF_NAME" >&2
  exit "$EXIT_INPUT_ERROR"
fi

if [[ -n "$TASK_FILE" ]]; then
  TASK_FILE_REAL="$(realpath "$TASK_FILE" 2>/dev/null || true)"
  if [[ -z "$TASK_FILE_REAL" || ! -f "$TASK_FILE_REAL" ]]; then
    echo "エラー: --task-file が見つかりません: $TASK_FILE" >&2
    exit "$EXIT_INPUT_ERROR"
  fi
  ensure_within_any_dir "$TASK_FILE_REAL" "task file" "$PROJECT_ROOT_REAL" "$HELIX_HOME_REAL" "$HOME_HELIX_REAL"
  TASK="$(cat "$TASK_FILE_REAL")"
fi

parse_array() {
  local key="$1"
  local file="$2"
  local in_array=false
  while IFS= read -r line; do
    if [[ "$line" == "${key}=(" ]]; then
      in_array=true
      continue
    fi
    if [[ "$in_array" == true ]]; then
      if [[ "$line" == ")" ]]; then
        break
      fi
      echo "$line" | sed 's/^[[:space:]]*//' | sed 's/[[:space:]]*$//'
    fi
  done < "$file"
}

conf_value() {
  local key="$1"
  local file="$2"
  local value
  value="$(grep -E "^${key}=" "$file" | head -n 1 | sed -E "s/^${key}=//" || true)"
  value="${value%\"}"
  value="${value#\"}"
  printf "%s" "$value"
}

system_prompt=$(grep '^system_prompt=' "$ROLE_FILE_REAL" | sed 's/^system_prompt="//' | sed 's/"$//' || true)
skills_list=$(parse_array "skills" "$ROLE_FILE_REAL" | sed '/^$/d' || true)
common_docs=$(parse_array "common_docs" "$ROLE_FILE_REAL" | sed '/^$/d' || true)
claude_model_id="$(conf_value "claude_model" "$ROLE_FILE_REAL")"
claude_thinking="$(conf_value "claude_thinking" "$ROLE_FILE_REAL")"
claude_permission_mode="$(conf_value "claude_permission_mode" "$ROLE_FILE_REAL")"
claude_disallowed_tools="$(conf_value "claude_disallowed_tools" "$ROLE_FILE_REAL")"
claude_allow_paths="$(conf_value "claude_allow_paths" "$ROLE_FILE_REAL")"
thinking_value="${THINKING_OVERRIDE:-$claude_thinking}"

if [[ -z "$PLAN_ID" && -f "$HELIX_DIR/phase.yaml" ]]; then
  PLAN_ID="$(python3 "$YAML_PARSER" read "$HELIX_DIR/phase.yaml" plan_id 2>/dev/null || true)"
  [[ "$PLAN_ID" == "null" ]] && PLAN_ID=""
fi

handover_note=""
if [[ "$HANDOVER" == true ]]; then
  if [[ -f "$HELIX_DIR/handover/CURRENT.md" ]]; then
    handover_note="- $HELIX_DIR/handover/CURRENT.md を Read し、Next Action と矛盾しないこと。"
  else
    handover_note="- handover 指定あり。ただし .helix/handover/CURRENT.md は存在しないため通常タスクとして扱うこと。"
  fi
fi

record_invocation_telemetry() {
  local exit_code="$1"
  local db_path="${HELIX_DIR}/helix.db"
  local parent_invocation_id=""
  local decision="failed"
  local payload=""

  if [[ $exit_code -eq 0 ]]; then
    decision="passed"
  fi

  if [[ "${HELIX_PARENT_INVOCATION_ID:-}" =~ ^[0-9]+$ ]]; then
    parent_invocation_id="${HELIX_PARENT_INVOCATION_ID}"
  fi

  payload="$(
    HELIX_INVOCATION_TYPE="claude" \
    HELIX_INVOCATION_ROLE="$ROLE" \
    HELIX_INVOCATION_MODEL="$claude_model_id" \
    HELIX_INVOCATION_TASK_ID="$ROLE_CONF_NAME" \
    HELIX_INVOCATION_PLAN_ID="${PLAN_ID:-}" \
    HELIX_INVOCATION_DECISION="$decision" \
    HELIX_INVOCATION_PARENT_ID="$parent_invocation_id" \
    HELIX_INVOCATION_PERMISSION_MODE="${permission_mode:-}" \
    HELIX_INVOCATION_ALLOW_PATHS="${ALLOW_PATHS:-}" \
    HELIX_INVOCATION_EXECUTE="${EXECUTE}" \
    HELIX_INVOCATION_HANDOVER="${HANDOVER}" \
    python3 - <<'PY'
import json
import os


def _bool_env(name):
    return os.environ.get(name, "").lower() == "true"


payload = {
    "type": os.environ["HELIX_INVOCATION_TYPE"],
    "role": os.environ.get("HELIX_INVOCATION_ROLE") or None,
    "model": os.environ.get("HELIX_INVOCATION_MODEL") or None,
    "task_id": os.environ.get("HELIX_INVOCATION_TASK_ID") or None,
    "plan_id": os.environ.get("HELIX_INVOCATION_PLAN_ID") or None,
    "decision": os.environ.get("HELIX_INVOCATION_DECISION") or None,
    "parent_invocation_id": int(os.environ["HELIX_INVOCATION_PARENT_ID"])
    if os.environ.get("HELIX_INVOCATION_PARENT_ID", "").isdigit()
    else None,
}
payload["raw_meta"] = {
    "role": payload["role"],
    "role_conf": os.environ.get("HELIX_INVOCATION_TASK_ID") or None,
    "model": payload["model"],
    "plan_id": payload["plan_id"],
    "decision": payload["decision"],
    "permission_mode": os.environ.get("HELIX_INVOCATION_PERMISSION_MODE") or None,
    "allow_paths": os.environ.get("HELIX_INVOCATION_ALLOW_PATHS") or None,
    "execute": _bool_env("HELIX_INVOCATION_EXECUTE"),
    "handover": _bool_env("HELIX_INVOCATION_HANDOVER"),
}
print(json.dumps(payload, ensure_ascii=False))
PY
  )" || return 0

  python3 "$SCRIPT_DIR/lib/helix_db.py" record-invocation "$db_path" "$payload" >/dev/null 2>&1 || true
}

if [[ "$ROLE" == "impl-sonnet" ]]; then
  if [[ -z "$claude_model_id" ]]; then
    echo "エラー: $ROLE_CONF_NAME.conf に claude_model がありません" >&2
    exit "$EXIT_INPUT_ERROR"
  fi
  permission_mode="${claude_permission_mode:-acceptEdits}"
  disallowed_tools=""
fi

if [[ "$ROLE" == "pm-advisor" || "$ROLE" == "tl-advisor" ]]; then
  if [[ -z "$claude_model_id" ]]; then
    echo "エラー: $ROLE_CONF_NAME.conf に claude_model がありません" >&2
    exit "$EXIT_INPUT_ERROR"
  fi
  permission_mode="${claude_permission_mode:-plan}"
  disallowed_tools="${claude_disallowed_tools:-Edit,Write,NotebookEdit}"
fi

if [[ "$ROLE" == "pmo" ]]; then
  if [[ -z "$claude_model_id" ]]; then
    echo "エラー: $ROLE_CONF_NAME.conf に claude_model がありません" >&2
    exit "$EXIT_INPUT_ERROR"
  fi
  if [[ -n "$ALLOW_PATHS" && "$MODEL_ALIAS" != "haiku" ]]; then
    echo "エラー: --allow-paths は PMO Haiku のみ指定できます" >&2
    exit "$EXIT_INPUT_ERROR"
  fi

  if [[ -n "$ALLOW_PATHS" ]]; then
    permission_mode="${claude_permission_mode:-acceptEdits}"
    disallowed_tools=""
  else
    permission_mode="plan"
    disallowed_tools="${claude_disallowed_tools:-Edit,Write,NotebookEdit}"
  fi

  prompt_template="$SCRIPT_DIR/templates/prompts/pmo-base.md"
  if [[ ! -f "$prompt_template" ]]; then
    echo "エラー: PMO prompt template が見つかりません: $prompt_template" >&2
    exit "$EXIT_INTERNAL_ERROR"
  fi

  PROMPT=$(
    HELIX_PMO_TEMPLATE="$prompt_template" \
    HELIX_TASK="$TASK" \
    HELIX_ROLE="$ROLE_CONF_NAME" \
    HELIX_ALLOW_PATHS="${ALLOW_PATHS:-none}" \
    HELIX_THINKING="${thinking_value:-none}" \
    HELIX_REQUIRE_APPROVAL="$REQUIRE_APPROVAL" \
    python3 - <<'PY'
import os
from pathlib import Path

template = Path(os.environ["HELIX_PMO_TEMPLATE"]).read_text(encoding="utf-8")
allow_paths = os.environ.get("HELIX_ALLOW_PATHS", "none")
rendered = (
    template.replace("{{TASK}}", os.environ.get("HELIX_TASK", ""))
    .replace("{{ROLE}}", os.environ.get("HELIX_ROLE", ""))
    .replace("{{ALLOW_PATHS}}", allow_paths)
    .replace("{{THINKING}}", os.environ.get("HELIX_THINKING", "none"))
)
if os.environ.get("HELIX_REQUIRE_APPROVAL") == "true":
    rendered += "\n\n## 人間承認\n\nこのタスクは --require-approval 指定です。判断が必要な変更は実行せず、承認待ちとして報告してください。\n"
print(rendered.rstrip())
PY
  )
else
  PROMPT=$(
  HELIX_ROLE="$ROLE" \
  HELIX_PLAN_ID="${PLAN_ID:-none}" \
  HELIX_SYSTEM_PROMPT="$system_prompt" \
  HELIX_SKILLS="$skills_list" \
  HELIX_DOCS="$common_docs" \
  HELIX_HANDOVER_NOTE="$handover_note" \
  HELIX_TASK="$TASK" \
  python3 - <<'PY'
import os

print("# HELIX Claude Code Delegation")
print()
print("この prompt は HELIX が Claude Code の契約プラン/CLI 利用を管理するためのローカル harness です。API/SDK 呼び出しは前提にしません。")
print()
print("## Role")
print(f"- role: {os.environ.get('HELIX_ROLE', '')}")
print(f"- plan_id: {os.environ.get('HELIX_PLAN_ID', 'none')}")
system_prompt = os.environ.get("HELIX_SYSTEM_PROMPT", "").strip()
if system_prompt:
    print(f"- system_prompt: {system_prompt}")
print()
print("## Required Context")
docs = [line for line in os.environ.get("HELIX_DOCS", "").splitlines() if line.strip()]
skills = [line for line in os.environ.get("HELIX_SKILLS", "").splitlines() if line.strip()]
for doc in docs:
    print(f"- common_doc: {doc}")
for skill in skills:
    print(f"- skill: {skill}")
handover = os.environ.get("HELIX_HANDOVER_NOTE", "").strip()
if handover:
    print(handover)
print()
print("## Operating Rules")
print("- HELIX の plan/task/handover を正本として扱う。")
print("- Claude Code hooks と CLAUDE.md の運用に従う。")
print("- 認証、PII、ライセンス、本番影響、破壊的 DB 操作は人間確認なしに確定しない。")
print("- 完了時は変更ファイル、検証結果、残リスクを返す。")
print()
print("## TASK_INPUT")
print("---TASK_INPUT_START---")
print(os.environ.get("HELIX_TASK", ""))
print("---TASK_INPUT_END---")
PY
  )
fi

if [[ -n "$OUTPUT_PATH" ]]; then
  OUTPUT_REAL="$(realpath -m "$OUTPUT_PATH")"
  ensure_within_dir "$OUTPUT_REAL" "$PROJECT_ROOT_REAL" "output"
  mkdir -p "$(dirname "$OUTPUT_REAL")"
  printf "%s\n" "$PROMPT" > "$OUTPUT_REAL"
  echo "[helix-claude] prompt written: ${OUTPUT_REAL#$PROJECT_ROOT_REAL/}"
fi

if [[ "$EXECUTE" == true ]]; then
  log_dir="$PROJECT_ROOT_REAL/.helix/cache/pmo"
  mkdir -p "$log_dir"
  task_sha="$(printf "%s" "$TASK" | sha256sum | cut -c1-8)"
  log_file="$log_dir/$(date +%Y%m%dT%H%M%S)-$task_sha.log"

  cmd=(timeout "$TIMEOUT_SECONDS" "$SCRIPT_DIR/claude" --print --model "$claude_model_id" --permission-mode "$permission_mode" --disallowedTools "$disallowed_tools" -p "$PROMPT")
  if [[ -n "${HELIX_PARENT_INVOCATION_ID:-}" ]]; then
    cmd=(env "HELIX_PARENT_INVOCATION_ID=${HELIX_PARENT_INVOCATION_ID}" "${cmd[@]}")
  fi

  set +e
  HELIX_CLAUDE_INTERNAL=1 "${cmd[@]}" > "$log_file" 2>&1
  status=$?
  set -e

  record_invocation_telemetry "$status"
  echo "[helix-claude] execute log: ${log_file#$PROJECT_ROOT_REAL/}"
  exit "$status"
fi

if [[ "$DRY_RUN" == true || -z "$OUTPUT_PATH" ]]; then
  echo "=== helix-claude dry-run ==="
  echo "Role:    $ROLE_CONF_NAME"
  echo "Plan:    ${PLAN_ID:-none}"
  echo "Output:  ${OUTPUT_PATH:-stdout}"
  if [[ "$ROLE" == "pmo" ]]; then
    echo "Model:   $claude_model_id"
    echo "Mode:    ${permission_mode:-plan}"
  fi
  echo "Prompt:  $(printf "%s" "$PROMPT" | wc -c) bytes"
  echo "=== Full prompt ==="
  echo "$PROMPT"
fi

record_invocation_telemetry 0
