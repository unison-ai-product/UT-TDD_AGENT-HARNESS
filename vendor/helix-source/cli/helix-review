#!/bin/bash
set -euo pipefail

# helix-review: Codex 自動レビュー
# Usage: helix review [--uncommitted] [--bg]
# Sprint .2/.5 完了時に自動発火、または手動で実行

source "$(cd "$(dirname "$0")" && pwd)/lib/helix-common.sh"

case "${1:-}" in
  --help|-h)
    echo "使い方: helix review [--uncommitted] [--bg]"
    echo ""
    echo "Options:"
    echo "  --uncommitted  git diff（未コミット変更）をレビュー"
    echo "  --bg           バックグラウンド実行（Sprint 連動用）"
    exit 0
    ;;
esac

if [[ -n "${HELIX_CODEX_INTERNAL:-}" ]]; then
  echo '[helix-review] skipped: nested review unsupported in read-only sandbox' >&2
  exit 0
fi

UNCOMMITTED=false
BACKGROUND=false

while [[ $# -gt 0 ]]; do
  case $1 in
    --uncommitted) UNCOMMITTED=true; shift ;;
    --bg)          BACKGROUND=true; shift ;;
    *) echo "エラー: 不明なオプションです: $1" >&2; exit 1 ;;
  esac
done

CODEX_BIN="${CODEX_BIN:-$(command -v codex 2>/dev/null || echo "")}"
if [[ -z "$CODEX_BIN" || ! -x "$CODEX_BIN" ]]; then
  echo "エラー: codex が見つかりません" >&2
  exit 1
fi

LOG_DIR="${TMPDIR:-/tmp}/helix-review"
mkdir -p "$LOG_DIR"
LOG_FILE="$LOG_DIR/review-$(date +%Y%m%d-%H%M%S).log"

run_review() {
  echo "[helix-review] レビュー開始..." >&2
  local exit_code=0
  if [[ "$UNCOMMITTED" == true ]]; then
    "$CODEX_BIN" review --uncommitted 2>&1 | tee "$LOG_FILE" || exit_code=$?
  else
    "$CODEX_BIN" review 2>&1 | tee "$LOG_FILE" || exit_code=$?
  fi

  # DB 記録
  if [[ -f "$DB_PATH" ]]; then
    local result="pass"
    [[ $exit_code -ne 0 ]] && result="fail"
    HELIX_DB_PATH="$DB_PATH" python3 "$DB_PY" insert hook_events \
      "{\"event_type\":\"codex_review\",\"file\":\"uncommitted\",\"result\":\"$result\"}" 2>/dev/null || true
  fi

  if [[ $exit_code -ne 0 ]]; then
    echo "[helix-review] FAIL: レビューを手動で再実行してください: helix review --uncommitted" >&2
  fi

  echo "[helix-review] 完了 (exit=$exit_code) → $LOG_FILE" >&2
  return $exit_code
}

if [[ "$BACKGROUND" == true ]]; then
  # バックグラウンド実行（Sprint 連動用）
  nohup bash -c "
    export CODEX_BIN='$CODEX_BIN'
    export DB_PATH='$DB_PATH'
    export DB_PY='$DB_PY'
    export UNCOMMITTED='$UNCOMMITTED'
    LOG_FILE='$LOG_FILE'

    echo '[helix-review] レビュー開始...' >&2
    exit_code=0
    if [[ \"\$UNCOMMITTED\" == true ]]; then
      \"\$CODEX_BIN\" review --uncommitted > \"\$LOG_FILE\" 2>&1 || exit_code=\$?
    else
      \"\$CODEX_BIN\" review > \"\$LOG_FILE\" 2>&1 || exit_code=\$?
    fi

    if [[ -f \"\$DB_PATH\" ]]; then
      result='pass'
      [[ \$exit_code -ne 0 ]] && result='fail'
      HELIX_DB_PATH=\"\$DB_PATH\" python3 \"\$DB_PY\" insert hook_events \
        \"{\\\"event_type\\\":\\\"codex_review\\\",\\\"file\\\":\\\"uncommitted\\\",\\\"result\\\":\\\"\$result\\\"}\" 2>/dev/null || true
    fi

    if [[ \$exit_code -ne 0 ]]; then
      echo '[helix-review] FAIL: レビューを手動で再実行してください: helix review --uncommitted' >&2
    fi
    echo \"[helix-review] 完了 (exit=\$exit_code) → \$LOG_FILE\" >&2
  " > /dev/null 2>&1 &

  echo "[helix-review] バックグラウンドで起動 (PID=$!)"
  echo "[helix-review] ログ: $LOG_FILE"
else
  run_review
fi
