#!/bin/bash
set -euo pipefail
# helix-doctor: 環境チェック
# Usage: helix doctor [check_recovery_plan_freshness] [--fix] [--cleanup-stale-locks] [--max-age-days N]

source "$(cd "$(dirname "$0")" && pwd)/lib/helix-common.sh"
PROJECT_NAME="$(basename "$PROJECT_ROOT")"
FIX=false
CLEANUP_STALE_LOCKS=false
SUBCOMMAND=""
MAX_AGE_DAYS=30

if [[ $# -gt 0 && "$1" != -* ]]; then
  case "$1" in
    check_recovery_plan_freshness)
      SUBCOMMAND="$1"
      shift
      ;;
    *)
      echo "エラー: 不明なサブコマンド: $1" >&2
      echo "使い方: helix doctor [check_recovery_plan_freshness] [--fix] [--cleanup-stale-locks] [--max-age-days N]" >&2
      exit 2
      ;;
  esac
fi

while [[ $# -gt 0 ]]; do
  case "$1" in
    --fix) FIX=true ;;
    --cleanup-stale-locks) CLEANUP_STALE_LOCKS=true ;;
    --max-age-days)
      shift
      if [[ $# -eq 0 || ! "$1" =~ ^[0-9]+$ ]]; then
        echo "エラー: --max-age-days には 0 以上の整数が必要です" >&2
        exit 2
      fi
      MAX_AGE_DAYS="$1"
      ;;
    --help|-h)
      echo "使い方: helix doctor [check_recovery_plan_freshness] [--fix] [--cleanup-stale-locks] [--max-age-days N]"
      echo ""
      echo "環境と .helix/ の整合性をチェックします。"
      echo "--cleanup-stale-locks を付けると dead PID の lockfile を削除します。"
      echo "check_recovery_plan_freshness は docs/plans/PLAN-*-recovery-*.md を走査し、鮮度警告を表示します。"
      exit 0
      ;;
    *)
      echo "エラー: 不明なオプション: $1" >&2
      echo "使い方: helix doctor [check_recovery_plan_freshness] [--fix] [--cleanup-stale-locks] [--max-age-days N]" >&2
      exit 2
      ;;
  esac
  shift
done

echo "=== HELIX Doctor ==="
PASS=0
FAIL=0
WARN=0
PACKAGE_MANAGER=""

detect_package_manager() {
  if [[ "$(uname -s)" == "Darwin" ]]; then
    echo "brew"
    return
  fi

  if [[ -r /etc/os-release ]]; then
    local os_id
    os_id="$(grep -E '^ID=' /etc/os-release | head -n1 | cut -d= -f2 | tr -d '"')"
    case "$os_id" in
      debian|ubuntu)
        echo "apt"
        return
        ;;
      arch|manjaro)
        echo "pacman"
        return
        ;;
    esac
  fi

  echo "unknown"
}

can_auto_fix_with_apt() {
  [[ "$PACKAGE_MANAGER" == "apt" ]] || return 1
  command -v sudo >/dev/null 2>&1 || return 1
  sudo -n true >/dev/null 2>&1
}

install_hint_for() {
  local dep="$1"
  local apt_pkg=""
  local pacman_pkg=""
  local brew_pkg=""

  case "$dep" in
    sqlite3)
      apt_pkg="sqlite3"
      pacman_pkg="sqlite"
      brew_pkg="sqlite"
      ;;
    rg)
      apt_pkg="ripgrep"
      pacman_pkg="ripgrep"
      brew_pkg="ripgrep"
      ;;
    *)
      return 0
      ;;
  esac

  case "$PACKAGE_MANAGER" in
    apt)
      printf '%s\n' "      → インストール: sudo apt install $apt_pkg"
      ;;
    pacman)
      printf '%s\n' "      → インストール: sudo pacman -S --needed $pacman_pkg"
      ;;
    brew)
      printf '%s\n' "      → インストール: brew install $brew_pkg"
      ;;
    *)
      printf '%s\n' \
        "      → インストール候補: sudo apt install $apt_pkg      (Debian/Ubuntu)" \
        "                        sudo pacman -S --needed $pacman_pkg  (Arch/Manjaro)" \
        "                        brew install $brew_pkg             (macOS)"
      ;;
  esac
}

check() {
  local name="$1"
  local cmd="$2"
  local fix_cmd="${3:-}"
  if bash -c "$cmd" >/dev/null 2>&1; then
    echo "  ✓ $name"
    PASS=$((PASS + 1))
  else
    if [[ -n "$fix_cmd" && "$FIX" == true ]]; then
      if bash -c "$fix_cmd" >/dev/null 2>&1; then
        echo "  ✓ $name（自動修正）"
        PASS=$((PASS + 1))
        return
      fi
    fi
    echo "  ✗ $name"
    FAIL=$((FAIL + 1))
  fi
}

warn() {
  local name="$1"
  local cmd="$2"
  local hint="${3:-}"
  local fix_cmd="${4:-}"
  if bash -c "$cmd" >/dev/null 2>&1; then
    echo "  ✓ $name"
    PASS=$((PASS + 1))
  else
    if [[ -n "$fix_cmd" && "$FIX" == true ]]; then
      if bash -c "$fix_cmd" >/dev/null 2>&1; then
        echo "  ✓ $name（自動修正）"
        PASS=$((PASS + 1))
        return
      fi
    fi
    echo "  △ $name（推奨）"
    if [[ -n "$hint" ]]; then
      while IFS= read -r line; do
        [[ -z "$line" ]] && continue
        echo "$line"
      done <<< "$hint"
    fi
    WARN=$((WARN + 1))
  fi
}

extract_template_version() {
  local file="$1"
  local version=""
  if [[ -f "$file" ]]; then
    version="$(grep -E -m1 'helix_template_version:[[:space:]]*[0-9]+' "$file" | sed -E 's/.*helix_template_version:[[:space:]]*([0-9]+).*/\1/' || true)"
  fi
  if [[ -n "$version" ]]; then
    echo "$version"
  else
    echo "0"
  fi
}

check_template_version() {
  local project_file="$1"
  local template_file="$2"
  local label="$3"
  local project_version template_version
  project_version="$(extract_template_version "$project_file")"
  template_version="$(extract_template_version "$template_file")"

  if [[ "$project_version" == "$template_version" ]]; then
    echo "  ✓ $label テンプレート版数 (v$project_version)"
    PASS=$((PASS + 1))
  else
    echo "  WARN: $label (v$project_version) が古い → テンプレート (v$template_version)。helix init --force で更新可"
    WARN=$((WARN + 1))
  fi
}

get_conf_value() {
  local conf_path="$1"
  local key="$2"
  local value
  value="$(sed -n "s/^${key}=//p" "$conf_path" | head -n1)"
  value="${value%\"}"
  value="${value#\"}"
  value="${value%\'}"
  value="${value#\'}"
  printf '%s' "$value"
}

check_role_config_consistency() {
  local roles_file="${HELIX_HOME}/cli/config/models.yaml"
  local roles_dir="${HELIX_HOME}/cli/roles"
  local runtime_yaml_parser
  local codex_mismatch=0
  local pmo_mismatch=0
  local conf_path
  local role
  local conf_value
  local yaml_value

  runtime_yaml_parser="$(cd "$(dirname "$0")" && pwd)/lib/yaml_parser.py"

  check_pmo_mirror() {
    local conf_path="$1"
    local conf_key="$2"
    local yaml_key="$3"
    local label="$4"
    local conf_value
    local yaml_value

    conf_value="$(get_conf_value "$conf_path" "$conf_key")"
    yaml_value="$(python3 "$runtime_yaml_parser" read "$roles_file" "$yaml_key" 2>/dev/null || true)"
    if [[ "$conf_value" != "$yaml_value" ]]; then
      echo "WARNING: pmo role $(basename "$conf_path" .conf): ${label} conf=${conf_value:-missing}, yaml=${yaml_value:-missing} (mismatch)"
      pmo_mismatch=$((pmo_mismatch + 1))
    fi
  }

  if [[ ! -f "$roles_file" || ! -d "$roles_dir" ]]; then
    echo "  ✗ role config consistency (required files missing)"
    FAIL=$((FAIL + 1))
    return
  fi

  for conf_path in "$roles_dir"/*.conf; do
    role="$(basename "$conf_path" .conf)"

    if [[ "$role" == pmo-* ]]; then
      conf_value="$(get_conf_value "$conf_path" "claude_model")"
      yaml_value="$(python3 "$runtime_yaml_parser" read "$roles_file" "roles.$role" 2>/dev/null || true)"
      if [[ "$conf_value" != "$yaml_value" ]]; then
        echo "WARNING: pmo role $role: claude_model conf=${conf_value:-missing}, yaml=${yaml_value:-missing} (mismatch)"
        pmo_mismatch=$((pmo_mismatch + 1))
      fi

      conf_value="$(get_conf_value "$conf_path" "claude_thinking")"
      yaml_value="$(python3 "$runtime_yaml_parser" read "$roles_file" "role_metadata.$role.thinking" 2>/dev/null || true)"
      if [[ "$conf_value" != "$yaml_value" ]]; then
        echo "WARNING: pmo role $role: claude_thinking conf=${conf_value:-missing}, yaml=${yaml_value:-missing} (mismatch)"
        pmo_mismatch=$((pmo_mismatch + 1))
      fi

      conf_value="$(get_conf_value "$conf_path" "claude_permission_mode")"
      yaml_value="$(python3 "$runtime_yaml_parser" read "$roles_file" "role_metadata.$role.permission_mode" 2>/dev/null || true)"
      if [[ -n "$conf_value" && "$conf_value" != "$yaml_value" ]]; then
        echo "WARNING: pmo role $role: claude_permission_mode conf=${conf_value:-missing}, yaml=${yaml_value:-missing} (mismatch)"
        pmo_mismatch=$((pmo_mismatch + 1))
      fi

      conf_value="$(get_conf_value "$conf_path" "claude_disallowed_tools")"
      yaml_value="$(python3 "$runtime_yaml_parser" read "$roles_file" "role_metadata.$role.disallowed_tools" 2>/dev/null || true)"
      if [[ -n "$conf_value" && "$conf_value" != "$yaml_value" ]]; then
        echo "WARNING: pmo role $role: claude_disallowed_tools conf=${conf_value:-missing}, yaml=${yaml_value:-missing} (mismatch)"
        pmo_mismatch=$((pmo_mismatch + 1))
      fi

      if [[ "$(get_conf_value "$conf_path" "codex_thinking")" != "" || "$(python3 "$runtime_yaml_parser" read "$roles_file" "role_metadata.$role.codex_thinking" 2>/dev/null || true)" != "" ]]; then
        check_pmo_mirror "$conf_path" "codex_thinking" "role_metadata.$role.codex_thinking" "codex_thinking"
      fi
      if [[ "$(get_conf_value "$conf_path" "codex_permission_mode")" != "" ]]; then
        check_pmo_mirror "$conf_path" "codex_permission_mode" "role_metadata.$role.codex_permission_mode" "codex_permission_mode"
      fi
      if [[ "$(get_conf_value "$conf_path" "codex_disallowed_tools")" != "" ]]; then
        check_pmo_mirror "$conf_path" "codex_disallowed_tools" "role_metadata.$role.codex_disallowed_tools" "codex_disallowed_tools"
      fi

      if [[ "$role" == "pmo-haiku" ]]; then
        conf_value="$(get_conf_value "$conf_path" "claude_allow_paths")"
        yaml_value="$(python3 "$runtime_yaml_parser" read "$roles_file" "role_metadata.$role.allow_paths" 2>/dev/null || true)"
        if [[ -n "$conf_value" && "$conf_value" != "$yaml_value" ]]; then
          echo "WARNING: pmo role $role: claude_allow_paths conf=${conf_value:-missing}, yaml=${yaml_value:-missing} (mismatch)"
          pmo_mismatch=$((pmo_mismatch + 1))
        fi

        if [[ "$(get_conf_value "$conf_path" "codex_allow_paths")" != "" ]]; then
          check_pmo_mirror "$conf_path" "codex_allow_paths" "role_metadata.$role.codex_allow_paths" "codex_allow_paths"
        fi
      fi

      continue
    fi

    conf_value="$(get_conf_value "$conf_path" "codex_model")"
    yaml_value="$(python3 "$runtime_yaml_parser" read "$roles_file" "roles.$role" 2>/dev/null || true)"

    if [[ -z "$conf_value" || -z "$yaml_value" ]]; then
      echo "WARNING: role $role: conf=${conf_value:-missing}, yaml=${yaml_value:-missing} (mismatch)"
      codex_mismatch=$((codex_mismatch + 1))
      continue
    fi

    if [[ "$conf_value" != "$yaml_value" ]]; then
      echo "WARNING: role $role: conf=$conf_value, yaml=$yaml_value (mismatch)"
      codex_mismatch=$((codex_mismatch + 1))
    fi
  done

  if [[ $codex_mismatch -eq 0 ]]; then
    echo "  ✓ role config consistency"
    PASS=$((PASS + 1))
  else
    echo "  △ role config consistency"
    WARN=$((WARN + 1))
  fi

  if [[ $pmo_mismatch -eq 0 ]]; then
    echo "  ✓ pmo role consistency"
    PASS=$((PASS + 1))
  else
    echo "  △ pmo role consistency"
    WARN=$((WARN + 1))
  fi
}

check_role_effort_consistency() {
  local roles_dir="$PROJECT_ROOT/cli/roles"
  local effort_drift_count=0
  local role_confs=()
  local role_conf
  local role_name
  local conf_effort

  shopt -s nullglob
  role_confs=("$roles_dir"/*.conf)
  shopt -u nullglob

  for role_conf in "${role_confs[@]}"; do
    role_name="$(basename "$role_conf" .conf)"
    conf_effort="$(grep '^codex_thinking=' "$role_conf" 2>/dev/null | cut -d= -f2 || true)"
    if [[ -n "$conf_effort" ]]; then
      if grep -qE "${role_name}.*${conf_effort}|${conf_effort}.*${role_name}" \
        "$PROJECT_ROOT/skills/SKILL_MAP.md" \
        "$PROJECT_ROOT/cli/ROLE_MAP.md" 2>/dev/null; then
        :
      else
        effort_drift_count=$((effort_drift_count + 1))
      fi
    fi
  done

  if [[ $effort_drift_count -gt 0 ]]; then
    echo "    △ role effort drift: $effort_drift_count 件"
    echo "      role conf vs CLAUDE.md / SKILL_MAP / ROLE_MAP の effort 表記乖離あり"
    WARN=$((WARN + 1))
  else
    echo "    ✓ role effort 整合性"
    PASS=$((PASS + 1))
  fi
}

check_mode_phase_consistency() {
  local phase_yaml="$PROJECT_ROOT/.helix/phase.yaml"
  if [[ ! -f "$phase_yaml" ]]; then
    return 0
  fi

  local current_mode current_phase
  current_mode=$(grep -E '^current_mode:' "$phase_yaml" | sed 's/^current_mode: *//' | tr -d "\"'" | tr -d ' ')
  current_phase=$(grep -E '^current_phase:' "$phase_yaml" | sed 's/^current_phase: *//' | tr -d "\"'" | tr -d ' ')
  if [[ -z "$current_mode" || -z "$current_phase" ]]; then
    return 0
  fi

  case "$current_mode" in
    forward)
      if ! [[ "$current_phase" =~ ^L([1-9]|1[01])$ ]]; then
        echo "  ⚠ phase_mode_consistency: mode=forward だが phase=$current_phase (L1-L11 期待)"
        WARN=$((WARN + 1))
      else
        echo "  ✓ phase_mode_consistency: forward + $current_phase"
      fi
      ;;
    reverse)
      if ! [[ "$current_phase" =~ ^(R[0-4]|RGC)$ ]]; then
        echo "  ⚠ phase_mode_consistency: mode=reverse だが phase=$current_phase (R0-R4/RGC 期待)"
        WARN=$((WARN + 1))
      else
        echo "  ✓ phase_mode_consistency: reverse + $current_phase"
      fi
      ;;
    scrum)
      if ! [[ "$current_phase" =~ ^S[0-4]$ ]]; then
        echo "  ⚠ phase_mode_consistency: mode=scrum だが phase=$current_phase (S0-S4 期待)"
        WARN=$((WARN + 1))
      else
        echo "  ✓ phase_mode_consistency: scrum + $current_phase"
      fi
      ;;
    *)
      echo "  ⚠ phase_mode_consistency: 未知 mode=$current_mode"
      WARN=$((WARN + 1))
      ;;
  esac
}

extract_declared_count() {
  local file="$1"
  local pattern="$2"
  python3 - <<'PY' "$file" "$pattern"
import re
import sys
from pathlib import Path

text = Path(sys.argv[1]).read_text(encoding="utf-8")
match = re.search(sys.argv[2], text)
if not match:
    raise SystemExit(1)
print(match.group(1))
PY
}

check_drift_count() {
  local name="$1"
  local measured="$2"
  local declared="$3"
  if [[ -n "$declared" && "$measured" == "$declared" ]]; then
    echo "  ✓ $name"
    PASS=$((PASS + 1))
    return
  fi

  echo "  △ $name"
  echo "    実測 ${measured:-unknown} / 文書記述 ${declared:-unknown}、SKILL_MAP.md / ROLE_MAP.md を更新してください"
  WARN=$((WARN + 1))
}

check_document_drift() {
  local skill_map="$PROJECT_ROOT/skills/SKILL_MAP.md"
  local role_map="$PROJECT_ROOT/cli/ROLE_MAP.md"

  # USER PROJECT (not HELIX home): skip count drift checks
  if [[ ! -f "$skill_map" ]]; then
    echo "  — drift check: スキップ (HELIX ホーム以外のプロジェクト)"
    return
  fi

  local skills_count agents_count roles_count
  local declared_skills="" declared_agents="" declared_roles=""

  skills_count="$(find "$PROJECT_ROOT/skills" -name SKILL.md | wc -l | tr -d '[:space:]')"

  if [[ -d "$PROJECT_ROOT/.claude/agents" ]]; then
    agents_count="$(find "$PROJECT_ROOT/.claude/agents" -maxdepth 1 -type f -name '*.md' | wc -l | tr -d '[:space:]')"
  else
    agents_count="0"
  fi

  if [[ -d "$PROJECT_ROOT/cli/roles" ]]; then
    roles_count="$(find "$PROJECT_ROOT/cli/roles" -maxdepth 1 -type f -name '*.conf' | wc -l | tr -d '[:space:]')"
  else
    roles_count="0"
  fi

  declared_skills="$(extract_declared_count "$skill_map" 'スキル群配置（([0-9]+)スキル）' 2>/dev/null || true)"
  declared_agents="$(extract_declared_count "$skill_map" '\.claude/agents/ は ([0-9]+) エージェント構成' 2>/dev/null || true)"
  declared_roles="$(extract_declared_count "$role_map" 'ロール一覧 \(([0-9]+)\)' 2>/dev/null || true)"

  check_drift_count "skills count drift" "$skills_count" "$declared_skills"
  check_drift_count ".claude/agents count drift" "$agents_count" "$declared_agents"
  check_drift_count "cli/roles count drift" "$roles_count" "$declared_roles"
}

check_vmodel_4artifact() {
  if [[ ! -f "$HELIX_HOME/cli/lib/vmodel_lint.py" ]]; then
    return 0
  fi

  local output=""
  local status=0
  local incomplete="0"

  if output="$(python3 "$HELIX_HOME/cli/lib/vmodel_lint.py" 2>&1)"; then
    status=0
  else
    status=$?
  fi

  incomplete="$(printf '%s\n' "$output" | grep -c '^\[⚠\]' || true)"

  if [[ $status -ne 0 ]]; then
    echo "  △ vmodel_4artifact_lint: execution failed (status=$status)"
    printf '%s\n' "$output" | head -20 | sed 's/^/    /'
    WARN=$((WARN + 1))
    return
  fi

  if [[ "$incomplete" -gt 0 ]]; then
    echo "  △ vmodel_4artifact_lint: $incomplete incomplete PLAN (V-model 4 artifact 不完全、PLAN-075 強化)"
    printf '%s\n' "$output" | grep '^\[⚠\]' | head -10 | sed 's/^/    /'
    WARN=$((WARN + incomplete))
    return
  fi

  echo "  ✓ vmodel_4artifact_lint"
  PASS=$((PASS + 1))
}

check_design_doc_reference_sections() {
  local output=""
  local status=0
  local empty_count="0"

  if output="$(python3 - "$PROJECT_ROOT" <<'PY' 2>&1
import json
import re
import sys
from pathlib import Path

project_root = Path(sys.argv[1])
targets = []
for directory, pattern in (("docs/plans", "PLAN-*.md"), ("docs/adr", "ADR-*.md")):
    base = project_root / directory
    if base.is_dir():
        targets.extend(sorted(base.glob(pattern)))

section_re = re.compile(r"^##\s+(?:\d+\.\s+)?業界 standard 参照(?:\b|\s*\()", re.MULTILINE)
next_section_re = re.compile(r"^##\s+", re.MULTILINE)
header_re = re.compile(r"^\|\s*参照\s*\|")
separator_re = re.compile(r"^\|\s*:?[- ]+:?\s*\|")
url_re = re.compile(r"https?://")
results = []

for path in targets:
    text = path.read_text(encoding="utf-8")
    match = section_re.search(text)
    if not match:
        continue
    next_match = next_section_re.search(text, match.end())
    end = next_match.start() if next_match else len(text)
    section = text[match.end():end]
    rows = 0
    for raw_line in section.splitlines():
        line = raw_line.strip()
        if not line.startswith("|"):
            continue
        if header_re.match(line) or separator_re.match(line):
            continue
        cells = [cell.strip() for cell in line.strip("|").split("|")]
        if len(cells) < 3:
            continue
        if all(not cell or (cell.startswith("<") and cell.endswith(">")) for cell in cells[:3]):
            continue
        rows += 1
    if rows == 0:
        for raw_line in section.splitlines():
            line = raw_line.strip()
            if not line.startswith(("-", "*")):
                continue
            if url_re.search(line):
                rows += 1
    if rows == 0:
        results.append(str(path.relative_to(project_root)))

print(json.dumps({"empty_count": len(results), "paths": results}, ensure_ascii=False))
PY
)"; then
    status=0
  else
    status=$?
  fi

  empty_count="$(printf '%s\n' "$output" | python3 -c 'import sys, json; print(json.load(sys.stdin).get("empty_count", 0))' 2>/dev/null || echo "0")"

  if [[ $status -ne 0 ]]; then
    echo "  △ design_doc_reference_sections: execution failed (status=$status)"
    printf '%s\n' "$output" | head -20 | sed 's/^/    /'
    WARN=$((WARN + 1))
    return
  fi

  if [[ "$empty_count" -gt 0 ]]; then
    echo "  △ design_doc_reference_sections: $empty_count docs with empty '業界 standard 参照' section (advisory、PLAN-087)"
    printf '%s\n' "$output" | python3 -c 'import sys, json; [print(path) for path in json.load(sys.stdin).get("paths", [])[:10]]' 2>/dev/null | sed 's/^/    /'
    WARN=$((WARN + empty_count))
    return
  fi

  echo "  ✓ design_doc_reference_sections"
  PASS=$((PASS + 1))
}

check_subagent_phase() {
  if [[ ! -f "$HELIX_HOME/cli/lib/agent_mandatory.py" ]]; then
    return 0
  fi
  local cur_phase=""
  if [[ -f "$HELIX_DIR/phase.yaml" ]]; then
    cur_phase="$(python3 -c "
import sys
try:
    import yaml
    with open('$HELIX_DIR/phase.yaml') as f:
        d = yaml.safe_load(f) or {}
    print(d.get('current_phase', '') or '')
except Exception:
    print('')
" 2>/dev/null || echo "")"
  fi
  if [[ -z "$cur_phase" ]]; then
    return 0
  fi

  local audit_json missing
  audit_json="$(PYTHONPATH="$HELIX_HOME" python3 -c "
import json
from cli.lib import agent_mandatory
print(json.dumps(agent_mandatory.audit_phase('$cur_phase')))
" 2>/dev/null || echo '{}')"
  missing="$(printf '%s' "$audit_json" | python3 -c 'import sys, json; print(json.load(sys.stdin).get("missing_count", 0))' 2>/dev/null || echo "0")"
  if [[ "$missing" -gt 0 ]]; then
    echo "  △ check_subagent_phase: $missing mandatory subagent 不在 (current_phase=$cur_phase, PLAN-082 PLAN-076 機械化)"
    WARN=$((WARN + 1))
    return
  fi
  echo "  ✓ check_subagent_phase (current_phase=$cur_phase)"
  PASS=$((PASS + 1))
}

check_sprint_completion() {
  if [[ ! -f "$HELIX_HOME/cli/lib/sprint_lint.py" ]]; then
    return 0
  fi
  local audit_json overall idle_context
  audit_json="$(PYTHONPATH="$HELIX_HOME" python3 -c "
