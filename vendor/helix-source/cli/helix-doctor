run_recovery_freshness_subcommand() {
  local report_json
  if ! report_json="$(run_doctor_recovery_helper 2>&1)"; then
    echo "[recovery freshness]"
    echo "  ✗ recovery plan freshness"
    printf '%s\n' "$report_json" | head -5 | sed 's/^/    /'
    return 2
  fi

  echo "[recovery freshness]"
  eval "$(python3 - <<'PY' "$report_json"
import json
import shlex
import sys

rows = json.loads(sys.argv[1])
warn_rows = [row for row in rows if row.get("status") == "warning"]
preview = [
    f"{row.get('plan_id', '-')}: {row.get('path', '-')}"
    f" ({row.get('age_days', '?')}d > {row.get('max_age_days', '?')}d)"
    for row in warn_rows[:10]
]
print(f"TOTAL_COUNT={len(rows)}")
print(f"WARN_COUNT={len(warn_rows)}")
print(f"PREVIEW={shlex.quote(chr(10).join(preview))}")
PY
)"

  if [[ "$WARN_COUNT" == "0" ]]; then
    echo "  ✓ recovery plan freshness"
    echo "    checked: $TOTAL_COUNT"
    return 0
  fi

  echo "  △ recovery plan freshness"
  echo "    warnings: $WARN_COUNT / checked: $TOTAL_COUNT"
  if [[ -n "${PREVIEW:-}" ]]; then
    while IFS= read -r line; do
      [[ -z "$line" ]] && continue
      echo "    $line"
    done <<< "$PREVIEW"
  fi
  return 1
}

run_doctor_plan_helper() {
  local helper_name="$1"
  HELIX_SCRIPT_LIB="$SCRIPT_DIR/lib" HELIX_DOCTOR_HELPER="$helper_name" HELIX_DB_PATH_VALUE="$DB_PATH" python3 - <<'PY'
import json
import os
import sqlite3
import sys

sys.path.insert(0, os.environ["HELIX_SCRIPT_LIB"])
import doctor_plan_checks

conn = sqlite3.connect(os.environ["HELIX_DB_PATH_VALUE"])
conn.row_factory = sqlite3.Row
try:
    rows = getattr(doctor_plan_checks, os.environ["HELIX_DOCTOR_HELPER"])(conn)
    print(json.dumps(rows, ensure_ascii=False))
