  local runtime_lib_dir
  runtime_lib_dir="$(cd "$(dirname "$0")" && pwd)/lib"
  HELIX_SCRIPT_LIB="$runtime_lib_dir" HELIX_MAX_AGE_DAYS="$MAX_AGE_DAYS" PYTHONPATH="$HELIX_HOME" python3 - <<'PY'
import json
import os
import sys

sys.path.insert(0, os.environ["HELIX_SCRIPT_LIB"])
import doctor_recovery_check

rows = doctor_recovery_check.run_check_recovery_freshness(
    max_age_days=int(os.environ["HELIX_MAX_AGE_DAYS"])
)
