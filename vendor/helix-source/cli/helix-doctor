collect_stale_lock_report() {
  local runtime_lib_dir
  runtime_lib_dir="$(cd "$(dirname "$0")" && pwd)/lib"
  python3 - <<'PY' "$runtime_lib_dir" "$CLEANUP_STALE_LOCKS"
import json
import sys
from pathlib import Path

runtime_lib_dir = Path(sys.argv[1])
cleanup = sys.argv[2] == "true"
sys.path.insert(0, str(runtime_lib_dir))

import concurrent_lock

if cleanup:
    report = concurrent_lock.cleanup_stale()
else:
    report = concurrent_lock.inspect_stale_locks()

print(json.dumps(report))
PY
}

check_stale_locks() {
  local report_json
  report_json="$(collect_stale_lock_report)"

  eval "$(python3 - <<'PY' "$report_json"
import json
import shlex
import sys

report = json.loads(sys.argv[1])
for key in ("stale", "cleaned", "alive_skipped", "errors"):
    values = report.get(key, [])
    print(f"{key.upper()}_COUNT={len(values)}")
    print(f"{key.upper()}_VALUES={shlex.quote(', '.join(values))}")
PY
)"

  if [[ "$CLEANUP_STALE_LOCKS" == true ]]; then
    if [[ $ERRORS_COUNT -gt 0 ]]; then
      echo "  △ stale lock cleanup"
      echo "    cleaned: ${CLEANED_VALUES:-none}"
      echo "    alive skipped: ${ALIVE_SKIPPED_VALUES:-none}"
      echo "    errors: $ERRORS_VALUES"
      WARN=$((WARN + 1))
      return
    fi

    if [[ $CLEANED_COUNT -eq 0 && $ALIVE_SKIPPED_COUNT -eq 0 ]]; then
      echo "  ✓ stale lock cleanup (対象なし)"
      PASS=$((PASS + 1))
      return
    fi

    if [[ $ALIVE_SKIPPED_COUNT -eq 0 ]]; then
      echo "  ✓ stale lock cleanup"
      echo "    cleaned: ${CLEANED_VALUES:-none}"
      PASS=$((PASS + 1))
      return
    fi

    echo "  △ stale lock cleanup"
    echo "    cleaned: ${CLEANED_VALUES:-none}"
    echo "    alive skipped: ${ALIVE_SKIPPED_VALUES:-none}"
    WARN=$((WARN + 1))
    return
  fi

  if [[ $ERRORS_COUNT -gt 0 ]]; then
    echo "  △ stale lock check"
    echo "    errors: $ERRORS_VALUES"
    WARN=$((WARN + 1))
    return
  fi

  if [[ $STALE_COUNT -eq 0 && $ALIVE_SKIPPED_COUNT -eq 0 ]]; then
    echo "  ✓ stale lock check"
    PASS=$((PASS + 1))
    return
  fi

  echo "  △ stale lock check"
  echo "    dead: ${STALE_VALUES:-none}"
  echo "    alive skipped: ${ALIVE_SKIPPED_VALUES:-none}"
  WARN=$((WARN + 1))
}

