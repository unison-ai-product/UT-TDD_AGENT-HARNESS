    conn.close()
PY
}

summarize_doctor_plan_rows() {
  local report_json="$1"
  python3 - <<'PY' "$report_json"
import json
import sys

rows = json.loads(sys.argv[1])
warn_rows = [row for row in rows if row.get("status") in {"warning", "error"}]

def summarize(row):
    plan_id = row.get("plan_id") or "-"
    if row.get("artifact_path"):
        return f"{plan_id}:{row['artifact_path']} ({row.get('reason', '-')})"
    if row.get("cycle"):
        return f"{plan_id}:{' -> '.join(row['cycle'])}"
    if row.get("missing_tables"):
        return f"missing tables: {', '.join(row['missing_tables'])}"
    return f"{plan_id} ({row.get('reason', '-')})"

preview = "; ".join(summarize(row) for row in warn_rows[:3])
print(len(rows))
print(len(warn_rows))
print(preview)
PY
}

check_plan_advisory() {
  local label="$1"
  local helper_name="$2"
  local report_json
  local summary
  local total_count
  local warn_count
  local preview

  if ! report_json="$(run_doctor_plan_helper "$helper_name" 2>&1)"; then
    echo "  △ $label"
    printf '%s\n' "$report_json" | head -5 | sed 's/^/    /'
    WARN=$((WARN + 1))
    return
  fi

  summary="$(summarize_doctor_plan_rows "$report_json")"
  total_count="$(printf '%s\n' "$summary" | sed -n '1p')"
  warn_count="$(printf '%s\n' "$summary" | sed -n '2p')"
  preview="$(printf '%s\n' "$summary" | sed -n '3p')"

  if [[ "$warn_count" == "0" ]]; then
    echo "  ✓ $label"
    PASS=$((PASS + 1))
    return
  fi

  echo "  △ $label"
  echo "    warnings: $warn_count / rows: $total_count"
  if [[ -n "$preview" ]]; then
    echo "    $preview"
  fi
  WARN=$((WARN + warn_count))
}

