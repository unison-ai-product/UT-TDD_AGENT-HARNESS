#!/bin/bash
set -euo pipefail
# helix-session-start: SessionStart hook
# セットアップ未完了 → README 強制熟読モード
# セットアップ完了   → 通常の HELIX コンテキスト注入

source "$(cd "$(dirname "$0")/.." && pwd)/lib/helix-common.sh"

SESSION_START_INPUT_FILE="$(mktemp)"
trap 'rm -f "$SESSION_START_INPUT_FILE"' EXIT
cat >"$SESSION_START_INPUT_FILE" || true

LOCK_FD=9
if command -v flock >/dev/null 2>&1; then
lock_hash="$(printf '%s' "$PROJECT_ROOT" | { md5sum 2>/dev/null || shasum 2>/dev/null || cksum; } | cut -c1-16)"
exec 9>"${TMPDIR:-/tmp}/helix-session-start.${USER:-unknown}.${lock_hash}.lock" 2>/dev/null || { exec 9>/dev/null; }
flock -n $LOCK_FD 2>/dev/null || { echo "[session-start] 別プロセスが実行中 — skip" >&2; exit 0; }

fi

git_status_suffix=""
if git rev-parse --is-inside-work-tree >/dev/null 2>/dev/null; then
  branch="$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo "HEAD")"
  if upstream="$(git rev-parse --abbrev-ref "@{u}" 2>/dev/null)"; then
    ahead="$(git rev-list --count "@{u}..HEAD" 2>/dev/null || echo "0")"
    behind="$(git rev-list --count "HEAD..@{u}" 2>/dev/null || echo "0")"
    if [[ "$ahead" -gt 0 ]]; then
      git_status_line="[Git] ${branch}: ${ahead} commits ahead of ${upstream} (push 未実施)"
    elif [[ "$behind" -eq 0 ]]; then
      git_status_line="[Git] ${branch}: up to date with ${upstream}"
    else
      git_status_line="[Git] ${branch}: ${behind} commits behind ${upstream}"
    fi
  else
    git_status_line="[Git] ${branch}: upstream 未設定"
  fi

  git_status_line_escaped="${git_status_line//\\/\\\\}"
  git_status_line_escaped="${git_status_line_escaped//\"/\\\"}"
  git_status_suffix="\\n\\n${git_status_line_escaped}"
fi

case "${1:-}" in
  --help|-h)
    echo "使い方: helix session-start [オプション]"
    echo ""
    echo "SessionStart フック用コンテキストを出力します。"
    exit 0
    ;;
esac

# --- セットアップ完了チェック ---
setup_ok=true

# 1. CLAUDE.md に @import があるか
if [[ -f "$HOME/.claude/CLAUDE.md" ]]; then
  grep -qF "@~/ai-dev-kit-vscode/skills/SKILL_MAP.md" "$HOME/.claude/CLAUDE.md" || setup_ok=false
else
  setup_ok=false
fi

# 2. user or project settings.json に HELIX hooks があるか
settings_hook_found=false
for settings_file in "$HOME/.claude/settings.json" "$PROJECT_ROOT/.claude/settings.json"; do
  if [[ -f "$settings_file" ]] && grep -q "helix-session-start" "$settings_file"; then
    settings_hook_found=true
    break
  fi
done
if [[ "$settings_hook_found" == false ]]; then
  setup_ok=false
fi

# 3. PATH に cli/ が通っているか（.bashrc or .zshrc）
path_found=false
for rcfile in "$HOME/.bashrc" "$HOME/.zshrc"; do
  if [[ -f "$rcfile" ]] && grep -qF "ai-dev-kit-vscode/cli" "$rcfile"; then
    path_found=true
    break
  fi
done
if [[ "$path_found" == false ]]; then
  setup_ok=false
fi

# --- 未完了: README 強制熟読モード ---
if [[ "$setup_ok" == false ]]; then
  setup_needed_output="$(cat <<'SETUP_NEEDED'
{
  "hookSpecificOutput": {
    "hookEventName": "SessionStart",
    "additionalContext": "## HELIX セットアップ未完了 — 自動セットアップを実行せよ\n\n**あなた（Claude Code）が以下を即座に実行すること。ユーザーに案内するのではなく、自分で実行する。**\n\n### Step 1: README を読んで HELIX フレームワークを理解する\n```bash\ncat ~/ai-dev-kit-vscode/README.md\n```\n\n### Step 2: セットアップスクリプトを実行する\n```bash\nbash ~/ai-dev-kit-vscode/setup.sh\n```\n\n### 制約\n- **セットアップ完了までユーザーの他のリクエストに着手してはならない**\n- setup.sh が [FAIL] を出したらユーザーに報告して対処を相談する\n- 全て [OK] / [SKIP] なら「HELIX セットアップ完了」と報告してから通常業務に入る\n\nこの指示はセットアップ完了後のセッションでは表示されなくなる。__GIT_STATUS_SUFFIX__"
  }
}
SETUP_NEEDED
)"
  setup_needed_output="${setup_needed_output//__GIT_STATUS_SUFFIX__/${git_status_suffix}}"
  printf '%s\n' "$setup_needed_output"
  exit 0
fi

# 進捗サマリを生成する。失敗しても SessionStart hook は止めない。
helix_progress=""
helix_progress_escaped=""

# PLAN-023 W-2b: session_id 生成 + HELIX_SESSION_ID export + helix.db sessions INSERT
HELIX_SESSION_ID=""
if [[ "${HELIX_DISABLE_SESSIONS:-0}" != "1" ]]; then
  HELIX_SESSION_ID="$(python3 -c "import uuid; print(uuid.uuid4())" 2>/dev/null || echo "")"
  if [[ -n "$HELIX_SESSION_ID" ]]; then
    export HELIX_SESSION_ID
    HELIX_SESSION_INPUT_PATH="$SESSION_START_INPUT_FILE" \
    python3 - <<'PY' || true
import json
import os
import sqlite3
import sys
from pathlib import Path


def warn(message: str) -> None:
    sys.stderr.write(f"WARNING: session-start telemetry skipped: {message}\n")


def load_payload(path_text: str) -> dict:
    if not path_text:
        return {}
    path = Path(path_text)
    if not path.exists() or path.stat().st_size == 0:
        return {}
    try:
        data = json.loads(path.read_text(encoding="utf-8"))
    except json.JSONDecodeError as exc:
        warn(f"stdin is not valid JSON ({exc})")
        return {}
    if not isinstance(data, dict):
        warn("stdin JSON root must be an object")
        return {}
    return data

db_path = os.path.join(os.environ.get("PROJECT_ROOT", os.getcwd()), ".helix", "helix.db")
payload = load_payload(os.environ.get("HELIX_SESSION_INPUT_PATH", ""))
raw_session_id = payload.get("session_id")
session_id = (
    str(raw_session_id).strip()
    if isinstance(raw_session_id, str) and raw_session_id.strip()
    else os.environ.get("HELIX_SESSION_ID", "").strip()
)
if not session_id or not os.path.exists(db_path):
    sys.exit(0)

helix_home = Path(os.environ["HELIX_HOME"])
sys.path.insert(0, str(helix_home / "cli" / "lib"))

import helix_db  # type: ignore

try:
    with helix_db._write_connection(db_path) as conn:
        try:
            conn.execute(
                "INSERT INTO sessions (id, cwd, claude_session_id) VALUES (?, ?, ?)",
                (
                    session_id,
                    os.getcwd(),
                    os.environ.get("CLAUDE_SESSION_ID") or "",
                ),
            )
        except sqlite3.Error:
            pass
        helix_db.upsert_session_telemetry(
            conn,
            session_id,
            actor="claude-code",
            tool_uses_count=0,
            tokens_total=0,
            cost_usd=0.0,
            ended=False,
        )
except Exception as exc:
    warn(str(exc))
PY
  fi
fi

if [[ -f "$PROJECT_ROOT/.helix/phase.yaml" ]]; then
  helix_progress="$(python3 "$SCRIPT_DIR/lib/session_start_helpers.py" progress "$PROJECT_ROOT" 2>/dev/null || true)"
fi

# PLAN-022 W-P1-1b: handover task → skill 推挙ヒント
HELIX_SKILL_HINT=""
if [[ "${HELIX_SKILL_SEARCH:-1}" == "1" ]]; then
  handover_task="$(python3 -c '
import sys
sys.path.insert(0, sys.argv[1])
from session_start_helpers import get_handover_task
print(get_handover_task(sys.argv[2]))
' "$SCRIPT_DIR/lib" "$PROJECT_ROOT" 2>/dev/null || echo "")"
  if [[ -n "$handover_task" ]]; then
    skill_hint="$(timeout 5 python3 "$SCRIPT_DIR/lib/skill_recommender.py" \
      --task "$handover_task" --json --top-n 1 2>/dev/null || echo "")"
    if [[ -n "$skill_hint" ]]; then
      HELIX_SKILL_HINT="$(python3 -c '
import json
import sys

try:
    data = json.loads(sys.argv[1])
    candidates = data.get("candidates", [])
    if candidates:
        candidate = candidates[0]
        skill_id = candidate.get("skill_id", "?")
        agent = candidate.get("recommended_agent", "?")
        print(f"推奨スキル: {skill_id} / 推奨 agent: {agent}")
except Exception:
    pass
' "$skill_hint" 2>/dev/null || echo "")"
    fi
  fi
fi

if [[ -n "$HELIX_SKILL_HINT" ]]; then
  if [[ -n "$helix_progress" ]]; then
    helix_progress="${helix_progress}

### タスク推挙ヒント (PLAN-022 自動発火)
${HELIX_SKILL_HINT}"
  else
    helix_progress="### タスク推挙ヒント (PLAN-022 自動発火)
${HELIX_SKILL_HINT}"
  fi
fi

if [[ -n "$helix_progress" ]]; then
  helix_progress_escaped="$(printf '%s' "$helix_progress" | python3 -c 'import json,sys; print(json.dumps(sys.stdin.read(), ensure_ascii=False)[1:-1])')"
  helix_progress_escaped="${helix_progress_escaped}\\n\\n"
fi

# --- 完了: 通常の HELIX コンテキスト ---
context_output="$(cat <<'CONTEXT'
{
  "hookSpecificOutput": {
    "hookEventName": "SessionStart",
    "additionalContext": "__HELIX_PROGRESS__## HELIX フレームワーク稼働中\n\nこのセッションでは HELIX 開発フレームワークが有効。以下のツールが使える:\n\n### Codex 委譲（バックエンド・設計・レビュー）\n```bash\nhelix codex --role <role> --task \"タスク内容\"\n```\nロール: tl(設計/レビュー) / se(上級実装) / pg(通常実装) / fe(FE) / qa(テスト) / security(監査) / dba(DB) / devops(インフラ) / docs(文書) / research(調査) / legacy(レガシー) / perf(性能)\n詳細: ~/ai-dev-kit-vscode/cli/ROLE_MAP.md\n\n### ゲート検証\n```bash\nhelix gate <G0.5|G1|G1R|G1.5|G2-G7|G9-G11> [--static-only] [--dry-run]\n```\n\n### FE 実装フロー（v2）\n- FE 設計判断は TL が担当し、必要に応じて `helix claude --role pmo --model sonnet` を read-only レビューに使う\n- FE 実装・回帰確認は Codex role / QA フローに集約し、ネイティブ `@fe-*` サブエージェントは使わない\n\n### 原則\n- Claude Code の役割は HELIX の plan / task / role で決める。PM/TL/実装のどれで動く場合も、該当ゲートと handover を正本にする\n- Codex 委譲や Claude harness は必要に応じて使い分ける\n- .helix/ があるプロジェクトでは Edit/Write/MultiEdit 時に設計整合チェックが自動発火する\n- 委譲ルール詳細: CLAUDE.md §ディスパッチ決定木 参照\n\n### CLAUDE.md 作成時\nCLAUDE.md を新規作成する場合は必ずテンプレートを使うこと:\n~/ai-dev-kit-vscode/cli/templates/CLAUDE.md.template\nテンプレートなしで Write すると PreToolUse hook でブロックされる。\n\n### その他ツール\n- helix init: プロジェクト初期化（.helix/ + CLAUDE.md + gitignore）\n- helix size --files N --lines N [--api] [--db] [--ui] --type TYPE: タスクサイジング + フェーズスキップ判定\n- helix sprint <status|next|complete|reset>: L4 マイクロスプリント管理\n- helix pr [--dry-run]: ゲート結果から PR 自動生成\n- helix reverse <R0-R4|status>: Reverse HELIX パイプライン\n\n### HELIX Scrum（検証駆動開発）\n要件未確定・実現可能性不明な場合に使う:\n- helix scrum init: Scrum モード初期化\n- helix scrum backlog add --id H001 --title '仮説' --question '検証内容' --acceptance '成功条件'\n- helix scrum plan --goal 'ゴール' --hypotheses H001,H002\n- helix scrum poc --hypothesis H001: PoC 実装を Codex に委譲\n- helix scrum verify: 全検証スクリプト実行（verify/*.sh）\n- helix scrum decide --hypothesis H001 --confirmed: 仮説判定\n検証スクリプトは蓄積され、毎回全実行でリグレッション検出。confirmed → Forward HELIX に接続。\n\n### スキル自動推挙（gpt-5.4-mini LLM マッチング）\nタスクを始める前に、最適なスキルと references を自動選定:\n```bash\nhelix skill search \"<タスク記述>\" [-n 5]       # top N 候補 + 推奨 agent\nhelix skill chain  \"<タスク記述>\" [--dry-run]  # search → use 一気通貫\nhelix skill use <skill-id> --task \"...\" [--dry-run]  # 手動委譲\nhelix skill list / show <id> / stats           # 一覧・詳細・統計\n```\n推挙結果は 1 時間キャッシュ (.helix/cache/recommendations/)。ブランド DESIGN.md 34件を含む全 references から選定される。__GIT_STATUS_SUFFIX__"
  }
}
CONTEXT
)"
context_output="${context_output//__HELIX_PROGRESS__/${helix_progress_escaped}}"
context_output="${context_output//__GIT_STATUS_SUFFIX__/${git_status_suffix}}"
printf '%s\n' "$context_output"
