#!/bin/bash
set -euo pipefail

# shellcheck source=cli/lib/helix-common.sh
source "$(cd "$(dirname "$0")" && pwd)/lib/helix-common.sh"

emit_filtered_stderr() {
  local stderr_file="$1"
  [[ -s "$stderr_file" ]] || return 0
  python3 - "$stderr_file" <<'PY'
import sys
from pathlib import Path

path = Path(sys.argv[1])
for line in path.read_text(encoding="utf-8").splitlines():
    if line.startswith("level=warn event=stale_lock_released "):
        continue
    print(line, file=sys.stderr)
PY
}

run_setup_helper_json() {
  local stdout_file stderr_file status
  stdout_file="$(mktemp)"
  stderr_file="$(mktemp)"
  if python3 "$SCRIPT_DIR/lib/setup_helper.py" \
    --setup-dir "$SCRIPT_DIR/setup" \
    --project-root "$PROJECT_ROOT" \
    --db-path "$DB_PATH" \
    "$@" >"$stdout_file" 2>"$stderr_file"; then
    status=0
  else
    status=$?
  fi
  cat "$stdout_file"
  emit_filtered_stderr "$stderr_file"
  rm -f "$stdout_file" "$stderr_file"
  return "$status"
}

usage() {
  cat <<'USAGE'
使い方: helix setup <subcommand> [args...]

サブコマンド:
  verify --name <component>     初期化状態を検証
  install --name <component>    初期化に必要な要素を導入
  repair --name <component>     初期化状態を修復
  list                          利用可能 component 一覧
  status [--name <component>]   component 状態を表示
  preflight --profile <profile> 実行前の入口チェック
  bootstrap [options]           preflight + init + safe components を一発実行
  packages <list|install>        開発支援パッケージ導入スクリプト

Profiles:
  project                       新規/既存プロジェクトの HELIX 導入前チェック
  reverse                       Reverse HELIX 開始前チェック

Bootstrap options:
  --project-name <name>         helix init に渡すプロジェクト名
  --start-phase <L1..L11>       途中導入時の開始フェーズ
  --force                       init テンプレートを更新
  --skip-components             redaction/gitignore component 導入をスキップ
  --json                        結果を JSON で出力

Package examples:
  helix setup packages list
  helix setup packages install --name textlint --dry-run
  helix setup packages install --name playwright --yes
USAGE
}

CMD="${1:-help}"
shift 2>/dev/null || true

case "$CMD" in
  verify|install|repair|list|status|preflight|bootstrap|packages)
    if [[ " $* " == *" --json "* ]]; then
      run_setup_helper_json "$CMD" "$@"
      exit $?
    fi
    exec python3 "$SCRIPT_DIR/lib/setup_helper.py" \
      --setup-dir "$SCRIPT_DIR/setup" \
      --project-root "$PROJECT_ROOT" \
      --db-path "$DB_PATH" \
      "$CMD" "$@"
    ;;
  help|-h|--help)
    usage
    ;;
  *)
    echo "エラー: 不明な setup subcommand: $CMD" >&2
    usage >&2
    exit 2
    ;;
esac
