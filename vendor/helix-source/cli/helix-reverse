stage_task() {
  local type="$1"
  local stage="$2"
  local target_desc="$3"
  local output_file="$4"
  local prev="$5"
  local generated_schema="stage_id / generated_at / source_paths を必須フィールドとして持つ YAML skeleton を出力すること。"

  case "$type:$stage" in
    code:R0)
      echo "R0 Evidence Acquisition: $target_desc のコード・DB・設定・外部APIを調査し、evidence_map を YAML で出力せよ。modules / db_schema / external_apis / config_files / unknowns の5カテゴリで整理。$prev 結果は $output_file に書き出すこと。"
      ;;
    code:R1)
      echo "R1 Observed Contracts: API/DB/型の機械抽出を行い、observed_contracts を YAML で出力せよ。各エンドポイントの request/response 型、DB テーブルの列定義、外部API呼び出しの契約を記録。characterization tests の候補も列挙。$prev 結果は $output_file に書き出すこと。"
      ;;
    code:R2)
      echo "R2 As-Is Design: アーキテクチャを復元し、ADR仮説を立てよ。コンポーネント図（テキスト）、データフロー、依存関係、推定された設計判断（ADR形式）を出力。矛盾点と不明点を明示。$prev 結果は $output_file に書き出すこと。"
      ;;
    code:R3)
      echo "R3 Intent Hypotheses: 要件仮説を立て、PO検証用の質問リストを作成せよ。各仮説に confidence (high/medium/low) を付与。unknown は全件タスク化。$prev 結果は $output_file に書き出すこと。"
      ;;
    code:R4)
      echo "R4 Gap & Routing: 差分を集約し、Forward HELIX への接続を設計せよ。各 gap を defect/assumption/quality/scope に分類し、L1/L2/L3/L4 への振り分けを提案。remediation plan を含める。$prev 結果は $output_file に書き出すこと。"
      ;;
    design:R0)
      echo "Design R0 Evidence Acquisition: 設計資産をスキャンし、design evidence map を YAML で出力せよ。対象: plans=$PLANS_PATH, design=$DESIGN_PATH, features=$FEATURES_PATH。docs/plans/, docs/design/D-*.md, docs/features/*/D-* の設計資産を source_paths として記録し、抽出不能参照を unknowns に列挙。$generated_schema 結果は $output_file に書き出すこと。"
      ;;
    design:R2)
      echo "Design R2 DAG Extraction: 設計資産から依存 DAG を抽出し、nodes / edges / cycles / unknowns を YAML で出力せよ。対象: plans=$PLANS_PATH, design=$DESIGN_PATH, features=$FEATURES_PATH。$prev $generated_schema 結果は $output_file に書き出すこと。"
      ;;
    design:R3)
      local topo_note=""
      [[ "$TOPOLOGICAL_SORT" == true ]] && topo_note="topological_sort セクションを含め、実装順序と並列実行可能グループを明示。"
      echo "Design R3 Implementation Order: D2 DAG から実装順序を導出し、implementation_order / parallel_groups / unknown_edges を YAML で出力せよ。$topo_note $prev $generated_schema 結果は $output_file に書き出すこと。"
      ;;
    design:R4)
      echo "Design R4 Routing: design DAG と任意の実装順序を Forward HELIX に接続し、routing_to_forward / disconnected_designs / deferred_findings_candidates を YAML で出力せよ。Forward L1/L2/L3/L4 の接続先と接続確度を明示。$prev $generated_schema 結果は $output_file に書き出すこと。"
      ;;
    upgrade:R0)
      echo "Upgrade R0 Context Acquisition: $target_desc の現行実装・依存・運用制約・既知障害を調査し、upgrade_context を YAML で出力せよ。from / to / source_paths / constraints / unknowns を含める。$generated_schema 結果は $output_file に書き出すこと。"
      ;;
    upgrade:R1)
      echo "Upgrade R1 Compatibility Contracts: 互換/保守/破壊変更候補を分類し、upgrade_contracts を YAML で出力せよ。API/DB/D-CONTRACT/依存ライブラリ/運用設定の観点を分ける。$prev $generated_schema 結果は $output_file に書き出すこと。"
      ;;
    upgrade:R2)
      echo "Upgrade R2 Impact Assessment: 変更影響一覧、migration 候補、rollback 注意点、検証条件を YAML で出力せよ。Reverse 内では migration/rollback 判断を確定せず、L2/L3/G3 への判断材料に留める。$prev $generated_schema 結果は $output_file に書き出すこと。"
      ;;
    upgrade:R3)
      echo "Upgrade R3 Hypotheses: 移行シナリオ仮説、成功条件、未確定前提、PO/TL 確認質問を Markdown で出力せよ。各仮説に confidence を付ける。$prev 結果は $output_file に書き出すこと。"
      ;;
    upgrade:R4)
      echo "Upgrade R4 Routing: upgrade assessment を Forward HELIX に接続し、routing_to_forward / compatibility_findings / freeze_pending を Markdown で出力せよ。API/DB/D-CONTRACT 疑義は L2/L3/G3 に振り分け、Reverse 内で設計 freeze しない。$prev 結果は $output_file に書き出すこと。"
      ;;
    normalization:R0)
      echo "Normalization R0 Drift Evidence: $target_desc の実装と設計文書の drift 根拠を収集し、drift_evidence を YAML で出力せよ。source_paths / observed_drift / confidence / unknowns を含める。$generated_schema 結果は $output_file に書き出すこと。"
      ;;
    normalization:R2)
      echo "Normalization R2 Drift Model: drift を設計再正規化単位に分解し、affected_docs / required_updates / risk / priority を YAML で出力せよ。$prev $generated_schema 結果は $output_file に書き出すこと。"
      ;;
    normalization:R3)
      echo "Normalization R3 Hypotheses: 設計更新仮説、優先順位、再発防止観点、確認質問を Markdown で出力せよ。$prev 結果は $output_file に書き出すこと。"
      ;;
    normalization:R4)
      echo "Normalization R4 Gap Register: 設計再正規化の gap register を YAML で出力せよ。routing_to_forward / design_update_todos / deferred_findings_candidates / unresolved を含める。$prev $generated_schema 結果は $output_file に書き出すこと。"
      ;;
    fullback:R0)
      echo "Fullback R0 Evidence: $target_desc の完了実装・設計 doc・変更履歴を調査し、fullback_evidence を YAML で出力せよ。raw 本文、secret、PII、env vars 平文は保存せず、source_path / line_range / content_hash / redacted_summary のみ記録する。$generated_schema 結果は $output_file に書き出すこと。"
      ;;
    fullback:R1)
      echo "Fullback R1 Contracts: PLAN/D-API/D-CONTRACT/ADR と実装状態の差分契約を YAML で出力せよ。doc_diff_summary / contract_alignment / security_review_required を含める。$prev $generated_schema 結果は $output_file に書き出すこと。"
      ;;
    fullback:R2)
      echo "Fullback R2 As-Is Review: 完了実装と管理文書の整合レビューを Markdown で出力せよ。監査追跡、未確定整合項目、L8/L9-L11 接続観点を明示。$prev 結果は $output_file に書き出すこと。"
      ;;
    fullback:R3)
      echo "Fullback R3 Handover Checklist: L8/L11 受入・運用学習・引継ぎのチェックリストを YAML で出力せよ。owners / acceptance_links / open_items を含める。$prev $generated_schema 結果は $output_file に書き出すこと。"
      ;;
    fullback:R4)
      echo "Fullback R4 Routing: 最終文書整合の routing を Markdown で出力せよ。resolved / partial / open gap、Forward/Run フェーズ接続先、RGC 実行条件を明示する。$prev 結果は $output_file に書き出すこと。"
      ;;
  esac
}

status_json() {
  local type="$1"
  local dir="$2"
  local gates
  case "$type" in
    design) gates="RG0 RG2 RG3 RGC" ;;
    normalization) gates="RG0 RG2 RG3 RGC" ;;
    upgrade) gates="RG0 RG1 RG2 RG3" ;;
    *) gates="RG0 RG1 RG2 RG3 RGC" ;;
  esac

  printf '{\n'
  printf '  "reverse_type": "%s",\n' "$type"
  printf '  "gates": {\n'
  local first=true gate status
  for gate in $gates; do
    status=$(get_rgate_status "$type" "$gate")
    [[ "$first" == false ]] && printf ',\n'
    printf '    "%s": "%s"' "$gate" "$status"
    first=false
  done
  printf '\n  },\n'
  printf '  "artifacts": ['
  local artifact_first=true f
  if [[ -d "$dir" ]]; then
    while IFS= read -r f; do
      [[ -z "$f" ]] && continue
      [[ "$artifact_first" == false ]] && printf ', '
      printf '"%s"' "$(basename "$f")"
      artifact_first=false
    done < <(find "$dir" -maxdepth 1 \( -name '*.yaml' -o -name '*.md' \) -type f 2>/dev/null | sort)
  fi
  printf ']\n'
  printf '}\n'
}

cmd_status() {
  local dir
  dir=$(reverse_dir_for_type "$TYPE")

  if [[ "$JSON_OUTPUT" == true || "$TYPE" != "code" ]]; then
    status_json "$TYPE" "$dir"
    return
  fi

  echo "=== Reverse HELIX Status ==="
  echo "reverse_type: $TYPE"
  echo ""
  for rg in RG0 RG1 RG2 RG3; do
    status=$(get_rgate_status "$TYPE" "$rg")
    echo "  $rg: $status"
  done
  echo ""
  if [[ -d "$dir" ]]; then
    echo "成果物:"
    find "$dir" -maxdepth 1 \( -name '*.yaml' -o -name '*.md' \) -type f 2>/dev/null | sort | while read -r f; do
      echo "  $(basename "$f")"
    done
  fi
}

cmd_rgc_code() {
  local gap_register="$CODE_REVERSE_DIR/R4-gap-register.md"
  if [[ ! -f "$gap_register" && -f "$CODE_REVERSE_DIR/R4-gap-register.yaml" ]]; then
    gap_register="$CODE_REVERSE_DIR/R4-gap-register.yaml"
  fi

  if [[ ! -f "$gap_register" ]]; then
    echo "Error: $CODE_REVERSE_DIR/R4-gap-register.md が見つかりません" >&2
    echo "  先に 'helix reverse R4' を実行してください" >&2
    exit "$EXIT_PREREQ_ERROR"
  fi

  echo "=== Reverse Gap Closure (RGC) ==="
  echo ""
  echo "Source: $gap_register"
  echo ""

  python3 - "$gap_register" <<'PY'
import re, sys
from collections import defaultdict

gap_file = sys.argv[1]
with open(gap_file, 'r', encoding='utf-8') as f:
    content = f.read()

gap_pattern = re.compile(
    r'\|\s*(GAP-\d{3})\s*\|.*?\|\s*\w+\s*\|\s*(P[012])\s*\|.*?\|\s*([^|]+?)\s*\|',
    re.MULTILINE
)

stats = defaultdict(lambda: defaultdict(int))
unresolved = []

for match in gap_pattern.finditer(content):
    gap_id, priority, status = match.groups()
    status_clean = status.strip()
    if "解決済" in status_clean and "部分" not in status_clean:
        stats[priority]['resolved'] += 1
    elif "部分解決" in status_clean:
        stats[priority]['partial'] += 1
        unresolved.append((gap_id, priority, status_clean[:50]))
    else:
        stats[priority]['open'] += 1
        unresolved.append((gap_id, priority, status_clean[:50]))

total = total_resolved = total_partial = total_open = 0
print(f"{'Priority':<10} {'Resolved':>10} {'Partial':>10} {'Open':>10} {'Total':>10}")
print(f"{'-'*10} {'-'*10:>10} {'-'*10:>10} {'-'*10:>10} {'-'*10:>10}")

for priority in ['P0', 'P1', 'P2']:
    s = stats[priority]
    t = s['resolved'] + s['partial'] + s['open']
    total += t
    total_resolved += s['resolved']
    total_partial += s['partial']
    total_open += s['open']
    print(f"{priority:<10} {s['resolved']:>10} {s['partial']:>10} {s['open']:>10} {t:>10}")

print(f"{'-'*10} {'-'*10:>10} {'-'*10:>10} {'-'*10:>10} {'-'*10:>10}")
print(f"{'Total':<10} {total_resolved:>10} {total_partial:>10} {total_open:>10} {total:>10}")
print()

if total > 0:
    closure_rate = (total_resolved + total_partial * 0.5) / total * 100
    print(f"Closure Rate: {closure_rate:.1f}% ({total_resolved} resolved + {total_partial} partial = {total_resolved + total_partial}/{total})")

if unresolved:
    print()
    print("=== 未解決/部分解決の Gap ===")
    for gap_id, priority, status in unresolved[:20]:
        marker = "◐" if "部分" in status else "○"
        print(f"  {marker} {gap_id} [{priority}] {status}")
    if len(unresolved) > 20:
        print(f"  ... 他 {len(unresolved) - 20} 件")

if total > 0 and total_open == 0 and total_partial == 0:
    print()
    print("All Reverse HELIX Gaps are CLOSED.")
    print("Forward HELIX is fully aligned with the Reverse analysis.")
PY
}

