get_rgate_status() {
  local type="$1"
  local rgate="$2"
  local path="reverse_gates.${rgate}.status"
  [[ "$type" != "code" ]] && path="reverse_gates.${type}.${rgate}.status"
  python3 "$YP" read "$PHASE_FILE" "$path" 2>/dev/null || echo "pending"
}

set_rgate_status() {
  local type="$1"
  local rgate="$2"
  local status="$3"
  local base="reverse_gates.${rgate}"
  [[ "$type" != "code" ]] && base="reverse_gates.${type}.${rgate}"
  python3 "$YP" write "$PHASE_FILE" "${base}.status" "$status" 2>/dev/null || true
  python3 "$YP" write "$PHASE_FILE" "${base}.date" "$(date '+%Y-%m-%d')" 2>/dev/null || true
}

invalidate_forward_gates() {
  local gate
  for gate in G2 G3 G4 G5 G6 G7 G9 G10 G11; do
    python3 "$YP" write "$PHASE_FILE" "gates.${gate}.status" "invalidated" 2>/dev/null || true
  done
  echo "[helix-reverse] Forward gates を invalidated に更新しました: G2-G11 (G8 excluded)"
}

stage_for_command() {
  case "$SUBCOMMAND" in
    run)
      echo "R0"
      ;;
    retry)
      if [[ -n "$RETRY_STAGE" ]]; then
        echo "$RETRY_STAGE"
      elif [[ "$LAST_FAILED" == true ]]; then
        find_last_failed_stage
      else
        echo "Error: retry requires <R0|R1|R2|R3|R4> or --last-failed" >&2
        exit "$EXIT_INPUT_ERROR"
      fi
      ;;
    R[0-4])
      echo "$SUBCOMMAND"
      ;;
    *)
      echo "Error: subcommand '$SUBCOMMAND' does not map to a stage" >&2
      exit "$EXIT_INPUT_ERROR"
      ;;
  esac
}

find_last_failed_stage() {
  local stage gate status
  for stage in R4 R3 R2 R1 R0; do
    if [[ ( "$TYPE" == "design" || "$TYPE" == "normalization" ) && "$stage" == "R1" ]]; then
      continue
    fi
    gate=$(stage_rgate "$TYPE" "$stage")
    status=$(get_rgate_status "$TYPE" "$gate")
    if [[ "$status" == "failed" ]]; then
      echo "$stage"
      return
    fi
  done
  echo "Error: no failed reverse stage found for type '$TYPE'" >&2
  exit "$EXIT_PREREQ_ERROR"
}

