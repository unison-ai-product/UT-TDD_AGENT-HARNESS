validate_stage_output() {
  local output_file="$1"
  if [[ ! -s "$output_file" ]]; then
    echo "empty output file" >&2
    return 1
  fi

  case "$output_file" in
    *.yaml|*.yml)
      python3 - "$SCRIPT_DIR" "$output_file" <<'PY'
from pathlib import Path
import sys

script_dir = Path(sys.argv[1])
path = Path(sys.argv[2])
sys.path.insert(0, str(script_dir / "lib"))
from yaml_parser import parse_yaml  # noqa: E402

try:
    data = parse_yaml(path.read_text(encoding="utf-8"))
except Exception as exc:
    print(f"invalid YAML: {exc}", file=sys.stderr)
    raise SystemExit(1)
if not isinstance(data, dict) or not data:
    print("YAML output must be a non-empty mapping", file=sys.stderr)
    raise SystemExit(1)
if not any(str(key).strip() for key in data.keys()):
    print("YAML output must contain at least one named field", file=sys.stderr)
    raise SystemExit(1)
PY
      ;;
    *.md)
      python3 - "$output_file" <<'PY'
from pathlib import Path
import sys

text = Path(sys.argv[1]).read_text(encoding="utf-8").strip()
if len(text) < 20:
    print("Markdown output is too short", file=sys.stderr)
    raise SystemExit(1)
PY
      ;;
  esac
}

run_stage() {
  local stage="$1"
  local dir role target_desc output_file prev task rgate prereq prereq_status
  dir=$(reverse_dir_for_type "$TYPE")
  role=$(stage_role "$TYPE" "$stage")
  output_file=$(resolve_output_file "$TYPE" "$stage")
  prev=$(prev_output_note "$TYPE" "$stage")
  target_desc="${TARGET:-$PROJECT_ROOT}"
  [[ "$TYPE" == "design" ]] && target_desc="plans=$PLANS_PATH design=$DESIGN_PATH features=$FEATURES_PATH"
  [[ "$TYPE" == "upgrade" ]] && target_desc="project=$PROJECT_ROOT from=${UPGRADE_FROM:-unspecified} to=${UPGRADE_TO:-unspecified} target=${TARGET:-all}"
  [[ "$TYPE" == "normalization" ]] && target_desc="project=$PROJECT_ROOT target=${TARGET:-drift}"
  [[ "$TYPE" == "fullback" ]] && target_desc="project=$PROJECT_ROOT artifact=${ARTIFACT_PATH:-${TARGET:-completed-work}}"
  if [[ "$FROM_SCRUM" == true ]]; then
    target_desc="${target_desc} scrum_hypothesis=${SCRUM_HYPOTHESIS} scrum_route=${TYPE}/${SCRUM_ROUTE_RATING}"
  fi

  auto_switch_reverse_mode "$stage"
  mkdir -p "$dir"

  if [[ "$SUBCOMMAND" != "retry" ]]; then
    prereq=$(stage_prereq "$TYPE" "$stage")
    if [[ -n "$prereq" ]]; then
      prereq_status=$(get_rgate_status "$TYPE" "$prereq")
      if [[ "$prereq_status" != "passed" ]]; then
        echo "Error: $prereq が未通過 (status: $prereq_status)" >&2
        echo "先に前のステージを完了してください" >&2
        exit "$EXIT_CHECK_FAILED"
      fi
    fi
  fi

  task=$(stage_task "$TYPE" "$stage" "$target_desc" "$output_file" "$prev")

  echo "=== Reverse HELIX: $TYPE $stage ==="
  echo "Role:   $role"
  echo "Target: $target_desc"
  echo "Output: $output_file"
  if [[ "$FROM_SCRUM" == true ]]; then
    echo "Scrum:  ${SCRUM_HYPOTHESIS} -> ${TYPE} (${SCRUM_ROUTE_RATING})"
  fi
  if [[ "$REVIEW" == true ]]; then
    echo "Review: $(review_output_hint "$stage")"
  fi
  echo ""

  if [[ "$DRY_RUN" == true ]]; then
    echo "[dry-run] helix codex --role $role --task:"
    echo "$task"
    if [[ "$REVIEW" == true ]]; then
      echo "[dry-run] --review: review JSON を $(review_output_hint "$stage") に保存します"
    fi
    if [[ "$INVALIDATE_FORWARD" == true && "$stage" =~ ^R[2-4]$ ]]; then
      echo "[dry-run] --invalidate-forward: Forward gates (G2-G11) を invalidated に更新します"
    fi
    return
  fi

  local log_dir log_name log_file run_status db_run_id codex_exit
  log_dir="$HELIX_DIR/task-logs"
  mkdir -p "$log_dir"
  log_name="$(basename "$output_file")"
  log_name="${log_name%.*}"
  log_file="$log_dir/${TYPE}-${stage}-${log_name}.log"
  run_status="completed"
  db_run_id=""

  if [[ -f "$DB_PATH" ]]; then
    db_run_id=$(python3 "$DB_PY" record-task "$DB_PATH" "$(python3 -c "
import json; print(json.dumps({
    'task_id': '$TYPE-$stage', 'task_type': 'reverse-$TYPE-${stage,,}',
    'plan_goal': 'Reverse HELIX', 'role': '$role', 'status': 'running'
}))" 2>/dev/null)" 2>/dev/null || echo "")
  fi

  set +e
  "$HELIX_CODEX" --role "$role" --task "$task" 2>&1 | tee "$log_file"
  codex_exit=${PIPESTATUS[0]}
  set -e
  if [[ "$codex_exit" -ne 0 ]]; then
    run_status="failed"
  fi

  if [[ -f "$DB_PATH" && -n "$db_run_id" ]]; then
    python3 -c "
from datetime import datetime
import sys
sys.path.insert(0, '$SCRIPT_DIR/lib')
import helix_db
conn = helix_db.get_connection('$DB_PATH')
conn.execute('UPDATE task_runs SET status=?, completed_at=?, output_log=? WHERE id=?',
    ('$run_status', datetime.now().isoformat(), '$log_file', $db_run_id))
conn.commit()
conn.close()
" 2>/dev/null || true
  fi

  echo ""
  echo "[helix-reverse] ログ: $log_file"
  echo "[helix-reverse] 'helix debug trace $log_file' でアクション追跡"
  echo ""

  rgate=$(stage_rgate "$TYPE" "$stage")
  if [[ "$run_status" == "failed" ]]; then
    set_rgate_status "$TYPE" "$rgate" "failed"
    echo "[helix-reverse] WARN: helix-codex が失敗したため $rgate failed"
    exit "$EXIT_CHECK_FAILED"
  fi

  if [[ -f "$output_file" ]] && validate_stage_output "$output_file"; then
    set_rgate_status "$TYPE" "$rgate" "passed"
    echo "[helix-reverse] $rgate passed — 成果物: $output_file"
    if [[ "$REVIEW" == true ]]; then
      local review_file
      review_file=$(write_review_artifact "$stage" "$rgate" "$output_file" "$log_file")
      echo "[helix-reverse] review saved: $review_file"
    fi
    if [[ "$INVALIDATE_FORWARD" == true && "$stage" =~ ^R[2-4]$ ]]; then
      invalidate_forward_gates
    fi
    if [[ "$stage" == "R4" ]]; then
      echo ""
      echo "=== Reverse HELIX 完了 ==="
      echo ""
      echo "Forward HELIX への接続:"
      echo "  1. helix size でサイジング"
      echo "  2. helix plan draft で設計提案"
      echo "  3. helix matrix init で成果物対照表を初期化"
      echo ""
      echo "Gap Register を確認し、Forward フェーズに振り分けてください。"
      python3 "$YP" write "$PHASE_FILE" "reverse.status" "completed" 2>/dev/null || true
      python3 "$YP" write "$PHASE_FILE" "reverse.completed_at" "$(date '+%Y-%m-%d')" 2>/dev/null || true
      python3 "$YP" write "$PHASE_FILE" "reverse.last_type" "$TYPE" 2>/dev/null || true
      python3 "$YP" write "$PHASE_FILE" "reverse.types.${TYPE}.status" "completed" 2>/dev/null || true
      python3 "$YP" write "$PHASE_FILE" "reverse.types.${TYPE}.completed_at" "$(date '+%Y-%m-%d')" 2>/dev/null || true
      python3 "$YP" write "$PHASE_FILE" "reverse.types.${TYPE}.routing_artifact" "${output_file#$PROJECT_ROOT/}" 2>/dev/null || true
    fi
  else
    set_rgate_status "$TYPE" "$rgate" "failed"
    echo ""
    echo "[helix-reverse] WARN: 成果物が未生成または validation 不合格です — $rgate failed"
    echo "[helix-reverse]   手動で有効な成果物を $output_file に作成してください"
    exit "$EXIT_CHECK_FAILED"
  fi
}

case "${1:-}" in
  from-scrum)
    shift || true
    cmd_from_scrum "$@"
    exit "$?"
    ;;
  local)
    shift || true
    cmd_local "$@"
    exit "$?"
    ;;
esac

parse_args "$@"
validate_args
ensure_helix_dir

case "$SUBCOMMAND" in
  status)
    cmd_status
    ;;
  rgc)
    case "$TYPE" in
      code) cmd_rgc_code ;;
      design) cmd_rgc_design ;;
      normalization|fullback) cmd_rgc_generic "$TYPE" ;;
      upgrade)
        echo "Error: upgrade RGC is skipped by PLAN-008; use R4 routing instead" >&2
        exit "$EXIT_INPUT_ERROR"
        ;;
    esac
    ;;
  run|retry|R[0-4])
    run_stage "$(stage_for_command)"
    ;;
  *)
    echo "Error: Unknown subcommand: $SUBCOMMAND" >&2
    exit "$EXIT_INPUT_ERROR"
    ;;
esac
