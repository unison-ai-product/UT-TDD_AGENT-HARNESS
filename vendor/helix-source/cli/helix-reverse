auto_switch_reverse_mode() {
  local stage="$1"
  if [[ "$stage" == "R0" ]]; then
    local current_mode
    current_mode=$(python3 "$YAML_PARSER" read "$PHASE_FILE" current_mode 2>/dev/null || echo "forward")
    if [[ "$current_mode" != "reverse" && -f "$PHASE_FILE" ]]; then
      python3 "$YAML_PARSER" write "$PHASE_FILE" current_mode reverse 2>/dev/null || true
      echo "[helix-reverse] モードを reverse に自動切替しました"
    fi
  fi
}

