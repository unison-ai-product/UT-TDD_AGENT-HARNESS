#!/bin/bash
if [[ "${BASH_VERSINFO[0]:-0}" -lt 4 ]]; then
  echo "エラー: helix reverse は bash 4 以上が必要です (現 ${BASH_VERSION:-unknown})" >&2
  echo "macOS の場合: brew install bash && シェルを /opt/homebrew/bin/bash に変更" >&2
  exit 1
fi
set -euo pipefail

# helix-reverse: Reverse HELIX pipeline
# Usage:
#   helix reverse <type> [<run|status|rgc|retry|R0|R1|R2|R3|R4>] [options]
#   helix reverse R0|R1|R2|R3|R4|status|rgc [options]  # legacy code alias

source "$(cd "$(dirname "$0")" && pwd)/lib/helix-common.sh"
PHASE_FILE="$HELIX_DIR/phase.yaml"
CODE_REVERSE_DIR="$HELIX_DIR/reverse"
HELIX_CODEX="$SCRIPT_DIR/helix-codex"
YP="$SCRIPT_DIR/lib/yaml_parser.py"

TYPE="code"
SUBCOMMAND=""
TYPE_EXPLICIT=false
TARGET=""
DRY_RUN=false
REVIEW=false
INVALIDATE_FORWARD=false
JSON_OUTPUT=false
LAST_FAILED=false
RETRY_STAGE=""
FROM_SCRUM=false
SCRUM_HYPOTHESIS=""
SCRUM_ROUTE_RATING=""
PLANS_PATH="docs/plans/"
DESIGN_PATH="docs/design/"
FEATURES_PATH="docs/features/"
OUTPUT_PATH=""
TOPOLOGICAL_SORT=false
UPGRADE_FROM=""
UPGRADE_TO=""
ARTIFACT_PATH=""

usage() {
  cat <<'USAGE'
Usage:
  helix reverse <type> [<subcommand>] [options]
  helix reverse [<type>] --from-scrum --scrum-hypothesis H001 [R0|run]
  helix reverse from-scrum --scrum-loop-id H-LOCAL-001 [--reverse-type scrum-to-forward]
  helix reverse local <subcommand> [options]
  helix reverse R0|R1|R2|R3|R4|status|rgc [options]  # legacy alias for code

Types:
  code        Existing Reverse HELIX behavior (default / legacy compatible)
  design      Reverse design assets into evidence, DAG, implementation order, routing
  upgrade     Version upgrade impact assessment and Forward routing
  normalization  Design drift normalization and Forward routing
  fullback    Post-implementation document alignment and closure routing

Subcommands:
  run         Run alias. Starts at the type's first stage (R0)
  status      Show type-specific Reverse status
  rgc         Reverse Gap Closure
  retry       Retry a stage: retry <R0|R1|R2|R3|R4>
  R0..R4      Run a stage directly

Options:
  --target <path>             code: target path (legacy)
  --invalidate-forward        code + R2/R3/R4/run/retry only; invalidate Forward gates on success
  --json                      status only
  --last-failed               retry only
  --dry-run                   Print delegated helix codex task without running it
  --review                    code only; save stage review JSON under .helix/reverse/r{0..4}/
                              R0 --review
                              R1 --review
                              R2 --review
                              R3 --review
                              R4 --review
  --from-scrum                Resolve reverse type from Scrum hypothesis routing (PLAN-095)
  --scrum-hypothesis <id>     Scrum backlog hypothesis ID used for --from-scrum routing

Design options:
  --plans <path>              default: docs/plans/
  --design <path>             default: docs/design/
  --features <path>           default: docs/features/
  --output <path>             R2/R3 custom output file or directory
  --topological-sort          R3 only; include topological sort result

Type-specific options:
  --from <version>            upgrade: current version/context label
  --to <version>              upgrade: target version/context label
  --artifact <path>           fullback: completed artifact or handoff root
USAGE
}

reverse_local_py() {
  local code="$1"
  shift
  PYTHONPATH="$PROJECT_ROOT${PYTHONPATH:+:$PYTHONPATH}" python3 -c "$code" "$@"
}

reverse_local_print_json() {
  local payload="$1"
  reverse_local_py $'import json\nimport sys\nprint(json.dumps(json.loads(sys.argv[1]), ensure_ascii=False, indent=2))' "$payload"
}

reverse_local_print_loops_table() {
  local payload="$1"
  reverse_local_py $'import json\nimport sys\nrows = json.loads(sys.argv[1])\nif not rows:\n    print("loop はありません。")\n    raise SystemExit(0)\nheaders = ["LOOP_ID", "SCRUM_LOOP", "TYPE", "STATE", "TARGET_PLAN", "TARGET_LAYER"]\nkeys = ["loop_id", "parent_scrum_loop_id", "reverse_type", "state", "target_forward_plan", "target_forward_layer"]\nwidths = [len(header) for header in headers]\ntable = []\nfor row in rows:\n    values = [str(row.get(key) or "-") for key in keys]\n    table.append(values)\n    for index, value in enumerate(values):\n        widths[index] = max(widths[index], len(value))\nfmt = " | ".join("{:<" + str(width) + "}" for width in widths)\nprint(fmt.format(*headers))\nprint("-+-".join("-" * width for width in widths))\nfor row in table:\n    print(fmt.format(*row))' "$payload"
}

reverse_local_print_stats_table() {
  local payload="$1"
  reverse_local_py $'import json\nimport sys\nstats = json.loads(sys.argv[1])\nrows = list((stats.get("layers") or {}).items())\nif not rows:\n    print("routing stats はありません。")\n    raise SystemExit(0)\nheaders = ["LAYER", "COUNT"]\nwidths = [len(header) for header in headers]\ntable = []\nfor layer, count in rows:\n    values = [str(layer), str(count)]\n    table.append(values)\n    for index, value in enumerate(values):\n        widths[index] = max(widths[index], len(value))\nfmt = " | ".join("{:<" + str(width) + "}" for width in widths)\nprint(fmt.format(*headers))\nprint("-+-".join("-" * width for width in widths))\nfor row in table:\n    print(fmt.format(*row))\nprint("TOTAL: {}".format(stats.get("total", 0)))' "$payload"
}

cmd_from_scrum() {
  local scrum_loop_id="" reverse_type="scrum-to-forward"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --scrum-loop-id) scrum_loop_id="${2:-}"; shift 2 ;;
      --reverse-type) reverse_type="${2:-}"; shift 2 ;;
      --help|-h)
        echo "Usage: helix reverse from-scrum --scrum-loop-id H-LOCAL-001 [--reverse-type scrum-to-forward]"
        return 0
        ;;
      *)
        echo "Usage: helix reverse from-scrum --scrum-loop-id H-LOCAL-001 [--reverse-type scrum-to-forward]" >&2
        exit "$EXIT_INPUT_ERROR"
        ;;
    esac
  done
  [[ -n "$scrum_loop_id" ]] || {
    echo "Usage: helix reverse from-scrum --scrum-loop-id H-LOCAL-001 [--reverse-type scrum-to-forward]" >&2
    exit "$EXIT_INPUT_ERROR"
  }
  reverse_local_py $'import sys\nfrom cli.lib import reverse_local\nprint(reverse_local.init_from_scrum(sys.argv[1], reverse_type=sys.argv[2]))' \
    "$scrum_loop_id" "$reverse_type"
}

cmd_local() {
  local subcmd="${1:-help}"
  shift 2>/dev/null || true

  case "$subcmd" in
    stage)
      local loop_id="" stage=""
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --loop-id) loop_id="${2:-}"; shift 2 ;;
          --stage) stage="${2:-}"; shift 2 ;;
          --help|-h)
            echo "Usage: helix reverse local stage --loop-id RL-001 --stage R1"
            return 0
            ;;
          *)
            echo "Usage: helix reverse local stage --loop-id RL-001 --stage R1" >&2
            exit "$EXIT_INPUT_ERROR"
            ;;
        esac
      done
      [[ -n "$loop_id" && -n "$stage" ]] || {
        echo "Usage: helix reverse local stage --loop-id RL-001 --stage R1" >&2
        exit "$EXIT_INPUT_ERROR"
      }
      reverse_local_py $'import sys\nfrom cli.lib import reverse_local\nreverse_local.transition_state(sys.argv[1], sys.argv[2])' \
        "$loop_id" "$stage"
      echo "[reverse] $loop_id -> $stage"
      ;;
    route)
      local loop_id="" target_plan="" target_layer=""
      local artifact_links=()
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --loop-id) loop_id="${2:-}"; shift 2 ;;
          --target-plan) target_plan="${2:-}"; shift 2 ;;
          --target-layer) target_layer="${2:-}"; shift 2 ;;
          --artifact-link) artifact_links+=("${2:-}"); shift 2 ;;
          --help|-h)
            echo "Usage: helix reverse local route --loop-id RL-001 --target-plan PLAN-XXX --target-layer L4 [--artifact-link '{\"type\":\"code\",\"path\":\"...\"}']"
            return 0
            ;;
          *)
            echo "Usage: helix reverse local route --loop-id RL-001 --target-plan PLAN-XXX --target-layer L4 [--artifact-link '{\"type\":\"code\",\"path\":\"...\"}']" >&2
            exit "$EXIT_INPUT_ERROR"
            ;;
        esac
      done
      [[ -n "$loop_id" && -n "$target_plan" && -n "$target_layer" ]] || {
        echo "Usage: helix reverse local route --loop-id RL-001 --target-plan PLAN-XXX --target-layer L4 [--artifact-link '{\"type\":\"code\",\"path\":\"...\"}']" >&2
        exit "$EXIT_INPUT_ERROR"
      }
      reverse_local_py $'import json\nimport sys\nfrom cli.lib import reverse_local\nitems = []\nfor raw in sys.argv[4:]:\n    parsed = json.loads(raw)\n    if isinstance(parsed, list):\n        items.extend(parsed)\n    else:\n        items.append(parsed)\nreverse_local.route_to_forward(sys.argv[1], sys.argv[2], sys.argv[3], artifact_links=(items or None))' \
        "$loop_id" "$target_plan" "$target_layer" "${artifact_links[@]}"
      echo "[reverse] $loop_id routed -> $target_plan/$target_layer"
      ;;
    list)
      local output_json=false
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --active) shift ;;
          --json) output_json=true; shift ;;
          --help|-h)
            echo "Usage: helix reverse local list [--active] [--json]"
            return 0
            ;;
          *)
            echo "Usage: helix reverse local list [--active] [--json]" >&2
            exit "$EXIT_INPUT_ERROR"
            ;;
        esac
      done
      local list_payload
      list_payload="$(reverse_local_py $'import json\nfrom cli.lib import reverse_local\nprint(json.dumps(reverse_local.list_active_loops(), ensure_ascii=False))')"
      if [[ "$output_json" == true ]]; then
        reverse_local_print_json "$list_payload"
      else
        reverse_local_print_loops_table "$list_payload"
      fi
      ;;
    stats)
      local days="7"
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --days) days="${2:-}"; shift 2 ;;
          --help|-h)
            echo "Usage: helix reverse local stats [--days 7]"
            return 0
            ;;
          *)
            echo "Usage: helix reverse local stats [--days 7]" >&2
            exit "$EXIT_INPUT_ERROR"
            ;;
        esac
      done
      local stats_payload
      stats_payload="$(reverse_local_py $'import json\nimport sys\nfrom cli.lib import reverse_local\nprint(json.dumps(reverse_local.get_routing_stats(days=int(sys.argv[1])), ensure_ascii=False))' "$days")"
      reverse_local_print_stats_table "$stats_payload"
      ;;
    help|-h|--help)
      cat <<'USAGE'
Usage: helix reverse local <subcommand> [options]

Subcommands:
  stage  --loop-id RL-001 --stage R1
  route  --loop-id RL-001 --target-plan PLAN-XXX --target-layer L4 [--artifact-link '{"type":"code","path":"..."}']
  list   [--active] [--json]
  stats  [--days 7]
USAGE
      ;;
    *)
      echo "Error: Unknown local subcommand '$subcmd'" >&2
      exit "$EXIT_INPUT_ERROR"
      ;;
  esac
}

usage_type_stage() {
  local type="$1"
  local stage="$2"
  local next_stage="通常 R0→R1→R2→R3→R4→Forward→RGC"
  local output_hint="TODO: type/stage 仕様確定中"
  local skip_note="なし"
  local stage_behavior="TODO: type/stage 仕様確定中"
  local stage_summary=""

  case "$type:$stage" in
    code:R0)
      stage_behavior="Legacy code reverse の証拠収集。コード・DB・設定・外部APIを起点に観測事実を集める。"
      output_hint=".helix/reverse/code/R0-evidence-map.yaml"
      ;;
    code:R1)
      stage_behavior="観測契約の抽出。API/DB/型の機械抽出と characterization test 候補を整理する。"
      output_hint=".helix/reverse/code/R1-observed-contracts.yaml"
      ;;
    code:R2)
      stage_behavior="As-Is 設計復元。アーキテクチャ、依存関係、ADR 仮説をまとめる。"
      output_hint=".helix/reverse/code/R2-as-is-design.md"
      ;;
    code:R3)
      stage_behavior="Intent 仮説化。PO 検証用質問と要件仮説を整理する。"
      output_hint=".helix/reverse/code/R3-intent-hypotheses.md"
      ;;
    code:R4)
      stage_behavior="Gap 集約と Forward 接続。差分を L1-L4 に路由する。"
      output_hint=".helix/reverse/code/R4-gap-register.yaml"
      ;;
    design:R0)
      stage_behavior="設計資産の evidence map を作る。plans / design / features を横断して参照元を記録する。"
      output_hint=".helix/reverse/design/D0-design-evidence-map.yaml"
      ;;
    design:R1)
      stage_behavior="design は R1 を実行しない。RG1 と矛盾するため code 以外では skip。"
      skip_note="design は R1 を skip。RG1 と矛盾するため実行しない。"
      output_hint="出力なし"
      ;;
    design:R2)
      stage_behavior="設計 DAG を抽出し、依存と循環と不明点を可視化する。"
      output_hint=".helix/reverse/design/D2-design-dag.yaml"
      ;;
    design:R3)
      stage_behavior="DAG から実装順序を導出し、並列実行グループも提示する。"
      output_hint=".helix/reverse/design/D3-impl-order.yaml"
      ;;
    design:R4)
      stage_behavior="Forward HELIX への routing を定義し、未接続設計を洗い出す。"
      output_hint=".helix/reverse/design/D4-design-routing.yaml"
      ;;
    upgrade:R0)
      stage_behavior="現行実装と制約を収集し、upgrade context を作る。"
      output_hint=".helix/reverse/upgrade/U0-upgrade-context.yaml"
      ;;
    upgrade:R1)
      stage_behavior="互換/保守/破壊変更候補を分類し、契約を整理する。"
      output_hint=".helix/reverse/upgrade/U1-upgrade-contracts.yaml"
      ;;
    upgrade:R2)
      stage_behavior="変更影響と rollback 注意点を集約し、検証条件を整理する。"
      output_hint=".helix/reverse/upgrade/U2-assessment-impact.yaml"
      ;;
    upgrade:R3)
      stage_behavior="移行シナリオ仮説と確認質問をまとめる。"
      output_hint=".helix/reverse/upgrade/U3-upgrade-hypotheses.md"
      ;;
    upgrade:R4)
      stage_behavior="Forward 接続用の routing を作り、freeze pending を明示する。"
      output_hint=".helix/reverse/upgrade/U4-upgrade-routing.md"
      ;;
    normalization:R0)
      stage_behavior="実装と文書の drift 証拠を収集し、正規化の起点を作る。"
      output_hint=".helix/reverse/normalization/N0-drift-evidence.yaml"
      ;;
    normalization:R1)
      stage_behavior="normalization は R1 を実行しない。design drift normalization の流れでは skip。"
      skip_note="normalization は R1 を skip。design drift normalization では R1 を使わない。"
      output_hint="出力なし"
      ;;
    normalization:R2)
      stage_behavior="drift を設計再正規化単位に分解し、更新対象を整理する。"
      output_hint=".helix/reverse/normalization/N2-normalization-drift.yaml"
      ;;
    normalization:R3)
      stage_behavior="設計更新仮説と再発防止観点をまとめる。"
      output_hint=".helix/reverse/normalization/N3-normalization-hypotheses.md"
      ;;
    normalization:R4)
      stage_behavior="gap register を作り、Forward への routing を確定する。"
      output_hint=".helix/reverse/normalization/N4-normalization-gap-register.yaml"
      ;;
    fullback:R0)
      stage_behavior="完了実装と設計 doc、変更履歴の evidence を集める。"
      output_hint=".helix/reverse/fullback/F0-fullback-evidence.yaml"
      ;;
    fullback:R1)
      stage_behavior="PLAN / D-API / D-CONTRACT / ADR と実装状態の差分契約を整理する。"
      output_hint=".helix/reverse/fullback/F1-fullback-contracts.yaml"
      ;;
    fullback:R2)
      stage_behavior="完了実装と管理文書の整合レビューを行う。"
      output_hint=".helix/reverse/fullback/F2-fullback-as-is-review.md"
      ;;
    fullback:R3)
      stage_behavior="受入・運用学習・引継ぎのチェックリストを作る。"
      output_hint=".helix/reverse/fullback/F3-fullback-handover-checklist.yaml"
      ;;
    fullback:R4)
      stage_behavior="最終文書整合の routing を作り、RGC 条件を明示する。"
      output_hint=".helix/reverse/fullback/F4-fullback-routing.md"
      ;;
  esac

  case "$type" in
    code) stage_summary="code は全 stage 該当、レガシーコードの逆引き設計を扱う。" ;;
    design) stage_summary="design は R1 を skip し、R0/R2/R3/R4 で設計復元と routing を扱う。" ;;
    upgrade) stage_summary="upgrade は R0/R1/R2/R3/R4 で version diff と影響分析を扱う。RGC は skip。" ;;
    normalization) stage_summary="normalization は R1 を skip し、design drift normalization に focus する。" ;;
    fullback) stage_summary="fullback は全 stage 該当、実装完遂後の文書 alignment を扱う。" ;;
  esac

  cat <<USAGE
Usage:
  helix reverse ${type} ${stage} [options]

## ${type} ${stage} 動作
${stage_behavior}

## skip 条件
${skip_note}

## 出力先
${output_hint}

## 次の stage
${next_stage}

${stage_summary}
USAGE
}

usage_type() {
  local type="$1"
  case "$type" in
    design)
      cat <<'USAGE'
Usage:
  helix reverse design [run|status|rgc|retry|R0|R2|R3|R4] [options]

Design stages:
  R0  Design Evidence Acquisition -> D0-design-evidence-map.yaml
  R1  skipped for design
  R2  Design DAG extraction       -> D2-design-dag.yaml
  R3  Implementation order        -> D3-impl-order.yaml (optional)
  R4  Design routing              -> D4-design-routing.yaml
  rgc Optional closure check for D4-design-routing.yaml after Forward L2 freeze

Options:
  --plans <path>              default: docs/plans/
  --design <path>             default: docs/design/
  --features <path>           default: docs/features/
  --output <path>             R2/R3 custom output file or directory
  --topological-sort          R3 only; include topological sort result
  --dry-run                   Print delegated helix codex task without running it
USAGE
      ;;
    *) usage ;;
  esac
}

is_type() {
  case "$1" in
    code|design|upgrade|normalization|fullback) return 0 ;;
    *) return 1 ;;
  esac
}

is_stage() {
  [[ "$1" =~ ^R[0-4]$ ]]
}

is_subcommand() {
  case "$1" in
    run|status|rgc|retry|R0|R1|R2|R3|R4) return 0 ;;
    *) return 1 ;;
  esac
}

parse_args() {
  if [[ $# -eq 0 ]]; then
    usage >&2
    exit "$EXIT_INPUT_ERROR"
  fi

  case "${1:-}" in
    --help|-h|help)
      usage
      exit "$EXIT_SUCCESS"
      ;;
  esac

  if is_type "$1"; then
    TYPE="$1"
    TYPE_EXPLICIT=true
    shift
    if is_stage "${1:-}" && [[ "${2:-}" == "--help" || "${2:-}" == "-h" ]]; then
      usage_type_stage "$TYPE" "$1"
      exit "$EXIT_SUCCESS"
    fi
    if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
      usage_type "$TYPE"
      exit "$EXIT_SUCCESS"
    fi
    if [[ $# -gt 0 && "$(printf '%s' "$1" | cut -c1)" != "-" ]]; then
      if is_subcommand "$1"; then
        SUBCOMMAND="$1"
        shift
      else
        echo "Error: Unknown subcommand for reverse type '$TYPE': $1" >&2
        exit "$EXIT_INPUT_ERROR"
      fi
    fi
    [[ -z "$SUBCOMMAND" ]] && SUBCOMMAND="run"
  elif [[ "${1:-}" == "--from-scrum" || "${1:-}" == "--scrum-hypothesis" ]]; then
    TYPE="code"
    SUBCOMMAND="run"
  else
    # Existing compatibility: helix reverse R0/status/rgc -> code <subcommand>
    if is_subcommand "$1"; then
      TYPE="code"
      SUBCOMMAND="$1"
      shift
    else
      echo "Error: Unknown reverse type or subcommand: $1" >&2
      usage >&2
      exit "$EXIT_INPUT_ERROR"
    fi
  fi

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --target)
        TARGET="${2:-}"
        [[ -n "$TARGET" ]] || { echo "Error: --target requires a value" >&2; exit "$EXIT_INPUT_ERROR"; }
        shift 2
        ;;
      --plans)
        PLANS_PATH="${2:-}"
        [[ -n "$PLANS_PATH" ]] || { echo "Error: --plans requires a value" >&2; exit "$EXIT_INPUT_ERROR"; }
        shift 2
        ;;
      --design)
        DESIGN_PATH="${2:-}"
        [[ -n "$DESIGN_PATH" ]] || { echo "Error: --design requires a value" >&2; exit "$EXIT_INPUT_ERROR"; }
        shift 2
        ;;
      --features)
        FEATURES_PATH="${2:-}"
        [[ -n "$FEATURES_PATH" ]] || { echo "Error: --features requires a value" >&2; exit "$EXIT_INPUT_ERROR"; }
        shift 2
        ;;
      --output)
        OUTPUT_PATH="${2:-}"
        [[ -n "$OUTPUT_PATH" ]] || { echo "Error: --output requires a value" >&2; exit "$EXIT_INPUT_ERROR"; }
        shift 2
        ;;
      --from)
        UPGRADE_FROM="${2:-}"
        [[ -n "$UPGRADE_FROM" ]] || { echo "Error: --from requires a value" >&2; exit "$EXIT_INPUT_ERROR"; }
        shift 2
        ;;
      --to)
        UPGRADE_TO="${2:-}"
        [[ -n "$UPGRADE_TO" ]] || { echo "Error: --to requires a value" >&2; exit "$EXIT_INPUT_ERROR"; }
        shift 2
        ;;
      --artifact)
        ARTIFACT_PATH="${2:-}"
        [[ -n "$ARTIFACT_PATH" ]] || { echo "Error: --artifact requires a value" >&2; exit "$EXIT_INPUT_ERROR"; }
        shift 2
        ;;
      --topological-sort)
        TOPOLOGICAL_SORT=true
        shift
        ;;
      --dry-run)
        DRY_RUN=true
        shift
        ;;
      --review)
        REVIEW=true
        shift
        ;;
      --from-scrum)
        FROM_SCRUM=true
        shift
        ;;
      --scrum-hypothesis)
        SCRUM_HYPOTHESIS="${2:-}"
        [[ -n "$SCRUM_HYPOTHESIS" ]] || { echo "Error: --scrum-hypothesis requires a value" >&2; exit "$EXIT_INPUT_ERROR"; }
        shift 2
        ;;
      --invalidate-forward)
        INVALIDATE_FORWARD=true
        shift
        ;;
      --json)
        JSON_OUTPUT=true
        shift
        ;;
      --last-failed)
        LAST_FAILED=true
        shift
        ;;
      --help|-h)
        usage_type "$TYPE"
        exit "$EXIT_SUCCESS"
        ;;
      *)
        if [[ "$SUBCOMMAND" == "retry" && -z "$RETRY_STAGE" && "$1" =~ ^R[0-4]$ ]]; then
          RETRY_STAGE="$1"
          shift
        else
          echo "Error: Unknown option: $1" >&2
          exit "$EXIT_INPUT_ERROR"
        fi
        ;;
    esac
  done
}

validate_args() {
  case "$TYPE" in
    code|design|upgrade|normalization|fullback) ;;
  esac

  if [[ "$JSON_OUTPUT" == true && "$SUBCOMMAND" != "status" ]]; then
    echo "Error: --json is valid only with status" >&2
    exit "$EXIT_INPUT_ERROR"
  fi

  if [[ "$LAST_FAILED" == true && "$SUBCOMMAND" != "retry" ]]; then
    echo "Error: --last-failed is valid only with retry" >&2
    exit "$EXIT_INPUT_ERROR"
  fi

  if [[ "$REVIEW" == true ]]; then
    if [[ "$TYPE" != "code" ]]; then
      echo "Error: --review is valid only for reverse type 'code'" >&2
      exit "$EXIT_INPUT_ERROR"
    fi
    case "$SUBCOMMAND" in
      run|retry|R[0-4]) ;;
      *)
        echo "Error: --review is valid only for code run/retry or R0/R1/R2/R3/R4" >&2
        exit "$EXIT_INPUT_ERROR"
        ;;
    esac
  fi

  if [[ "$INVALIDATE_FORWARD" == true ]]; then
    if [[ "$TYPE" != "code" ]]; then
      echo "Error: --invalidate-forward is valid only for reverse type 'code'" >&2
      exit "$EXIT_INPUT_ERROR"
    fi
    case "$SUBCOMMAND" in
      run|retry|R2|R3|R4) ;;
      *)
        echo "Error: --invalidate-forward is valid only for code run/retry or R2/R3/R4" >&2
        exit "$EXIT_INPUT_ERROR"
        ;;
    esac
  fi

  if [[ "$TOPOLOGICAL_SORT" == true && "$TYPE" == "design" ]]; then
    if [[ "$SUBCOMMAND" != "R3" && ! ( "$SUBCOMMAND" == "retry" && "$RETRY_STAGE" == "R3" ) ]]; then
      echo "Error: --topological-sort is valid only for design R3" >&2
      exit "$EXIT_INPUT_ERROR"
    fi
  elif [[ "$TOPOLOGICAL_SORT" == true ]]; then
    echo "Error: --topological-sort is valid only for reverse type 'design'" >&2
    exit "$EXIT_INPUT_ERROR"
  fi

  if [[ "$TYPE" == "design" && "$SUBCOMMAND" == "R1" ]]; then
    echo "Error: design R1 is skipped by PLAN-008 and cannot be executed" >&2
    exit "$EXIT_INPUT_ERROR"
  fi
  if [[ "$TYPE" == "normalization" && "$SUBCOMMAND" == "R1" ]]; then
    echo "Error: normalization R1 is skipped by PLAN-008 and cannot be executed" >&2
    exit "$EXIT_INPUT_ERROR"
  fi
  if [[ "$TYPE" == "upgrade" && "$SUBCOMMAND" == "rgc" ]]; then
    echo "Error: upgrade RGC is skipped by PLAN-008; use R4 routing instead" >&2
    exit "$EXIT_INPUT_ERROR"
  fi

  if [[ -n "$SCRUM_HYPOTHESIS" && "$FROM_SCRUM" != true ]]; then
    echo "Error: --scrum-hypothesis is valid only with --from-scrum" >&2
    exit "$EXIT_INPUT_ERROR"
  fi

  if [[ "$FROM_SCRUM" == true ]]; then
    if [[ -z "$SCRUM_HYPOTHESIS" ]]; then
      echo "Error: --from-scrum requires --scrum-hypothesis <id>" >&2
      exit "$EXIT_INPUT_ERROR"
    fi
    case "$SUBCOMMAND" in
      run|R0) ;;
      *)
        echo "Error: --from-scrum is valid only with reverse run or R0" >&2
        exit "$EXIT_INPUT_ERROR"
        ;;
    esac
    resolve_from_scrum_route
  fi
}

resolve_from_scrum_route() {
  local route_lines
  mapfile -t route_lines < <(
    reverse_local_py $'import sys\nfrom cli.lib.scrum_to_reverse_routing import route_scrum_to_reverse\nreverse_type, rating = route_scrum_to_reverse(sys.argv[1])\nprint(reverse_type)\nprint(rating)' \
      "$SCRUM_HYPOTHESIS"
  )
  local resolved_type="${route_lines[0]:-}"
  local resolved_rating="${route_lines[1]:-}"
  if [[ -z "$resolved_type" || -z "$resolved_rating" ]]; then
    echo "Error: failed to resolve Scrum routing for hypothesis '$SCRUM_HYPOTHESIS'" >&2
    exit "$EXIT_CHECK_FAILED"
  fi
  if [[ "$TYPE_EXPLICIT" == true && "$TYPE" != "$resolved_type" ]]; then
    echo "Error: scrum hypothesis '$SCRUM_HYPOTHESIS' routes to reverse type '$resolved_type' ($resolved_rating), but explicit type '$TYPE' was provided" >&2
    exit "$EXIT_INPUT_ERROR"
  fi
  TYPE="$resolved_type"
  SCRUM_ROUTE_RATING="$resolved_rating"
}

ensure_helix_dir() {
