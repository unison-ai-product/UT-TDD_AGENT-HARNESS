state = json.loads(state_path.read_text(encoding="utf-8"))

rules = index.get("rules", {})
roots = rules.get("roots", {}) if isinstance(rules.get("roots"), dict) else {}
path_mapping = rules.get("path_mapping", {}) if isinstance(rules.get("path_mapping"), dict) else {}

heading_requirements = {}
for item in rules.get("deliverables", []):
    if not isinstance(item, dict):
        continue
    did = item.get("id")
    if not isinstance(did, str):
        continue
    required = []
    for validator in item.get("validators", []):
        if not isinstance(validator, dict):
            continue
        if validator.get("type") != "heading_check":
            continue
        params = validator.get("params", {})
        if isinstance(params, dict):
            values = params.get("required", [])
            if isinstance(values, list):
                required.extend([str(x) for x in values if isinstance(x, str)])
    heading_requirements[did] = required


def render(template: str, values: dict[str, str]) -> str:
    return re.sub(r"{([a-zA-Z0-9_]+)}", lambda m: str(values.get(m.group(1), m.group(0))), template)


features = index.get("features", {})
for feature_id, feature in features.items():
    if not isinstance(feature, dict):
        continue
    requires = feature.get("requires", {})
    if not isinstance(requires, dict):
        continue

    docs_root = str(roots.get("docs_root", "docs"))
    src_root = str(roots.get("src_root", "src"))
    docs_scope_root = str(feature.get("docs_root", f"{docs_root}/features/{feature_id}"))
    src_scope_root = str(feature.get("src_root", f"{src_root}/features/{feature_id}"))

    ordered = []
    for layer in ("L1", "L2", "L3", "L4", "L5", "L6", "L7", "L8"):
        values = requires.get(layer, [])
        if not isinstance(values, list):
            continue
        for did in values:
            if isinstance(did, str) and did not in ordered:
                ordered.append(did)

    for did in ordered:
        mapping = path_mapping.get(did, {})
        if not isinstance(mapping, dict):
            continue
        template = mapping.get("primary_path")
        if not isinstance(template, str) or not template:
            continue
        default_filename = "manifest.json"
        defaults = mapping.get("default_filenames", [])
        if isinstance(defaults, list) and defaults:
            default_filename = str(defaults[0])
        context = {
            "docs_root": docs_root,
            "src_root": src_root,
            "infra_root": str(roots.get("infra_root", "infra")),
            "state_root": str(roots.get("state_root", ".helix/state")),
            "runtime_root": str(roots.get("runtime_root", ".helix/runtime")),
            "scope_id": feature_id,
            "deliverable_id": did,
            "docs_scope_root": docs_scope_root,
            "src_scope_root": src_scope_root,
            "filename": default_filename,
        }
        rel = render(template, context)
        path = root / rel
        path.parent.mkdir(parents=True, exist_ok=True)
        headings = heading_requirements.get(did, [])
        body = [f"# {did}", "seed content"]
        body.extend([f"## {h}" for h in headings])
        path.write_text("\n".join(body) + "\n", encoding="utf-8")

state_features = state.get("features", {})
if isinstance(state_features, dict):
