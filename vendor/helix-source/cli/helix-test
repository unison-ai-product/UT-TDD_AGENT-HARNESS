#!/bin/bash
set -euo pipefail

# helix-test: HELIX CLI 全ツールのセルフテスト
# Usage: helix-test

RUN_CORE_TESTS=1
RUN_BATS_TESTS=1
RUN_PYTEST_TESTS=1
BATS_STRICT=0
PYTEST_STRICT=0

if [[ "${HELIX_TEST_SELF_CHECK_ONLY:-0}" == "1" ]]; then
  RUN_CORE_TESTS=0
fi

while [[ $# -gt 0 ]]; do
  case "$1" in
    --help|-h)
      echo "Usage: helix test [--no-bats] [--no-pytest] [--bats-only] [--bats-strict] [--pytest-strict]"
      echo ""
      echo "HELIX CLI 全ツールのセルフテストを実行します。"
      echo "  --no-pytest  pytest テストを実行しない"
      echo "  --no-bats     bats テストを実行しない"
      echo "  --bats-only   bats テストのみ実行する"
      echo "  --bats-strict bats 未導入時を FAIL 扱いにする"
      echo "  --pytest-strict pytest 未導入時を FAIL 扱いにする"
      exit 0
      ;;
    --no-pytest)
      RUN_PYTEST_TESTS=0
      ;;
    --no-bats)
      RUN_BATS_TESTS=0
      ;;
    --bats-only)
      RUN_CORE_TESTS=0
      RUN_PYTEST_TESTS=0
      RUN_BATS_TESTS=1
      ;;
    --bats-strict)
      BATS_STRICT=1
      ;;
    --pytest-strict)
      PYTEST_STRICT=1
      ;;
    *)
      echo "エラー: 不明なオプション '$1'" >&2
      echo "使い方: helix test [--no-bats] [--no-pytest] [--bats-only] [--bats-strict] [--pytest-strict]" >&2
      exit 2
      ;;
  esac
  shift
done

source "$(cd "$(dirname "$0")" && pwd)/lib/helix-common.sh"

SHELL_PASS=0
SHELL_FAIL=0
ERRORS=()
PYTEST_PASS=0
PYTEST_FAIL=0
PYTEST_SKIP=0
PYTEST_STATUS="not-run"
BATS_PASS=0
BATS_FAIL=0
BATS_SKIP=0
BATS_STATUS="not-run"
CODEX_BOOTSTRAP_RUNBOOK="docs/runbook/codex-test-bootstrap.md"

emit_missing_dep_warning() {
  local dep_name="$1"
  [[ "${HELIX_CODEX_INTERNAL:-0}" == "1" ]] || return 0
  echo "[helix-test] WARNING: ${dep_name} not found, see ${CODEX_BOOTSTRAP_RUNBOOK}" >&2
}

# run_test* helpers: $cmd は本ファイル内で定義した固定テストケース文字列のみ。
# 外部入力は通らないため eval 注入リスクなし (CLAUDE.md コーディング規約)。
run_test() {
  local name="$1"
  local cmd="$2"
  local expect_exit="${3:-0}"
  printf "  %-40s " "$name"
  set +e
  output=$(eval "$cmd" 2>&1 </dev/null)
  actual_exit=$?
  set -e
  if [[ "$actual_exit" -eq "$expect_exit" ]]; then
    echo "PASS"
    SHELL_PASS=$((SHELL_PASS + 1))
  else
    echo "FAIL (exit=$actual_exit, expected=$expect_exit)"
    ERRORS+=("$name: $output")
    SHELL_FAIL=$((SHELL_FAIL + 1))
  fi
}

run_test_contains() {
  local name="$1"
  local cmd="$2"
  local pattern="$3"
  printf "  %-40s " "$name"
  set +e
  output=$(eval "$cmd" 2>&1 </dev/null)
  set -e
  if echo "$output" | grep -q "$pattern"; then
    echo "PASS"
    SHELL_PASS=$((SHELL_PASS + 1))
  else
    echo "FAIL (pattern '$pattern' not found)"
    ERRORS+=("$name: output=$output")
    SHELL_FAIL=$((SHELL_FAIL + 1))
  fi
}

run_test_not_contains() {
  local name="$1"
  local cmd="$2"
  local pattern="$3"
  printf "  %-40s " "$name"
  set +e
  output=$(eval "$cmd" 2>&1 </dev/null)
  set -e
  if echo "$output" | grep -q "$pattern"; then
    echo "FAIL (pattern '$pattern' was found)"
    ERRORS+=("$name: output=$output")
    SHELL_FAIL=$((SHELL_FAIL + 1))
  else
    echo "PASS"
    SHELL_PASS=$((SHELL_PASS + 1))
  fi
}

run_test_json_valid() {
  local name="$1"
  local cmd="$2"
  printf "  %-40s " "$name"
  set +e
  eval "$cmd" >/dev/null 2>&1
  local actual_exit=$?
  set -e
  if [[ "$actual_exit" -eq 0 ]]; then
    echo "PASS"
    SHELL_PASS=$((SHELL_PASS + 1))
  else
    echo "FAIL (invalid json or command error, exit=$actual_exit)"
    ERRORS+=("$name: json validation failed")
    SHELL_FAIL=$((SHELL_FAIL + 1))
  fi
}

run_pytest_tests() {
  local pytest_output pytest_rc
  if ! python3 -c "import pytest" >/dev/null 2>&1; then
    emit_missing_dep_warning "pytest"
    PYTEST_STATUS="skipped (pytest not installed)"
    PYTEST_SKIP=1
    if [[ "$PYTEST_STRICT" -eq 1 ]]; then
      PYTEST_FAIL=1
      ERRORS+=("pytest: pytest モジュールが未導入です（--pytest-strict）")
      return 1
    fi
    return 0
  fi

  echo "[pytest]"
  set +e
  pytest_output="$(python3 -m pytest "$SCRIPT_DIR/lib/tests/" -q --tb=short 2>&1)"
  pytest_rc=$?
  set -e
  echo "$pytest_output"

  PYTEST_PASS=$(printf '%s\n' "$pytest_output" | grep -Eo '[0-9]+ passed' | awk '{sum += $1} END {print (sum+0)}')
  PYTEST_FAIL=$(printf '%s\n' "$pytest_output" | grep -Eo '[0-9]+ failed' | awk '{sum += $1} END {print (sum+0)}')
  PYTEST_SKIP=$(printf '%s\n' "$pytest_output" | grep -Eo '[0-9]+ skipped' | awk '{sum += $1} END {print (sum+0)}')
  PYTEST_STATUS="done"
  if [[ "$pytest_rc" -ne 0 ]]; then
    ERRORS+=("pytest: one or more tests failed")
    return 1
  fi
  return 0
}

run_bats_tests() {
  local bats_bin
  bats_bin="$(command -v bats || true)"
  if [[ -z "$bats_bin" ]]; then
    emit_missing_dep_warning "bats"
    BATS_STATUS="skipped (bats not installed)"
    BATS_SKIP=1
    if [[ "$BATS_STRICT" -eq 1 ]]; then
      BATS_FAIL=1
      ERRORS+=("bats: bats コマンドが未導入です（--bats-strict）")
      return 1
    fi
    return 0
  fi

  echo "[bats]"
  local bats_output bats_rc bats_tmp_root
  bats_tmp_root="$(mktemp -d /tmp/helix-bats-run-XXXXXX)"
  set +e
  bats_output="$(
    env -i \
      PATH="$PATH" \
      HOME="${HOME:-/tmp}" \
      TERM="${TERM:-dumb}" \
      TMPDIR="$bats_tmp_root" \
      PYTHONIOENCODING="utf-8" \
      PYTHONUTF8="1" \
      GIT_CONFIG_COUNT="2" \
      GIT_CONFIG_KEY_0="core.autocrlf" \
      GIT_CONFIG_VALUE_0="false" \
      GIT_CONFIG_KEY_1="core.safecrlf" \
      GIT_CONFIG_VALUE_1="false" \
      "$bats_bin" "$SCRIPT_DIR/tests/"*.bats 2>&1
  )"
  bats_rc=$?
  set -e
  rm -rf "$bats_tmp_root"
  echo "$bats_output"

  BATS_PASS=$(printf '%s\n' "$bats_output" | grep -Ec '^ok [0-9]+' || true)
  BATS_FAIL=$(printf '%s\n' "$bats_output" | grep -Ec '^not ok [0-9]+' || true)
  BATS_STATUS="done"
  if [[ "$bats_rc" -ne 0 ]]; then
    ERRORS+=("bats: one or more tests failed")
    return 1
  fi
  return 0
}

run_bats_cleanup_post_run_hook() {
  [[ "$RUN_BATS_TESTS" -eq 1 ]] || return 0
  [[ -x "$SCRIPT_DIR/helix" ]] || return 0
  [[ "${RUN_BATS_CLEANUP_POST_RUN_DONE:-0}" -eq 0 ]] || return 0
  RUN_BATS_CLEANUP_POST_RUN_DONE=1

  local cleanup_output cleanup_rc cleanup_count
  set +e
  cleanup_output="$("$SCRIPT_DIR/helix" bats-cleanup --list 2>&1)"
  cleanup_rc=$?
  set -e

  if [[ "$cleanup_rc" -ne 0 ]]; then
    echo "[helix-test] WARN: bats-cleanup post-run hook failed: $cleanup_output" >&2
    return 0
  fi

  cleanup_count=$(printf '%s\n' "$cleanup_output" | grep -Ec '^/tmp/bats-(run|test)-' || true)
  if [[ "$cleanup_count" -ge 5 ]]; then
    echo "[helix-test] WARNING: bats cleanup candidates remain (${cleanup_count})."
    echo "[helix-test] Review 'helix bats-cleanup --list', then run 'helix bats-cleanup --delete --older-than <N>' only for confirmed targets."
    echo "[helix-test] See docs/runbook/bats-cleanup-routine.md"
  fi
}

finish_and_exit() {
  run_bats_cleanup_post_run_hook

  local total_fail
  total_fail=$((SHELL_FAIL + PYTEST_FAIL + BATS_FAIL))
  echo "==================================="
  echo "Results: $SHELL_PASS passed, $SHELL_FAIL failed (shell-based)"
  echo "pytest: $PYTEST_PASS passed, $PYTEST_FAIL failed, $PYTEST_SKIP skipped ($PYTEST_STATUS)"
  echo "bats: $BATS_PASS passed, $BATS_FAIL failed, $BATS_SKIP skipped ($BATS_STATUS)"
  echo "==================================="

  if [[ $total_fail -gt 0 ]]; then
    echo ""
    echo "Failures:"
    for err in "${ERRORS[@]}"; do
      echo "  - $err" | head -c 200
      echo ""
    done
    exit 1
  fi

  exit 0
}

