run_test "v5 to v6 migration adds stdout/stderr columns" "python3 -c 'import sqlite3, sys, tempfile, os; sys.path.insert(0, \"$SCRIPT_DIR/lib\"); import helix_db
with tempfile.TemporaryDirectory() as d:
    db=os.path.join(d,\"v5.db\")
    c=sqlite3.connect(db)
    c.executescript(helix_db.SCHEMA_VERSION_SCHEMA)
    c.execute(\"CREATE TABLE skill_usage (id INTEGER PRIMARY KEY AUTOINCREMENT, task_text TEXT NOT NULL, skill_id TEXT NOT NULL, outcome TEXT)\")
    c.execute(\"INSERT INTO skill_usage (task_text, skill_id, outcome) VALUES (?, ?, ?)\", (\"t\",\"x/y\",\"delegated\"))
    c.execute(\"DELETE FROM schema_version\")
    c.execute(\"INSERT INTO schema_version (version, applied_at) VALUES (5, datetime(\\\"now\\\"))\")
    c.commit()
    helix_db.migrate(c)
    cols={r[1] for r in c.execute(\"PRAGMA table_info(skill_usage)\")}
    assert \"result_stdout\" in cols, f\"missing result_stdout: {cols}\"
    assert \"result_stderr\" in cols, f\"missing result_stderr: {cols}\"
    v=c.execute(\"SELECT MAX(version) FROM schema_version\").fetchone()[0]
    assert v == helix_db.CURRENT_SCHEMA_VERSION, f\"expected {helix_db.CURRENT_SCHEMA_VERSION}, got {v}\"
    row=c.execute(\"SELECT task_text, skill_id FROM skill_usage\").fetchone()
    assert row == (\"t\",\"x/y\"), f\"data not preserved: {row}\"
    c.close()
'"
