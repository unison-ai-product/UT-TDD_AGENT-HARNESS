#!/bin/bash
set -euo pipefail

# helix-skill: スキル catalog の管理・表示・検索

HELIX_SKILL_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$HELIX_SKILL_DIR/lib/helix-common.sh"

LIB_DIR="$HELIX_SKILL_DIR/lib"
CATALOG_PY="$LIB_DIR/skill_catalog.py"
CLASSIFY_RUNNER_PY="$LIB_DIR/skill_classify_runner.py"
RECOMMENDER_PY="$LIB_DIR/skill_recommender.py"
DISPATCHER_MODULE="lib.skill_dispatcher"
CACHE_PATH="$PROJECT_ROOT/.helix/cache/skill-catalog.json"
JSONL_CACHE_PATH="$PROJECT_ROOT/.helix/cache/skill-catalog.jsonl"
RECOMMEND_CACHE_DIR="$PROJECT_ROOT/.helix/cache/recommendations"
SKILLS_ROOT="${HELIX_SKILLS_ROOT:-${HELIX_HOME:-$HOME/ai-dev-kit-vscode}/skills}"
TASK_CATALOG_PATH="$HELIX_SKILL_DIR/templates/task-catalog.yaml"
SKILL_TELEMETRY_SUBCOMMAND=""
SKILL_TELEMETRY_TASK_ID=""
SKILL_TELEMETRY_SKILL_ID=""
SKILL_TELEMETRY_DRY_RUN="false"
SKILL_TELEMETRY_FORCE_AGENT=""

# bash↔Python 境界で巨大 JSON を受け渡すヘルパー。
# 使用例:
#   run_py_with_json "$json" <<'PY'
#   import json, os
#   with open(os.environ["HELIX_PAYLOAD_FILE"], encoding="utf-8") as _f:
#       d = json.load(_f)
#   ...
#   PY
# ARG_MAX 回避のため一時ファイル経由。env var には path だけ入る。
run_py_with_json() {
  local json="$1"
  local tmpf rc
  tmpf=$(mktemp "${TMPDIR:-/tmp}/helix-skill-payload.XXXXXX") || return 3
  # 明示削除 (trap RETURN は dynamic scope で親関数の戻りも拾い set -u 下で誤発火するため使わない)
  if ! printf '%s' "$json" > "$tmpf"; then
    rm -f "$tmpf"
    return 3
  fi
  set +e
  HELIX_PAYLOAD_FILE="$tmpf" python3 -
  rc=$?
  set -e
  rm -f "$tmpf"
  return $rc
}

