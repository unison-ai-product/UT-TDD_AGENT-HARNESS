dispatcher_available() {
  (cd "$HELIX_SKILL_DIR" && python3 - <<'PY'
import importlib.util
import sys

spec = importlib.util.find_spec("lib.skill_dispatcher")
sys.exit(0 if spec is not None else 1)
PY
  )
}

run_dispatcher_dispatch() {
  local skill_id="$1"
  local task="$2"
  local dry_run="$3"
  local agent="$4"
  local references="$5"

  if ! dispatcher_available; then
    echo "エラー: skill_dispatcher が利用できません（lib.skill_dispatcher が未配置です）" >&2
    return 3
  fi

  local -a cmd=()
  if [[ -n "${HELIX_PARENT_INVOCATION_ID:-}" ]]; then
    cmd+=(env "HELIX_PARENT_INVOCATION_ID=${HELIX_PARENT_INVOCATION_ID}")
  fi
  cmd+=(
    python3 -m "$DISPATCHER_MODULE"
    --mode dispatch
    --skill-id "$skill_id"
    --task "$task"
    --json
  )
  if [[ "$dry_run" == "true" ]]; then
    cmd+=(--dry-run)
  fi
  if [[ -n "$agent" ]]; then
    cmd+=(--agent "$agent")
  fi
  if [[ -n "$references" ]]; then
    cmd+=(--references "$references")
  fi

  local output err_file rc
  err_file=$(mktemp "${TMPDIR:-/tmp}/helix-skill-err.XXXXXX") || return 3
  set +e
  output=$(cd "$HELIX_SKILL_DIR" && "${cmd[@]}" 2>"$err_file")
  rc=$?
  set -e
  if [[ $rc -ne 0 ]]; then
    echo "エラー: skill_dispatcher の実行に失敗しました (exit=$rc)" >&2
    [[ -s "$err_file" ]] && cat "$err_file" >&2
    rm -f "$err_file"
    # dispatcher の exit code をそのまま伝搬 (7=unknown skill / 5=timeout / 3=prereq 等)
    return $rc
  fi
  # dispatcher からの警告 (path traversal 拒否等) は stderr に出ているので転送
  [[ -s "$err_file" ]] && cat "$err_file" >&2
  rm -f "$err_file"

  if ! printf '%s' "$output" | python3 -c 'import json,sys; json.load(sys.stdin)' >/dev/null 2>&1; then
    echo "エラー: skill_dispatcher の応答 JSON を解析できませんでした" >&2
    return 4
  fi

  printf '%s\n' "$output"
}

record_invocation_telemetry() {
  local exit_code="$1"
  local db_path="${HELIX_DIR}/helix.db"
  local parent_invocation_id=""
  local decision="failed"
  local payload=""
  local task_id="${SKILL_TELEMETRY_TASK_ID:-${SKILL_TELEMETRY_SUBCOMMAND:-skill}}"
  local skill_id="${SKILL_TELEMETRY_SKILL_ID:-}"
  local subcommand="${SKILL_TELEMETRY_SUBCOMMAND:-}"

  if [[ $exit_code -eq 0 ]]; then
    decision="passed"
  fi
  if [[ "${HELIX_PARENT_INVOCATION_ID:-}" =~ ^[0-9]+$ ]]; then
    parent_invocation_id="${HELIX_PARENT_INVOCATION_ID}"
  fi

  payload="$(
    HELIX_INVOCATION_TYPE="skill" \
    HELIX_INVOCATION_ROLE="recommender" \
    HELIX_INVOCATION_MODEL="" \
    HELIX_INVOCATION_TASK_ID="$task_id" \
    HELIX_INVOCATION_DECISION="$decision" \
    HELIX_INVOCATION_PARENT_ID="$parent_invocation_id" \
    HELIX_INVOCATION_SKILL_ID="$skill_id" \
    HELIX_INVOCATION_SUBCOMMAND="$subcommand" \
    HELIX_INVOCATION_DRY_RUN="${SKILL_TELEMETRY_DRY_RUN:-false}" \
    HELIX_INVOCATION_FORCE_AGENT="${SKILL_TELEMETRY_FORCE_AGENT:-}" \
    python3 - <<'PY'
import json
import os


def _bool_env(name):
    return os.environ.get(name, "").lower() == "true"


payload = {
    "type": os.environ["HELIX_INVOCATION_TYPE"],
    "role": os.environ.get("HELIX_INVOCATION_ROLE") or None,
    "model": os.environ.get("HELIX_INVOCATION_MODEL") or None,
    "task_id": os.environ.get("HELIX_INVOCATION_TASK_ID") or None,
    "decision": os.environ.get("HELIX_INVOCATION_DECISION") or None,
    "parent_invocation_id": int(os.environ["HELIX_INVOCATION_PARENT_ID"])
    if os.environ.get("HELIX_INVOCATION_PARENT_ID", "").isdigit()
    else None,
}
payload["raw_meta"] = {
    "role": payload["role"],
    "model": payload["model"],
    "task_id": payload["task_id"],
    "skill_id": os.environ.get("HELIX_INVOCATION_SKILL_ID") or None,
    "subcommand": os.environ.get("HELIX_INVOCATION_SUBCOMMAND") or None,
    "dry_run": _bool_env("HELIX_INVOCATION_DRY_RUN"),
    "force_agent": os.environ.get("HELIX_INVOCATION_FORCE_AGENT") or None,
}
print(json.dumps(payload, ensure_ascii=False))
PY
  )" || return 0

  python3 "$HELIX_SKILL_DIR/lib/helix_db.py" record-invocation "$db_path" "$payload" >/dev/null 2>&1 || true
}

print_dispatch_dry_run() {
  local payload="$1"
  run_py_with_json "$payload" <<'PY'
import json
import os
import pathlib
import sys

with open(os.environ["HELIX_PAYLOAD_FILE"], encoding="utf-8") as _f:
    d = json.load(_f)

skill_id = str(d.get("skill_id") or d.get("skill", {}).get("id") or "")
agent = d.get("agent") if isinstance(d.get("agent"), dict) else {}
agent_invoke = str(agent.get("invoke") or d.get("recommended_agent") or "")
agent_type = str(agent.get("type") or "")
is_claude_native = bool(agent.get("is_claude_native", False))

refs = d.get("references")
if not isinstance(refs, list):
    refs = []
refs = [str(ref).strip() for ref in refs if str(ref).strip()]

bundle = d.get("context_bundle")
bundle_path = ""
bundle_size = d.get("context_bundle_lines") or d.get("context_bundle_size")

if isinstance(bundle, dict):
    bundle_path = str(bundle.get("path") or "")
    for key in ("line_count", "lines", "size", "size_lines", "line_size"):
        value = bundle.get(key)
        if isinstance(value, int):
            bundle_size = value
            break

if not bundle_path:
    bundle_path = str(d.get("context_bundle_path") or "")

if not isinstance(bundle_size, int) and isinstance(bundle, str):
    bundle_size = bundle.count("\n") + 1

size_text = str(bundle_size) if isinstance(bundle_size, int) else "unknown"

print(f"スキル: {skill_id}")
print(f"委譲先: {agent_invoke} ({agent_type}, is_claude_native={str(is_claude_native).lower()})")
print(f"参考資料 ({len(refs)}):")
for ref in refs:
    print(f"  - {ref}")
print(f"コンテキスト束: {size_text} 行")
print("(dry-run モード — 実行しません)")
PY
}

print_dispatch_execute() {
  local payload="$1"
  run_py_with_json "$payload" <<'PY'
import json
import os
import sys

with open(os.environ["HELIX_PAYLOAD_FILE"], encoding="utf-8") as _f:
    d = json.load(_f)
agent = d.get("agent") if isinstance(d.get("agent"), dict) else {}
agent_invoke = str(agent.get("invoke") or d.get("recommended_agent") or "").strip()
agent_type = str(agent.get("type") or "").strip()

is_codex = agent_type == "codex" or agent_invoke == "codex"

stdout = ""
for source in (
    d.get("execution"),
    d.get("result"),
):
    if isinstance(source, dict) and isinstance(source.get("stdout"), str):
        stdout = source.get("stdout", "")
        if stdout:
            break
if not stdout and isinstance(d.get("stdout"), str):
    stdout = d.get("stdout", "")

usage_id = str(
    d.get("usage_id")
    or (d.get("usage", {}).get("id") if isinstance(d.get("usage"), dict) else "")
    or ""
).strip()

bundle_path = ""
bundle = d.get("context_bundle")
if isinstance(bundle, dict):
    bundle_path = str(bundle.get("path") or "")
elif isinstance(bundle, str):
    bundle_path = bundle
if not bundle_path:
    bundle_path = str(d.get("context_bundle_path") or "").strip()

if is_codex:
    if stdout.strip():
        print(stdout.rstrip())
    if usage_id:
        print(f"usage_id: {usage_id}")
    raise SystemExit(0)

if agent_invoke:
    # agent_invoke は既に "helix-codex --role X" 等の実行表現に正規化されている
    print(f"{agent_invoke} を呼び出してください")
else:
    print("@subagent を呼び出してください")
if bundle_path:
    print(f"context_bundle: {bundle_path}")
if usage_id:
    print(f"usage_id: {usage_id}")
PY
}

use_skill() {
  local skill_id="$1"
  local task="$2"
  local dry_run="$3"
  local as_json="$4"
  local force_agent="$5"
  shift 5
  # 残り引数は references 配列（各要素を独立して検証可能、, を含むパスも安全）
  local -a refs_array=("$@")

  # dispatcher への受け渡しは CSV だが、事前に安全性チェック:
  #   - bash 側 path traversal 検証 (2 層防御、dispatcher 側に加えて)
  #   - ref にカンマが含まれる場合は警告してスキップ
  local -a safe_refs=()
  local r
  for r in "${refs_array[@]}"; do
    if [[ -z "$r" ]]; then
      continue
    fi
    if [[ "$r" == *,* ]]; then
      echo "警告: reference にカンマが含まれるためスキップしました: $r" >&2
      continue
    fi
    if [[ "$r" == /* ]]; then
      echo "警告: 絶対パス指定の reference は拒否しました (bash 側): $r" >&2
      continue
    fi
    if [[ "$r" == *..* ]]; then
      echo "警告: parent 参照を含む reference は拒否しました (bash 側): $r" >&2
      continue
    fi
    safe_refs+=("$r")
  done
  local force_references=""
  if [[ ${#safe_refs[@]} -gt 0 ]]; then
    printf -v force_references '%s,' "${safe_refs[@]}"
    force_references="${force_references%,}"
  fi

  SKILL_TELEMETRY_SUBCOMMAND="use"
  SKILL_TELEMETRY_TASK_ID="$skill_id"
  SKILL_TELEMETRY_SKILL_ID="$skill_id"
  SKILL_TELEMETRY_DRY_RUN="$dry_run"
  SKILL_TELEMETRY_FORCE_AGENT="$force_agent"

  local dispatch_json
  dispatch_json=$(run_dispatcher_dispatch "$skill_id" "$task" "$dry_run" "$force_agent" "$force_references") || return $?

  if [[ "$as_json" == "true" ]]; then
    printf '%s\n' "$dispatch_json"
    return 0
  fi

  if [[ "$dry_run" == "true" ]]; then
    print_dispatch_dry_run "$dispatch_json"
  else
    print_dispatch_execute "$dispatch_json"
  fi
}

chain_skill() {
  local task="$1"
  local top_n="$2"
  local dry_run="$3"
  local force_agent="$4"
  local layer="$5"
  local category="$6"

  SKILL_TELEMETRY_SUBCOMMAND="chain"
  SKILL_TELEMETRY_TASK_ID="chain"
  SKILL_TELEMETRY_SKILL_ID=""
  SKILL_TELEMETRY_DRY_RUN="$dry_run"
  SKILL_TELEMETRY_FORCE_AGENT="$force_agent"

  local -a rec_cmd=()
  if [[ -n "${HELIX_PARENT_INVOCATION_ID:-}" ]]; then
    rec_cmd+=(env "HELIX_PARENT_INVOCATION_ID=${HELIX_PARENT_INVOCATION_ID}")
  fi
  rec_cmd+=(python3 "$RECOMMENDER_PY" --task "$task" --top-n "$top_n" --json)
  if [[ -n "$layer" ]]; then
    rec_cmd+=(--layer "$layer")
  fi
  if [[ -n "$category" ]]; then
    rec_cmd+=(--category "$category")
  fi

  local rec_json
  if ! rec_json=$("${rec_cmd[@]}" 2>/dev/null); then
    echo "エラー: スキル推挙に失敗しました" >&2
    return 3
  fi

  if ! printf '%s' "$rec_json" | python3 -c 'import json,sys; json.load(sys.stdin)' >/dev/null 2>&1; then
    echo "エラー: スキル推挙結果の JSON を解析できませんでした" >&2
    return 3
  fi

  # Python 側は JSON で構造化出力し、Bash 側は一時ファイル経由で個別フィールドを取り出す
  # (改行区切りでは summary/reason に改行が入ると列崩れするため)
  local parsed_json
  parsed_json=$(run_py_with_json "$rec_json" <<'PY'
import json
import os
with open(os.environ["HELIX_PAYLOAD_FILE"], encoding="utf-8") as _f:
    d = json.load(_f)
cands = d.get("candidates") or []
if cands:
    c = cands[0] if isinstance(cands[0], dict) else {}
    skill_id = (c.get("skill_id") or "").strip()
    agent = (c.get("recommended_agent") or "").strip()
    try:
        score = float(c.get("score", 0.0))
    except Exception:
        score = 0.0
    refs = c.get("references") or []
    if not isinstance(refs, list):
        refs = []
    refs = [str(x).strip() for x in refs if str(x).strip()]
    commands = c.get("commands") or []
    if not isinstance(commands, list):
        commands = []
    commands = [str(x).strip() for x in commands if str(x).strip()]
    out = {
        "has_candidate": True,
        "summary": (d.get("task_summary") or "").strip(),
        "skill_id": skill_id,
        "agent": agent,
        "score": score,
        "references": refs,
        "commands": commands,
        "selected_line": f"[{skill_id}] score {score:.2f}  agent: {agent}  commands: {' | '.join(commands) if commands else 'なし'}",
    }
else:
    out = {
        "has_candidate": False,
        "no_match_reason": (d.get("no_match_reason") or "該当スキルが見つかりませんでした。").strip(),
        "summary": (d.get("task_summary") or "").strip(),
    }
print(json.dumps(out, ensure_ascii=False))
PY
)

  # JSON から個別フィールドを抽出（一時ファイル経由で大 JSON にも耐える）
  local has_candidate
  has_candidate=$(run_py_with_json "$parsed_json" <<'PY'
import json, os
with open(os.environ["HELIX_PAYLOAD_FILE"], encoding="utf-8") as _f:
    d = json.load(_f)
print("1" if d.get("has_candidate") else "0")
PY
)

  if [[ "$has_candidate" != "1" ]]; then
    local reason
    reason=$(run_py_with_json "$parsed_json" <<'PY'
import json, os
with open(os.environ["HELIX_PAYLOAD_FILE"], encoding="utf-8") as _f:
    d = json.load(_f)
print(d.get("no_match_reason", "該当スキルが見つかりませんでした。"))
PY
)
    echo "=== 検索 ==="
    echo "検索: $task"
    echo "候補なし: $reason"
    return 0
  fi

  local summary selected_line skill_id selected_agent
  summary=$(run_py_with_json "$parsed_json" <<'PY'
import json, os
with open(os.environ["HELIX_PAYLOAD_FILE"], encoding="utf-8") as _f:
    print(json.load(_f).get("summary", ""))
PY
)
  selected_line=$(run_py_with_json "$parsed_json" <<'PY'
import json, os
with open(os.environ["HELIX_PAYLOAD_FILE"], encoding="utf-8") as _f:
    print(json.load(_f).get("selected_line", ""))
PY
)
  skill_id=$(run_py_with_json "$parsed_json" <<'PY'
import json, os
with open(os.environ["HELIX_PAYLOAD_FILE"], encoding="utf-8") as _f:
    print(json.load(_f).get("skill_id", ""))
PY
)
  selected_agent=$(run_py_with_json "$parsed_json" <<'PY'
import json, os
with open(os.environ["HELIX_PAYLOAD_FILE"], encoding="utf-8") as _f:
    print(json.load(_f).get("agent", ""))
PY
)

  # references を bash 配列として受け取る（改行区切り、空行は除外）
  local -a refs_array=()
  local refs_nl
  refs_nl=$(run_py_with_json "$parsed_json" <<'PY'
import json, os
with open(os.environ["HELIX_PAYLOAD_FILE"], encoding="utf-8") as _f:
    for r in json.load(_f).get("references", []) or []:
        if r and "\n" not in r:
            print(r)
PY
)
  if [[ -n "$refs_nl" ]]; then
    mapfile -t refs_array <<< "$refs_nl"
  fi

  if [[ -z "$summary" ]]; then
    summary="$task"
  fi

  local use_agent="$force_agent"
  if [[ -z "$use_agent" ]]; then
    use_agent="$selected_agent"
  fi

  echo "=== 検索 ==="
  echo "検索: $summary"
  echo "選定: $selected_line"
  echo ""
  echo "=== 委譲 ==="

  use_skill "$skill_id" "$task" "$dry_run" "false" "$use_agent" "${refs_array[@]}"
}

rebuild_catalog() {
  local auto_classify="${1:-false}"
  local only_pending="${2:-false}"
  local dry_run="${3:-false}"

  local output
  if ! output=$(python3 "$CATALOG_PY" build "$SKILLS_ROOT" "$CACHE_PATH" 2>/dev/null); then
