search_skills() {
  local task="$1"
  local top_n="$2"
  local layer="$3"
  local category="$4"
  local phase="$5"
  local as_json="$6"
  local no_cache="$7"
  local no_jsonl="$8"

  python3 - "$LIB_DIR" "$task" "$top_n" "$layer" "$category" "$phase" "$as_json" "$no_cache" "$no_jsonl" "$CACHE_PATH" "$JSONL_CACHE_PATH" "$RECOMMEND_CACHE_DIR" <<'PY'
import json
import sys
from pathlib import Path

lib_dir = Path(sys.argv[1])
task = sys.argv[2]
top_n = int(sys.argv[3])
layer = sys.argv[4] or None
category = sys.argv[5] or None
phase = sys.argv[6] or None
as_json = sys.argv[7] == "true"
no_cache = sys.argv[8] == "true"
no_jsonl = sys.argv[9] == "true"
catalog_path = Path(sys.argv[10])
jsonl_catalog_path = Path(sys.argv[11])
cache_dir = Path(sys.argv[12])

sys.path.insert(0, str(lib_dir))
import skill_recommender  # type: ignore

phase_filter = [part.strip() for part in (phase or "").split(",") if part.strip()] or None

try:
    result = skill_recommender.recommend(
        task_text=task,
        top_n=top_n,
        layer_filter=layer,
        category_filter=category,
        catalog_path=catalog_path,
        jsonl_catalog_path=jsonl_catalog_path,
        cache_dir=cache_dir,
        phase_filter=phase_filter,
        use_no_jsonl=no_jsonl,
        force_refresh=no_cache,
    )
except skill_recommender.RecommenderError as exc:
    print(f"エラー: {exc}", file=sys.stderr)
    raise SystemExit(exc.code)

if as_json:
    print(json.dumps(result, ensure_ascii=False, indent=2))
    raise SystemExit(0)

summary = (result.get("task_summary") or task).strip()
print(f"検索: {summary}")
print("")

candidates = result.get("candidates") or []
if not candidates:
    reason = (result.get("no_match_reason") or "該当スキルが見つかりませんでした。").strip()
    print(f"候補なし: {reason}")
    raise SystemExit(0)

for idx, cand in enumerate(candidates, start=1):
    skill_id = (cand.get("skill_id") or "").strip()
    score = float(cand.get("score", 0.0))
    agent = (cand.get("recommended_agent") or "").strip()
    reason = (cand.get("reason") or "").strip()
    refs = cand.get("references") if isinstance(cand.get("references"), list) else []
    refs = [str(ref).strip() for ref in refs if str(ref).strip()]
    commands = cand.get("commands") if isinstance(cand.get("commands"), list) else []
    commands = [str(command).strip() for command in commands if str(command).strip()]
    refs_text = ", ".join(refs) if refs else "なし"
    commands_text = " | ".join(commands) if commands else "なし"
    print(f"{idx}. [{skill_id}] score {score:.2f}  agent: {agent}")
    print(f"   reason: {reason}")
    print(f"   refs ({len(refs)}): {refs_text}")
    print(f"   関連コマンド: {commands_text}")
    if idx < len(candidates):
        print("")
PY
}

