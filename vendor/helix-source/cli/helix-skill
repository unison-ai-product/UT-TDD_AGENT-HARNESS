main() {
  local cmd="${1:---help}"
  shift || true
  SKILL_TELEMETRY_SUBCOMMAND="$cmd"
  SKILL_TELEMETRY_TASK_ID="$cmd"
  SKILL_TELEMETRY_SKILL_ID=""

  case "$cmd" in
    --help|-h|help)
      usage
      return 0
      ;;
    catalog)
      local sub="${1:-}"
      shift || true
      case "$sub" in
        rebuild)
          local auto_classify="false"
          local only_pending="false"
          local dry_run="false"
          while [[ $# -gt 0 ]]; do
            case "$1" in
              --auto-classify)
                auto_classify="true"
                shift
                ;;
              --only-pending)
                only_pending="true"
                shift
                ;;
              --dry-run)
                dry_run="true"
                shift
                ;;
              --help|-h)
                catalog_rebuild_usage
                return 0
                ;;
              *)
                echo "エラー: 不明なオプションです: $1" >&2
                catalog_rebuild_usage >&2
                return 64
                ;;
            esac
          done
          rebuild_catalog "$auto_classify" "$only_pending" "$dry_run"
          return $?
          ;;
        *)
          echo "エラー: 不明なサブコマンドです: catalog ${sub:-<none>}" >&2
          usage >&2
          return 64
          ;;
      esac
      ;;
    list)
      local layer=""
      local category=""
      local as_json="false"
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --layer)
            [[ $# -ge 2 ]] || { echo "エラー: --layer には値が必要です" >&2; return 64; }
            layer="$2"
            shift 2
            ;;
          --category)
            [[ $# -ge 2 ]] || { echo "エラー: --category には値が必要です" >&2; return 64; }
            category="$2"
            shift 2
            ;;
          --json)
            as_json="true"
            shift
            ;;
          *)
            echo "エラー: 不明なオプションです: $1" >&2
            return 64
            ;;
        esac
      done
      list_skills "$layer" "$category" "$as_json"
      return $?
      ;;
    show)
      [[ $# -ge 1 ]] || { echo "エラー: show には skill-id が必要です" >&2; return 64; }
      local skill_id="$1"
      shift
      local with_content="false"
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --with-content)
            with_content="true"
            shift
            ;;
          *)
            echo "エラー: 不明なオプションです: $1" >&2
            return 64
            ;;
        esac
      done
      show_skill "$skill_id" "$with_content"
      return $?
      ;;
    search)
      if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
        search_usage
        return 0
      fi
      [[ $# -ge 1 ]] || { echo "エラー: search にはタスク記述が必要です" >&2; search_usage >&2; return 64; }
      local task="$1"
      shift
      local top_n="5"
      local layer=""
      local category=""
      local phase=""
      local as_json="false"
      local no_cache="false"
      local no_jsonl="false"
      while [[ $# -gt 0 ]]; do
        case "$1" in
          -n)
            [[ $# -ge 2 ]] || { echo "エラー: -n には値が必要です" >&2; return 64; }
            top_n="$2"
            shift 2
            ;;
          --layer)
            [[ $# -ge 2 ]] || { echo "エラー: --layer には値が必要です" >&2; return 64; }
            layer="$2"
            shift 2
            ;;
          --category)
            [[ $# -ge 2 ]] || { echo "エラー: --category には値が必要です" >&2; return 64; }
            category="$2"
            shift 2
            ;;
          --phase)
            [[ $# -ge 2 ]] || { echo "エラー: --phase には値が必要です" >&2; return 64; }
            phase="$2"
            shift 2
            ;;
          --json)
            as_json="true"
            shift
            ;;
          --no-cache)
            no_cache="true"
            shift
            ;;
          --no-jsonl)
            no_jsonl="true"
            shift
            ;;
          --help|-h)
            search_usage
            return 0
            ;;
          *)
            echo "エラー: 不明なオプションです: $1" >&2
            return 64
            ;;
        esac
      done
      if [[ ! "$top_n" =~ ^[0-9]+$ ]] || [[ "$top_n" -le 0 ]]; then
        echo "エラー: -n には 1 以上の整数を指定してください" >&2
        return 64
      fi
      search_skills "$task" "$top_n" "$layer" "$category" "$phase" "$as_json" "$no_cache" "$no_jsonl"
      return $?
      ;;
    use)
      if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
        use_usage
        return 0
      fi
      [[ $# -ge 1 ]] || { echo "エラー: use には skill-id が必要です" >&2; use_usage >&2; return 64; }
      local skill_id="$1"
      shift
      SKILL_TELEMETRY_TASK_ID="$skill_id"
      SKILL_TELEMETRY_SKILL_ID="$skill_id"
      local task=""
      local dry_run="false"
      local as_json="false"
      local force_agent=""
      local force_references=""
      local auto_thinking="false"
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --task)
            [[ $# -ge 2 ]] || { echo "エラー: --task には値が必要です" >&2; return 64; }
            task="$2"
            shift 2
            ;;
          --agent)
            [[ $# -ge 2 ]] || { echo "エラー: --agent には値が必要です" >&2; return 64; }
            force_agent="$2"
            shift 2
            ;;
          --references)
            [[ $# -ge 2 ]] || { echo "エラー: --references には値が必要です" >&2; return 64; }
            force_references="$2"
            shift 2
            ;;
          --auto-thinking)
            auto_thinking="true"
            shift
            ;;
          --dry-run)
            dry_run="true"
            shift
            ;;
          --json)
            as_json="true"
            shift
            ;;
          --help|-h)
            use_usage
            return 0
            ;;
          *)
            echo "エラー: 不明なオプションです: $1" >&2
            return 64
            ;;
        esac
      done
      [[ -n "$task" ]] || { echo "エラー: --task は必須です" >&2; use_usage >&2; return 64; }
      if [[ "$auto_thinking" == "true" ]]; then
        export HELIX_SKILL_AUTO_THINKING=1
        echo "[auto-thinking] helix-skill use: Codex ロール選択時のみ effort classifier を適用" >&2
      fi
      # --references は CSV 入力を bash 配列に展開して use_skill に可変長で渡す
      # (use_skill 内で各要素を個別に検証 + 安全に dispatcher へ再エンコード)
      local -a cli_refs_array=()
      if [[ -n "$force_references" ]]; then
        IFS=',' read -ra cli_refs_array <<< "$force_references"
      fi
      use_skill "$skill_id" "$task" "$dry_run" "$as_json" "$force_agent" "${cli_refs_array[@]}"
      return $?
      ;;
    chain)
      if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
        chain_usage
        return 0
      fi
      [[ $# -ge 1 ]] || { echo "エラー: chain にはタスク記述が必要です" >&2; chain_usage >&2; return 64; }
      local task="$1"
      shift
      local top_n="1"
      local dry_run="false"
      local force_agent=""
      local layer=""
      local category=""
      while [[ $# -gt 0 ]]; do
        case "$1" in
          -n|--top-n)
            [[ $# -ge 2 ]] || { echo "エラー: $1 には値が必要です" >&2; return 64; }
            top_n="$2"
            shift 2
            ;;
          --dry-run)
            dry_run="true"
            shift
            ;;
          --agent)
            [[ $# -ge 2 ]] || { echo "エラー: --agent には値が必要です" >&2; return 64; }
            force_agent="$2"
            shift 2
            ;;
          --layer)
            [[ $# -ge 2 ]] || { echo "エラー: --layer には値が必要です" >&2; return 64; }
            layer="$2"
            shift 2
            ;;
          --category)
            [[ $# -ge 2 ]] || { echo "エラー: --category には値が必要です" >&2; return 64; }
            category="$2"
            shift 2
            ;;
          --help|-h)
            chain_usage
            return 0
            ;;
          *)
            echo "エラー: 不明なオプションです: $1" >&2
            return 64
            ;;
        esac
      done
      if [[ ! "$top_n" =~ ^[0-9]+$ ]] || [[ "$top_n" -le 0 ]]; then
        echo "エラー: -n/--top-n には 1 以上の整数を指定してください" >&2
        return 64
      fi
      chain_skill "$task" "$top_n" "$dry_run" "$force_agent" "$layer" "$category"
      return $?
      ;;
    classify)
      [[ $# -ge 1 ]] || { echo "エラー: classify には skill-id が必要です" >&2; classify_usage >&2; return 64; }
      local skill_id="$1"
      shift
      SKILL_TELEMETRY_TASK_ID="$skill_id"
      SKILL_TELEMETRY_SKILL_ID="$skill_id"
      local approve="false"
      local dry_run="false"
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --approve)
            approve="true"
            shift
            ;;
          --dry-run)
            dry_run="true"
            shift
            ;;
          --help|-h)
            classify_usage
            return 0
            ;;
          *)
            echo "エラー: 不明なオプションです: $1" >&2
            classify_usage >&2
            return 64
            ;;
        esac
      done
      classify_skill_entry "$skill_id" "$approve" "$dry_run"
      return $?
      ;;
    review-pending)
      local as_json="false"
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --json)
            as_json="true"
            shift
            ;;
          --help|-h)
            review_pending_usage
            return 0
            ;;
          *)
            echo "エラー: 不明なオプションです: $1" >&2
            review_pending_usage >&2
            return 64
            ;;
        esac
      done
      review_pending_skills "$as_json"
      return $?
      ;;
    approve)
      if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
        approve_usage
        return 0
      fi
      local skill_id=""
      local all_pending="false"
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --all-pending)
            all_pending="true"
            shift
            ;;
          --help|-h)
            approve_usage
            return 0
            ;;
          -*)
            echo "エラー: 不明なオプションです: $1" >&2
            approve_usage >&2
            return 64
            ;;
          *)
            if [[ -n "$skill_id" ]]; then
              echo "エラー: skill-id は 1 つだけ指定してください" >&2
              approve_usage >&2
              return 64
            fi
            skill_id="$1"
            shift
            ;;
        esac
      done
      if [[ -n "$skill_id" ]]; then
        SKILL_TELEMETRY_TASK_ID="$skill_id"
        SKILL_TELEMETRY_SKILL_ID="$skill_id"
      fi
      if [[ "$all_pending" == "true" && -n "$skill_id" ]]; then
        echo "エラー: --all-pending と skill-id は同時指定できません" >&2
        approve_usage >&2
        return 64
      fi
      if [[ "$all_pending" != "true" && -z "$skill_id" ]]; then
        echo "エラー: approve には skill-id か --all-pending が必要です" >&2
        approve_usage >&2
        return 64
      fi
      approve_skills "$skill_id" "$all_pending"
      return $?
      ;;
    stats)
      local days="30"
      local as_json="false"
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --days)
            [[ $# -ge 2 ]] || { echo "エラー: --days には値が必要です" >&2; return 64; }
            days="$2"
            shift 2
            ;;
          --json)
            as_json="true"
            shift
            ;;
          --help|-h)
            cat <<'USAGE'
使い方: helix skill stats [--days N] [--json]

直近 N 日間のスキル使用統計を表示する（デフォルト 30 日）。
USAGE
            return 0
            ;;
          *)
            echo "エラー: 不明なオプションです: $1" >&2
            return 64
            ;;
        esac
      done
      if [[ ! "$days" =~ ^[0-9]+$ ]]; then
        echo "エラー: --days には整数を指定してください" >&2
        return 64
      fi
      local -a stats_cmd=(python3 -m lib.skill_dispatcher --mode stats --days "$days")
      if [[ "$as_json" == "true" ]]; then
        stats_cmd+=(--json)
      fi
      (cd "$HELIX_SKILL_DIR" && "${stats_cmd[@]}")
      return $?
      ;;
    *)
      echo "エラー: 不明なサブコマンドです: $cmd" >&2
      usage >&2
      return 64
      ;;
  esac
}

main "$@"
status=$?
record_invocation_telemetry "$status"
exit "$status"
