#!/bin/bash
set -euo pipefail

# shellcheck source=cli/lib/helix-common.sh
source "$(cd "$(dirname "$0")" && pwd)/lib/helix-common.sh"

usage() {
  cat <<'USAGE'
使い方: helix observe <subcommand> [args...]

サブコマンド:
  log --event <name> --data <json> [--severity debug|info|warning|error|critical] [--source <name>]
            イベントログを記録
  metric --name <name> --value <num> [--tags k=v,k=v]
            メトリクスを記録
  report [--event <name>] [--metric <name>] [--since <iso>] [--until <iso>] [--limit N] [--format text|json]
            観測レポートを表示
  export [--event <name>] [--metric <name>] [--since <iso>] --format prometheus|json --output <path>
            ~/.helix/quarantine/ 配下へ観測データをエクスポート
USAGE
}

CMD="${1:-help}"
shift 2>/dev/null || true

case "$CMD" in
  log|metric|report|export)
    exec python3 "$SCRIPT_DIR/lib/observability_helper.py" \
      --db-path "$DB_PATH" \
      "$CMD" "$@"
    ;;
  help|-h|--help)
    usage
    ;;
  *)
    echo "エラー: 不明な observe subcommand: $CMD" >&2
    usage >&2
    exit 1
    ;;
esac
