#!/bin/bash
set -euo pipefail

# shellcheck source=cli/lib/helix-common.sh
source "$(cd "$(dirname "$0")" && pwd)/lib/helix-common.sh"

usage() {
  cat <<'USAGE'
Usage: helix audit <subcommand> [options]

Subcommands:
  preflight        Phase 0 preflight を一括実行
                   Options: [--repair] [--verify-only]
  a0 discover      A0 discovery を実行して decisions.yaml draft を生成
                   Options: --scope-hash <sha256> [--output <summary.log>] [--raw <raw.log>] [--draft <decisions.yaml>]
  a1 import        decisions.yaml を audit_decisions テーブルへ同期
                   Options: --file <decisions.yaml> [--dry-run]
  a1 verify-sync   decisions.yaml と audit_decisions の差分検証
                   Options: --file <decisions.yaml>
  a1 status        active な audit_decisions を表示
                   Options: [--candidate-id <id>]

exit code:
  0 = success
  1 = validation error
  2 = drift detected (verify-sync)
  3 = lock conflict
  4 = internal error
USAGE
}

require_value() {
  local opt="$1"
  local value="${2:-}"
  if [[ -z "$value" ]]; then
    echo "$opt requires a value" >&2
    exit 1
  fi
}

require_sha256() {
  local label="$1"
  local value="$2"
  if [[ ! "$value" =~ ^[a-f0-9]{64}$ ]]; then
    echo "$label must be sha256 hex 64 chars" >&2
    exit 1
  fi
}

observe_log() {
  "$SCRIPT_DIR/helix-observe" log "$@" >/dev/null 2>&1 || true
}

json_file_data() {
  python3 - "$1" <<'PY'
import json
import sys
print(json.dumps({"file": sys.argv[1]}, ensure_ascii=False))
PY
}

json_preflight_data() {
  python3 - "$1" "$2" <<'PY'
import json
import sys
print(json.dumps({"fail_closed": int(sys.argv[1]), "log_path": sys.argv[2]}, ensure_ascii=False))
PY
}

redact_to_log() {
  python3 "$SCRIPT_DIR/lib/redaction.py" --stream >>"$1"
}

run_setup_logged() {
  local log_path="$1" action="$2" component="$3" rc
  set +e
  "$SCRIPT_DIR/helix-setup" "$action" --name "$component" 2>&1 | redact_to_log "$log_path"
  rc="${PIPESTATUS[0]}"
  set -e
  return "$rc"
}

extract_discovery_path() {
  local label="$1"
  local text="$2"
  printf '%s\n' "$text" | awk -v label="${label}:" '$1 == label {sub("^[^:]+: ", ""); print; exit}'
}

cmd_preflight() {
  local repair=0 verify_only=0
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --repair)
        repair=1
        shift
        ;;
      --verify-only)
        verify_only=1
        shift
        ;;
      *)
        echo "Unknown: $1" >&2
        exit 4
        ;;
    esac
  done

  local components=("gitleaks" "gitignore-helix" "redaction-denylist")
  local head_short head_full timestamp log_rel log_path fail_closed=0
  head_short="$(git -C "$PROJECT_ROOT" rev-parse --short HEAD 2>/dev/null || echo no-git)"
  head_full="$(git -C "$PROJECT_ROOT" rev-parse HEAD 2>/dev/null || echo no-git)"
  timestamp="$(date +%s)"
  log_rel=".helix/audit/preflight-${head_short}-${timestamp}.log"
  log_path="$PROJECT_ROOT/$log_rel"
  mkdir -p "$(dirname "$log_path")"

  {
    echo "## preflight"
    echo "head_sha: $head_full"
    echo "started_at: $(date -u +%Y-%m-%dT%H:%M:%SZ)"
    echo ""
  } >"$log_path"

  local comp
  for comp in "${components[@]}"; do
    echo "### $comp" >>"$log_path"

    if [[ $verify_only -eq 1 ]]; then
      run_setup_logged "$log_path" verify "$comp" || fail_closed=$((fail_closed + 1))
    else
      if ! run_setup_logged "$log_path" verify "$comp"; then
        if [[ $repair -eq 1 ]]; then
          echo "  -> repair attempt" >>"$log_path"
          run_setup_logged "$log_path" repair "$comp" || fail_closed=$((fail_closed + 1))
        else
          echo "  -> install attempt" >>"$log_path"
          run_setup_logged "$log_path" install "$comp" || fail_closed=$((fail_closed + 1))
        fi
      fi
    fi
    echo "" >>"$log_path"
  done

  {
    echo "## summary"
    echo "fail_closed_count: $fail_closed"
    echo "completed_at: $(date -u +%Y-%m-%dT%H:%M:%SZ)"
  } >>"$log_path"

  observe_log \
    --event audit.preflight.completed \
    --data "$(json_preflight_data "$fail_closed" "$log_rel")" \
    --severity "$(if [[ $fail_closed -gt 0 ]]; then echo error; else echo info; fi)" \
    --source helix-audit

  cat "$log_path"

  if [[ $fail_closed -gt 0 ]]; then
    echo "" >&2
    echo "PREFLIGHT FAILED: $fail_closed component(s) need attention" >&2
    echo "  -> 詳細: $log_rel" >&2
    echo "  -> 修復: helix audit preflight --repair" >&2
    exit 1
  fi

  echo "PREFLIGHT OK ($((${#components[@]} - fail_closed))/${#components[@]} ready)" >&2
}

cmd_a0_discover() {
  local scope_hash="" output_path="" raw_path="" draft_path=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --scope-hash)
        require_value "$1" "${2:-}"
        scope_hash="$2"
        shift 2
        ;;
      --output)
        require_value "$1" "${2:-}"
        output_path="$2"
        shift 2
        ;;
      --raw)
        require_value "$1" "${2:-}"
        raw_path="$2"
        shift 2
        ;;
      --draft)
        require_value "$1" "${2:-}"
        draft_path="$2"
        shift 2
        ;;
      *)
        echo "Unknown: $1" >&2
        exit 4
        ;;
    esac
  done
  [[ -z "$scope_hash" ]] && { echo "--scope-hash required" >&2; exit 1; }
  require_sha256 "--scope-hash" "$scope_hash"

  [[ -z "$output_path" ]] && output_path="$PROJECT_ROOT/.helix/audit/inventory-summary-$(date +%s).log"
  [[ -z "$draft_path" ]] && draft_path="$PROJECT_ROOT/.helix/audit/decisions-draft.yaml"

  local discovery_output
  if [[ -n "$raw_path" ]]; then
    discovery_output=$("$SCRIPT_DIR/setup/inventory-discovery.sh" discover "$output_path" "$raw_path")
  else
    discovery_output=$("$SCRIPT_DIR/setup/inventory-discovery.sh" discover "$output_path")
  fi

  raw_path="$(extract_discovery_path raw "$discovery_output")"
  output_path="$(extract_discovery_path summary "$discovery_output")"
  if [[ -z "$raw_path" || -z "$output_path" ]]; then
    echo "inventory discovery did not report raw/summary paths" >&2
    exit 4
  fi

  mkdir -p "$(dirname "$draft_path")"
  python3 - "$SCRIPT_DIR/lib" "$output_path" "$raw_path" "$scope_hash" "$draft_path" <<'PY'
import sys
from pathlib import Path

sys.path.insert(0, sys.argv[1])
from audit_inventory import dump_decisions_yaml, generate_decisions_draft

summary_path = Path(sys.argv[2])
raw_path = Path(sys.argv[3])
scope_hash = sys.argv[4]
draft_path = Path(sys.argv[5])

data = generate_decisions_draft(summary_path, raw_path, scope_hash)
draft_path.write_text(dump_decisions_yaml(data), encoding="utf-8")
PY

  echo "$discovery_output"
  echo "draft: $draft_path"
}

cmd_a1_import() {
  local file="" dry_run=0
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --file)
        require_value "$1" "${2:-}"
        file="$2"
        shift 2
        ;;
      --dry-run)
        dry_run=1
        shift
        ;;
      *)
        echo "Unknown: $1" >&2
        exit 4
        ;;
    esac
  done
  [[ -z "$file" ]] && { echo "--file required" >&2; exit 1; }

  if [[ $dry_run -eq 1 ]]; then
    python3 - "$SCRIPT_DIR/lib" "$DB_PATH" "$file" <<'PY'
import json
import sys
sys.path.insert(0, sys.argv[1])
from audit_a1 import A1ImportEngine

eng = A1ImportEngine(sys.argv[2], sys.argv[3])
report = eng.dry_run()
print(json.dumps({
    "validation_errors": report.validation_errors,
    "case_counts": report.case_counts,
    "has_errors": report.has_errors,
}, ensure_ascii=False, indent=2))
sys.exit(1 if report.has_errors else 0)
PY
    return
  fi

  local lock_timeout="${HELIX_AUDIT_LOCK_TIMEOUT:-30}"
  if ! "$SCRIPT_DIR/helix-lock" acquire --name a1_import --timeout "$lock_timeout" --scope project >/dev/null 2>&1; then
    echo "lock conflict: a1_import" >&2
    exit 3
  fi

  trap '"$SCRIPT_DIR/helix-lock" release --name a1_import --scope project >/dev/null 2>&1 || true' EXIT

  observe_log --event audit.a1.import.started --data "$(json_file_data "$file")" --severity info --source helix-audit

  local result rc
  set +e
  result=$(python3 - "$SCRIPT_DIR/lib" "$DB_PATH" "$file" <<'PY'
import json
import sys
sys.path.insert(0, sys.argv[1])
from audit_a1 import A1ImportEngine

eng = A1ImportEngine(sys.argv[2], sys.argv[3])
result = eng.import_sync()
print(json.dumps({
    "run_id": result.run_id,
    "success": result.success,
    "imported_rows": result.imported_rows,
    "error_summary": result.error_summary,
    "case_counts": result.case_counts,
}, ensure_ascii=False, indent=2))
if result.success:
    sys.exit(0)
if result.error_summary and result.error_summary.startswith("validation:"):
    sys.exit(1)
sys.exit(4)
PY
  )
  rc=$?
  set -e

  echo "$result"

  if [[ $rc -eq 0 ]]; then
    observe_log --event audit.a1.import.completed --data "$result" --severity info --source helix-audit
  else
    observe_log --event audit.a1.import.failed --data "$result" --severity error --source helix-audit
  fi
  exit "$rc"
}

cmd_a1_verify_sync() {
  local file=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --file)
        require_value "$1" "${2:-}"
        file="$2"
        shift 2
        ;;
      *)
        echo "Unknown: $1" >&2
        exit 4
        ;;
    esac
  done
  [[ -z "$file" ]] && { echo "--file required" >&2; exit 1; }

  local result rc
  set +e
  result=$(python3 - "$SCRIPT_DIR/lib" "$DB_PATH" "$file" <<'PY'
import json
import sys
sys.path.insert(0, sys.argv[1])
from audit_a1 import A1ImportEngine

eng = A1ImportEngine(sys.argv[2], sys.argv[3])
validation_report = eng.dry_run()
if validation_report.validation_errors:
    print(json.dumps({
        "in_sync": False,
        "validation_errors": validation_report.validation_errors,
    }, ensure_ascii=False, indent=2))
    sys.exit(1)
result = eng.verify_sync()
print(json.dumps({
    "in_sync": result.in_sync,
    "yaml_count": result.yaml_count,
    "db_active_count": result.db_active_count,
    "missing_in_db": result.missing_in_db,
    "extra_in_db": result.extra_in_db,
    "hash_mismatch": result.hash_mismatch,
}, ensure_ascii=False, indent=2))
sys.exit(0 if result.in_sync else 2)
PY
  )
  rc=$?
  set -e

  echo "$result"
  if [[ $rc -eq 2 ]]; then
    observe_log --event audit.a1.verify_sync.drift_detected --data "$result" --severity warning --source helix-audit
  fi
  exit "$rc"
}

cmd_a1_status() {
  local candidate_id=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --candidate-id)
        require_value "$1" "${2:-}"
        candidate_id="$2"
        shift 2
        ;;
      *)
        echo "Unknown: $1" >&2
        exit 4
        ;;
    esac
  done

  python3 - "$SCRIPT_DIR/lib" "$DB_PATH" "$candidate_id" <<'PY'
import json
import sys
sys.path.insert(0, sys.argv[1])
import helix_db

filters = {}
if sys.argv[3]:
    filters["candidate_id"] = sys.argv[3]
rows = helix_db.query_active_audit_decisions(sys.argv[2], **filters)
print(json.dumps({"count": len(rows), "active": rows}, ensure_ascii=False, indent=2, default=str))
PY
}

main() {
  [[ $# -eq 0 ]] && { usage; exit 0; }
  case "$1" in
    preflight)
      shift
      cmd_preflight "$@"
      ;;
    a0)
      shift
      [[ $# -eq 0 ]] && { usage; exit 0; }
      case "$1" in
        discover) shift; cmd_a0_discover "$@" ;;
        *) usage; exit 4 ;;
      esac
      ;;
    a1)
      shift
      [[ $# -eq 0 ]] && { usage; exit 0; }
      case "$1" in
        import) shift; cmd_a1_import "$@" ;;
        verify-sync) shift; cmd_a1_verify_sync "$@" ;;
        status) shift; cmd_a1_status "$@" ;;
        *) usage; exit 4 ;;
      esac
      ;;
    --help|-h|help)
      usage
      ;;
    *)
      usage >&2
      exit 4
      ;;
  esac
}

main "$@"
