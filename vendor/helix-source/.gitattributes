# Default: detect text vs binary, normalize text to LF in repo
* text=auto eol=lf

# Shell / Bash scripts must stay LF (CRLF breaks bash shebangs on POSIX
# *and* on Git Bash for Windows).
*.sh        text eol=lf
*.bash      text eol=lf
*.bats      text eol=lf

# Executable CLIs in cli/ have no extension but are bash scripts
cli/helix*           text eol=lf
cli/claude           text eol=lf
cli/codex            text eol=lf
cli/lib/helix-*.sh   text eol=lf
cli/libexec/*        text eol=lf
cli/scripts/*        text eol=lf
cli/setup/*          text eol=lf
cli/templates/hooks/* text eol=lf

# Config / template files read by bash via line-by-line parsing
*.conf      text eol=lf
*.yaml      text eol=lf
*.yml       text eol=lf
*.json      text eol=lf
*.toml      text eol=lf
*.ini       text eol=lf

# Python keeps LF
*.py        text eol=lf

# Markdown / docs: LF (matches repo norm; avoids cross-platform diff noise)
*.md        text eol=lf

# Binary safety
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.pdf       binary
*.zip       binary
*.gz        binary
*.tgz       binary
*.tar       binary
*.db        binary
*.sqlite    binary
