{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "bun \"$CLAUDE_PROJECT_DIR/.claude/hooks/agent-guard.ts\"",
            "timeout": 5,
            "statusMessage": "subagent allowlist + explicit-model + opus-override guard (env-independent TS)",
            "blockOnFailure": true
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bun \"$CLAUDE_PROJECT_DIR/.claude/hooks/work-guard.ts\"",
            "timeout": 5,
            "statusMessage": "work guard: block edits to foreign uncommitted files unless explicitly bypassed",
            "blockOnFailure": true
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun \"$CLAUDE_PROJECT_DIR/src/cli.ts\" session start",
            "timeout": 5,
            "statusMessage": "session-log: session start (fail-open)"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bun \"$CLAUDE_PROJECT_DIR/src/cli.ts\" hook post-tool-use",
            "timeout": 5,
            "statusMessage": "session-log: post tool use (fail-open)"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun \"$CLAUDE_PROJECT_DIR/src/cli.ts\" session summary",
            "timeout": 5,
            "statusMessage": "session-log: PLAN digest summary (fail-open)"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun \"$CLAUDE_PROJECT_DIR/src/cli.ts\" hook subagent-stop",
            "timeout": 5,
            "statusMessage": "agent-slots: release subagent slot (fail-open)"
          }
        ]
      }
    ]
  }
}
